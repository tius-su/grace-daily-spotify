{
  "crons": [
    {
      "path": "/api/cron/daily-devotion",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/cron/generate-blog",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/cron/generate-encyclopedia",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/cleanup-subscriptions",
      "schedule": "0 19 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/media/public",
      "has": [
        {
          "type": "query",
          "key": "key",
          "value": "(?<folder>encyclopedia-banners/.*)\\.png"
        }
      ],
      "destination": "/api/media/public?key=%{folder}.webp"
    },
    {
      "source": "/podcast.xml",
      "destination": "/api/podcast.xml"
    },
    {
      "source": "/podcast-en.xml",
      "destination": "/api/podcast-en.xml"
    },
    {
      "source": "/podcast-zh.xml",
      "destination": "/api/podcast-zh.xml"
    },
    {
      "source": "/podcast-es.xml",
      "destination": "/api/podcast-es.xml"
    }
  ]
}