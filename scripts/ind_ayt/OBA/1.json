{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"OBA","translationId":"ind_ayt","name":"OBAJA","commonName":"OBAJA","title":"Obaja","order":31,"numberOfChapters":1,"sha256":"e800223eea7e687153e08e4966f03af3fbd9635038540626605ca160cd351a36","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/OBA/1.json","lastChapterNumber":1,"lastChapterApiLink":"/api/ind_ayt/OBA/1.json","totalNumberOfVerses":21},"chapter":{"number":1,"content":[{"type":"heading","content":["Nubuat tentang Edom"]},{"type":"verse","number":1,"content":["Penglihatan Obaja. Inilah firman Tuhan ALLAH mengenai Edom:",{"lineBreak":true},{"text":"Kami telah mendengar kabar dari TUHAN,","poem":1},{"text":"dan seorang utusan telah dikirim di antara bangsa-bangsa, katanya,","poem":2},{"text":"“Bangkitlah, dan mari kita bangkit berperang melawannya!”","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"“Lihat, Aku akan membuatmu kecil di antara bangsa-bangsa,","poem":1},{"text":"kamu akan sangat dihina.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Keangkuhan hatimu telah menipumu,","poem":1},{"text":"kamu yang tinggal di celah-celah batu,","poem":2},{"lineBreak":true},{"text":"di tempat kediaman yang tinggi.","poem":2},{"text":"Kamu berkata dalam hatimu,","poem":1},{"text":"‘Siapa yang akan menurunkan aku ke tanah?’","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Sekalipun kamu terbang tinggi seperti burung rajawali,","poem":1},{"lineBreak":true},{"text":"sekalipun kamu meletakkan sarangmu di antara bintang-bintang,","poem":1},{"text":"dari sana pun Aku akan membawamu turun,”","poem":2},{"lineBreak":true},{"text":"Firman TUHAN.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"“Kalau perampok datang kepadamu","poem":1},{"text":"pada malam hari","poem":2},{"text":"betapa kamu akan dibinasakan!","poem":1},{"text":"Akankah mereka hanya mencuri secukupnya saja?","poem":2},{"text":"Jika pemetik buah anggur datang kepadamu,","poem":1},{"text":"bukankah mereka akan meninggalkan sisa-sisa petikan?","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Betapa kaum Esau digeledah,","poem":1},{"text":"betapa harta bendanya yang tersembunyi akan dicari-cari!","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Semua teman sekutumu","poem":1},{"text":"akan mengusirmu sampai ke perbatasan,","poem":2},{"text":"semua sahabat-sahabatmu akan menipumu","poem":1},{"text":"dan menang melawanmu.","poem":2},{"text":"Mereka yang makan rotimu","poem":1},{"text":"akan memasang jebakan untuk kamu.","poem":2},{"text":"Kamu tidak akan menyadarinya.”","poem":1}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"“Pada hari itu,”","poem":1},{"text":"kata TUHAN,","poem":2},{"lineBreak":true},{"text":"“Aku akan membinasakan orang-orang bijaksana dari Edom dan orang-orang berpengertian dari Pegunungan Esau.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Lalu, para pejuangmu, hai Teman,","poem":1},{"text":"akan gentar.","poem":2},{"lineBreak":true},{"text":"Pada akhirnya, semua orang dari Pegunungan Esau akan mati dibantai.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Oleh kekerasan terhadap saudaramu, Yakub,","poem":1},{"text":"kamu akan dirundung malu,","poem":2},{"lineBreak":true},{"text":"dan kamu akan diputus untuk selama-lamanya.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Pada hari kamu berdiri di seberang,","poem":1},{"text":"pada hari itu orang-orang tidak dikenal mengangkut kekayaannya,","poem":2},{"text":"dan orang-orang asing melewati pintu gerbangnya,","poem":1},{"text":"dan membuang undi atas Yerusalem,","poem":2},{"lineBreak":true},{"text":"kamu adalah salah seorang dari mereka.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Akan tetapi, jangan kamu memandang rendah saudaramu","poem":1},{"text":"pada hari ia menjadi orang asing.","poem":2},{"text":"Jangan kamu bergembira atas anak-anak Yehuda","poem":1},{"text":"pada hari kehancurannya.","poem":2},{"text":"Juga, jangan berbicara dengan bangga.","poem":1},{"text":"pada hari kesedihannya.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Kamu seharusnya tidak masuk ke pintu gerbang umat-Ku","poem":1},{"text":"pada hari malapetakanya.","poem":2},{"text":"Betul, kamu seharusnya tidak memandang remeh pada penderitaannya","poem":1},{"text":"pada hari malapetakanya.","poem":2},{"text":"Juga, jangan mengambil barang-barangnya,","poem":1},{"text":"pada hari malapetakanya.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Kamu seharusnya tidak berdiri di persimpangan jalan","poem":1},{"text":"untuk menghalangi di antara orang-orang yang terluput,","poem":2},{"text":"dan kamu seharusnya tidak menyerahkan mereka yang tertinggal","poem":1},{"text":"pada hari kesesakannya.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Karena Hari TUHAN sudah dekat","poem":1},{"text":"atas semua bangsa.","poem":2},{"text":"Sama seperti yang kamu telah lakukan,","poem":1},{"text":"demikianlah akan dilakukan kepadamu,","poem":2},{"text":"perbuatanmu akan berbalik","poem":1},{"text":"menimpa kepalamu sendiri.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Sebab, sebagaimana kamu telah minum","poem":1},{"text":"di gunung-Ku yang kudus,","poem":2},{"lineBreak":true},{"text":"biarlah segala bangsa akan minum terus-menerus.","poem":2},{"text":"Ya, mereka akan minum dan meneguk,","poem":1},{"text":"dan mereka tidak akan seperti sebelumnya.","poem":2}]},{"type":"heading","content":["Sion Terluput dari Hukuman TUHAN"]},{"type":"verse","number":17,"content":[{"text":"Akan tetapi, di atas Gunung Sion akan ada pembebasan,","poem":1},{"text":"akan ada kekudusan;","poem":2},{"text":"dan kaum keturunan Yakub akan menduduki","poem":1},{"text":"tanah miliknya.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Keturunan Yakub akan menjadi api","poem":1},{"text":"dan keturunan Yusuf menjadi nyala api,","poem":2},{"text":"dan keturunan Esau akan menjadi jerami.","poem":1},{"text":"Mereka akan terbakar di dalamnya","poem":2},{"text":"Dan, tidak akan ada yang selamat yang tinggal di rumah Esau,","poem":1},{"text":"demikianlah TUHAN telah berfirman.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Orang-orang di selatan","poem":1},{"text":"akan memiliki Pegunungan Esau,","poem":2},{"text":"orang-orang dari dataran rendah","poem":1},{"text":"akan menduduki tanah orang Filistin.","poem":2},{"text":"Mereka akan menduduki ladang Efraim dan ladang Samaria,","poem":1},{"text":"dan suku Benyamin akan memiliki daerah Gilead.","poem":2}]},{"type":"verse","number":20,"content":[{"text":"Orang-orang Israel yang tertangkap","poem":1},{"text":"akan memiliki tanah orang Kanaan sampai ke Zarfat,","poem":2},{"text":"dan orang-orang Yerusalem yang tertangkap, yang berada di Sefarad,","poem":1},{"text":"akan memiliki kota-kota di selatan.","poem":2}]},{"type":"verse","number":21,"content":[{"text":"Penyelamat-penyelamat akan naik ke Gunung Sion,","poem":1},{"text":"untuk menghakimi Pegunungan Esau,","poem":2},{"text":"kerajaan akan menjadi milik TUHAN.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/OBA/1.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/JON/1.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/AMO/9.json","previousChapterAudioLinks":{},"numberOfVerses":21}