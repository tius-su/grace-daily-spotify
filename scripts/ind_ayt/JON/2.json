{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"JON","translationId":"ind_ayt","name":"YUNUS","commonName":"YUNUS","title":"Yunus","order":32,"numberOfChapters":4,"sha256":"435c10973d7df3a604923a696403c2383a3706fb322ecf4704f377dd2ef152a5","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/JON/1.json","lastChapterNumber":4,"lastChapterApiLink":"/api/ind_ayt/JON/4.json","totalNumberOfVerses":48},"chapter":{"number":2,"content":[{"type":"heading","content":["Doa Yunus"]},{"type":"verse","number":1,"content":["Kemudian, Yunus berdoa kepada TUHAN, Allahnya, dari dalam perut ikan."]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"Ia berkata,","poem":1},{"lineBreak":true},{"text":"“Dalam kesengsaraanku, aku berteriak kepada TUHAN,","poem":1},{"text":"dan Ia menjawab aku.","poem":2},{"text":"Dari perut bumi","poem":1},{"text":"aku berteriak,","poem":2},{"lineBreak":true},{"text":"dan Engkau mendengar suaraku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Engkau telah membuang aku ke tempat yang dalam,","poem":1},{"text":"ke dalam laut,","poem":2},{"text":"dan aliran air mengelilingi aku,","poem":1},{"text":"seluruh pecahan ombak-Mu dan gelombang-Mu menghempas aku.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Lalu, aku berkata,","poem":1},{"lineBreak":true},{"text":"‘Aku telah dibuang dari hadirat-Mu.","poem":1},{"text":"Namun, aku akan memandang lagi ke bait-Mu yang kudus.’","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"Air mengelilingi aku,","poem":1},{"lineBreak":true},{"text":"bahkan mengancam nyawaku,","poem":1},{"text":"lautan yang dalam mengelilingi aku,","poem":2},{"text":"rumput laut","poem":1},{"text":"melilit kepalaku.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Aku turun","poem":1},{"text":"ke dasar pegunungan,","poem":2},{"text":"palang pintu bumi menutup di belakangku untuk selama-lamanya.","poem":1},{"text":"Namun, Engkau mengambil kembali nyawaku dari lubang kubur,","poem":2},{"text":"ya TUHAN, Allahku.","poem":1}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Ketika jiwaku lemah lesu di dalam aku,","poem":1},{"text":"aku ingat kepada TUHAN,","poem":2},{"text":"dan doaku sampai kepada-Mu,","poem":1},{"text":"ke dalam tempat-Mu yang kudus.","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"Mereka yang bergantung pada berhala kesia-siaan,","poem":1},{"text":"menolak kasih setia yang dapat mereka miliki.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Namun, aku akan mempersembahkan kepada-Mu","poem":1},{"text":"ucapan syukur.","poem":2},{"text":"Aku akan membayar","poem":1},{"text":"apa yang telah kunazarkan.","poem":2},{"lineBreak":true},{"text":"Keselamatan adalah dari TUHAN!”","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":["Lalu, TUHAN berfirman kepada ikan itu, dan ikan itu memuntahkan Yunus ke darat."]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/JON/2.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/JON/3.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/JON/1.json","previousChapterAudioLinks":{},"numberOfVerses":10}