{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"NUM","translationId":"ind_ayt","name":"BILANGAN","commonName":"BILANGAN","title":"Bilangan","order":4,"numberOfChapters":36,"sha256":"6a25538c6758142bc04e3de79aa09e5e8f9f8070ffad5aae7b0e3ff9de578353","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/NUM/1.json","lastChapterNumber":36,"lastChapterApiLink":"/api/ind_ayt/NUM/36.json","totalNumberOfVerses":1288},"chapter":{"number":24,"content":[{"type":"heading","content":["Pesan Ketiga dari Bileam"]},{"type":"verse","number":1,"content":["Bileam telah melihat bahwa TUHAN akan memberkati Israel sehingga dia tidak berusaha untuk mencari tanda lagi, dan memandang ke arah padang gurun."]},{"type":"verse","number":2,"content":["Ketika Bileam memandang dan melihat orang Israel berkemah menurut sukunya masing-masing, Roh Allah mendatangi dia."]},{"type":"verse","number":3,"content":["Lalu, dia bersajak dan berkata:",{"lineBreak":true},{"text":"“Pesan ini dari Bileam, anak Beor.","poem":1},{"text":"perkataan orang yang dibuka matanya.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Kata-kata dari mendengarkan firman Allah,","poem":1},{"text":"penglihatan dari Yang Mahakuasa,","poem":2},{"lineBreak":true},{"text":"dengan rebah mataku tersingkap.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Hai Yakub, tenda-tendamu indah!","poem":1},{"text":"Hai Israel, tempat kediamanmu indah!","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Terbentang bagai sungai,","poem":1},{"text":"serupa taman di tepi sungai,","poem":2},{"text":"bagaikan pohon gaharu,","poem":1},{"text":"ditanam oleh TUHAN,","poem":2},{"text":"bagaikan pohon aras,","poem":1},{"text":"di tepi air.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Dari timbanya mengalirlah air,","poem":1},{"text":"melimpahlah air untuk benihmu.","poem":2},{"text":"Rajamu akan lebih tinggi dari Agag,","poem":1},{"text":"kerajaanmu akan dimuliakan.","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"Allah yang membawa mereka keluar dari Mesir,","poem":1},{"text":"Dia seperti tanduk banteng.","poem":2},{"text":"Dia memangsa bangsa-bangsa, lawan-Nya,","poem":1},{"text":"Dia akan meremukkan tulang-tulang mereka","poem":2},{"lineBreak":true},{"text":"dan akan memanah mereka.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Dia seperti singa jantan dan betina yang merunduk dan membaringkan diri,","poem":1},{"text":"siapa yang berani membangunkannya!","poem":2},{"text":"Setiap orang yang memberkatimu","poem":1},{"text":"akan diberkati.","poem":2},{"text":"Dan siapa yang mengutukmu","poem":1},{"text":"akan dikutuk.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":["Balak marah kepada Bileam sambil meremas-remas jarinya, lalu berkata kepada Bileam, “Aku memanggilmu untuk mengutuk musuh-musuhku, tetapi kamu malah memberkati mereka sampai tiga kali."]},{"type":"verse","number":11,"content":["Sekarang, pulanglah! Aku telah mengatakan bahwa aku akan mengupahmu sangat banyak, tetapi TUHAN membuatmu kehilangan upah.”"]},{"type":"verse","number":12,"content":["Bileam berkata kepada Balak, “Ingatlah pada pesan yang kukatakan kepada utusan-utusanmu, kataku,"]},{"type":"verse","number":13,"content":["‘Sekalipun Balak memberikan kepadaku rumahnya yang penuh perak dan emas, aku tidak dapat melanggar perintah TUHAN untuk berbuat baik atau buruk dari hatiku sendiri. Aku hanya mengatakan yang diperintahkan TUHAN.’"]},{"type":"verse","number":14,"content":["Sekarang, aku pulang kepada bangsaku. Namun, aku akan mengatakan kepadamu perihal yang akan dilakukan oleh bangsa itu terhadap bangsamu nanti.”"]},{"type":"heading","content":["Pesan Bileam yang Terakhir"]},{"type":"verse","number":15,"content":["Kemudian, Bileam menyampaikan sajaknya, dan berkata:",{"lineBreak":true},{"text":"“Inilah pesan Bileam, anak Beor.","poem":1},{"text":"Orang yang dibukakan matanya,","poem":2}]},{"type":"verse","number":16,"content":[{"text":"yang mendengar dari firman Allah,","poem":1},{"text":"yang tahu hikmat Yang Mahatinggi.","poem":2},{"text":"Aku telah melihat penglihatan dari Yang Mahakuasa,","poem":1},{"text":"dengan rebah mataku tersingkap.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Aku melihatnya datang, tetapi bukan sekarang.","poem":1},{"text":"Aku memandangnya, tetapi tidak dari dekat.","poem":2},{"text":"Sebuah bintang akan datang dari Yakub.","poem":1},{"text":"Tongkat kerajaan akan bangkit dari orang Israel.","poem":2},{"text":"Dia akan meremukkan pelipis Moab","poem":1},{"text":"dan menghancurkan semua anak Set.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Israel akan berbuat hal besar!","poem":1},{"text":"Edom jadi kepunyaannya.","poem":2},{"lineBreak":true},{"text":"Seir akan dia duduki, musuhnya itu.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Pemimpin akan datang dari Yakub,","poem":1},{"text":"yang akan membinasakan orang yang lari dari kota.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":20,"content":["Dia melihat orang Amalek dan berkata:",{"lineBreak":true},{"text":"“Amalek adalah yang pertama dari semua bangsa,","poem":1},{"text":"tetapi Amalek pun akan binasa!”","poem":2}]},{"type":"line_break"},{"type":"verse","number":21,"content":["Bileam melihat orang Keni dan berkata:",{"lineBreak":true},{"text":"“Negerimu kukuh,","poem":1},{"text":"sarangmu ada di atas bukit batu.","poem":2}]},{"type":"verse","number":22,"content":[{"text":"Namun Keni akan binasa,","poem":1},{"lineBreak":true},{"text":"Asyur akan segera menawanmu.”","poem":1}]},{"type":"line_break"},{"type":"verse","number":23,"content":["Kemudian, Bileam berkata:",{"lineBreak":true},{"text":"“Celaka! Siapa yang hidup apabila Allah melakukan hal ini?","poem":1}]},{"type":"verse","number":24,"content":[{"text":"Kapal-kapal akan datang dari pantai Kitim.","poem":2},{"text":"Mereka akan mengalahkan Asyur dan Heber,","poem":1},{"text":"tetapi dia pun akan binasa.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":25,"content":["Kemudian Bileam bangkit dan pulang, Balak juga pergi."]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/NUM/24.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/NUM/25.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/NUM/23.json","previousChapterAudioLinks":{},"numberOfVerses":25}