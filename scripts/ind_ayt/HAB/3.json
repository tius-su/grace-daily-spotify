{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"HAB","translationId":"ind_ayt","name":"HABAKUK","commonName":"HABAKUK","title":"Habakuk","order":35,"numberOfChapters":3,"sha256":"d9318d8079fc8e6728a7ae7a8c1ee71d3ddbb5478a0873167c9d8c83b505ec96","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/HAB/1.json","lastChapterNumber":3,"lastChapterApiLink":"/api/ind_ayt/HAB/3.json","totalNumberOfVerses":56},"chapter":{"number":3,"content":[{"type":"heading","content":["Doa Habakuk"]},{"type":"verse","number":1,"content":["Doa Nabi Habakuk. Menurut nyanyian ratapan."]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"“TUHAN, aku telah mendengar kabar tentang Engkau,","poem":1},{"text":"dan Engkau kutakuti, ya TUHAN!","poem":2},{"text":"Hidupkanlah perbuatan-Mu dalam pertengahan tahun,","poem":1},{"text":"nyatakanlah itu dalam lintasan tahun,","poem":2},{"text":"di dalam murka,","poem":1},{"text":"ingatlah belas kasihan!” Sela","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"“Allah datang dari negeri Teman","poem":1},{"text":"dan Yang Mahakudus dari gunung Paran. Sela","poem":2},{"text":"Kemuliaan-Nya menutupi semesta langit,","poem":1},{"text":"dan bumi penuh dengan puji-pujian-Nya.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Cahaya-Nya seperti cahaya matahari,","poem":1},{"text":"sinar memancar dari tangan-Nya,","poem":2},{"text":"dan di situlah tersembunyi kekuatan-Nya.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Di hadapan-Nya penyakit sampar pergi,","poem":1},{"text":"dan demam mengikuti langkah-Nya.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Dia berdiri maka bumi berguncang,","poem":1},{"text":"Dia memandang dan bangsa-bangsa pun gemetar.","poem":2},{"lineBreak":true},{"text":"Gunung-gunung yang ada sejak dahulu kala terserak,","poem":2},{"text":"bukit-bukit dari zaman purbakala tertunduk,","poem":1},{"text":"perbuatan-Nya kekal.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"“Aku melihat kemah-kemah orang Kusyan dalam tekanan,","poem":1},{"text":"tirai tenda-tenda tanah Midian bergetar.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Apakah TUHAN murka terhadap sungai-sungai,","poem":1},{"text":"atau amarah-Mu terhadap sungai-sungai?","poem":2},{"text":"Ataukah kegeramanmu terhadap laut,","poem":1},{"text":"sehingga Engkau mengendarai kuda-kuda-Mu, pada kereta kuda kemenangan-Mu?”","poem":2}]},{"type":"line_break"},{"type":"verse","number":9,"content":[{"text":"“Busur-Mu telah Engkau buka,","poem":1},{"text":"maka keluarlah kata-kata-Mu.” Sela","poem":2},{"lineBreak":true},{"text":"“Engkau membagi bumi dengan sungai-sungai.","poem":1}]},{"type":"verse","number":10,"content":[{"text":"Gunung-gunung melihat Engkau dan menjadi gemetar,","poem":2},{"text":"air bah menderu,","poem":1},{"text":"samudra raya memperdengarkan suaranya,","poem":2},{"lineBreak":true},{"text":"dan mengangkat tinggi tangannya.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Matahari dan bulan berhenti di tempatnya berdiam,","poem":1},{"text":"dengan sinar anak-anak panah-Mu mereka berjalan,","poem":2},{"lineBreak":true},{"text":"dan karena kilau tombak-Mu yang berkilat.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Dalam kegeraman, Engkau melintasi bumi,","poem":1},{"text":"dalam amarah, Engkau menginjak-injak bangsa-bangsa.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Engkau berjalan maju untuk keselamatan umat-Mu,","poem":1},{"text":"untuk keselamatan orang yang Engkau urapi.","poem":2},{"text":"Engkau meremukkan bagian atas rumah orang jahat,","poem":1},{"text":"dengan membuka dasar-dasarnya","poem":2},{"lineBreak":true},{"text":"sampai bagian atas.” Sela","poem":2}]},{"type":"line_break"},{"type":"verse","number":14,"content":[{"text":"“Engkau menusuk kepala pasukan dengan tombaknya.","poem":1},{"text":"Mereka mengamuk untuk menyerakkan aku,","poem":2},{"text":"sorak-sorai mereka seperti orang-orang yang melahap orang-orang miskin","poem":1},{"text":"secara tersembunyi.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Engkau melintasi laut dengan kuda-kuda-Mu,","poem":1},{"text":"melalui buih-buih samudra.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Ketika aku mendengarnya, hatiku gemetar,","poem":1},{"text":"bibirku bergetar mendengar bunyinya.","poem":2},{"text":"Kebusukan memasuki tulang-tulangku,","poem":1},{"text":"di tempatku berdiri aku gemetar.","poem":2},{"text":"Sebab, dengan diam-diam aku menunggu hari kesesakan","poem":1},{"text":"yang akan menimpa bangsa-bangsa yang akan menyerang kita.”","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Sekalipun pohon ara tidak berbunga,","poem":1},{"text":"atau pohon anggur tidak berbuah,","poem":2},{"text":"hasil pohon zaitun mengecewakan,","poem":1},{"text":"dan ladang-ladang tidak menghasilkan bahan makanan,","poem":2},{"text":"kawanan domba terhalau dari kurungan,","poem":1},{"text":"dan tidak ada sapi dalam kandang,","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Namun, aku akan bersukacita dalam TUHAN,","poem":1},{"text":"bergembira dalam Allah keselamatanku.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":19,"content":[{"text":"“TUHAN Allah adalah kekuatanku,","poem":1},{"text":"dan Dia membuat kakiku seperti rusa,","poem":2},{"lineBreak":true},{"text":"Dia membuatku berjalan pada tempat-tempat tinggi.”","poem":2},{"lineBreak":true},"Untuk pemimpin pujian. Dengan permainan kecapi."]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/HAB/3.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/ZEP/1.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/HAB/2.json","previousChapterAudioLinks":{},"numberOfVerses":19}