{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"LAM","translationId":"ind_ayt","name":"RATAPAN","commonName":"RATAPAN","title":"Ratapan","order":25,"numberOfChapters":5,"sha256":"28f6241cfd413638ca9cf1f9264cb20521ecadb5c86eeeb7358970bb8d6954cc","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/LAM/1.json","lastChapterNumber":5,"lastChapterApiLink":"/api/ind_ayt/LAM/5.json","totalNumberOfVerses":154},"chapter":{"number":4,"content":[{"type":"heading","content":["Hukuman bagi Sion"]},{"type":"verse","number":1,"content":[{"text":"Betapa emas telah menjadi pudar,","poem":1},{"text":"betapa emas murni telah berubah!","poem":2},{"text":"Batu-batu suci berserakan","poem":1},{"text":"di setiap ujung jalan.","poem":2}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"Anak-anak laki-laki Sion yang berharga,","poem":1},{"text":"yang sebanding dengan emas murni,","poem":2},{"text":"betapa mereka dianggap seperti guci-guci tanah liat","poem":1},{"text":"buatan tangan tukang periuk.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Serigala saja memberikan teteknya","poem":1},{"text":"untuk menyusui anak-anak mereka.","poem":2},{"text":"Akan tetapi, putri bangsaku telah menjadi kejam","poem":1},{"text":"seperti burung unta di padang belantara.","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"Lidah bayi yang menyusu","poem":1},{"text":"melekat pada langit-langit mulutnya karena kehausan.","poem":2},{"text":"Anak-anak meminta roti,","poem":1},{"text":"tetapi tidak ada yang membaginya untuk mereka.","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"Mereka yang dahulu makan makanan yang enak-enak","poem":1},{"text":"kini mati di jalan-jalan.","poem":2},{"text":"Mereka yang dahulu dibesarkan dengan pakaian kirmizi","poem":1},{"text":"kini mendekap timbunan sampah.","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"Sebab, hukuman atas kedurhakaan putri bangsaku lebih besar","poem":1},{"text":"daripada atas dosa-dosa Sodom,","poem":2},{"text":"yang ditunggangbalikkan dalam sekejap,","poem":1},{"text":"dan tidak ada tangan yang menolongnya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Pemimpin-pemimpinnya","poem":1},{"text":"lebih murni daripada salju,","poem":2},{"text":"dan lebih putih","poem":1},{"text":"daripada susu.","poem":2},{"text":"Tubuh mereka lebih merah daripada rubi,","poem":1},{"text":"dan sosok mereka seperti safir.","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"Penampilan mereka lebih hitam daripada jelaga.","poem":1},{"text":"Mereka tidak dikenali di jalan-jalan.","poem":2},{"text":"Kulit mereka berkerut pada tulang-tulang mereka,","poem":1},{"text":"kering seperti kayu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":9,"content":[{"text":"Orang yang mati karena pedang","poem":1},{"text":"lebih baik daripada orang yang mati karena kelaparan.","poem":2},{"text":"Sebab, mereka merana,","poem":1},{"text":"tertikam oleh kekurangan hasil ladang.","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"Tangan perempuan-perempuan penyayang","poem":1},{"text":"merebus anak-anak mereka sendiri.","poem":2},{"text":"Anak-anak itu menjadi makanan mereka","poem":1},{"text":"selama penghancuran putri bangsaku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"TUHAN telah melampiaskan kemurkaan-Nya.","poem":1},{"text":"Dia mencurahkan kemarahan-Nya yang menyala-nyala,","poem":2},{"text":"dan menyalakan api di Sion","poem":1},{"text":"yang telah membakar fondasi-fondasinya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":12,"content":[{"text":"Raja-raja di bumi tidak percaya,","poem":1},{"text":"begitu juga seluruh penduduk dunia,","poem":2},{"text":"bahwa musuh dan lawan","poem":1},{"text":"dapat memasuki pintu-pintu gerbang Yerusalem.","poem":2}]},{"type":"line_break"},{"type":"verse","number":13,"content":[{"text":"Itu karena dosa para nabinya","poem":1},{"text":"dan kedurhakaan para imamnya,","poem":2},{"text":"yang telah menumpahkan darah orang-orang benar","poem":1},{"text":"di tengah-tengahnya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":14,"content":[{"text":"Mereka mengembara","poem":1},{"text":"seperti orang buta di jalan-jalan.","poem":2},{"text":"Mereka begitu cemar karena darah","poem":1},{"text":"sehingga tidak ada yang dapat menyentuh pakaian mereka.","poem":2}]},{"type":"line_break"},{"type":"verse","number":15,"content":[{"text":"“Pergi! Najis!” teriak orang-orang kepada mereka.","poem":1},{"text":"“Pergi, pergi, jangan menyentuh!”","poem":2},{"lineBreak":true},{"text":"Maka dari itu, mereka lari dan mengembara.","poem":2},{"text":"Orang-orang berkata di antara bangsa-bangsa,","poem":1},{"text":"“Mereka tidak boleh lagi tinggal di sini.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":16,"content":[{"text":"TUHAN sendiri telah mencerai-beraikan mereka.","poem":1},{"text":"Dia tidak akan lagi menganggap mereka.","poem":2},{"text":"Mereka tidak menghormati para imam.","poem":1},{"text":"Mereka tidak menyukai para tua-tua.","poem":2}]},{"type":"line_break"},{"type":"verse","number":17,"content":[{"text":"Lagi pula, mata kami gagal,","poem":1},{"text":"terus menatap dengan sia-sia untuk pertolongan.","poem":2},{"text":"Dalam pengamatan kami,","poem":1},{"text":"kami mengamati suatu bangsa","poem":2},{"lineBreak":true},{"text":"yang tidak dapat menyelamatkan.","poem":2}]},{"type":"line_break"},{"type":"verse","number":18,"content":[{"text":"Mereka memburu langkah-langkah kami","poem":1},{"text":"sehingga kami tidak dapat berjalan di jalan-jalan kami.","poem":2},{"text":"Akhir hidup kami sudah dekat. Hari-hari kami sudah habis","poem":1},{"text":"karena kesudahan kami sudah datang.","poem":2}]},{"type":"line_break"},{"type":"verse","number":19,"content":[{"text":"Para pengejar kami","poem":1},{"text":"lebih cepat daripada elang di langit.","poem":2},{"text":"Mereka mengejar kami di gunung-gunung.","poem":1},{"text":"Mereka mengintai kami di padang belantara.","poem":2}]},{"type":"line_break"},{"type":"verse","number":20,"content":[{"text":"Napas dari lubang hidung kami,","poem":1},{"lineBreak":true},{"text":"yaitu yang diurapi TUHAN,","poem":1},{"text":"tertangkap di lubang-lubang mereka,","poem":2},{"text":"yang tentangnya kami berkata,","poem":1},{"text":"“Di bawah bayangannya,","poem":2},{"lineBreak":true},{"text":"kami akan hidup di antara bangsa-bangsa.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":21,"content":[{"text":"Bersukacitalah dan bergembiralah,","poem":1},{"text":"hai putri Edom, yang tinggal di tanah Us.","poem":2},{"text":"Akan tetapi, cawan itu juga akan melewati kamu.","poem":1},{"text":"Kamu akan menjadi mabuk,","poem":2},{"lineBreak":true},{"text":"dan membuat dirimu sendiri telanjang.","poem":2}]},{"type":"line_break"},{"type":"verse","number":22,"content":[{"text":"Hukuman atas kesalahanmu telah dilaksanakan, hai putri Sion.","poem":1},{"text":"Dia tidak akan lagi menahanmu di pembuangan.","poem":2},{"text":"Akan tetapi, Dia akan menghukum kedurhakaanmu, hai putri Edom.","poem":1},{"text":"Dia akan menyingkapkan dosa-dosamu.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/LAM/4.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/LAM/5.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/LAM/3.json","previousChapterAudioLinks":{},"numberOfVerses":22}