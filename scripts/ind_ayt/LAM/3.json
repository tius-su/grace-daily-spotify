{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"LAM","translationId":"ind_ayt","name":"RATAPAN","commonName":"RATAPAN","title":"Ratapan","order":25,"numberOfChapters":5,"sha256":"28f6241cfd413638ca9cf1f9264cb20521ecadb5c86eeeb7358970bb8d6954cc","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/LAM/1.json","lastChapterNumber":5,"lastChapterApiLink":"/api/ind_ayt/LAM/5.json","totalNumberOfVerses":154},"chapter":{"number":3,"content":[{"type":"heading","content":["Pengharapan dalam Penderitaan"]},{"type":"verse","number":1,"content":[{"text":"Akulah orang","poem":1},{"text":"yang telah melihat penderitaan","poem":2},{"lineBreak":true},{"text":"akibat tongkat kemurkaan-Nya.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Dia menggiringku dan membawaku ke dalam kegelapan,","poem":1},{"text":"dan bukan terang.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Sesungguhnya, Dia membalikkan tangan-Nya terhadapku","poem":1},{"text":"berkali-kali sepanjang hari.","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"Dia membuat daging dan kulitku susut;","poem":1},{"text":"Dia mematahkan tulang-tulangku.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Dia mengepung dan melingkupiku","poem":1},{"text":"dengan kepahitan dan kesulitan.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Dia membuatku tinggal dalam kegelapan,","poem":1},{"text":"seperti mereka yang telah lama mati.","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Dia membangun tembok di sekelilingku sehingga aku tidak dapat keluar;","poem":1},{"text":"Dia membuat rantai-rantaiku berat.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Bahkan, ketika aku berseru dan berteriak minta tolong,","poem":1},{"text":"Dia mendiamkan doaku.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Dia menghalangi jalan-jalanku dengan batu-batu pahat;","poem":1},{"text":"Dia membuat jalan-jalanku berliku-liku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"Dia seperti beruang yang mengadang aku,","poem":1},{"text":"seperti singa di tempat-tempat persembunyian.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Dia membelokkan jalan-jalanku,","poem":1},{"text":"mencabik-cabik aku, dan membuatku gersang.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Dia melenturkan busur-Nya,","poem":1},{"text":"dan menjadikanku sasaran anak panah.","poem":2}]},{"type":"line_break"},{"type":"verse","number":13,"content":[{"text":"Dia menusuk ginjalku","poem":1},{"text":"dengan anak-anak panah dari tabung anak panah-Nya.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Aku menjadi bahan tertawaan bagi seluruh bangsaku,","poem":1},{"text":"menjadi nyanyian ejekan mereka sepanjang hari.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Dia mengenyangkanku dengan kepahitan;","poem":1},{"text":"Dia membuatku mabuk dengan ipuh.","poem":2}]},{"type":"line_break"},{"type":"verse","number":16,"content":[{"text":"Dia mematahkan gigiku dengan kerikil;","poem":1},{"text":"Dia membuatku meringkuk di dalam abu.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Jiwaku dijauhkan dari kedamaian;","poem":1},{"text":"aku telah lupa akan kebahagiaan.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Aku berkata,","poem":1},{"text":"“Kekuatanku telah hilang;","poem":2},{"lineBreak":true},{"text":"begitu juga harapanku dari TUHAN.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":19,"content":[{"text":"Ingatlah penderitaanku,","poem":1},{"text":"dan pengembaraanku,","poem":2},{"text":"ipuh dan kepahitan itu.","poem":1}]},{"type":"verse","number":20,"content":[{"lineBreak":true},{"text":"Jiwaku terus-menerus mengingatnya,","poem":1},{"text":"dan tertunduk dalam diriku.","poem":2}]},{"type":"verse","number":21,"content":[{"text":"Inilah yang kuingat dalam pikiranku,","poem":1},{"text":"dan karena itu, aku berharap.","poem":2}]},{"type":"line_break"},{"type":"verse","number":22,"content":[{"text":"Kasih setia TUHAN tidak pernah habis,","poem":1},{"text":"rahmat-Nya tidak pernah berakhir,","poem":2}]},{"type":"verse","number":23,"content":[{"text":"selalu baru setiap pagi;","poem":1},{"text":"besarlah kesetiaan-Mu.","poem":2}]},{"type":"verse","number":24,"content":[{"text":"“TUHAN adalah bagianku,” kata jiwaku,","poem":1},{"text":"“Karena itu, aku berharap dalam Dia.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":25,"content":[{"text":"TUHAN itu baik bagi orang yang menantikan Dia,","poem":1},{"text":"bagi jiwa yang mencari Dia.","poem":2}]},{"type":"verse","number":26,"content":[{"text":"Baik bagi seseorang untuk menanti dengan tenang","poem":1},{"text":"keselamatan dari TUHAN.","poem":2}]},{"type":"verse","number":27,"content":[{"text":"Baik bagi seorang laki-laki","poem":1},{"text":"jika dia memikul kuk pada masa mudanya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":28,"content":[{"text":"Biarlah dia duduk sendirian dan berdiam diri","poem":1},{"text":"karena Dia telah memasangkannya ke atasnya.","poem":2}]},{"type":"verse","number":29,"content":[{"text":"Biarlah dia menaruh mulutnya dalam debu,","poem":1},{"text":"barangkali ada harapan.","poem":2}]},{"type":"verse","number":30,"content":[{"text":"Biarlah dia memberikan pipinya kepada orang yang memukulnya,","poem":1},{"text":"dan biarlah dia dikenyangkan dengan hinaan.","poem":2}]},{"type":"line_break"},{"type":"verse","number":31,"content":[{"text":"Sebab, Tuhan tidak akan menolak","poem":1},{"text":"untuk selama-lamanya.","poem":2}]},{"type":"verse","number":32,"content":[{"text":"Sebab, meski Dia menyebabkan dukacita,","poem":1},{"text":"Dia akan berbelaskasihan","poem":2},{"text":"sesuai dengan kasih setia-Nya yang berlimpah.","poem":1}]},{"type":"line_break"},{"type":"verse","number":33,"content":[{"text":"Sebab, tidak dengan senang hati Dia menindas","poem":1},{"text":"atau mendukakan anak-anak manusia.","poem":2}]},{"type":"verse","number":34,"content":[{"text":"Menghancurkan semua tawanan di bumi di bawah kaki-Nya,","poem":1}]},{"type":"verse","number":35,"content":[{"lineBreak":true},{"text":"mengesampingkan hak orang","poem":1},{"text":"di hadapan Yang Mahatinggi,","poem":2}]},{"type":"verse","number":36,"content":[{"text":"menjatuhkan seseorang dalam perkaranya,","poem":1},{"text":"Tuhan tidak menyetujui semuanya itu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":37,"content":[{"text":"Siapakah yang berkata, maka itu terjadi,","poem":1},{"text":"kalau Tuhan tidak memerintahkannya?","poem":2}]},{"type":"verse","number":38,"content":[{"text":"Bukankah dari mulut Yang Mahatinggi","poem":1},{"text":"yang baik dan yang jahat itu datang?","poem":2}]},{"type":"verse","number":39,"content":[{"text":"Mengapa manusia, manusia yang hidup, harus mengeluh","poem":1},{"text":"ketika dia dihukum karena dosa-dosanya?","poem":2}]},{"type":"line_break"},{"type":"verse","number":40,"content":[{"text":"Mari kita menyelidiki dan memeriksa jalan-jalan kita,","poem":1},{"text":"dan kembali kepada TUHAN.","poem":2}]},{"type":"verse","number":41,"content":[{"text":"Mari kita mengangkat hati dan tangan kita","poem":1},{"text":"kepada Allah di surga.","poem":2}]},{"type":"verse","number":42,"content":[{"text":"“Kami telah melanggar dan memberontak,","poem":1},{"text":"dan Engkau tidak mengampuni.","poem":2}]},{"type":"line_break"},{"type":"verse","number":43,"content":[{"text":"Engkau menyelubungi diri-Mu sendiri dengan kemarahan,","poem":1},{"text":"dan mengejar kami","poem":2},{"lineBreak":true},{"text":"serta membunuh tanpa belas kasihan.","poem":2}]},{"type":"verse","number":44,"content":[{"text":"Engkau menyelubungi diri-Mu sendiri dengan awan","poem":1},{"text":"sehingga tidak ada doa yang dapat menembus.","poem":2}]},{"type":"verse","number":45,"content":[{"text":"Engkau menjadikan kami sampah dan kotoran","poem":1},{"text":"di antara bangsa-bangsa.","poem":2}]},{"type":"line_break"},{"type":"verse","number":46,"content":[{"text":"Semua musuh kami","poem":1},{"text":"membuka mulut mereka melawan kami.","poem":2}]},{"type":"verse","number":47,"content":[{"text":"Kepanikan dan jebakan","poem":1},{"text":"menimpa kami,","poem":2},{"text":"kerusakan","poem":1},{"text":"dan kehancuran.","poem":2}]},{"type":"verse","number":48,"content":[{"text":"Aliran air mata turun dari mataku","poem":1},{"text":"karena kehancuran putri bangsaku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":49,"content":[{"text":"Air mataku bercucuran tanpa henti,","poem":1},{"text":"tanpa putus,","poem":2}]},{"type":"verse","number":50,"content":[{"text":"sampai TUHAN melihat","poem":1},{"text":"ke bawah","poem":2},{"text":"dan memperhatikan","poem":1},{"text":"dari surga.","poem":2}]},{"type":"verse","number":51,"content":[{"text":"Mataku mendukakan jiwaku","poem":1},{"text":"karena semua putri di kotaku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":52,"content":[{"text":"Musuh-musuhku memburuku,","poem":1},{"text":"seperti seekor burung, tanpa sebab.","poem":2}]},{"type":"verse","number":53,"content":[{"text":"Mereka melemparkanku hidup-hidup ke dalam lubang,","poem":1},{"text":"dan melempariku dengan batu.","poem":2}]},{"type":"verse","number":54,"content":[{"text":"Air mengalir di atas kepalaku;","poem":1},{"text":"aku berkata, ‘Matilah aku.’","poem":2}]},{"type":"verse","number":55,"content":[{"text":"Aku memanggil nama-Mu, ya TUHAN,","poem":1},{"text":"dari dasar lubang.","poem":2}]},{"type":"verse","number":56,"content":[{"text":"Engkau telah mendengar suaraku,","poem":1},{"text":"‘Jangan sembunyikan telinga-Mu","poem":2},{"lineBreak":true},{"text":"dari teriakanku minta tolong.’","poem":2}]},{"type":"verse","number":57,"content":[{"text":"Engkau mendekat ketika aku memanggil-Mu.","poem":1},{"text":"Engkau berfirman, ‘Jangan takut!’","poem":2}]},{"type":"line_break"},{"type":"verse","number":58,"content":[{"text":"Ya Tuhan, Engkau telah membela perkara-perkara jiwaku;","poem":1},{"text":"Engkau telah menebus hidupku.","poem":2}]},{"type":"verse","number":59,"content":[{"text":"Ya TUHAN, Engkau telah melihat penindasan terhadap aku;","poem":1},{"text":"adililah perkaraku.","poem":2}]},{"type":"verse","number":60,"content":[{"text":"Engkau telah melihat","poem":1},{"text":"semua pembalasan dendam mereka,","poem":2},{"text":"semua rencana mereka","poem":1},{"text":"terhadap aku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":61,"content":[{"text":"Engkau telah mendengar hinaan mereka, ya TUHAN,","poem":1},{"text":"semua rencana mereka","poem":2},{"lineBreak":true},{"text":"terhadap aku.","poem":2}]},{"type":"verse","number":62,"content":[{"text":"Bibir para penyerangku","poem":1},{"text":"dan pikiran mereka melawan aku sepanjang hari.","poem":2}]},{"type":"verse","number":63,"content":[{"text":"Perhatikanlah duduk dan berdiri mereka;","poem":1},{"text":"aku adalah nyanyian ejekan mereka.","poem":2}]},{"type":"line_break"},{"type":"verse","number":64,"content":[{"text":"Engkau akan membalas mereka dengan ganjaran, ya TUHAN,","poem":1},{"text":"sesuai dengan perbuatan tangan mereka.","poem":2}]},{"type":"verse","number":65,"content":[{"text":"Engkau akan memberi mereka kekerasan hati;","poem":1},{"text":"kutuk-Mu akan ada atas mereka.","poem":2}]},{"type":"verse","number":66,"content":[{"text":"Engkau akan mengejar mereka dalam kemarahan,","poem":1},{"text":"dan menghancurkan mereka dari kolong langit TUHAN.”","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/LAM/3.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/LAM/4.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/LAM/2.json","previousChapterAudioLinks":{},"numberOfVerses":66}