{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"LAM","translationId":"ind_ayt","name":"RATAPAN","commonName":"RATAPAN","title":"Ratapan","order":25,"numberOfChapters":5,"sha256":"28f6241cfd413638ca9cf1f9264cb20521ecadb5c86eeeb7358970bb8d6954cc","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/LAM/1.json","lastChapterNumber":5,"lastChapterApiLink":"/api/ind_ayt/LAM/5.json","totalNumberOfVerses":154},"chapter":{"number":2,"content":[{"type":"heading","content":["Murka TUHAN terhadap Sion"]},{"type":"verse","number":1,"content":[{"text":"Betapa Tuhan menutupi putri Sion dengan awan dalam kemarahan-Nya.","poem":1},{"text":"Dia melemparkan kemuliaan Israel dari langit ke bumi.","poem":2},{"text":"Dia tidak mengingat tumpuan kaki-Nya","poem":1},{"text":"pada hari kemarahan-Nya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"Tuhan telah menelan semua tempat tinggal Yakub","poem":1},{"text":"tanpa belas kasihan.","poem":2},{"text":"Dalam kemurkaan-Nya,","poem":1},{"text":"Dia merobohkan benteng-benteng putri Yehuda.","poem":2},{"text":"Dia menjatuhkannya ke tanah,","poem":1},{"text":"dan menajiskan kerajaan serta para pemimpinnya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Dalam kemarahan yang dahsyat, Dia mematahkan semua tanduk Israel.","poem":1},{"text":"Dia menarik kembali tangan kanan-Nya dari hadapan musuh,","poem":2},{"text":"dan membakar Yakub seperti api yang menyala-nyala,","poem":1},{"text":"menghabiskan semua yang ada di sekelilingnya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"Dia melenturkan busur-Nya seperti seorang musuh.","poem":1},{"text":"Dia mengacungkan tangan kanan-Nya seperti seorang lawan,","poem":2},{"text":"dan membunuh semua yang menyenangkan mata di kemah putri Sion.","poem":1},{"text":"Dia mencurahkan kemurkaan-Nya seperti api.","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"Tuhan menjadi seperti seorang musuh.","poem":1},{"text":"Dia menelan Israel.","poem":2},{"text":"Dia menelan semua istananya.","poem":1},{"text":"Dia menghancurkan benteng-bentengnya,","poem":2},{"text":"dan melipatgandakan perkabungan dan ratapan","poem":1},{"text":"pada putri Yehuda.","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"Dia merusak kemah-Nya","poem":1},{"text":"seolah-olah itu sebuah kebun.","poem":2},{"text":"Dia menghancurkan","poem":1},{"text":"tempat pertemuan-Nya.","poem":2},{"text":"TUHAN membuat Sion","poem":1},{"text":"melupakan perayaan dan hari Sabat.","poem":2},{"text":"Dia merendahkan raja dan imam","poem":1},{"text":"dalam kedahsyatan kemarahan-Nya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Tuhan menolak mazbah-Nya,","poem":1},{"text":"dan meninggalkan tempat kudus-Nya.","poem":2},{"text":"Dia menyerahkan tembok-tembok istananya","poem":1},{"text":"ke tangan musuh.","poem":2},{"text":"Mereka membuat kegaduhan di bait TUHAN","poem":1},{"text":"seperti pada hari perayaan.","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"TUHAN bertekad menghancurkan tembok putri Sion.","poem":1},{"text":"Dia merentangkan tali pengukur.","poem":2},{"text":"Dia tidak menahan tangan-Nya untuk menghancurkan.","poem":1},{"text":"Dia membuat benteng dan tembok meratap;","poem":2},{"lineBreak":true},{"text":"mereka merana bersama-sama.","poem":2}]},{"type":"line_break"},{"type":"verse","number":9,"content":[{"text":"Pintu-pintu gerbangnya tenggelam ke tanah.","poem":1},{"text":"Dia menghancurkan dan mematahkan palang-palang pintunya.","poem":2},{"text":"Raja dan para pemimpinnya ada di antara bangsa-bangsa.","poem":1},{"text":"Hukum Taurat tidak ada lagi.","poem":2},{"text":"Nabi-nabinya juga tidak mendapatkan","poem":1},{"text":"penglihatan dari TUHAN.","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"Para tua-tua putri Sion duduk di tanah,","poem":1},{"text":"dan berdiam diri.","poem":2},{"text":"Mereka menabur debu ke atas kepala mereka,","poem":1},{"text":"dan mengenakan pakaian berkabung.","poem":2},{"text":"Gadis-gadis Yerusalem","poem":1},{"text":"menundukkan kepala mereka ke tanah.","poem":2}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"Mataku sembap karena air mata,","poem":1},{"text":"dan batinku bergejolak.","poem":2},{"text":"Hatiku ditumpahkan ke tanah","poem":1},{"text":"karena kehancuran putri bangsaku.","poem":2},{"text":"Anak-anak dan bayi-bayi pingsan","poem":1},{"text":"di jalan-jalan kota.","poem":2}]},{"type":"line_break"},{"type":"verse","number":12,"content":[{"text":"Mereka bertanya kepada ibu mereka,","poem":1},{"text":"“Di mana gandum dan anggur?”","poem":2},{"text":"saat mereka pingsan seperti seorang yang terluka","poem":1},{"text":"di jalan-jalan kota itu,","poem":2},{"text":"saat nyawa mereka ditumpahkan","poem":1},{"text":"ke pangkuan ibu mereka.","poem":2}]},{"type":"line_break"},{"type":"verse","number":13,"content":[{"text":"Apa yang dapat kunyatakan kepadamu?","poem":1},{"text":"Dengan apa aku dapat membandingkanmu, hai putri Yerusalem?","poem":2},{"text":"Dengan apa aku dapat menyamakanmu","poem":1},{"text":"sehingga aku dapat menghiburmu, hai putri perawan Sion?","poem":2},{"text":"Sebab, kehancuranmu sangat luas seperti lautan.","poem":1},{"text":"Siapa yang dapat menyembuhkanmu?","poem":2}]},{"type":"line_break"},{"type":"verse","number":14,"content":[{"text":"Nabi-nabimu melihat","poem":1},{"text":"hal-hal yang hampa dan bodoh.","poem":2},{"text":"Mereka tidak menyingkapkan kesalahanmu","poem":1},{"text":"untuk mengembalikanmu dari penawananmu,","poem":2},{"text":"melainkan melihat bagimu","poem":1},{"text":"ramalan-ramalan palsu dan menyesatkan.","poem":2}]},{"type":"line_break"},{"type":"verse","number":15,"content":[{"text":"Semua yang melintas di jalan","poem":1},{"text":"bertepuk tangan kepadamu.","poem":2},{"text":"Mereka bersiul","poem":1},{"text":"dan menggeleng-gelengkan kepala terhadap putri Yerusalem.","poem":2},{"text":"“Inikah kota yang disebut,","poem":1},{"text":"‘kesempurnaan dari keindahan,","poem":2},{"lineBreak":true},{"text":"sukacita seluruh bumi?’”","poem":2}]},{"type":"line_break"},{"type":"verse","number":16,"content":[{"text":"Semua musuhmu membuka mulut mereka terhadapmu.","poem":1},{"text":"Mereka bersiul dan menggertakkan gigi.","poem":2},{"text":"Mereka berkata, “Kami telah menelannya.","poem":1},{"text":"Sungguh, inilah hari yang kami nantikan.","poem":2},{"lineBreak":true},{"text":"Kami telah mendapatkannya. Kami telah melihatnya.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":17,"content":[{"text":"TUHAN telah melakukan apa yang Dia rencanakan.","poem":1},{"text":"Dia telah menggenapi firman-Nya,","poem":2},{"lineBreak":true},{"text":"yang Dia perintahkan pada zaman dahulu.","poem":2},{"text":"Dia merobohkan tanpa belas kasihan.","poem":1},{"text":"Dia membuat musuh-musuhmu bersukacita atasmu,","poem":2},{"lineBreak":true},{"text":"dan meninggikan tanduk lawan-lawanmu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":18,"content":[{"text":"Hati mereka menjerit kepada Tuhan.","poem":1},{"text":"Hai tembok putri Sion,","poem":2},{"lineBreak":true},{"text":"biarlah air mata mengalir seperti sungai siang dan malam.","poem":2},{"text":"Jangan berikan istirahat kepada dirimu sendiri;","poem":1},{"text":"jangan biarkan matamu beristirahat.","poem":2}]},{"type":"line_break"},{"type":"verse","number":19,"content":[{"text":"Bangunlah, berserulah pada malam hari, pada awal penjagaan malam.","poem":1},{"text":"Curahkan hatimu seperti air di hadapan Tuhan.","poem":2},{"text":"Angkatlah tanganmu kepada-Nya","poem":1},{"text":"demi nyawa anak-anakmu,","poem":2},{"lineBreak":true},{"text":"yang pingsan karena kelaparan di ujung setiap jalan.","poem":2}]},{"type":"line_break"},{"type":"verse","number":20,"content":[{"text":"Lihatlah, ya TUHAN, dan perhatikanlah!","poem":1},{"text":"Terhadap siapakah Engkau telah berbuat demikian?","poem":2},{"text":"Haruskah para perempuan memakan anak kandung mereka, anak-anak yang mereka timang?","poem":1},{"text":"Haruskah imam dan nabi dibunuh di tempat kudus Tuhan?","poem":2}]},{"type":"line_break"},{"type":"verse","number":21,"content":[{"text":"Pemuda dan orang tua","poem":1},{"text":"tergeletak di atas tanah di jalan-jalan.","poem":2},{"text":"Gadis-gadisku dan pemuda-pemudaku","poem":1},{"text":"telah dibunuh dengan pedang.","poem":2},{"text":"Engkau membunuh mereka pada hari kemarahan-Mu;","poem":1},{"text":"Engkau membantai tanpa belas kasihan.","poem":2}]},{"type":"line_break"},{"type":"verse","number":22,"content":[{"text":"Seperti pada hari perayaan,","poem":1},{"text":"Engkau memanggil","poem":2},{"text":"kengerian-kengerianku","poem":1},{"text":"dari segala penjuru.","poem":2},{"text":"Tidak ada seorang pun yang luput atau bertahan","poem":1},{"text":"pada hari kemarahan TUHAN.","poem":2},{"text":"Mereka yang aku asuh dan besarkan","poem":1},{"text":"dibinasakan oleh musuhku.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/LAM/2.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/LAM/3.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/LAM/1.json","previousChapterAudioLinks":{},"numberOfVerses":22}