{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"LAM","translationId":"ind_ayt","name":"RATAPAN","commonName":"RATAPAN","title":"Ratapan","order":25,"numberOfChapters":5,"sha256":"28f6241cfd413638ca9cf1f9264cb20521ecadb5c86eeeb7358970bb8d6954cc","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/LAM/1.json","lastChapterNumber":5,"lastChapterApiLink":"/api/ind_ayt/LAM/5.json","totalNumberOfVerses":154},"chapter":{"number":5,"content":[{"type":"heading","content":["Doa untuk Pemulihan"]},{"type":"verse","number":1,"content":[{"text":"Ingatlah, ya TUHAN, apa yang terjadi atas kami.","poem":1},{"text":"Pandanglah dan lihatlah aib kami.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Milik pusaka kami dialihkan kepada orang-orang asing,","poem":1},{"text":"rumah kami kepada orang-orang yang tidak dikenal.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Kami menjadi yatim,","poem":1},{"text":"tidak mempunyai ayah,","poem":2},{"lineBreak":true},{"text":"dan ibu kami seperti janda.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Kami harus membayar untuk air yang kami minum.","poem":1},{"text":"Kayu harus kami dapatkan dengan suatu harga.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Para pengejar kami begitu dekat.","poem":1},{"text":"Kami lelah; tidak ada istirahat bagi kami.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Kami menyerahkan tangan kepada Mesir,","poem":1},{"text":"dan kepada Asyur,","poem":2},{"lineBreak":true},{"text":"supaya dikenyangkan dengan roti.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Nenek moyang kami berbuat dosa,","poem":1},{"text":"dan sudah tiada lagi,","poem":2},{"lineBreak":true},{"text":"dan kami menanggung kesalahan-kesalahan mereka.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Budak-budak memerintah atas kami.","poem":1},{"text":"Tidak ada yang melepaskan kami dari tangan mereka.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Kami mendapatkan roti kami dengan mempertaruhkan nyawa kami","poem":1},{"text":"karena ancaman pedang di padang belantara.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Kulit kami panas seperti perapian","poem":1},{"text":"karena demam panas kelaparan.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Mereka memerkosa perempuan-perempuan di Sion,","poem":1},{"text":"gadis-gadis di kota-kota Yehuda.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Para pemimpin digantung oleh tangan mereka;","poem":1},{"text":"para tua-tua tidak dihormati.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Pemuda-pemuda","poem":1},{"text":"harus memikul batu kilangan,","poem":2},{"text":"dan anak-anak laki-laki terhuyung-huyung","poem":1},{"text":"di bawah pikulan kayu.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Para orang tua meninggalkan pintu-pintu gerbang kota,","poem":1},{"text":"para pemuda menghentikan musik mereka.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Sukacita hati kami telah berakhir.","poem":1},{"text":"Tarian kami diubah menjadi ratapan.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Mahkota telah jatuh dari kepala kami.","poem":1},{"text":"Celakalah kami karena kami telah berdosa.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Karena hal ini, hati kami menjadi lemah;","poem":1},{"text":"Karena hal-hal ini, mata kami menjadi kabur;","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Karena Gunung Sion tinggal sunyi,","poem":1},{"text":"dan rubah-rubah berkeliaran di sana.","poem":2}]},{"type":"line_break"},{"type":"verse","number":19,"content":[{"text":"Engkau, ya TUHAN, memerintah selama-lamanya;","poem":1},{"text":"takhta-Mu dari generasi ke generasi.","poem":2}]},{"type":"verse","number":20,"content":[{"text":"Mengapa Engkau melupakan kami selama-lamanya,","poem":1},{"text":"meninggalkan kami begitu lama?","poem":2}]},{"type":"verse","number":21,"content":[{"text":"Kembalikanlah kami kepada-Mu, ya TUHAN,","poem":1},{"text":"supaya kami dapat dipulihkan.","poem":2},{"lineBreak":true},{"text":"Perbaruilah hari-hari kami seperti dahulu kala,","poem":2}]},{"type":"verse","number":22,"content":[{"text":"kecuali Engkau benar-benar telah menolak kami,","poem":1},{"text":"dan sangat marah terhadap kami.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/LAM/5.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/EZK/1.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/LAM/4.json","previousChapterAudioLinks":{},"numberOfVerses":22}