{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"LAM","translationId":"ind_ayt","name":"RATAPAN","commonName":"RATAPAN","title":"Ratapan","order":25,"numberOfChapters":5,"sha256":"28f6241cfd413638ca9cf1f9264cb20521ecadb5c86eeeb7358970bb8d6954cc","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/LAM/1.json","lastChapterNumber":5,"lastChapterApiLink":"/api/ind_ayt/LAM/5.json","totalNumberOfVerses":154},"chapter":{"number":1,"content":[{"type":"heading","content":["Yerusalem Menangis atas Kebinasaannya"]},{"type":"verse","number":1,"content":[{"text":"Betapa ia tinggal dalam keterasingan, yaitu kota yang dahulu penuh dengan orang-orang itu!","poem":1},{"text":"Ia yang dahulu sangat besar di antara bangsa-bangsa telah menjadi seperti seorang janda!","poem":2},{"lineBreak":true},{"text":"Putri di antara provinsi-provinsi telah menjadi seorang budak.","poem":2}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"Ia menangis getir pada malam hari;","poem":1},{"text":"air matanya berlinang di pipinya.","poem":2},{"lineBreak":true},{"text":"Di antara semua kekasihnya, tidak ada yang menghibur dia.","poem":2},{"text":"Semua temannya berkhianat kepadanya;","poem":1},{"text":"mereka telah menjadi musuhnya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Yehuda telah pergi ke pembuangan karena penderitaan","poem":1},{"text":"dan perbudakan yang berat.","poem":2},{"text":"Ia tinggal di antara bangsa-bangsa,","poem":1},{"text":"tetapi tidak menemukan tempat istirahat.","poem":2},{"text":"Semua pengejarnya menyusul dia","poem":1},{"text":"di tengah kesesakannya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"Jalan-jalan Sion berkabung","poem":1},{"text":"karena tidak seorang pun datang ke perayaan yang telah ditetapkan.","poem":2},{"text":"Semua pintu gerbangnya sepi,","poem":1},{"text":"imam-imamnya berkeluh kesah,","poem":2},{"text":"gadis-gadisnya bersedih,","poem":1},{"text":"dan ia sendiri dalam kepahitan.","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"Lawan-lawannya telah menjadi pemimpin.","poem":1},{"text":"Musuh-musuhnya makmur.","poem":2},{"text":"Sebab, TUHAN membuatnya menderita","poem":1},{"text":"karena banyaknya pelanggarannya.","poem":2},{"text":"Anak-anaknya berjalan","poem":1},{"text":"sebagai tawanan di hadapan musuh.","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"Segala kemuliaan telah berlalu","poem":1},{"text":"dari putri Sion.","poem":2},{"text":"Para pemimpinnya telah menjadi seperti rusa","poem":1},{"text":"yang tidak menemukan padang rumput.","poem":2},{"text":"Mereka melarikan diri tanpa kekuatan","poem":1},{"text":"di hadapan pengejar.","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Pada hari-hari penderitaan dan pengembaraannya,","poem":1},{"text":"Yerusalem teringat akan segala harta bendanya,","poem":2},{"lineBreak":true},{"text":"yang ia miliki pada zaman dahulu.","poem":2},{"text":"Ketika orang-orangnya jatuh ke tangan musuh,","poem":1},{"text":"dan tidak ada seorang pun yang menolongnya,","poem":2},{"text":"musuh-musuhnya memandanginya,","poem":1},{"text":"dan tertawa atas kehancurannya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"Yerusalem sangat berdosa.","poem":1},{"text":"Karena itu, ia menjadi najis.","poem":2},{"text":"Semua orang yang dahulu menghormatinya kini merendahkannya","poem":1},{"text":"karena mereka telah melihat ketelanjangannya.","poem":2},{"text":"Ia sendiri berkeluh kesah,","poem":1},{"text":"dan berpaling.","poem":2}]},{"type":"line_break"},{"type":"verse","number":9,"content":[{"text":"Kenajisannya ada pada pakaiannya;","poem":1},{"text":"Ia tidak memikirkan akhirnya.","poem":2},{"text":"Karena itu, kejatuhannya luar biasa.","poem":1},{"text":"Ia tidak memiliki penghibur.","poem":2},{"text":"“Ya TUHAN, lihatlah penderitaanku,","poem":1},{"text":"karena musuh telah meninggikan diri!”","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"Musuh telah merentangkan tangannya","poem":1},{"text":"ke atas segala harta bendanya.","poem":2},{"text":"Bahkan, ia telah melihat bangsa-bangsa itu masuk ke tempat kudusnya,","poem":1},{"text":"yang Engkau perintahkan agar mereka tidak masuk ke dalam jemaat-Mu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"Semua penduduknya berkeluh kesah","poem":1},{"text":"sambil mencari roti.","poem":2},{"text":"Mereka memberikan harta benda mereka","poem":1},{"text":"ganti makanan untuk bertahan hidup.","poem":2},{"text":"“Lihatlah, ya TUHAN, dan perhatikanlah,","poem":1},{"text":"karena aku direndahkan.","poem":2}]},{"type":"line_break"},{"type":"verse","number":12,"content":[{"text":"Apakah ini tidak ada artinya bagimu,","poem":1},{"text":"hai kamu semua yang lewat di jalan?","poem":2},{"text":"Lihatlah dan perhatikanlah","poem":1},{"text":"apabila ada kesengsaraan seperti kesengsaraanku,","poem":2},{"text":"yang ditimpakan ke atasku,","poem":1},{"text":"yang TUHAN timbulkan pada hari kemarahan-Nya yang dahsyat.","poem":2}]},{"type":"line_break"},{"type":"verse","number":13,"content":[{"text":"Dari ketinggian, Dia mengirimkan api ke dalam tulang-tulangku,","poem":1},{"text":"dan menguasainya.","poem":2},{"text":"Dia menebarkan jala untuk kakiku.","poem":1},{"text":"Dia telah membalikkan aku.","poem":2},{"text":"Dia telah membuatku hancur,","poem":1},{"text":"lemah sepanjang hari.","poem":2}]},{"type":"line_break"},{"type":"verse","number":14,"content":[{"text":"Kuk pelanggaran-pelanggaranku diikat.","poem":1},{"text":"Dengan tangan-Nya, semua itu dijalin bersama-sama,","poem":2},{"text":"dan dipasangkan pada leherku.","poem":1},{"text":"Dia telah membuat kekuatanku lenyap.","poem":2},{"text":"Tuhan telah menyerahkan aku ke tangan mereka,","poem":1},{"text":"yang tidak dapat aku lawan.","poem":2}]},{"type":"line_break"},{"type":"verse","number":15,"content":[{"text":"Tuhan telah menolak semua orangku yang perkasa di tengah-tengahku,","poem":1},{"text":"Dia telah memanggil suatu kumpulan melawan aku","poem":2},{"lineBreak":true},{"text":"untuk menghancurkan orang-orang mudaku.","poem":2},{"text":"Tuhan telah menginjak-injak anak dara, putri Yehuda,","poem":1},{"text":"seperti dalam pemerasan anggur.","poem":2}]},{"type":"line_break"},{"type":"verse","number":16,"content":[{"text":"Karena hal-hal inilah aku menangis.","poem":1},{"text":"Mataku, mataku mencucurkan air mata.","poem":2},{"text":"Sebab, penghibur yang menyegarkan jiwaku","poem":1},{"text":"berada jauh dariku.","poem":2},{"text":"Anak-anakku hancur","poem":1},{"text":"karena musuh telah menang.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":17,"content":[{"text":"Sion membentangkan tangannya,","poem":1},{"text":"tetapi tidak seorang pun menghiburnya.","poem":2},{"text":"TUHAN telah memerintahkan terhadap Yakub","poem":1},{"text":"bahwa musuh-musuhnya akan ada di sekelilingnya.","poem":2},{"lineBreak":true},{"text":"Yerusalem telah menjadi hal yang najis di antara mereka.","poem":2}]},{"type":"line_break"},{"type":"verse","number":18,"content":[{"text":"“TUHAN itu benar,","poem":1},{"text":"karena aku telah memberontak terhadap firman-Nya.","poem":2},{"text":"Dengarlah, hai segala bangsa,","poem":1},{"text":"dan lihatlah penderitaanku.","poem":2},{"text":"Gadis-gadisku dan pemuda-pemudaku","poem":1},{"text":"telah pergi ke pembuangan.","poem":2}]},{"type":"line_break"},{"type":"verse","number":19,"content":[{"text":"Aku memanggil kekasih-kekasihku,","poem":1},{"text":"tetapi mereka menipuku.","poem":2},{"text":"Para imam dan tua-tuaku mati di kota","poem":1},{"text":"ketika mereka mencari makanan untuk bertahan hidup.","poem":2}]},{"type":"line_break"},{"type":"verse","number":20,"content":[{"text":"Lihatlah, ya TUHAN,","poem":1},{"text":"karena aku dalam kesesakan.","poem":2},{"text":"Batinku gelisah,","poem":1},{"text":"dan hatiku bergejolak di dalam diriku","poem":2},{"lineBreak":true},{"text":"karena aku telah sangat memberontak.","poem":2},{"text":"Di jalan, pedang menggugurkan;","poem":1},{"text":"di rumah, ada kematian.","poem":2}]},{"type":"line_break"},{"type":"verse","number":21,"content":[{"text":"Mereka telah mendengar bahwa aku berkeluh kesah,","poem":1},{"text":"tetapi tidak seorang pun menghiburku.","poem":2},{"text":"Semua musuhku telah mendengar kemalanganku.","poem":1},{"text":"Mereka senang karena Engkau telah melakukannya.","poem":2},{"text":"Engkau akan mendatangkan hari yang telah Engkau sebut,","poem":1},{"text":"dan mereka akan menjadi seperti aku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":22,"content":[{"text":"Biarlah semua kejahatan mereka sampai ke hadapan-Mu,","poem":1},{"text":"dan perlakukanlah mereka seperti Engkau memperlakukan aku karena semua kesalahanku.","poem":2},{"text":"Sebab, keluh kesahku banyak,","poem":1},{"text":"dan hatiku lemah.”","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/LAM/1.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/LAM/2.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/JER/52.json","previousChapterAudioLinks":{},"numberOfVerses":22}