{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"JER","translationId":"ind_ayt","name":"YEREMIA","commonName":"YEREMIA","title":"Yeremia","order":24,"numberOfChapters":52,"sha256":"a01e12b3ecfc86d080f4c575bcc6c056c26bc7651d1f251c60d7480ffa6e11e5","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/JER/1.json","lastChapterNumber":52,"lastChapterApiLink":"/api/ind_ayt/JER/52.json","totalNumberOfVerses":1364},"chapter":{"number":30,"content":[{"type":"heading","content":["Janji-Janji Pengharapan"]},{"type":"verse","number":1,"content":["Firman yang datang kepada Yeremia dari TUHAN,"]},{"type":"verse","number":2,"content":["“Beginilah firman TUHAN, Allah Israel, ‘Tuliskanlah semua firman yang sudah Aku sampaikan kepadamu dalam sebuah buku."]},{"type":"verse","number":3,"content":["Sebab, lihatlah, waktunya akan tiba,’ firman TUHAN, ‘saat Aku akan mengembalikan keadaan jemaat-Ku, Israel dan Yehuda,’ firman TUHAN, ‘dan Aku akan membawa mereka kembali ke negeri yang Aku berikan kepada nenek moyang mereka, dan mereka akan memiliki negeri itu lagi.’”"]},{"type":"verse","number":4,"content":["Inilah firman yang TUHAN firmankan mengenai Israel dan Yehuda:"]},{"type":"verse","number":5,"content":["“Beginilah firman TUHAN,",{"lineBreak":true},{"text":"‘Kami telah mendengar suara kegentaran,","poem":1},{"text":"kengerian, dan tidak ada kedamaian.","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"Sekarang, bertanyalah","poem":1},{"text":"dan perhatikanlah, dapatkah seorang laki-laki melahirkan bayi?","poem":2},{"text":"Lalu, mengapa Aku melihat setiap laki-laki","poem":1},{"text":"meletakkan tangannya di pinggangnya,","poem":2},{"text":"seperti seorang perempuan yang melahirkan?","poem":1},{"text":"Mengapa wajah setiap orang menjadi pucat?","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Celaka! Sebab, hari itu sangat hebat,","poem":1},{"text":"tidak ada yang seperti itu.","poem":2},{"text":"Itulah masa kesesakan Yakub,","poem":1},{"text":"tetapi dia akan diselamatkan.’","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":["‘Akan terjadi pada waktu itu,’ firman TUHAN semesta alam, ‘bahwa Aku akan mematahkan kuknya dari tengkukmu dan akan memutuskan tali-talimu, dan orang-orang asing tidak akan lagi membuatnya menjadi budak."]},{"type":"verse","number":9,"content":["Akan tetapi, mereka akan melayani TUHAN, Allah mereka, dan Daud, raja mereka, yang akan Aku bangkitkan bagi mereka.’"]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"‘Karena itu, janganlah kamu takut, hai hambaku Yakub,’","poem":1},{"text":"firman TUHAN,","poem":2},{"text":"‘ataupun cemas, hai Israel.","poem":1},{"text":"Sebab, ketahuilah, Aku akan menyelamatkanmu dari tempat jauh,","poem":2},{"text":"dan keturunanmu dari negeri","poem":1},{"text":"yang menawan mereka.","poem":2},{"lineBreak":true},{"text":"Yakub akan kembali","poem":2},{"text":"dan akan beristirahat","poem":1},{"text":"dan akan tenang,","poem":2},{"lineBreak":true},{"text":"dan tidak seorang pun akan membuatnya takut.’","poem":2}]},{"type":"verse","number":11,"content":[{"text":"‘Sebab Aku menyertaimu,’","poem":1},{"text":"firman TUHAN,","poem":2},{"text":"‘untuk menyelamatkanmu.","poem":1},{"text":"Aku akan menghabisi semua bangsa","poem":2},{"lineBreak":true},{"text":"tempat Aku mencerai-beraikanmu,","poem":2},{"text":"tetapi Aku tidak akan","poem":1},{"text":"menghabisi kamu sampai habis.","poem":2},{"text":"Aku akan menghajarmu dengan ukuran yang adil,","poem":1},{"text":"dan Aku tidak akan meninggalkanmu tanpa hukuman sama sekali.’”","poem":2}]},{"type":"line_break"},{"type":"verse","number":12,"content":[{"text":"“Sebab, beginilah firman TUHAN,","poem":1},{"lineBreak":true},{"text":"‘Lukamu tidak dapat disembuhkan","poem":1},{"text":"dan lukamu sangat pedih.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Tidak ada yang membela perkaramu,","poem":1},{"text":"tidak ada obat untuk lukamu, tidak ada kesembuhan bagimu.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Semua kekasihmu","poem":1},{"text":"telah melupakan kamu,","poem":2},{"lineBreak":true},{"text":"mereka tidak mencarimu.","poem":2},{"text":"Sebab, Aku melukaimu dengan luka seorang musuh,","poem":1},{"text":"dengan hukuman dari musuh yang kejam,","poem":2},{"text":"karena kesalahanmu sangat besar,","poem":1},{"text":"karena dosa-dosamu banyak.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Mengapa kamu menjerit karena lukamu?","poem":1},{"text":"Rasa sakitmu tidak dapat disembuhkan","poem":2},{"text":"karena sangat besarnya kesalahanmu,","poem":1},{"text":"karena banyaknya dosa-dosamu,","poem":2},{"lineBreak":true},{"text":"Aku telah melakukan hal-hal ini kepadamu.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Karena itu, semua orang yang melahap kamu","poem":1},{"text":"akan dilahap,","poem":2},{"lineBreak":true},{"text":"dan semua musuhmu, masing-masing mereka, akan masuk ke dalam penawanan.","poem":2},{"text":"Orang-orang yang menjarahmu","poem":1},{"text":"akan menjadi jarahan,","poem":2},{"text":"dan semua orang yang memangsamu","poem":1},{"text":"akan Aku buat menjadi mangsa.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Sebab, Aku akan memulihkan kembali kesehatanmu","poem":1},{"text":"dan Aku akan menyembuhkanmu dari luka-lukamu,’ firman TUHAN,","poem":2},{"text":"‘karena mereka telah memanggilmu orang buangan dengan berkata,","poem":1},{"text":"‘Inilah Sion, yang tidak seorang pun mencarinya.’’”","poem":2}]},{"type":"line_break"},{"type":"verse","number":18,"content":[{"text":"“Beginilah firman TUHAN,","poem":1},{"lineBreak":true},{"text":"‘Ketahuilah, Aku akan memulihkan keadaan tenda-tenda Yakub,","poem":1},{"text":"dan berbelas kasihan","poem":2},{"lineBreak":true},{"text":"kepada tempat-tempat kediamannya.","poem":2},{"text":"Kota itu akan dibangun kembali","poem":1},{"text":"di atas puing-puingnya,","poem":2},{"lineBreak":true},{"text":"dan istana akan tetap berdiri","poem":2},{"lineBreak":true},{"text":"di tempatnya.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Dari antara mereka akan keluar ucapan syukur","poem":1},{"text":"dan suara mereka yang bersukaria.","poem":2},{"text":"Aku akan melipatgandakan mereka","poem":1},{"text":"sehingga mereka tidak akan menjadi sedikit.","poem":2},{"text":"Aku akan membuat mereka dihormati,","poem":1},{"text":"dan mereka tidak akan dihinakan.","poem":2}]},{"type":"verse","number":20,"content":[{"text":"Anak-anak mereka akan menjadi seperti sebelumnya,","poem":1},{"lineBreak":true},{"text":"dan jemaat mereka akan ditegakkan di depan-Ku,","poem":1},{"text":"dan Aku akan menghukum semua orang yang menindas mereka.","poem":2}]},{"type":"verse","number":21,"content":[{"text":"Pemimpin mereka akan berasal dari mereka sendiri,","poem":1},{"lineBreak":true},{"text":"penguasa mereka akan datang dari tengah-tengah mereka.","poem":1},{"text":"Aku akan membuatnya mendekat","poem":2},{"text":"dan dia akan mendekat kepada-Ku.","poem":1},{"text":"Sebab, siapakah yang berani mempertaruhkan nyawanya untuk mendekati-Ku?’","poem":2},{"lineBreak":true},{"text":"firman TUHAN.","poem":2}]},{"type":"verse","number":22,"content":[{"text":"‘Kamu akan menjadi jemaat-Ku","poem":1},{"text":"dan Aku akan menjadi Allahmu.’","poem":2}]},{"type":"line_break"},{"type":"verse","number":23,"content":[{"text":"Lihatlah, badai TUHAN menyambar dengan kemarahan,","poem":1},{"text":"angin topan yang menyapu;","poem":2},{"text":"itu akan menimpa","poem":1},{"text":"kepala orang-orang jahat.","poem":2}]},{"type":"verse","number":24,"content":[{"text":"Kedahsyatan kemarahan TUHAN","poem":1},{"text":"tidak akan reda","poem":2},{"text":"sampai Dia melaksanakannya","poem":1},{"text":"dan menyelesaikan maksud hati-Nya.","poem":2},{"text":"Pada hari-hari terakhir,","poem":1},{"text":"kamu akan memahami ini.”","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/JER/30.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/JER/31.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/JER/29.json","previousChapterAudioLinks":{},"numberOfVerses":24}