{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"JER","translationId":"ind_ayt","name":"YEREMIA","commonName":"YEREMIA","title":"Yeremia","order":24,"numberOfChapters":52,"sha256":"a01e12b3ecfc86d080f4c575bcc6c056c26bc7651d1f251c60d7480ffa6e11e5","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/JER/1.json","lastChapterNumber":52,"lastChapterApiLink":"/api/ind_ayt/JER/52.json","totalNumberOfVerses":1364},"chapter":{"number":50,"content":[{"type":"heading","content":["Mengenai Babel"]},{"type":"verse","number":1,"content":["Firman yang TUHAN katakan mengenai Babel, tanah orang-orang Kasdim, melalui Nabi Yeremia,"]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"“Umumkanlah dan nyatakanlah di antara bangsa-bangsa.","poem":1},{"text":"Nyatakanlah dan angkatlah sebuah panji.","poem":2},{"text":"Jangan merahasiakannya, tetapi katakanlah,","poem":1},{"text":"‘Babel telah direbut,","poem":2},{"text":"Bel dipermalukan,","poem":1},{"text":"Merodakh dihancurkan berkeping-keping.","poem":2},{"text":"Berhala-berhalanya telah dipermalukan,","poem":1},{"text":"patung-patungnya dihancurkan berkeping-keping.’","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Sebab, dari utara, suatu bangsa telah muncul melawan ia,","poem":1},{"text":"yang akan membuat negerinya menjadi tandus,","poem":2},{"text":"dan tidak seorang pun akan tinggal di sana,","poem":1},{"text":"baik manusia maupun binatang akan melarikan diri.”","poem":2}]},{"type":"verse","number":4,"content":[{"text":"“Pada hari-hari itu dan pada waktu itu,” firman TUHAN,","poem":1},{"text":"“orang-orang Israel dan orang-orang Yehuda akan datang, mereka dan keturunan Yehuda bersama-sama,","poem":2},{"text":"mereka datang sambil menangis,","poem":1},{"text":"dan mereka akan mencari TUHAN, Allah mereka.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Mereka akan menanyakan jalan menuju Sion","poem":1},{"text":"dengan wajah yang menghadapnya,","poem":2},{"text":"kata mereka, ‘Datanglah, marilah kita menggabungkan diri kita kepada TUHAN","poem":1},{"text":"dalam suatu perjanjian yang abadi,","poem":2},{"lineBreak":true},{"text":"yang tidak akan dilupakan.’","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"Umat-Ku telah menjadi domba yang hilang.","poem":1},{"text":"Para gembala mereka telah","poem":2},{"text":"menyesatkan mereka di gunung-gunung. Mereka telah pergi dari gunung ke bukit.","poem":1},{"text":"Mereka telah melupakan tempat peristirahatan mereka.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Semua yang menjumpai mereka telah melahap mereka,","poem":1},{"text":"dan musuh-musuh mereka telah berkata,","poem":2},{"text":"‘Kami tidak bersalah","poem":1},{"text":"karena mereka telah berdosa terhadap TUHAN,","poem":2},{"text":"tempat tinggal kebenaran mereka,","poem":1},{"text":"TUHAN, pengharapan nenek moyang mereka.’","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"Larilah dari tengah-tengah Babel,","poem":1},{"text":"dan pergilah dari negeri orang-orang Kasdim,","poem":2},{"lineBreak":true},{"text":"dan jadilah seperti kambing jantan di depan kawanan.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Sebab, ketahuilah,","poem":1},{"text":"Aku akan membangkitkan dan membuat kumpulan bangsa yang besar dari negeri utara menyerang Babel.","poem":2},{"text":"Mereka akan berjajar melawan dia.","poem":1},{"text":"Dari sana, ia akan direbut,","poem":2},{"text":"panah-panah mereka seperti kesatria andal","poem":1},{"text":"yang tidak kembali dengan tangan kosong.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Kasdim akan menjadi rampasan,","poem":1},{"text":"semua yang merampasnya akan dipuaskan,”","poem":2},{"lineBreak":true},{"text":"firman TUHAN.","poem":2}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"“Karena kamu bergembira, karena kamu bersukaria,","poem":1},{"text":"hai kamu perusak warisan-Ku,","poem":2},{"text":"karena kamu bertambah gemuk seperti anak lembu muda","poem":1},{"text":"di rerumputan,","poem":2},{"text":"dan meringkik","poem":1},{"text":"seperti kuda jantan,","poem":2}]},{"type":"verse","number":12,"content":[{"text":"ibumu akan menjadi sangat malu,","poem":1},{"text":"dia yang melahirkanmu akan dipermalukan.","poem":2},{"text":"Ketahuilah, dia akan menjadi yang terkecil dari bangsa-bangsa,","poem":1},{"text":"suatu padang belantara, suatu tanah yang kering, dan suatu gurun pasir.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Karena murka TUHAN,","poem":1},{"text":"ia tidak akan dihuni,","poem":2},{"lineBreak":true},{"text":"melainkan akan sepenuhnya menjadi tempat tandus.","poem":2},{"text":"Setiap orang yang melintasi Babel akan takut","poem":1},{"text":"dan mendesis","poem":2},{"lineBreak":true},{"text":"karena semua luka-lukanya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":14,"content":[{"text":"Aturlah barisan melawan Babel dari semua sisi,","poem":1},{"text":"hai kamu semua yang melengkungkan busur,","poem":2},{"lineBreak":true},{"text":"panahkan ke arahnya, jangan menyayangkan anak panahmu","poem":2},{"text":"karena ia telah berdosa terhadap TUHAN.","poem":1}]},{"type":"verse","number":15,"content":[{"lineBreak":true},{"text":"Berserulah terhadapnya dari segala penjuru,","poem":1},{"text":"ia telah menyerah,","poem":2},{"text":"tiang-tiangnya telah runtuh,","poem":1},{"text":"tembok-temboknya telah dirobohkan.","poem":2},{"text":"Sebab, inilah pembalasan TUHAN,","poem":1},{"text":"lakukan pembalasan kepadanya,","poem":2},{"text":"lakukan kepadanya seperti yang telah ia lakukan.","poem":1}]},{"type":"verse","number":16,"content":[{"lineBreak":true},{"text":"Lenyapkanlah penabur dari Babel,","poem":1},{"text":"dan dia yang memegang sabit pada masa panen.","poem":2},{"text":"Karena pedang si penindas, setiap orang akan kembali kepada bangsanya sendiri,","poem":1},{"text":"dan setiap orang akan melarikan diri ke negerinya sendiri.","poem":2}]},{"type":"line_break"},{"type":"verse","number":17,"content":[{"text":"Israel adalah kawanan yang tercerai-berai,","poem":1},{"text":"singa-singa telah menghalau mereka.","poem":2},{"text":"Pertama, Raja Asyur","poem":1},{"text":"menelannya,","poem":2},{"text":"dan yang terakhir, Nebukadnezar, raja Babel,","poem":1},{"text":"telah mematahkan tulang-tulangnya.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Karena itu, beginilah firman TUHAN semesta alam, Allah Israel,","poem":1},{"lineBreak":true},{"text":"‘Ketahuilah, Aku akan menghukum Raja Babel dan negerinya,","poem":1},{"text":"seperti Aku telah menghukum Raja Asyur.","poem":2}]},{"type":"line_break"},{"type":"verse","number":19,"content":[{"text":"Aku akan membawa Israel kembali ke padang rumputnya,","poem":1},{"text":"dan ia akan merumput di Karmel dan di Basan,","poem":2},{"text":"dan jiwanya akan dipuaskan","poem":1},{"text":"di atas Pegunungan Efraim dan di Gilead.’","poem":2}]},{"type":"verse","number":20,"content":[{"text":"Pada hari-hari itu dan pada waktu itu,” firman TUHAN,","poem":1},{"text":"“kesalahan akan dicari-cari di Israel, tetapi tidak ada satu pun,","poem":2},{"text":"dan dosa-dosa di Yehuda,","poem":1},{"text":"tetapi tidak ada satu pun ditemukan,","poem":2},{"text":"karena Aku akan mengampuni mereka,","poem":1},{"text":"yang Aku sisakan.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":21,"content":[{"text":"“Majulah melawan negeri Merataim","poem":1},{"text":"dan melawan penduduk Pekod.","poem":2},{"lineBreak":true},{"text":"Bunuhlah dan hancurkan mereka seluruhnya,” firman TUHAN,","poem":2},{"text":"“lakukan semuanya","poem":1},{"text":"sesuai dengan yang Aku perintahkan kepadamu.","poem":2}]},{"type":"verse","number":22,"content":[{"text":"Suara pertempuran ada di negeri itu,","poem":1},{"text":"dan kehancuran besar.","poem":2}]},{"type":"verse","number":23,"content":[{"text":"Betapa palu seluruh bumi","poem":1},{"text":"telah dipatahkan dan dihancurkan!","poem":2},{"text":"Betapa Babel telah menjadi kengerian","poem":1},{"text":"di antara bangsa-bangsa!","poem":2}]},{"type":"verse","number":24,"content":[{"text":"Aku telah memasang jerat untukmu,","poem":1},{"text":"dan kamu terjebak juga, hai Babel, tetapi kamu tidak menyadarinya.","poem":2},{"text":"Kamu telah ditemukan dan juga ditangkap","poem":1},{"text":"karena kamu telah melawan TUHAN.","poem":2}]},{"type":"verse","number":25,"content":[{"text":"TUHAN telah membuka gudang senjata-Nya","poem":1},{"text":"dan mengeluarkan senjata-senjata murka-Nya.","poem":2},{"text":"Sebab, inilah pekerjaan TUHAN, Allah semesta alam","poem":1},{"text":"di negeri orang-orang Kasdim.","poem":2}]},{"type":"line_break"},{"type":"verse","number":26,"content":[{"text":"Datanglah menyerangnya dari segala penjuru.","poem":1},{"text":"Bukalah lumbung-lumbungnya,","poem":2},{"text":"tumpuklah ia seperti timbunan,","poem":1},{"text":"dan hancurkan ia seluruhnya,","poem":2},{"lineBreak":true},{"text":"jangan biarkan sesuatu pun tertinggal darinya.","poem":2}]},{"type":"verse","number":27,"content":[{"text":"Bunuhlah semua sapinya,","poem":1},{"text":"biarkan mereka menuju ke pembantaian.","poem":2},{"text":"Celakalah mereka!","poem":1},{"text":"Sebab, hari mereka sudah datang, masa penghukuman mereka.","poem":2}]},{"type":"verse","number":28,"content":[{"text":"Terdengar suara mereka yang melarikan diri dan lolos dari Babel,","poem":1},{"text":"untuk menyatakan di Sion","poem":2},{"text":"pembalasan TUHAN, Allah kita,","poem":1},{"text":"pembalasan atas bait suci-Nya!","poem":2}]},{"type":"line_break"},{"type":"verse","number":29,"content":[{"text":"Kumpulkanlah para pemanah","poem":1},{"text":"melawan Babel.","poem":2},{"text":"Hai semua orang yang melengkungkan busur, berkemahlah mengepung ia,","poem":1},{"text":"jangan biarkan seorang pun lolos.","poem":2},{"text":"Balaskanlah ia sesuai dengan perbuatannya,","poem":1},{"text":"perbuatlah terhadapnya sesuai dengan apa yang telah ia perbuat.","poem":2},{"text":"Sebab, ia telah bersikap angkuh terhadap TUHAN,","poem":1},{"text":"terhadap Yang Mahakudus Israel.","poem":2}]},{"type":"verse","number":30,"content":[{"text":"Karena itu, orang-orang mudanya akan rebah di tempat-tempat terbuka,","poem":1},{"text":"dan semua tentaranya akan dibungkam pada hari itu,”","poem":2},{"text":"firman TUHAN.","poem":1}]},{"type":"line_break"},{"type":"verse","number":31,"content":[{"text":"“Ketahuilah, Aku melawanmu,","poem":1},{"text":"hai kamu yang sombong,”","poem":2},{"lineBreak":true},{"text":"firman TUHAN, Allah semesta alam.","poem":2},{"text":"“Sebab, harimu telah tiba,","poem":1},{"text":"saat ketika Aku akan menghukummu.","poem":2}]},{"type":"verse","number":32,"content":[{"text":"Si sombong itu akan tersandung dan jatuh,","poem":1},{"text":"dan tak seorang pun akan membuatnya berdiri,","poem":2},{"text":"dan Aku akan menyalakan api di kota-kotanya,","poem":1},{"text":"dan api itu akan membakar habis semua yang ada di sekelilingnya.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":33,"content":[{"text":"Beginilah firman TUHAN semesta alam,","poem":1},{"lineBreak":true},{"text":"“Keturunan Israel ditindas, dan keturunan Yehuda juga,","poem":1},{"text":"dan semua yang menawan mereka mencengkeram mereka, dan menolak untuk melepaskan mereka.","poem":2}]},{"type":"verse","number":34,"content":[{"text":"Penebus mereka itu kuat,","poem":1},{"text":"TUHAN semesta alam nama-Nya.","poem":2},{"text":"Dia pasti akan membela perkara mereka","poem":1},{"text":"sehingga Dia dapat memberikan ketenangan kepada negeri itu,","poem":2},{"text":"tetapi tidak ada ketenangan bagi penduduk Babel.”","poem":1}]},{"type":"line_break"},{"type":"verse","number":35,"content":[{"text":"“Pedang melawan orang-orang Kasdim,”","poem":1},{"lineBreak":true},{"text":"firman TUHAN,","poem":1},{"text":"“melawan penduduk Babel","poem":2},{"lineBreak":true},{"text":"dan melawan para pejabat dan orang-orang bijaksananya.","poem":2}]},{"type":"verse","number":36,"content":[{"text":"Pedang melawan para peramal","poem":1},{"text":"sehingga mereka menjadi orang-orang bodoh!","poem":2},{"text":"Pedang melawan orang-orang gagahnya","poem":1},{"text":"sehingga mereka akan dihancurkan!","poem":2}]},{"type":"verse","number":37,"content":[{"text":"Pedang melawan kuda-kudanya dan melawan kereta-kereta kudanya,","poem":1},{"text":"dan melawan semua orang asing yang ada di tengah-tengahnya,","poem":2},{"lineBreak":true},{"text":"sehingga mereka akan menjadi seperti para perempuan!","poem":2},{"text":"Pedang melawan semua harta bendanya,","poem":1},{"text":"dan harta benda itu akan dirampok.","poem":2}]},{"type":"verse","number":38,"content":[{"text":"Kekeringan menimpa air-airnya,","poem":1},{"text":"sehingga menjadi kering.","poem":2},{"text":"Sebab, ini adalah negeri patung-patung,","poem":1},{"text":"dan mereka tergila-gila","poem":2},{"lineBreak":true},{"text":"dengan berhala-berhala.","poem":2}]},{"type":"verse","number":39,"content":[{"text":"Karena itu, binatang-binatang gurun akan tinggal di sana bersama serigala-serigala,","poem":1},{"text":"burung-burung unta akan tinggal di dalamnya.","poem":2},{"lineBreak":true},{"text":"Negeri itu tidak akan dihuni untuk selama-lamanya, maupun akan ditinggali dari generasi ke generasi.","poem":2}]},{"type":"verse","number":40,"content":[{"text":"Seperti ketika Allah menunggang balikkan Sodom dan Gomora","poem":1},{"text":"bersama kota-kota di sekitarnya,” firman TUHAN,","poem":2},{"text":"“demikianlah tidak ada orang yang akan tinggal di sana,","poem":1},{"text":"dan tidak ada anak manusia","poem":2},{"lineBreak":true},{"text":"yang akan menetap di sana.","poem":2}]},{"type":"line_break"},{"type":"verse","number":41,"content":[{"text":"Lihatlah! Suatu bangsa akan datang dari utara,","poem":1},{"text":"suatu bangsa yang besar,","poem":2},{"lineBreak":true},{"text":"dan banyak raja akan dibangkitkan dari tempat-tempat terjauh di bumi.","poem":2}]},{"type":"verse","number":42,"content":[{"text":"Mereka memegang busur dan tombak,","poem":1},{"text":"mereka kejam","poem":2},{"lineBreak":true},{"text":"dan tidak berbelaskasihan.","poem":2},{"text":"Suara mereka menderu seperti laut,","poem":1},{"text":"mereka menunggang kuda,","poem":2},{"text":"berjajar seperti prajurit perang melawan kamu,","poem":1},{"text":"hai anak perempuan Babel.","poem":2}]},{"type":"verse","number":43,"content":[{"text":"Raja Babel telah mendengar laporan tentang mereka,","poem":1},{"text":"dan tangannya menjadi lunglai.","poem":2},{"text":"Kecemasan menguasai dia,","poem":1},{"text":"kesakitan seperti perempuan yang melahirkan.","poem":2}]},{"type":"line_break"},{"type":"verse","number":44,"content":[{"text":"Lihatlah, seperti singa muncul","poem":1},{"text":"dari hutan Yordan","poem":2},{"text":"menuju","poem":1},{"text":"padang penggembalaan yang subur,","poem":2},{"text":"Aku akan dengan tiba-tiba membuatnya lari","poem":1},{"text":"dari negeri itu,","poem":2},{"text":"dan Aku akan menetapkan atasnya siapa pun yang Aku pilih.","poem":1},{"text":"Sebab, siapakah seperti Aku?","poem":2},{"lineBreak":true},{"text":"Siapa yang akan mendakwa-Ku?","poem":2},{"text":"Dan siapakah gembala yang dapat berdiri","poem":1},{"text":"di hadapan-Ku?”","poem":2}]},{"type":"line_break"},{"type":"verse","number":45,"content":[{"text":"“Karena itu, dengarlah rencana yang ditetapkan TUHAN","poem":1},{"text":"melawan Babel,","poem":2},{"text":"dan rancangan yang dibuat-Nya","poem":1},{"text":"melawan negeri orang Kasdim.","poem":2},{"text":"Sesungguhnya yang terkecil dari kawanan domba itu akan diseret,","poem":1},{"text":"sesungguhnya Dia akan membuat tempat tinggal mereka sunyi sepi karena mereka.","poem":2}]},{"type":"verse","number":46,"content":[{"text":"Bumi berguncang","poem":1},{"text":"karena suara direbutnya Babel,","poem":2},{"text":"dan teriakan mereka","poem":1},{"text":"terdengar di antara bangsa-bangsa.”","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/JER/50.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/JER/51.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/JER/49.json","previousChapterAudioLinks":{},"numberOfVerses":46}