{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"JER","translationId":"ind_ayt","name":"YEREMIA","commonName":"YEREMIA","title":"Yeremia","order":24,"numberOfChapters":52,"sha256":"a01e12b3ecfc86d080f4c575bcc6c056c26bc7651d1f251c60d7480ffa6e11e5","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/JER/1.json","lastChapterNumber":52,"lastChapterApiLink":"/api/ind_ayt/JER/52.json","totalNumberOfVerses":1364},"chapter":{"number":4,"content":[{"type":"verse","number":1,"content":[{"text":"“Jika kamu hendak kembali, hai Israel,”","poem":1},{"lineBreak":true},{"text":"firman TUHAN,","poem":1},{"text":"“kembalilah kepada-Ku.","poem":2},{"text":"Jika kamu membuang kenajisan dari hadapan-Ku,","poem":1},{"text":"dan tidak bimbang,","poem":2}]},{"type":"verse","number":2,"content":[{"text":"dan jika kamu bersumpah,","poem":1},{"text":"‘demi TUHAN yang hidup,’","poem":2},{"text":"dalam kebenaran, dalam keadilan, dan dalam kebajikan,","poem":1},{"text":"bangsa-bangsa akan memberkati diri mereka sendiri di dalam Dia,","poem":2},{"lineBreak":true},{"text":"dan di dalam Dia mereka akan bermegah.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":["Sebab, beginilah firman TUHAN kepada orang-orang Yehuda dan kepada Yerusalem,",{"lineBreak":true},{"text":"“Bajaklah ladang-ladangmu","poem":1},{"text":"yang kosong,","poem":2},{"lineBreak":true},{"text":"dan janganlah menanam di antara semak duri.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Sunatlah dirimu sendiri bagi TUHAN","poem":1},{"text":"dan buanglah kulit khitan hatimu,","poem":2},{"text":"hai orang-orang Yehuda","poem":1},{"text":"dan penghuni Yerusalem,","poem":2},{"text":"supaya kemarahan-Ku tidak datang seperti api,","poem":1},{"text":"dan membakar,","poem":2},{"text":"tanpa ada yang dapat memadamkannya","poem":1},{"text":"karena jahatnya perbuatan-perbuatanmu.”","poem":2}]},{"type":"heading","content":["Bencana dari Utara"]},{"type":"verse","number":5,"content":["Nyatakanlah di Yehuda dan serukanlah di Yerusalem,",{"lineBreak":true},{"text":"dan katakanlah,","poem":1},{"text":"“Tiuplah trompet di negeri,","poem":2},{"text":"berteriaklah dengan keras dan katakan,","poem":1},{"text":"‘Berkumpullah,","poem":2},{"lineBreak":true},{"text":"dan marilah kita masuk ke kota-kota yang berkubu.’","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Angkatlah panji-panji ke arah Sion.","poem":1},{"text":"Mengungsilah, jangan berdiam diri,","poem":2},{"text":"karena Aku mendatangkan bencana dari utara,","poem":1},{"text":"bahkan kerusakan yang besar.”","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Seekor singa telah keluar dari semak-semaknya,","poem":1},{"text":"seorang perusak bangsa-bangsa telah berangkat.","poem":2},{"text":"Ia telah berangkat dari tempatnya untuk membuat negerimu menjadi tandus.","poem":1},{"text":"Kota-kotamu akan menjadi reruntuhan","poem":2},{"lineBreak":true},{"text":"tak berpenduduk.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Karena itu, kenakanlah kain berkabung, meratap, dan menangislah","poem":1},{"text":"karena murka yang besar dari TUHAN belum berbalik dari kita.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"“Pada hari itu,” firman TUHAN,","poem":1},{"text":"“Hati raja dan hati para pemimpinnya akan hilang.","poem":2},{"text":"Imam-imam akan keheranan","poem":1},{"text":"dan nabi-nabi akan terkejut.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":["Kemudian, aku berkata, “Ah, Tuhanku, ALLAH, sesungguhnya Engkau benar-benar telah mengelabui orang-orang ini dan Yerusalem, dengan berkata, ‘Engkau akan mendapatkan kedamaian,’ padahal pedang telah mengancam nyawa mereka.”"]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"Pada waktu itu, akan disampaikan","poem":1},{"text":"kepada orang-orang ini dan kepada Yerusalem,","poem":2},{"text":"“Angin panas dari tempat-tempat tinggi yang gundul di padang belantara","poem":1},{"text":"menuju ke anak perempuan jemaat-Ku,","poem":2},{"text":"bukan untuk menampi","poem":1},{"text":"atau membersihkan,","poem":2}]},{"type":"verse","number":12,"content":[{"text":"angin yang begitu kencang dari tempat-tempat itu","poem":1},{"text":"akan datang kepada-Ku.","poem":2},{"text":"Sekarang juga, Aku akan memberikan hukuman","poem":1},{"text":"terhadap mereka.”","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Lihatlah! Dia naik bagaikan awan-awan,","poem":1},{"text":"kereta-kereta-Nya bagaikan puting beliung,","poem":2},{"lineBreak":true},{"text":"kuda-kuda-Nya lebih cepat daripada elang.","poem":2},{"text":"Celakalah kita","poem":1},{"text":"karena kita binasa!","poem":2}]},{"type":"line_break"},{"type":"verse","number":14,"content":[{"text":"Hai Yerusalem,","poem":1},{"text":"bersihkanlah hatimu dari kejahatan supaya kamu dapat diselamatkan.","poem":2},{"text":"Berapa lama pikiran-pikiranmu yang jahat","poem":1},{"text":"akan menetap di dalam dirimu?","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Sebab, sebuah suara menyerukan dari Dan,","poem":1},{"text":"dan mengumumkan kejahatan dari Gunung Efraim.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"“Beritakanlah itu kepada bangsa-bangsa,","poem":1},{"text":"serukanlah kepada Yerusalem.","poem":2},{"text":"‘Para pengepung datang dari negeri yang jauh","poem":1},{"text":"dan mengangkat suara mereka terhadap kota-kota Yehuda.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Seperti para penjaga ladang","poem":1},{"text":"mereka mengepungnya","poem":2},{"text":"karena ia telah memberontak","poem":1},{"text":"terhadap Aku,’”","poem":2},{"lineBreak":true},{"text":"firman TUHAN.","poem":2}]},{"type":"line_break"},{"type":"verse","number":18,"content":[{"text":"“Jalan-jalanmu dan perbuatan-perbuatanmu telah mendatangkan hal ini ke atasmu.","poem":1},{"text":"Itu adalah hukumanmu","poem":2},{"text":"dan itu pahit","poem":1},{"text":"karena hukuman itu menusuk ke hatimu.”","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Perutku, perutku!","poem":1},{"text":"Aku sangat menderita,","poem":2},{"text":"oh, dinding hatiku!","poem":1},{"text":"Jantungku berdebar-debar di dalamku.","poem":2},{"text":"Aku tidak dapat diam karena aku telah mendengar","poem":1},{"text":"suara trompet, sirene perang.","poem":2}]},{"type":"verse","number":20,"content":[{"text":"Bencana demi bencana diserukan","poem":1},{"text":"karena seluruh negeri dihancurkan.","poem":2},{"text":"Tiba-tiba, tenda-tendaku dirusak,","poem":1},{"text":"tirai-tiraiku dalam sekejap.","poem":2}]},{"type":"verse","number":21,"content":[{"text":"Berapa lama aku harus melihat panji-panji itu","poem":1},{"text":"dan mendengar bunyi trompet?","poem":2}]},{"type":"line_break"},{"type":"verse","number":22,"content":[{"text":"“Sebab, jemaat-Ku bodoh,","poem":1},{"text":"mereka tidak mengenal Aku.","poem":2},{"text":"Mereka adalah anak-anak yang tolol","poem":1},{"text":"dan mereka tidak memiliki pengertian.","poem":2},{"text":"Mereka pintar melakukan yang jahat,","poem":1},{"text":"tetapi melakukan yang baik mereka tidak tahu.”","poem":2}]},{"type":"verse","number":23,"content":[{"text":"Aku memandang ke bumi,","poem":1},{"text":"dan lihatlah,","poem":2},{"lineBreak":true},{"text":"bumi tidak berbentuk dan kosong,","poem":2},{"text":"dan ke langit,","poem":1},{"text":"dan langit itu tidak memiliki cahaya.","poem":2}]},{"type":"verse","number":24,"content":[{"text":"Aku memandang ke gunung-gunung, dan lihatlah,","poem":1},{"text":"mereka berguncang;","poem":2},{"lineBreak":true},{"text":"dan semua bukit bergoyang.","poem":2}]},{"type":"verse","number":25,"content":[{"text":"Aku memandang, dan lihatlah, tidak ada orang.","poem":1},{"text":"Dan, semua burung di udara sudah terbang.","poem":2}]},{"type":"verse","number":26,"content":[{"text":"Aku melihat dan mengamati, negeri yang subur itu menjadi padang belantara;","poem":1},{"text":"dan semua kotanya diruntuhkan di hadapan TUHAN, di hadapan murka-Nya yang menyala.","poem":2}]},{"type":"line_break"},{"type":"verse","number":27,"content":[{"text":"Sebab, Tuhan telah berkata,","poem":1},{"lineBreak":true},{"text":"“Seluruh negeri itu akan menjadi kehancuran,","poem":1},{"text":"tetapi Aku tidak akan menghabisi negeri itu seluruhnya.","poem":2}]},{"type":"verse","number":28,"content":[{"text":"Karena hal ini, bumi akan meratap","poem":1},{"text":"dan langit di atas menjadi gelap.","poem":2},{"text":"Sebab, Aku sudah mengatakannya; Aku telah merencanakan,","poem":1},{"text":"dan Aku tidak akan berbelas kasihan ataupun berbalik dari hal itu.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":29,"content":[{"text":"Karena gemuruh suara para penunggang kuda","poem":1},{"text":"dan para pemanah,","poem":2},{"lineBreak":true},{"text":"setiap kota melarikan diri.","poem":2},{"text":"Mereka akan masuk ke semak-semak","poem":1},{"text":"dan naik","poem":2},{"lineBreak":true},{"text":"ke batu-batu.","poem":2},{"text":"Seluruh kota ditinggalkan","poem":1},{"text":"dan tidak ada seorang pun yang tinggal di sana.","poem":2}]},{"type":"line_break"},{"type":"verse","number":30,"content":[{"text":"Dan kamu, hai yang dihancurkan,","poem":1},{"text":"apa yang akan kamu lakukan?","poem":2},{"text":"Walaupun kamu mengenakan pakaian merah,","poem":1},{"text":"walaupun kamu mendandani diri dengan perhiasan-perhiasan emas,","poem":2},{"text":"walaupun kamu merias matamu","poem":1},{"text":"dengan celak,","poem":2},{"lineBreak":true},{"text":"percuma saja kamu mempercantik dirimu sendiri.","poem":2},{"text":"Kekasih-kekasihmu mencampakkanmu,","poem":1},{"text":"mereka berusaha membunuhmu.","poem":2}]},{"type":"verse","number":31,"content":[{"text":"Sebab, Aku mendengar suara tangisan seperti seorang perempuan melahirkan,","poem":1},{"text":"jeritan seperti seorang perempuan yang melahirkan anak pertamanya,","poem":2},{"lineBreak":true},{"text":"jeritan Putri Sion, yang terengah-engah,","poem":2},{"text":"merentangkan kedua tangannya, dan berkata,","poem":1},{"text":"“Oh, celakalah aku!","poem":2},{"lineBreak":true},{"text":"Aku tidak berdaya di hadapan para pembunuh!”","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/JER/4.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/JER/5.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/JER/3.json","previousChapterAudioLinks":{},"numberOfVerses":31}