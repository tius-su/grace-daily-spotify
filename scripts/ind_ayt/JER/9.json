{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"JER","translationId":"ind_ayt","name":"YEREMIA","commonName":"YEREMIA","title":"Yeremia","order":24,"numberOfChapters":52,"sha256":"a01e12b3ecfc86d080f4c575bcc6c056c26bc7651d1f251c60d7480ffa6e11e5","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/JER/1.json","lastChapterNumber":52,"lastChapterApiLink":"/api/ind_ayt/JER/52.json","totalNumberOfVerses":1364},"chapter":{"number":9,"content":[{"type":"verse","number":1,"content":[{"text":"“Seandainya di kepala-Ku ada air","poem":1},{"text":"dan mata-Ku adalah pancaran air mata,","poem":2},{"lineBreak":true},{"text":"Aku akan menangis siang dan malam untuk putri jemaat-Ku yang terbunuh.","poem":2}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"Seandainya Aku memiliki tempat persinggahan","poem":1},{"text":"di padang gurun,","poem":2},{"text":"sehingga Aku dapat meninggalkan jemaat-Ku","poem":1},{"text":"dan pergi dari mereka!","poem":2},{"text":"Sebab, mereka semua adalah pezina,","poem":1},{"text":"kumpulan orang-orang yang tidak setia.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Mereka membengkokkan lidah mereka","poem":1},{"text":"seperti busur mereka,","poem":2},{"text":"untuk berdusta;","poem":1},{"text":"bukan dengan kebenaran mereka menang di negeri itu.","poem":2},{"text":"Mereka melakukan kejahatan demi kejahatan,","poem":1},{"text":"dan mereka tidak mengenal Aku,” firman TUHAN.","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"“Biarlah setiap orang berhati-hati terhadap sesamanya,","poem":1},{"text":"dan jangan percaya kepada saudara mana pun","poem":2},{"text":"karena setiap saudara adalah seorang penipu","poem":1},{"text":"dan setiap sesama ke sana kemari seperti pemfitnah.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Setiap orang menipu sesamanya,","poem":1},{"text":"dan tidak seorang pun mengatakan kebenaran.","poem":2},{"text":"Mereka telah mengajari","poem":1},{"text":"lidah mereka untuk berdusta","poem":2},{"text":"dan melelahkan diri sendiri","poem":1},{"text":"dengan melakukan kesalahan.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Kediamanmu ada di tengah-tengah tipu daya.","poem":1},{"text":"Dengan tipu daya,","poem":2},{"lineBreak":true},{"text":"mereka menolak untuk mengenal Aku,”","poem":2},{"text":"firman TUHAN.","poem":1}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Karena itu, beginilah firman TUHAN semesta alam,","poem":1},{"lineBreak":true},{"text":"“Lihatlah, Aku akan melebur mereka","poem":1},{"text":"dan menguji mereka.","poem":2},{"text":"Sebab, apa lagi yang dapat Aku lakukan","poem":1},{"text":"terhadap putri jemaat-Ku?","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Lidah mereka adalah anak panah yang mematikan.","poem":1},{"text":"Lidah itu mengucapkan tipu daya.","poem":2},{"text":"Dengan mulutnya, masing-masing","poem":1},{"text":"orang mengatakan damai kepada sesamanya,","poem":2},{"lineBreak":true},{"text":"tetapi di dalam hatinya, dia merencanakan penyergapan kepadanya.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Tidakkah Aku akan menghukum mereka untuk hal-hal ini?”","poem":1},{"text":"firman TUHAN.","poem":2},{"text":"“Tidakkah Aku akan menuntut balas atas diri-Ku sendiri","poem":1},{"text":"kepada bangsa seperti ini?”","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"“Aku akan menaikkan tangisan dan ratapan untuk gunung-gunung,","poem":1},{"text":"dan nyanyian penguburan untuk padang rumput di padang belantara","poem":2},{"lineBreak":true},{"text":"karena mereka ditelantarkan sehingga","poem":2},{"text":"tidak ada seorang pun yang melewatinya,","poem":1},{"text":"dan lenguhan ternak tidak terdengar.","poem":2},{"text":"Baik burung-burung di udara maupun binatang-binatang","poem":1},{"text":"telah melarikan diri dan menghilang.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"“Aku akan menjadikan Kota Yerusalem suatu tumpukan reruntuhan,","poem":1},{"text":"sarang serigala-serigala;","poem":2},{"text":"dan Aku akan menjadikan kota-kota di Yehuda","poem":1},{"text":"kesunyian, tanpa penghuni.”","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Siapakah orang bijaksana yang dapat mengerti hal ini?","poem":1},{"text":"Kepada siapakah mulut TUHAN telah berbicara","poem":2},{"text":"sehingga dia dapat menyatakannya?","poem":1},{"text":"Mengapa negeri itu diruntuhkan","poem":2},{"text":"dan dibiarkan tandus seperti padang belantara","poem":1},{"text":"sehingga tidak ada seorang pun yang lewat?","poem":2}]},{"type":"line_break"},{"type":"verse","number":13,"content":[{"text":"TUHAN berkata,","poem":1},{"text":"“Karena mereka telah meninggalkan hukum-Ku,","poem":2},{"text":"yang telah aku tetapkan di hadapan mereka,","poem":1},{"text":"dan tidak menaati suara-Ku","poem":2},{"lineBreak":true},{"text":"ataupun berjalan mengikutinya,","poem":2}]},{"type":"verse","number":14,"content":[{"text":"melainkan telah berjalan","poem":1},{"text":"mengikuti kekerasan hati mereka,","poem":2},{"text":"dan mengikuti para Baal,","poem":1},{"text":"seperti yang diajarkan nenek moyang mereka kepada mereka.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":15,"content":[{"text":"Oleh sebab itu, beginilah firman TUHAN semesta alam, Allah Israel,","poem":1},{"lineBreak":true},{"text":"“Sesungguhnya, Aku akan memberi mereka, yaitu bangsa ini, makan","poem":1},{"text":"dari tanaman pahit dan memberi mereka minum dari air beracun.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Aku akan mencerai-beraikan mereka di antara bangsa-bangsa","poem":1},{"text":"yang belum dikenal baik oleh mereka","poem":2},{"lineBreak":true},{"text":"ataupun oleh nenek moyang mereka;","poem":2},{"text":"dan Aku akan mengirim pedang","poem":1},{"text":"yang mengejar mereka","poem":2},{"lineBreak":true},{"text":"sampai Aku menghabisi mereka.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":17,"content":[{"text":"Beginilah firman TUHAN semesta alam,","poem":1},{"lineBreak":true},{"text":"“Pertimbangkanlah, dan panggillah perempuan-perempuan peratap","poem":1},{"text":"untuk datang;","poem":2},{"lineBreak":true},{"text":"dan suruhlah orang menjemput perempuan-perempuan bijaksana supaya mereka datang.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Biarlah mereka bersegera dan menaikkan tangisan untuk kita","poem":1},{"text":"supaya mata kita dapat mencucurkan air mata,","poem":2},{"lineBreak":true},{"text":"dan kelopak mata kita berlinangan air.","poem":2}]},{"type":"line_break"},{"type":"verse","number":19,"content":[{"text":"Sebab, suara ratapan terdengar dari Sion,","poem":1},{"text":"‘Betapa kami hancur!","poem":2},{"lineBreak":true},{"text":"Kami benar-benar dibuat malu","poem":2},{"text":"karena kami telah meninggalkan negeri kami","poem":1},{"text":"karena tempat-tempat tinggal kami telah mengusir kami.’”","poem":2}]},{"type":"line_break"},{"type":"verse","number":20,"content":[{"text":"“Sekarang, dengarkanlah firman TUHAN, hai perempuan-perempuan,","poem":1},{"text":"dan biarkanlah telingamu mendengar firman dari mulut-Nya.","poem":2},{"text":"Ajarlah anak-anakmu perempuan meratap,","poem":1},{"text":"dan setiap mereka mengajarkan nyanyian penguburan kepada sesamanya.","poem":2}]},{"type":"verse","number":21,"content":[{"text":"Sebab, kematian telah memanjat ke jendela-jendela kita,","poem":1},{"text":"ia telah memasuki istana-istana kita;","poem":2},{"text":"untuk melenyapkan anak-anak dari jalan-jalan","poem":1},{"text":"dan anak-anak muda dari tempat-tempat umum.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":22,"content":[{"text":"Katakanlah, “Beginilah firman TUHAN,","poem":1},{"text":"‘Mayat-mayat orang akan jatuh seperti kotoran di tanah terbuka,","poem":2},{"text":"dan seperti berkas gandum di belakang pemanen,","poem":1},{"text":"dan tidak ada seorang pun akan mengumpulkan mereka.’”","poem":2}]},{"type":"line_break"},{"type":"verse","number":23,"content":[{"text":"Beginilah firman TUHAN,","poem":1},{"lineBreak":true},{"text":"“Janganlah orang bijaksana membanggakan diri","poem":1},{"text":"karena hikmatnya,","poem":2},{"text":"janganlah orang kuat membanggakan diri","poem":1},{"text":"karena kekuatannya,","poem":2},{"text":"janganlah orang kaya membanggakan diri","poem":1},{"text":"karena kekayaannya.","poem":2}]},{"type":"verse","number":24,"content":[{"text":"Akan tetapi, biarlah orang yang berbangga, berbangga akan hal ini:","poem":1},{"text":"bahwa dia mengerti dan mengenal Aku,","poem":2},{"text":"bahwa Akulah TUHAN,","poem":1},{"text":"yang menunjukkan kasih, keadilan,","poem":2},{"lineBreak":true},{"text":"dan kebenaran di bumi. Sebab,","poem":2},{"text":"dalam hal-hal itulah Aku senang,”","poem":1},{"text":"firman TUHAN.","poem":2}]},{"type":"line_break"},{"type":"verse","number":25,"content":["“Lihatlah, hari-harinya akan datang,” firman TUHAN, “bahwa Aku akan menghukum mereka semua yang bersunat kulit khatannya."]},{"type":"verse","number":26,"content":["Mesir, Yehuda, Edom, keturunan Amon, dan Moab, dan semua orang yang tinggal di padang gurun, yang mencukur tepi rambut mereka karena semua bangsa ini tidak bersunat dan semua keturunan Israel tidak bersunat di dalam hati.”"]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/JER/9.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/JER/10.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/JER/8.json","previousChapterAudioLinks":{},"numberOfVerses":26}