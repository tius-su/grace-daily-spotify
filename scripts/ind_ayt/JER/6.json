{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"JER","translationId":"ind_ayt","name":"YEREMIA","commonName":"YEREMIA","title":"Yeremia","order":24,"numberOfChapters":52,"sha256":"a01e12b3ecfc86d080f4c575bcc6c056c26bc7651d1f251c60d7480ffa6e11e5","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/JER/1.json","lastChapterNumber":52,"lastChapterApiLink":"/api/ind_ayt/JER/52.json","totalNumberOfVerses":1364},"chapter":{"number":6,"content":[{"type":"heading","content":["Musuh Mengepung Yerusalem"]},{"type":"verse","number":1,"content":[{"text":"“Larilah demi keselamatan,","poem":1},{"text":"hai anak-anak Benyamin, dari tengah-tengah Yerusalem!","poem":2},{"text":"Tiuplah trompet di Tekoa,","poem":1},{"text":"dan naikkan tanda di Bet-Kerem,","poem":2},{"text":"karena bencana mengintai dari utara,","poem":1},{"text":"dan kehancuran yang sangat besar.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Aku akan menghancurkan Putri Sion,","poem":1},{"text":"yang cantik dan lembut itu.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Para gembala","poem":1},{"text":"dan kawanan ternak mereka akan datang kepadanya.","poem":2},{"text":"Mereka akan mendirikan tenda-tenda mereka di sekelilingnya,","poem":1},{"text":"mereka akan menggembalakan masing-masing di tempatnya.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"“Bersiaplah berperang melawan dia.","poem":1},{"text":"Berdirilah dan marilah kita menyerang pada tengah hari.","poem":2},{"text":"Celakalah kita karena hari sudah menjelang sore.","poem":1},{"text":"Sebab, bayang-bayang malam memanjang.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Berdirilah, dan mari kita menyerang pada malam hari","poem":1},{"text":"dan menghancurkan puri-purinya.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"Sebab, beginilah firman TUHAN semesta alam,","poem":1},{"text":"“Tebanglah pohon-pohonnya","poem":2},{"lineBreak":true},{"text":"dan bangunlah tanggul pengepungan terhadap Yerusalem.","poem":2},{"text":"Inilah kota yang harus dihukum,","poem":1},{"text":"di tengah-tengahnya hanya penindasan belaka.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Seperti sumur yang terus mengeluarkan airnya,","poem":1},{"text":"demikianlah ia terus melakukan kejahatannya.","poem":2},{"text":"Kekerasan dan kehancuran terdengar di dalamnya.","poem":1},{"text":"Penyakit dan luka-luka selalu ada di depan-Ku.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Didiklah dirimu, hai Yerusalem,","poem":1},{"text":"supaya Aku tidak menjauh darimu,","poem":2},{"text":"supaya Aku tidak menjadikanmu reruntuhan,","poem":1},{"text":"suatu negeri yang tidak berpenghuni.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":9,"content":[{"text":"Beginilah firman TUHAN semesta alam,","poem":1},{"lineBreak":true},{"text":"“Mereka benar-benar akan memungut","poem":1},{"text":"sisa-sisa Israel seperti pohon anggur.","poem":2},{"text":"Ulurkan tanganmu kembali,","poem":1},{"text":"seperti seorang pemetik buah anggur melewati cabang-cabangnya.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Kepada siapakah Aku akan berbicara","poem":1},{"text":"dan memberi peringatan,","poem":2},{"lineBreak":true},{"text":"supaya mereka mau mendengar?”","poem":2},{"text":"Lihatlah, telinga-telinga mereka tidak bersunat,","poem":1},{"text":"mereka tidak dapat mendengar.","poem":2},{"text":"Sungguh, firman Tuhan bagi mereka adalah suatu hinaan.","poem":1},{"text":"Mereka tidak menyukainya.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Karena itu, aku kenyang dengan murka TUHAN,","poem":1},{"text":"aku lelah menahannya.","poem":2},{"text":"“Curahkanlah itu ke atas anak-anak di jalan","poem":1},{"text":"dan ke atas kumpulan orang-orang muda.","poem":2},{"text":"Baik suami maupun istri akan ditawan,","poem":1},{"text":"orang-orang tua dan orang-orang lanjut usia.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Rumah-rumah mereka akan diserahkan kepada orang lain,","poem":1},{"text":"bersama ladang-ladang dan istri-istri mereka.","poem":2},{"text":"Sebab, Aku akan mengulurkan tangan-Ku melawan penduduk negeri itu,”","poem":1},{"text":"firman TUHAN.","poem":2}]},{"type":"line_break"},{"type":"verse","number":13,"content":[{"text":"“Sebab, dari yang paling kecil sampai yang paling besar dari mereka,","poem":1},{"text":"setiap orang tamak akan keuntungan;","poem":2},{"lineBreak":true},{"text":"dan dari para nabi sampai para imam, setiap orang berbuat dusta.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Mereka telah menyembuhkan luka jemaat-Ku","poem":1},{"text":"dengan enteng,","poem":2},{"text":"dengan berkata, ‘Damai, damai,’","poem":1},{"text":"padahal tidak ada kedamaian.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Apakah mereka malu ketika mereka melakukan kekejian?","poem":1},{"text":"Tidak, mereka tidak malu sama sekali;","poem":2},{"text":"mereka tidak tahu bagaimana merasa malu.","poem":1},{"text":"Karena itu, mereka akan jatuh di antara mereka yang jatuh.","poem":2},{"text":"Pada waktu Aku menghukum mereka,","poem":1},{"text":"mereka akan tersandung,” firman TUHAN.","poem":2}]},{"type":"line_break"},{"type":"verse","number":16,"content":[{"text":"Beginilah firman TUHAN,","poem":1},{"lineBreak":true},{"text":"“Berdirilah di jalan-jalan dan lihatlah","poem":1},{"text":"serta tanyakan tentang jalan-jalan lama,","poem":2},{"text":"manakah jalan yang benar,","poem":1},{"text":"dan berjalanlah di situ,","poem":2},{"text":"dan temukan peristirahatan bagi jiwamu.”","poem":1},{"text":"Akan tetapi, mereka menjawab, “Kami tidak akan berjalan di situ.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Aku menempatkan para penjaga atasmu dan berfirman,","poem":1},{"text":"‘Dengarkanlah suara trompet!’”","poem":2},{"lineBreak":true},{"text":"Akan tetapi, mereka menjawab, “Kami tidak akan mendengarkannya.”","poem":2}]},{"type":"verse","number":18,"content":[{"text":"“Oleh sebab itu, dengarlah, hai bangsa-bangsa,","poem":1},{"text":"dan ketahuilah, hai jemaat, apa yang akan terjadi kepada mereka.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Dengarkanlah, hai bumi,","poem":1},{"text":"lihatlah, Aku mendatangkan bencana ke atas bangsa ini,","poem":2},{"lineBreak":true},{"text":"buah dari rencana-rencana mereka,","poem":2},{"text":"karena mereka tidak mendengarkan firman-firman-Ku","poem":1},{"text":"dan hukum-hukum-Ku, bahkan menolaknya.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":20,"content":[{"text":"“Untuk apa kemenyan-kemenyan dibawa kepada-Ku dari Syeba?","poem":1},{"text":"Atau, tebu manis dari negeri yang jauh?","poem":2},{"text":"Kurban bakaranmu tidak diterima,","poem":1},{"text":"dan kurban-kurbanmu tidak menyenangkan bagi-Ku.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":21,"content":[{"text":"Karena itu, beginilah","poem":1},{"lineBreak":true},{"text":"firman TUHAN,","poem":1},{"text":"“Lihatlah, Aku akan meletakkan batu-batu sandungan di depan bangsa ini,","poem":2},{"text":"maka bapak-bapak dan anak-anak bersama-sama akan tersandung kepadanya,","poem":1},{"text":"tetangga dan teman akan mati.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":22,"content":[{"text":"Inilah firman TUHAN,","poem":1},{"lineBreak":true},{"text":"“Lihatlah, suatu bangsa akan datang dari tanah utara,","poem":1},{"text":"suatu bangsa yang besar akan dibangkitkan dari tempat-tempat terjauh di bumi.","poem":2}]},{"type":"verse","number":23,"content":[{"text":"Mereka membawa panah dan tombak.","poem":1},{"text":"Mereka kejam dan tidak memiliki belas kasihan.","poem":2},{"text":"Suara mereka bergemuruh seperti laut,","poem":1},{"text":"dan mereka menunggang kuda,","poem":2},{"text":"berbaris seperti pasukan perang melawan kamu,","poem":1},{"text":"hai Putri Sion.”","poem":2}]},{"type":"verse","number":24,"content":[{"text":"Kami telah mendengar kabar tentang itu,","poem":1},{"text":"tangan-tangan kami lemas.","poem":2},{"text":"Derita telah menguasai kami,","poem":1},{"text":"kesakitan seperti seorang perempuan yang melahirkan.","poem":2}]},{"type":"verse","number":25,"content":[{"text":"Jangan pergi ke ladang","poem":1},{"text":"ataupun berjalan di jalan","poem":2},{"text":"karena musuh memiliki pedang,","poem":1},{"text":"kengerian ada di mana-mana.","poem":2}]},{"type":"verse","number":26,"content":[{"text":"“Hai putri jemaat-Ku, pakailah kain berkabung","poem":1},{"text":"dan bergulunglah di dalam abu.”","poem":2},{"text":"Berkabunglah, seperti untuk seorang anak tunggal,","poem":1},{"text":"ratapan yang paling pahit,","poem":2},{"text":"karena dengan tiba-tiba, si perusak","poem":1},{"text":"akan datang kepada kita.","poem":2}]},{"type":"line_break"},{"type":"verse","number":27,"content":[{"text":"“Aku telah menjadikanmu sebagai seorang pemeriksa dan penguji","poem":1},{"text":"di antara jemaat-Ku,","poem":2},{"text":"supaya kamu tahu","poem":1},{"text":"dan menguji jalan-jalan mereka.","poem":2}]},{"type":"verse","number":28,"content":[{"text":"Mereka semua adalah pemberontak","poem":1},{"text":"yang keras kepala.","poem":2},{"lineBreak":true},{"text":"Yang pergi kian kemari bersama para pemfitnah.","poem":2},{"text":"Mereka adalah tembaga dan besi,","poem":1},{"text":"mereka semua berbuat jahat.","poem":2}]},{"type":"verse","number":29,"content":[{"text":"Alat peniup berembus dengan dahsyat","poem":1},{"text":"untuk membakar habis timah dengan api.","poem":2},{"text":"Akan tetapi, sia-sialah pemurnian dilakukan","poem":1},{"text":"karena orang jahat tidak disingkirkan.","poem":2}]},{"type":"verse","number":30,"content":[{"text":"‘Perak yang tertolak’ akan menjadi sebutan mereka","poem":1},{"text":"karena TUHAN telah menolak mereka.”","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/JER/6.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/JER/7.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/JER/5.json","previousChapterAudioLinks":{},"numberOfVerses":30}