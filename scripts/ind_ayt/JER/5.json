{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"JER","translationId":"ind_ayt","name":"YEREMIA","commonName":"YEREMIA","title":"Yeremia","order":24,"numberOfChapters":52,"sha256":"a01e12b3ecfc86d080f4c575bcc6c056c26bc7651d1f251c60d7480ffa6e11e5","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/JER/1.json","lastChapterNumber":52,"lastChapterApiLink":"/api/ind_ayt/JER/52.json","totalNumberOfVerses":1364},"chapter":{"number":5,"content":[{"type":"heading","content":["Hukuman TUHAN Tidak Dapat Dihindari"]},{"type":"verse","number":1,"content":["“Berlarilah ke sana kemari melalui jalan-jalan Yerusalem. Sekarang, lihatlah dan perhatikanlah! Carilah di tanah-tanah lapangnya kalau-kalau kamu dapat menemukan seseorang, kalau-kalau ada orang yang melakukan keadilan dan mencari kebenaran, maka Aku akan mengampuni Yerusalem."]},{"type":"verse","number":2,"content":["Meskipun mereka berkata, ‘Demi TUHAN yang hidup,’ sesungguhnya mereka itu bersumpah palsu.”"]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Ya TUHAN,","poem":1},{"text":"bukankah mata-Mu mengharapkan kebenaran?","poem":2},{"text":"Engkau telah memukul mereka,","poem":1},{"text":"tetapi mereka tidak menderita.","poem":2},{"text":"Engkau telah menghancurkan mereka,","poem":1},{"text":"tetapi mereka menolak untuk dikoreksi.","poem":2},{"text":"Mereka telah membuat wajah mereka lebih keras daripada batu,","poem":1},{"text":"mereka telah menolak untuk bertobat.","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"Aku berpikir,","poem":1},{"lineBreak":true},{"text":"“Mereka hanyalah orang-orang malang,","poem":1},{"text":"mereka bodoh karena mereka tidak mengenal jalan TUHAN,","poem":2},{"lineBreak":true},{"text":"hukum Allah mereka.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Aku akan pergi kepada orang-orang hebat","poem":1},{"text":"dan akan berbicara kepada mereka.","poem":2},{"text":"Sebab, mereka mengenal jalan TUHAN,","poem":1},{"text":"dan hukum Allah mereka.”","poem":2},{"text":"Akan tetapi, mereka pun telah bersama-sama","poem":1},{"text":"mematahkan kuk dan melepaskan ikatan-ikatan.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Karena itu,","poem":1},{"text":"seekor singa dari hutan akan membunuh mereka","poem":2},{"lineBreak":true},{"text":"seekor serigala dari padang gurun akan menghancurkan mereka.","poem":2},{"text":"Seekor macan tutul sedang mengawasi kota-kota mereka,","poem":1},{"text":"setiap orang yang keluar dari sana akan dicabik-cabik","poem":2},{"text":"karena dosa mereka banyak","poem":1},{"text":"dan kemurtadan mereka sangat besar.","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"“Bagaimana Aku bisa mengampunimu?","poem":1},{"text":"Anak-anakmu telah meninggalkan Aku","poem":2},{"lineBreak":true},{"text":"dan telah bersumpah demi mereka yang bukan Allah.","poem":2},{"text":"Ketika Aku memberi mereka makan sampai kenyang,","poem":1},{"text":"mereka melakukan perzinaan","poem":2},{"lineBreak":true},{"text":"dan berbondong-bondong ke rumah pelacur.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Mereka seperti kuda-kuda jantan yang gemuk dan penuh nafsu,","poem":1},{"text":"masing-masing meringkik menginginkan istri sesamanya.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Tidakkah Aku akan menghukum orang-orang ini?” firman TUHAN.","poem":1},{"text":"“Dan, tidakkah Aku akan menuntut balas terhadap bangsa semacam ini?","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"Naiklah melalui deretan pohon anggurnya dan hancurkan,","poem":1},{"text":"tetapi jangan menghabisi semuanya.","poem":2},{"lineBreak":true},{"text":"Potonglah cabang-cabangnya karena itu bukan milik TUHAN.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Sebab, kaum Israel dan kaum Yehuda","poem":1},{"text":"sudah benar-benar tidak setia kepada-Ku,”","poem":2},{"lineBreak":true},{"text":"firman TUHAN.","poem":2}]},{"type":"line_break"},{"type":"verse","number":12,"content":[{"text":"“Mereka telah berbohong tentang TUHAN","poem":1},{"lineBreak":true},{"text":"dan berkata,","poem":1},{"text":"‘Bukan Dia. Kemalangan tidak akan menimpa kita.","poem":2},{"text":"Kita tidak akan melihat pedang","poem":1},{"text":"ataupun kelaparan.’","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Para nabi akan menjadi angin","poem":1},{"text":"dan firman tidak ada pada mereka.","poem":2},{"lineBreak":true},{"text":"Maka, hal itu akan terlaksana atas mereka!”","poem":2}]},{"type":"line_break"},{"type":"verse","number":14,"content":[{"text":"Karena itu, beginilah firman TUHAN, Allah semesta alam,","poem":1},{"text":"“Karena kamu telah mengucapkan perkataan ini,","poem":2},{"text":"ketahuilah, Aku akan membuat firman-firman-Ku di dalam mulutmu seperti api,","poem":1},{"text":"dan bangsa ini seperti kayu;","poem":2},{"lineBreak":true},{"text":"api itu akan menghabiskan mereka.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Dengarkanlah, Aku akan membawa suatu bangsa melawanmu dari jauh, hai kaum Israel,”","poem":1},{"text":"firman TUHAN.","poem":2},{"text":"“Bangsa itu adalah bangsa yang kuat,","poem":1},{"text":"bangsa yang kuno,","poem":2},{"text":"suatu bangsa yang bahasanya tidak kamu ketahui,","poem":1},{"text":"ataupun kamu pahami apa yang mereka katakan.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Tempat anak panah mereka seperti kubur yang terbuka.","poem":1},{"text":"Mereka semua adalah orang-orang yang perkasa.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Mereka akan melahap panenanmu","poem":1},{"text":"dan makananmu;","poem":2},{"lineBreak":true},{"text":"melahap anak-anakmu laki-laki dan anak-anakmu perempuan;","poem":2},{"text":"melahap kawanan dombamu dan ternakmu;","poem":1},{"text":"melahap pohon-pohon anggurmu dan pohon-pohon aramu.","poem":2},{"text":"Mereka akan menghancurkan kota-kotamu yang berkubu,","poem":1},{"text":"yang kamu percayai, dengan pedang.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":18,"content":[{"text":"“Akan tetapi, bahkan pada hari-hari itu,”","poem":1},{"lineBreak":true},{"text":"firman TUHAN,","poem":1},{"text":"“Aku tidak akan menghancurkanmu sepenuhnya.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Dan akan terjadi ketika kamu berkata,","poem":1},{"text":"‘Mengapa TUHAN, Allah kita, telah melakukan semua ini terhadap kita?’","poem":2},{"text":"kamu akan menjawab mereka,","poem":1},{"text":"‘Karena kamu telah meninggalkan-Ku","poem":2},{"lineBreak":true},{"text":"dan melayani ilah-ilah asing di negerimu,","poem":2},{"text":"maka kamu akan melayani orang-orang asing","poem":1},{"text":"di negeri yang bukan milikmu.’”","poem":2}]},{"type":"line_break"},{"type":"verse","number":20,"content":[{"text":"Beritahukan ini di antara kaum Yakub,","poem":1},{"text":"dan sampaikanlah kepada Yehuda:","poem":2}]},{"type":"verse","number":21,"content":[{"text":"“Dengarkanlah ini,","poem":1},{"text":"hai bangsa yang bodoh dan tidak berpengertian,","poem":2},{"text":"yang mempunyai mata, tetapi tidak melihat,","poem":1},{"text":"yang memiliki telinga, tetapi tidak mendengar.","poem":2}]},{"type":"verse","number":22,"content":[{"text":"‘Tidakkah kamu takut kepada-Ku?’","poem":1},{"text":"firman TUHAN.","poem":2},{"lineBreak":true},{"text":"‘Tidakkah kamu gemetar di hadapan-Ku?","poem":2},{"text":"Akulah yang menempatkan pasir menjadi batas laut,","poem":1},{"text":"suatu rintangan kekal yang tidak dapat dilewatinya.","poem":2},{"text":"Walaupun gelombang-gelombang mengempas,","poem":1},{"text":"tetapi mereka tidak dapat menang;","poem":2},{"text":"meskipun mereka menderu,","poem":1},{"text":"tetapi mereka tidak dapat melampaui pasir itu.","poem":2}]},{"type":"verse","number":23,"content":[{"text":"Namun, bangsa ini memiliki hati yang keras","poem":1},{"text":"dan memberontak.","poem":2},{"lineBreak":true},{"text":"Mereka telah menyimpang dan pergi.","poem":2}]},{"type":"verse","number":24,"content":[{"text":"Mereka tidak berkata dalam hati mereka,","poem":1},{"text":"‘Marilah kita takut kepada TUHAN, Allah kita,","poem":2},{"text":"yang memberikan hujan pada waktunya, baik hujan awal maupun hujan akhir musim gugur dan hujan musim semi,","poem":1},{"text":"dan menyediakan bagi kita, minggu-minggu panen yang ditetapkan.’","poem":2}]},{"type":"verse","number":25,"content":[{"text":"Kejahatan-kejahatanmu","poem":1},{"text":"telah menyingkirkan semua itu,","poem":2},{"text":"dan dosa-dosamu","poem":1},{"text":"telah menahan kebaikan darimu.","poem":2}]},{"type":"verse","number":26,"content":[{"text":"Sebab, di antara jemaat-Ku ditemukan orang-orang jahat.","poem":1},{"text":"Mereka mengintai seperti para penangkap burung yang menunggu sambil berbaring.","poem":2},{"text":"Mereka memasang perangkap,","poem":1},{"text":"mereka menjerat orang-orang.","poem":2}]},{"type":"verse","number":27,"content":[{"text":"Seperti sebuah sangkar penuh dengan burung,","poem":1},{"text":"demikianlah rumah-rumah mereka penuh dengan tipu muslihat.","poem":2},{"text":"Karena itulah mereka menjadi sangat besar dan kaya.","poem":1}]},{"type":"verse","number":28,"content":[{"text":"Mereka gemuk dan berseri-seri.","poem":2},{"text":"Mereka sudah melampaui batas dalam berbuat jahat,","poem":1},{"text":"Mereka tidak mengadili perkara,","poem":2},{"lineBreak":true},{"text":"perkara anak-anak yatim, untuk membela perkara itu,","poem":2},{"lineBreak":true},{"text":"dan mereka tidak memperjuangkan hak-hak orang-orang yang membutuhkan.","poem":2}]},{"type":"verse","number":29,"content":[{"text":"‘Tidakkah Aku akan menghukum mereka karena hal-hal itu?’","poem":1},{"text":"firman TUHAN,","poem":2},{"text":"‘Tidakkah Aku sendiri akan menuntut balas","poem":1},{"text":"terhadap bangsa seperti ini?’","poem":2}]},{"type":"line_break"},{"type":"verse","number":30,"content":[{"text":"Sesuatu yang mengerikan dan mengejutkan","poem":1},{"text":"telah terjadi di negeri itu:","poem":2}]},{"type":"verse","number":31,"content":[{"text":"para nabi bernubuat palsu,","poem":1},{"lineBreak":true},{"text":"dan para imam memerintah dengan kekuasaan mereka sendiri,","poem":1},{"text":"dan jemaat-Ku menyukai keadaan itu!","poem":2},{"text":"Akan tetapi, apa yang akan kamu lakukan","poem":1},{"text":"pada akhirnya?”","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/JER/5.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/JER/6.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/JER/4.json","previousChapterAudioLinks":{},"numberOfVerses":31}