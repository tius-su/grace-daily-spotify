{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"JER","translationId":"ind_ayt","name":"YEREMIA","commonName":"YEREMIA","title":"Yeremia","order":24,"numberOfChapters":52,"sha256":"a01e12b3ecfc86d080f4c575bcc6c056c26bc7651d1f251c60d7480ffa6e11e5","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/JER/1.json","lastChapterNumber":52,"lastChapterApiLink":"/api/ind_ayt/JER/52.json","totalNumberOfVerses":1364},"chapter":{"number":10,"content":[{"type":"heading","content":["Allah dan Ilah-Ilah"]},{"type":"verse","number":1,"content":["Dengarkanlah firman yang TUHAN firmankan kepadamu, hai keturunan Israel."]},{"type":"verse","number":2,"content":["Beginilah firman TUHAN,",{"lineBreak":true},{"text":"“Janganlah mempelajari jalan bangsa-bangsa,","poem":1},{"text":"ataupun cemas akan tanda-tanda langit","poem":2},{"text":"walaupun bangsa-bangsa","poem":1},{"text":"takut terhadap mereka.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Sebab, kebiasaan-kebiasaan orang-orang itu tidak berguna.","poem":1},{"text":"Sebab, seseorang menebang sebatang pohon dari hutan,","poem":2},{"lineBreak":true},{"text":"dan dikerjakan dengan sebuah kapak oleh tangan seorang pengrajin.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Mereka menghiasnya dengan perak dan emas.","poem":1},{"text":"Mereka mengencangkannya dengan paku-paku dan palu-palu","poem":2},{"lineBreak":true},{"text":"supaya itu tidak bergeser.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Berhala-berhala itu","poem":1},{"text":"seperti orang-orangan sawah di ladang mentimun.","poem":2},{"text":"Mereka tidak dapat berbicara,","poem":1},{"text":"mereka harus diusung karena mereka tidak dapat berjalan.","poem":2},{"text":"Jangan takut kepada mereka","poem":1},{"text":"karena mereka tidak dapat berbuat jahat","poem":2},{"lineBreak":true},{"text":"dan juga tidak dapat berbuat baik.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"Tidak ada satu pun seperti Engkau, ya TUHAN.","poem":1},{"text":"Engkau besar!","poem":2},{"lineBreak":true},{"text":"Nama-Mu memiliki kuasa yang besar!","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Siapakah yang tidak takut kepada-Mu, ya Raja segala bangsa?","poem":1},{"text":"Sebab, itulah yang layak diberikan kepada-Mu.","poem":2},{"text":"Sebab, di antara semua orang bijaksana dari bangsa-bangsa","poem":1},{"text":"dan di semua kerajaan-kerajaan mereka, tidak ada seorang pun seperti Engkau.","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"Akan tetapi, mereka semuanya dungu dan bodoh;","poem":1},{"text":"ajarannya dari berhala kayu yang sia-sia.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Perak tempaan dibawa dari Tarsis","poem":1},{"text":"dan emas dari Ufas,","poem":2},{"text":"hasil karya pengrajin dan pekerjaan tangan tukang emas.","poem":1},{"text":"Mereka memakai pakaian biru dan ungu,","poem":2},{"lineBreak":true},{"text":"mereka semua adalah hasil karya orang-orang terampil.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Akan tetapi, TUHAN adalah Allah yang benar.","poem":1},{"text":"Dia adalah Allah yang hidup","poem":2},{"lineBreak":true},{"text":"dan Raja yang kekal.","poem":2},{"text":"Terhadap murka-Nya, bumi berguncang,","poem":1},{"text":"dan bangsa-bangsa tidak dapat bertahan terhadap kemarahan-Nya.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"“Jadi, hendaklah kamu berkata kepada mereka,","poem":1},{"text":"‘Ilah-ilah itu, yang tidak membuat langit dan bumi,","poem":2},{"lineBreak":true},{"text":"akan lenyap dari bumi dan dari bawah langit.’”","poem":2}]},{"type":"line_break"},{"type":"verse","number":12,"content":[{"text":"Dialah yang menjadikan bumi dengan kuasa-Nya,","poem":1},{"text":"yang menegakkan dunia dengan hikmat-Nya,","poem":2},{"text":"dan membentangkan langit","poem":1},{"text":"dengan pengertian-Nya.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Ketika Dia memperdengarkan suara-Nya,","poem":1},{"text":"ada gemuruh air di langit,","poem":2},{"text":"Dia membuat kabut naik dari ujung bumi.","poem":1},{"text":"Dia membuat kilat dan hujan,","poem":2},{"lineBreak":true},{"text":"Dia mengeluarkan angin dari tempat penyimpanan-Nya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":14,"content":[{"text":"Semua manusia itu bodoh dan tidak berpengetahuan;","poem":1},{"text":"semua tukang emas dipermalukan oleh patung ukirannya.","poem":2},{"text":"Patung-patung tuangannya adalah kebohongan,","poem":1},{"text":"dan tidak ada napas di dalam mereka.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Semua itu kesia-siaan,","poem":1},{"text":"suatu karya yang menjadi cemoohan.","poem":2},{"text":"Mereka akan binasa,","poem":1},{"text":"pada waktu penghakiman mereka.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Namun, Dia yang menjadi bagian Yakub tidaklah demikian","poem":1},{"lineBreak":true},{"text":"karena Dialah yang membentuk segala sesuatu,","poem":1},{"text":"dan Israel adalah suku pewaris-Nya.","poem":2},{"lineBreak":true},{"text":"TUHAN semesta alam adalah nama-Nya.","poem":2}]},{"type":"heading","content":["Yehuda Menjadi Sunyi"]},{"type":"verse","number":17,"content":[{"text":"Kumpulkanlah","poem":1},{"text":"berkas-berkasmu dari negeri itu,","poem":2},{"lineBreak":true},{"text":"hai kamu yang tinggal dalam pengepungan.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Sebab, beginilah firman TUHAN,","poem":1},{"lineBreak":true},{"text":"“Ketahuilah, Aku akan melempar keluar penduduk negeri ini kali ini,","poem":1},{"text":"dan Aku akan mendatangkan kesengsaraan ke atas mereka","poem":2},{"lineBreak":true},{"text":"supaya mereka dapat merasakannya.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":19,"content":[{"text":"Celakalah aku karena sakitku!","poem":1},{"text":"Lukaku parah.","poem":2},{"text":"Akan tetapi, aku berkata, “Sesungguhnya, ini adalah suatu kesedihan,","poem":1},{"text":"dan aku harus menanggungnya.”","poem":2}]},{"type":"verse","number":20,"content":[{"text":"“Tendaku dihancurkan","poem":1},{"text":"dan semua taliku diputuskan.","poem":2},{"text":"Anak-anakku telah pergi dariku","poem":1},{"text":"dan mereka tidak ada lagi.","poem":2},{"text":"Tidak ada seorang pun yang akan membentangkan tendaku lagi","poem":1},{"text":"dan memasang tirai-tiraiku.”","poem":2}]},{"type":"verse","number":21,"content":[{"text":"Sebab, para gembala telah menjadi bodoh","poem":1},{"text":"dan tidak mencari TUHAN.","poem":2},{"text":"Karena itu, mereka tidak makmur","poem":1},{"text":"dan semua ternak mereka tercerai-berai.","poem":2}]},{"type":"verse","number":22,"content":[{"text":"Dengarlah,","poem":1},{"text":"suatu kabar datang:","poem":2},{"text":"Keributan yang besar keluar dari negeri utara","poem":1},{"text":"untuk membuat kota-kota Yehuda menjadi sunyi","poem":2},{"lineBreak":true},{"text":"dan menjadi sarang serigala.","poem":2}]},{"type":"line_break"},{"type":"verse","number":23,"content":[{"text":"Aku tahu, ya TUHAN, bahwa jalan manusia tidak ada di dalam dirinya sendiri,","poem":1},{"text":"bukanlah di dalam diri manusia yang berjalan yang menuntun langkah-langkahnya.","poem":2}]},{"type":"verse","number":24,"content":[{"text":"Hajarlah aku, ya TUHAN,","poem":1},{"text":"tetapi dalam keadilan;","poem":2},{"lineBreak":true},{"text":"bukan dalam marah-Mu, supaya Engkau tidak membawaku kepada ketiadaan.","poem":2}]},{"type":"verse","number":25,"content":[{"text":"Curahkanlah murka-Mu","poem":1},{"text":"ke atas bangsa-bangsa yang tidak mengenal Engkau,","poem":2},{"text":"ke atas kaum-kaum","poem":1},{"text":"yang tidak memanggil nama-Mu.","poem":2},{"text":"Sebab, mereka telah menghancurkan Yakub,","poem":1},{"text":"mereka telah menghancurkan dia dan menghabisinya,","poem":2},{"lineBreak":true},{"text":"dan telah menjadikan tempat tinggalnya sunyi.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/JER/10.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/JER/11.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/JER/9.json","previousChapterAudioLinks":{},"numberOfVerses":25}