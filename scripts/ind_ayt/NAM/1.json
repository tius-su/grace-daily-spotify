{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"NAM","translationId":"ind_ayt","name":"NAHUM","commonName":"NAHUM","title":"Nahum","order":34,"numberOfChapters":3,"sha256":"d27ed7cf9206ac956232c418416b436f843443b2c51a05441aed264fd0b8550c","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/NAM/1.json","lastChapterNumber":3,"lastChapterApiLink":"/api/ind_ayt/NAM/3.json","totalNumberOfVerses":47},"chapter":{"number":1,"content":[{"type":"verse","number":1,"content":["Petaka Niniwe. Kitab penglihatan Nahum, orang Elkosh."]},{"type":"heading","content":["Murka dan Kedahsyatan TUHAN"]},{"type":"verse","number":2,"content":[{"text":"TUHAN adalah Allah yang cemburu","poem":1},{"text":"dan pembalas.","poem":2},{"text":"TUHAN itu pembalas","poem":1},{"text":"dan penuh dengan murka.","poem":2},{"text":"TUHAN akan melakukan pembalasan kepada lawan-lawannya,","poem":1},{"text":"dan menyimpan murka untuk musuh-musuhnya.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"TUHAN itu panjang sabar","poem":1},{"text":"dan besar kuasa.","poem":2},{"text":"Ia tidak sekali-kali membebaskan orang bersalah","poem":1},{"text":"dari hukuman.","poem":2},{"text":"Ia berjalan dalam angin puting beliung","poem":1},{"text":"dan badai,","poem":2},{"text":"dan awan","poem":1},{"text":"adalah debu kaki-Nya.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Ia menghardik laut","poem":1},{"text":"dan mengeringkannya,","poem":2},{"text":"segala sungai dijadikan-Nya kering.","poem":1},{"text":"Basan dan Karmel merana,","poem":2},{"lineBreak":true},{"text":"dan bunga-bunga Lebanon menjadi layu.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Gunung-gunung berguncang","poem":1},{"text":"di hadapan Dia","poem":2},{"lineBreak":true},{"text":"dan bukit-bukit meleleh.","poem":2},{"text":"Bumi menjadi sunyi di hadirat-Nya,","poem":1},{"text":"dunia dan semua yang tinggal di dalamnya.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Siapakah yang dapat tahan berdiri di hadapan murka-Nya?","poem":1},{"text":"Siapakah yang bertahan dari kemarahan-Nya yang menyala-nyala?","poem":2},{"text":"Murka-Nya tercurah seperti api,","poem":1},{"text":"gunung-gunung batu roboh karena Dia.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"TUHAN itu baik.","poem":1},{"text":"Ia adalah tempat perlindungan pada waktu kesesakan.","poem":2},{"lineBreak":true},{"text":"Ia mengenal orang-orang yang berlindung kepada-Nya.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Akan tetapi, dengan banjir yang melanda,","poem":1},{"text":"Ia akan menghabisi mereka","poem":2},{"text":"dan akan mengejar musuh-musuh-Nya","poem":1},{"text":"ke dalam kegelapan.","poem":2}]},{"type":"heading","content":["Firman TUHAN kepada Yehuda dan Niniwe"]},{"type":"verse","number":9,"content":[{"text":"Apakah kamu bermaksud menentang TUHAN?","poem":1},{"text":"Ia akan menghabisi semuanya.","poem":2},{"lineBreak":true},{"text":"Kesusahan tidak akan timbul dua kali.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Sebab sebagaimana duri","poem":1},{"text":"yang membelit,","poem":2},{"text":"dan saat mereka mabuk sebagai peminum","poem":1},{"text":"mereka akan dilahap seperti tunggul jerami kering.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Dari tengah-tengahmu, muncul orang yang merancang kejahatan terhadap TUHAN,","poem":1},{"text":"seorang penasihat jahat.","poem":2}]},{"type":"line_break"},{"type":"verse","number":12,"content":["Beginilah firman TUHAN,",{"lineBreak":true},{"text":"“Sekalipun mereka kuat","poem":1},{"text":"dan sangat banyak,","poem":2},{"text":"tetapi mereka akan dihancurkan","poem":1},{"text":"dan lenyap.","poem":2},{"text":"Sekalipun Aku merendahkan dirimu,","poem":1},{"text":"Aku tidak akan merendahkan kamu lagi.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Sekarang, Aku akan meremukkan gandarnya","poem":1},{"text":"dari atasmu,","poem":2},{"lineBreak":true},{"text":"dan memutuskan tali-tali pengikatmu.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":14,"content":[{"text":"“Inilah perintah TUHAN atasmu,","poem":1},{"text":"“Tidak akan ada lagi keturunan dengan namamu.","poem":2},{"text":"Dari rumah ilahmu, Aku akan melenyapkan patung pahatan dan patung tuangan.","poem":1},{"text":"Aku akan menyediakan kuburmu,","poem":2},{"text":"sebab kamu terkutuk.”","poem":1}]},{"type":"line_break"},{"type":"verse","number":15,"content":[{"text":"Lihatlah!","poem":1},{"text":"Di atas gunung-gunung, berjalan orang yang membawa kabar baik,","poem":2},{"lineBreak":true},{"text":"yang mengabarkan damai sejahtera.","poem":2},{"text":"Rayakanlah hari-hari rayamu, hai Yehuda,","poem":1},{"text":"bayarlah nazarmu!","poem":2},{"text":"Sebab, tidak akan datang lagi orang-orang dursila yang melewatimu,","poem":1},{"text":"mereka sudah dilenyapkan habis!","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/NAM/1.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/NAM/2.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/MIC/7.json","previousChapterAudioLinks":{},"numberOfVerses":15}