{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PRO","translationId":"ind_ayt","name":"AMSAL","commonName":"AMSAL","title":"Amsal","order":20,"numberOfChapters":31,"sha256":"65a4ef8addfe0e5a23791e9de69059bdf59b7737711d7aa061f88bace1fb26fa","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PRO/1.json","lastChapterNumber":31,"lastChapterApiLink":"/api/ind_ayt/PRO/31.json","totalNumberOfVerses":915},"chapter":{"number":9,"content":[{"type":"heading","content":["Undangan Hikmat dan Undangan Kebodohan"]},{"type":"verse","number":1,"content":[{"text":"Hikmat telah membangun rumahnya;","poem":1},{"text":"ia telah menggali ketujuh tiangnya.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Ia telah memotong ternak sembelihannya, mencampur anggurnya,","poem":1},{"text":"dan menata mejanya.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Ia telah mengutus pelayan-pelayannya perempuan;","poem":1},{"text":"ia berseru-seru dari tempat-tempat tinggi di kota,","poem":2}]},{"type":"verse","number":4,"content":[{"text":"“Siapa yang naif, singgahlah ke sini.”","poem":1},{"text":"Lalu, kepada yang kekurangan akal budi, ia berkata,","poem":2}]},{"type":"verse","number":5,"content":[{"text":"“Mari, makanlah rotiku,","poem":1},{"text":"dan minumlah anggur yang telah kucampur.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Tinggalkanlah kenaifanmu, dan hiduplah,","poem":1},{"text":"serta berjalanlah di jalan pengertian.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Siapa mendidik seorang pencemooh","poem":1},{"text":"mendapatkan malu bagi dirinya sendiri;","poem":2},{"text":"siapa menegur orang fasik","poem":1},{"text":"mendapatkan cela.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Jangan menegur seorang pencemooh","poem":1},{"text":"supaya jangan sampai dia membencimu.","poem":2},{"text":"Tegurlah orang bijak,","poem":1},{"text":"dan dia akan mengasihimu.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Berikanlah didikan kepada orang bijak,","poem":1},{"text":"dan dia akan terus menjadi lebih bijak.","poem":2},{"text":"Ajarlah orang benar,","poem":1},{"text":"dan mereka akan bertambah dalam pengajaran.","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"Takut akan TUHAN adalah permulaan hikmat,","poem":1},{"text":"dan pengetahuan tentang Yang Mahakudus adalah pengertian.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Sebab, oleh karena aku, hari-harimu akan diperbanyak,","poem":1},{"text":"dan tahun-tahun hidupmu akan ditambahkan.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Apabila kamu bijak,","poem":1},{"text":"kamu bijak bagi dirimu sendiri.","poem":2},{"text":"Apabila kamu mencemooh,","poem":1},{"text":"kamu sendiri akan menanggungnya.","poem":2}]},{"type":"heading","content":["Jalan Kebodohan"]},{"type":"verse","number":13,"content":[{"text":"Perempuan yang bodoh itu cerewet; dia naif,","poem":1},{"text":"dan tidak tahu apa-apa.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Dia duduk di pintu rumahnya,","poem":1},{"text":"di atas kursi di tempat-tempat tinggi di kota,","poem":2}]},{"type":"verse","number":15,"content":[{"text":"sambil berseru-seru kepada orang yang lewat di jalan,","poem":1},{"text":"yang berjalan lurus di jalan mereka,","poem":2}]},{"type":"verse","number":16,"content":[{"text":"“Siapa yang naif, singgahlah ke sini.”","poem":1},{"text":"Lalu, kepada yang kekurangan akal budi, dia berkata,","poem":2}]},{"type":"verse","number":17,"content":[{"text":"“Air curian itu manis,","poem":1},{"text":"dan roti yang dimakan dengan sembunyi-sembunyi itu nikmat.”","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Namun, dia tidak tahu bahwa arwah-arwah ada di sana,","poem":1},{"text":"bahwa orang-orang yang diundangnya ada dalam dunia orang mati.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PRO/9.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PRO/10.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PRO/8.json","previousChapterAudioLinks":{},"numberOfVerses":18}