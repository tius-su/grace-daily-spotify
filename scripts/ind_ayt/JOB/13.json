{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"JOB","translationId":"ind_ayt","name":"AYUB","commonName":"AYUB","title":"Ayub","order":18,"numberOfChapters":42,"sha256":"b9bae911b0ef8e8b19b3a726b1638177d115bb4026e627cebc9d465f7bff9f30","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/JOB/1.json","lastChapterNumber":42,"lastChapterApiLink":"/api/ind_ayt/JOB/42.json","totalNumberOfVerses":1070},"chapter":{"number":13,"content":[{"type":"verse","number":1,"content":[{"text":"“Lihatlah, mataku telah melihat semua ini,","poem":1},{"text":"telingaku telah mendengar dan memahaminya.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Apa yang kamu tahu, aku juga tahu.","poem":1},{"text":"Aku tidak lebih rendah darimu.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Akan tetapi, aku mau berbicara kepada Yang Mahakuasa,","poem":1},{"text":"dan aku ingin berbantah tentang perkaraku dengan Allah.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Namun, kamu, kamu membalut dirimu dengan dusta;","poem":1},{"text":"kamu semua adalah tabib-tabib yang tidak berguna.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Seandainya kamu semua tinggal diam,","poem":1},{"text":"maka itu akan menjadi hikmatmu.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Sekarang, dengarkan pembelaanku,","poem":1},{"text":"dan perhatikan bantahan dari bibirku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Akankah kamu berbicara tidak benar kepada Allah,","poem":1},{"text":"dan berkata dusta kepada-Nya?","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Akankah kamu memihak kepada-Nya?","poem":1},{"text":"Akankah kamu berdebat bagi Allah?","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Akankah baik bagimu jika Dia mengujimu?","poem":1},{"text":"Atau, dapatkah kamu membohongi Dia seperti orang membohongi sesamanya?","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Dia pasti akan menghakimimu","poem":1},{"text":"jika kamu menunjukkan keberpihakanmu secara diam-diam.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Bukankah keagungan-Nya akan menakutkanmu,","poem":1},{"text":"dan kengerian-Nya jatuh ke atasmu?","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Pepatah-pepatahmu adalah amsal-amsal dari abu;","poem":1},{"text":"pertahananmu adalah pertahanan dari tanah liat.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Diamlah, dan aku akan berbicara.","poem":1},{"text":"Apa pun yang akan terjadi kepadaku biarlah terjadi.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Mengapa aku menaruh dagingku di gigiku,","poem":1},{"text":"dan meletakkan nyawaku dalam tanganku?","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Meskipun Dia membunuhku, aku akan menaruh harapan dalam Dia;","poem":1},{"text":"Akan tetapi, aku akan tetap memperdebatkan jalanku di hadapan-Nya.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Ini akan menjadi keselamatanku,","poem":1},{"text":"karena orang munafik tidak dapat datang ke hadapan-Nya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":17,"content":[{"text":"Dengarkan baik-baik perkataanku;","poem":1},{"text":"biarlah pernyataanku ada dalam telingamu.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Lihatlah, aku sudah menyiapkan perkaraku.","poem":1},{"text":"Aku tahu bahwa aku akan ada di sisi yang benar.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Siapa yang akan berbantah denganku?","poem":1},{"text":"Sebab, aku sudah akan diam, dan mati.","poem":2}]},{"type":"verse","number":20,"content":[{"text":"Hanya berikan dua hal ini kepadaku, ya Allah,","poem":1},{"text":"maka aku tidak akan bersembunyi dari hadapan-Mu.","poem":2}]},{"type":"verse","number":21,"content":[{"text":"Jauhkanlah tangan-Mu dariku,","poem":1},{"text":"dan jangan membuatku takut dengan kengerian-Mu.","poem":2}]},{"type":"verse","number":22,"content":[{"text":"Kemudian, panggillah, maka aku akan menjawab,","poem":1},{"text":"atau biarkan aku berbicara, dan Engkau menjawab aku.","poem":2}]},{"type":"verse","number":23,"content":[{"text":"Berapa banyakkah kesalahan dan dosaku?","poem":1},{"text":"Beritahukan kepadaku pelanggaran dan dosaku.","poem":2}]},{"type":"verse","number":24,"content":[{"text":"Mengapa Engkau menyembunyikan wajah-Mu,","poem":1},{"text":"dan menganggapku seperti musuh-Mu?","poem":2}]},{"type":"verse","number":25,"content":[{"text":"Akankah Engkau menggentarkan daun yang tertiup angin,","poem":1},{"text":"dan mengejar jerami yang kering?","poem":2}]},{"type":"verse","number":26,"content":[{"text":"Sebab, Engkau menulis hal-hal pahit melawan aku,","poem":1},{"text":"dan membuatku mewarisi dosa-dosa masa mudaku.","poem":2}]},{"type":"verse","number":27,"content":[{"text":"Engkau meletakkan kakiku dalam pasungan,","poem":1},{"text":"dan mengawasi segala jalanku,","poem":2},{"lineBreak":true},{"text":"Engkau menetapkan batas untuk telapak kakiku.","poem":2}]},{"type":"verse","number":28,"content":[{"text":"Manusia menjadi rusak seperti benda yang busuk,","poem":1},{"text":"seperti pakaian yang dimakan oleh ngengat.”","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/JOB/13.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/JOB/14.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/JOB/12.json","previousChapterAudioLinks":{},"numberOfVerses":28}