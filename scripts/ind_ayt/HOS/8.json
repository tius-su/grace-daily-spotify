{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"HOS","translationId":"ind_ayt","name":"HOSEA","commonName":"HOSEA","title":"Hosea","order":28,"numberOfChapters":14,"sha256":"b38642cddd0453a1c298ac4b7dfc5d412f6f084e17077ac1feb9d0211e0c62d1","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/HOS/1.json","lastChapterNumber":14,"lastChapterApiLink":"/api/ind_ayt/HOS/14.json","totalNumberOfVerses":197},"chapter":{"number":8,"content":[{"type":"heading","content":["Penyembahan Ilah Membawa Kebinasaan"]},{"type":"verse","number":1,"content":[{"text":"Tiuplah trompet!","poem":1},{"text":"Seperti burung rajawali yang menunggu di atas rumah TUHAN.","poem":2},{"text":"Sebab, mereka telah melanggar perjanjian-Ku,","poem":1},{"text":"dan memberontak terhadap hukum-Ku.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Israel berseru kepada-Ku,","poem":1},{"text":"“Allahku, kami mengenal Engkau!”","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Israel telah menolak yang baik,","poem":1},{"text":"musuh akan mengejarnya.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Mereka mengangkat raja,","poem":1},{"text":"tetapi tidak melalui Aku.","poem":2},{"text":"Mereka mengangkat pemimpin-pemimpin,","poem":1},{"text":"tetapi Aku tidak mengetahuinya.","poem":2},{"text":"Dengan emas dan perak mereka, mereka membuat berhala bagi kehancuran mereka sendiri,","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Aku telah membuang anak sapimu, hai Samaria.","poem":1},{"text":"Murka-Ku menyala-nyala terhadap mereka!","poem":2},{"text":"Berapa lama mereka tidak mampu untuk tidak bersalah?","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Sebab, dari Israellah anak sapimu, tukang pengrajin yang membuatnya. Itu bukan dari Allah!","poem":1},{"lineBreak":true},{"text":"Anak sapi Samaria itu","poem":1},{"text":"akan dihancurkan berkeping-keping.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Sebab, mereka menabur angin,","poem":1},{"text":"dan mereka akan menuai badai.","poem":2},{"text":"Gandum yang tegak,","poem":1},{"text":"tidak ada isinya;","poem":2},{"lineBreak":true},{"text":"tidak akan menghasilkan tepung.","poem":2},{"text":"Kalaupun memberi hasil,","poem":1},{"text":"orang-orang asing akan melahapnya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"Israel ditelan mentah-mentah,","poem":1},{"text":"di antara bangsa-bangsa,","poem":2},{"text":"mereka seperti peralatan yang tidak berguna.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Sebab, mereka telah pergi ke Asyur,","poem":1},{"text":"seperti keledai hutan yang mengembara sendirian.","poem":2},{"lineBreak":true},{"text":"Efraim menyewa kekasih-kekasih cinta.","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"Sekalipun mereka menyewa kekasih-kekasih di antara bangsa-bangsa,","poem":1},{"text":"Aku akan segera menghimpun mereka.","poem":2},{"text":"mereka akan terluka untuk sementara waktu","poem":1},{"text":"karena beban dari raja dan para pemimpin.”","poem":2}]},{"type":"verse","number":11,"content":[{"text":"“Sebab, Efraim telah memperbanyak mazbah untuk berbuat dosa,","poem":1},{"text":"mereka menjadi mazbah-mazbah untuk berdosa bagi dia.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Walaupun Aku telah menulis banyak hukum-Ku baginya,","poem":1},{"text":"tetapi mereka menganggapnya sebagai sesuatu yang asing","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Tentang persembahan pengurbanan-Ku,","poem":1},{"text":"mereka mempersembahkan daging dan memakannya.","poem":2},{"text":"Akan tetapi, TUHAN tidak berkenan terhadap mereka.","poem":1},{"text":"Sekarang, Dia akan ingat kejahatan mereka dan menghukum dosa-dosa mereka.","poem":2},{"text":"Mereka akan kembali ke Mesir.","poem":1}]},{"type":"verse","number":14,"content":[{"lineBreak":true},{"text":"Sebab, Israel telah melupakan Penciptanya dan membangun istana-istana.","poem":1},{"text":"Yehuda telah memperbanyak kota-kota yang berkubu.","poem":2},{"text":"Oleh karena itu, Aku akan mengirim api ke atas kota-kotanya,","poem":1},{"text":"yang akan melahap benteng-benteng pertahanannya.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/HOS/8.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/HOS/9.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/HOS/7.json","previousChapterAudioLinks":{},"numberOfVerses":14}