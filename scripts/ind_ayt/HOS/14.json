{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"HOS","translationId":"ind_ayt","name":"HOSEA","commonName":"HOSEA","title":"Hosea","order":28,"numberOfChapters":14,"sha256":"b38642cddd0453a1c298ac4b7dfc5d412f6f084e17077ac1feb9d0211e0c62d1","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/HOS/1.json","lastChapterNumber":14,"lastChapterApiLink":"/api/ind_ayt/HOS/14.json","totalNumberOfVerses":197},"chapter":{"number":14,"content":[{"type":"verse","number":1,"content":[{"text":"(14-2) Kembalilah, hai Israel, kepada TUHAN Allahmu,","poem":1},{"text":"sebab kamu telah tersandung karena kesalahanmu.","poem":2}]},{"type":"heading","content":["Pertobatan dan Janji"]},{"type":"verse","number":2,"content":[{"text":"(14-3) Bawalah serta kata-katamu","poem":1},{"text":"dan berbaliklah kepada TUHAN!","poem":2},{"text":"Katakan kepada-Nya,","poem":1},{"text":"“Buanglah kesalahan kami","poem":2},{"lineBreak":true},{"text":"dan terimalah yang baik,","poem":2},{"text":"maka kami akan mempersembahkan","poem":1},{"text":"sapi-sapi jantan dari bibir kami.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"(14-4) Asyur takkan menyelamatkan kami.","poem":1},{"text":"Kami tidak akan menunggangi kuda.","poem":2},{"text":"Dan, kami takkan berkata lagi, ‘ilah kami!’","poem":1},{"text":"kepada patung karya kami.","poem":2},{"text":"Sebab, di dalam Engkau anak yatim mendapat belas kasih.”","poem":1}]},{"type":"heading","content":["TUHAN Mengampuni Israel"]},{"type":"verse","number":4,"content":[{"text":"(14-5) “Aku akan menyembuhkan","poem":1},{"lineBreak":true},{"text":"kemurtadan mereka,","poem":1},{"text":"Aku akan mengasihi mereka dengan rela hati,","poem":2},{"lineBreak":true},{"text":"sebab kemarahan-Ku telah surut dari mereka.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"(14-6) Aku akan menjadi seperti embun pagi bagi Israel,","poem":1},{"text":"Ia akan mekar seperti bunga bakung,","poem":2},{"lineBreak":true},{"text":"dan akan berakar seperti pohon lebanon.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"(14-7) Ranting-rantingnya akan menyebar,","poem":1},{"text":"keindahannya akan seperti pohon zaitun,","poem":2},{"text":"dan keharumannya","poem":1},{"text":"seperti Lebanon.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"(14-8) Mereka akan tinggal di bawah naungan-Ku,","poem":1},{"text":"mereka akan tumbuh subur seperti gandum.","poem":2},{"text":"Mereka akan mekar seperti pohon anggur,","poem":1},{"text":"kemasyhurannya seperti anggur lebanon.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"(14-9) Hai Efraim, apa hubungan-Ku dengan berhala-berhala?","poem":1},{"text":"Bukankah Aku yang menjawab dan memelihara kamu!","poem":2},{"text":"Aku seperti pohon sanobar yang hijau,","poem":1},{"text":"dari Akulah semua buahmu.”","poem":2}]},{"type":"heading","content":["Nasihat Terakhir"]},{"type":"verse","number":9,"content":[{"text":"(14-10) Siapa yang bijaksana,","poem":1},{"text":"biarlah dia memahami semuanya ini.","poem":2},{"text":"Siapa yang berakal budi,","poem":1},{"text":"biarlah dia mengetahuinya.","poem":2},{"text":"Sebab, jalan-jalan TUHAN benar,","poem":1},{"text":"dan orang benar berjalan di dalamnya,","poem":2},{"lineBreak":true},{"text":"tetapi pemberontak akan tersandung di dalamnya.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/HOS/14.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/JOL/1.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/HOS/13.json","previousChapterAudioLinks":{},"numberOfVerses":9}