{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"HOS","translationId":"ind_ayt","name":"HOSEA","commonName":"HOSEA","title":"Hosea","order":28,"numberOfChapters":14,"sha256":"b38642cddd0453a1c298ac4b7dfc5d412f6f084e17077ac1feb9d0211e0c62d1","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/HOS/1.json","lastChapterNumber":14,"lastChapterApiLink":"/api/ind_ayt/HOS/14.json","totalNumberOfVerses":197},"chapter":{"number":6,"content":[{"type":"heading","content":["Upah Pertobatan"]},{"type":"verse","number":1,"content":[{"text":"“Mari, kita berbalik kepada TUHAN,","poem":1},{"text":"sebab Dia telah mencabik-cabik kita, biarlah Dia menyembuhkan kita;","poem":2},{"lineBreak":true},{"text":"Dia telah menyerang kita, dan Dia akan membalut kita.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Setelah dua hari, Dia akan menghidupkan kita.","poem":1},{"text":"Pada hari yang ketiga, Dia akan membangkitkan kita","poem":2},{"lineBreak":true},{"text":"supaya kita boleh hidup dalam hadirat-Nya.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Marilah kita mengenal, marilah kita mengejar untuk","poem":1},{"text":"mengenal TUHAN.","poem":2},{"text":"Kemunculan-Nya sepasti terbitnya fajar,","poem":1},{"text":"dan Dia akan datang kepada kita seperti hujan,","poem":2},{"text":"seperti hujan pada akhir musim","poem":1},{"text":"yang mengairi bumi.”","poem":2}]},{"type":"verse","number":4,"content":[{"text":"“Apa yang harus Aku lakukan kepadamu, hai Efraim?","poem":1},{"text":"Apa yang harus Aku lakukan kepadamu, hai Yehuda?","poem":2},{"text":"Kesetiaanmu seperti awan pagi,","poem":1},{"text":"seperti embun yang menghilang lebih awal.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Oleh sebab itu, Aku telah memotong mereka","poem":1},{"text":"melalui para nabi,","poem":2},{"text":"Aku telah membunuh mereka dengan perkataan dari mulut-Ku,","poem":1},{"text":"dan penghukuman-Ku menembus seperti cahaya.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Sebab, Aku menginginkan kesetiaan,","poem":1},{"text":"bukan kurban,","poem":2},{"text":"dan pengenalan akan Allah,","poem":1},{"text":"bukan kurban-kurban bakaran.","poem":2}]},{"type":"heading","content":["Efraim Tidak Bertobat"]},{"type":"verse","number":7,"content":[{"text":"Namun, seperti Adam, mereka melanggar perjanjian.","poem":1},{"text":"Di sana, mereka berlaku dengan tidak setia terhadap Aku.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Gilead adalah kota pembuat kejahatan,","poem":1},{"text":"ditandai dengan jejak darah.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Seperti gerombolan perampok yang mengintai seseorang,","poem":1},{"text":"demikianlah perkumpulan para imam","poem":2},{"lineBreak":true},{"text":"mereka membunuh dalam perjalanan ke Sikhem,","poem":2},{"text":"mereka melakukan kejahatan persundalan.","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Dalam kaum Israel telah Kulihat hal yang mengerikan.","poem":1},{"lineBreak":true},{"text":"Persundalan, Efraim ada di sana,","poem":1},{"text":"Israel tercemar.","poem":2}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"Juga untukmu, hai Yehuda, penuaian telah ditetapkan bagimu,","poem":1},{"text":"ketika Aku memulihkan kemakmuran umat-Ku.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/HOS/6.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/HOS/7.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/HOS/5.json","previousChapterAudioLinks":{},"numberOfVerses":11}