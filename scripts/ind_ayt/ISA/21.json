{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"ISA","translationId":"ind_ayt","name":"YESAYA","commonName":"YESAYA","title":"Yesaya","order":23,"numberOfChapters":66,"sha256":"f891415032abc4205058a3f5640978e2960ef78dd8c37c7f0c7c220e7bbb2d1c","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/ISA/1.json","lastChapterNumber":66,"lastChapterApiLink":"/api/ind_ayt/ISA/66.json","totalNumberOfVerses":1292},"chapter":{"number":21,"content":[{"type":"heading","content":["Nubuat tentang Babel"]},{"type":"verse","number":1,"content":["Inilah pesan ilahi tentang “padang belantara di tepi laut”:",{"lineBreak":true},{"text":"Seperti angin puting beliung melintasi tanah Negeb,","poem":1},{"text":"demikianlah datangnya dari padang belantara,","poem":2},{"lineBreak":true},{"text":"dari negeri yang mengerikan.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Suatu penglihatan yang sukar telah ditunjukkan kepadaku:","poem":1},{"text":"Orang yang berkhianat akan melakukan pengkhianatan.","poem":2},{"lineBreak":true},{"text":"Para perampok akan merampok.","poem":2},{"lineBreak":true},{"text":"Majulah, hai Elam!","poem":1},{"text":"Kepunglah, hai Madai!","poem":2},{"lineBreak":true},{"text":"Aku akan menghentikan segala keluh kesah yang ditimbulkannya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Karena hal itulah pinggangku dipenuhi rasa sakit,","poem":1},{"text":"penderitaan telah menangkapku","poem":2},{"text":"seperti rasa sakit seorang wanita yang hendak melahirkan;","poem":1},{"text":"aku terbungkuk-bungkuk sehingga tidak bisa mendengar,","poem":2},{"text":"aku gemetar sehingga tidak dapat melihat.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Hatiku cemas; kengerian menyelubungi aku.","poem":1},{"text":"Malam yang aku rindukan telah berubah menjadi ketakutan bagiku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"Persiapkan meja,","poem":1},{"text":"hamparkan permadani,","poem":2},{"lineBreak":true},{"text":"makan dan minumlah.","poem":2},{"lineBreak":true},{"text":"Tiba-tiba terdengar perintah:","poem":2},{"text":"“Bangkitlah, hai perwira-perwira!","poem":1},{"text":"Minyaki perisaimu!”","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"Sebab, beginilah firman Tuhan kepadaku,","poem":1},{"lineBreak":true},{"text":"“Pergilah, tempatkan seorang pengawas,","poem":1},{"text":"dan biarkan dia melaporkan apa yang dilihatnya.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Apabila dia melihat kereta perang,","poem":1},{"text":"penunggang kuda berpasang-pasangan, para penunggang keledai, dan para penunggang unta,","poem":2},{"text":"mintalah dia untuk memerhatikannya baik-baik, mengamatinya dengan sungguh-sungguh.”","poem":1}]},{"type":"line_break"},{"type":"verse","number":8,"content":["Kemudian, pengawas itu berseru,",{"lineBreak":true},{"text":"“Di menara pengawas, ya Tuanku, aku senantiasa berdiri pada siang hari,","poem":1},{"text":"dan di pos penjagaan, aku ditempatkan sepanjang malam.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Lihatlah! Sudah datang orang-orang berkereta, para penunggang kuda berpasang-pasangan.”","poem":1},{"lineBreak":true},{"text":"Lalu, dia berkata,","poem":1},{"text":"“Sudah jatuh! Sudah jatuh Babel!","poem":2},{"text":"Semua patung dewa ukirannya","poem":1},{"text":"telah hancur berserakan di tanah.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"Oh, bangsa-Ku yang diirik","poem":1},{"text":"di tempat pengirikan,","poem":2},{"text":"apa yang kudengar dari TUHAN semesta alam, Allah Israel,","poem":1},{"text":"telah kuberitahukan kepadamu.","poem":2}]},{"type":"heading","content":["Nubuat tentang Edom"]},{"type":"verse","number":11,"content":["Pesan ilahi tentang Duma:",{"lineBreak":true},{"text":"Ada orang yang berseru kepadaku dari Seir,","poem":1},{"text":"“Hai, pengawal, sudah selarut apakah malam ini?","poem":2},{"lineBreak":true},{"text":"Hai, pengawal, sudah selarut apakah malam ini?”","poem":2}]},{"type":"line_break"},{"type":"verse","number":12,"content":[{"text":"Pengawal itu menjawab,","poem":1},{"text":"“Pagi datang, dan demikian juga malam.","poem":2},{"text":"Kalau kamu ingin bertanya, bertanyalah,","poem":1},{"text":"datanglah lagi!”","poem":2}]},{"type":"heading","content":["Nubuat tentang Arab"]},{"type":"verse","number":13,"content":["Pesan ilahi tentang Arab:",{"lineBreak":true},{"text":"Dalam belukar Jazirah Arab kamu akan bermalam,","poem":1},{"text":"hai kafilah-kafilah orang Dedan!","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Hai, penghuni negeri Tema, bawalah air untuk yang haus, hai penduduk negeri Tema,","poem":1},{"text":"sambutlah para pelarian dengan membawa roti.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Sebab, mereka telah melarikan diri dari pedang,","poem":1},{"text":"dari pedang yang terhunus;","poem":2},{"text":"dari busur yang dilengkungkan,","poem":1},{"lineBreak":true},{"text":"dan dari pertempuran sengit.","poem":1}]},{"type":"line_break"},{"type":"verse","number":16,"content":["Sebab, beginilah firman TUHAN kepadaku, “Dalam waktu setahun, menurut tahun-tahun orang upahan, segala kemuliaan Kedar akan berakhir."]},{"type":"verse","number":17,"content":["Sisa jumlah para pemanah, yaitu orang-orang kuat keturunan Kedar, akan tinggal sedikit karena TUHAN, Allah Israel telah berfirman.”"]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/ISA/21.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/ISA/22.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/ISA/20.json","previousChapterAudioLinks":{},"numberOfVerses":17}