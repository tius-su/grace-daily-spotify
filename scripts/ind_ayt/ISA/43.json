{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"ISA","translationId":"ind_ayt","name":"YESAYA","commonName":"YESAYA","title":"Yesaya","order":23,"numberOfChapters":66,"sha256":"f891415032abc4205058a3f5640978e2960ef78dd8c37c7f0c7c220e7bbb2d1c","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/ISA/1.json","lastChapterNumber":66,"lastChapterApiLink":"/api/ind_ayt/ISA/66.json","totalNumberOfVerses":1292},"chapter":{"number":43,"content":[{"type":"heading","content":["Allah Adalah Penebus"]},{"type":"verse","number":1,"content":[{"text":"Sekarang, beginilah perkataan TUHAN, yang menciptakanmu,","poem":1},{"text":"hai Yakub, dan yang membentukmu, hai Israel,","poem":2},{"lineBreak":true},{"text":"“Jangan takut karena Aku telah menebusmu,","poem":2},{"text":"Aku telah memanggilmu dengan namamu;","poem":1},{"text":"kamu adalah milik-Ku.”","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Ketika kamu menyeberangi perairan, Aku akan menyertaimu,","poem":1},{"text":"melalui sungai-sungai, mereka tidak akan menghanyutkanmu.","poem":2},{"text":"Ketika kamu berjalan melalui api, kamu tidak akan terbakar","poem":1},{"text":"ataupun nyala api akan menghanguskanmu.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Sebab, Akulah TUHAN, Allahmu,","poem":1},{"text":"Yang Kudus dari Israel, Juru Selamatmu.","poem":2},{"text":"Aku memberikan Mesir sebagai tebusanmu,","poem":1},{"text":"Etiopia dan Syeba sebagai gantimu.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Karena kamu berharga dalam pandangan-Ku, dan mulia,","poem":1},{"text":"dan Aku ini mengasihimu, Aku memberikan orang lain sebagai gantimu,","poem":2},{"lineBreak":true},{"text":"dan bangsa-bangsa sebagai ganti nyawamu.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Jangan takut karena Aku menyertaimu.","poem":1},{"text":"Aku akan membawa anak cucumu dari timur,","poem":2},{"lineBreak":true},{"text":"dan mengumpulkanmu dari barat.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Aku akan mengatakan kepada utara: “Berikanlah!”","poem":1},{"text":"dan kepada selatan, “Jangan menahan mereka!”","poem":2},{"text":"Bawalah anak-anak-Ku laki-laki","poem":1},{"text":"dari tempat yang jauh dan anak-anak-Ku perempuan dari ujung-ujung bumi,","poem":2}]},{"type":"verse","number":7,"content":[{"text":"setiap orang yang disebut dengan nama-Ku,","poem":1},{"text":"yang Kuciptakan untuk kemuliaan-Ku","poem":2},{"text":"yang telah Kubentuk,","poem":1},{"text":"dan yang telah Kujadikan.","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"Bawalah bangsa yang buta, sekalipun memiliki mata,","poem":1},{"text":"dan yang tuli, sekalipun memiliki telinga.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Semua bangsa berhimpun bersama dan suku-suku bangsa berkumpul.","poem":1},{"text":"Siapakah di antara mereka yang dapat memberitahukan hal ini, atau menyatakan kepada kita hal-hal yang terdahulu?","poem":2},{"text":"Biarlah mereka mengajukan saksi-saksi","poem":1},{"text":"untuk membuktikan bahwa mereka benar.","poem":2},{"lineBreak":true},{"text":"Biarlah mereka mendengar dan berkata, “Itu benar.”","poem":2}]},{"type":"verse","number":10,"content":[{"text":"“Kamu adalah saksi-Ku”, firman TUHAN,","poem":1},{"text":"“dan hamba-Ku yang telah Aku pilih,","poem":2},{"text":"supaya kamu dapat mengetahui dan percaya kepada-Ku,","poem":1},{"text":"dan memahami bahwa Akulah Dia.","poem":2},{"text":"Sebelum Aku, tidak ada allah dibentuk","poem":1},{"text":"dan juga tidak akan ada sesudah Aku.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Aku, Akulah TUHAN,","poem":1},{"text":"dan selain Aku, tidak ada juru selamat.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Akulah yang menyatakan,","poem":1},{"text":"menyelamatkan,","poem":2},{"text":"dan memaklumkan,","poem":1},{"text":"bukan allah asing yang ada di antaramu;","poem":2},{"text":"dan kamulah saksi-saksi-Ku, firman TUHAN,","poem":1},{"text":"dan Akulah Allah.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Ya, sejak sebelum permulaan zaman, Akulah Dia,","poem":1},{"text":"dan tidak ada satu pun yang dapat membebaskan dari tangan-Ku.","poem":2},{"lineBreak":true},{"text":"Aku bertindak dan siapakah yang dapat mengembalikannya?","poem":2}]},{"type":"line_break"},{"type":"verse","number":14,"content":[{"text":"Beginilah firman TUHAN, Penebusmu, Yang Kudus dari Israel,","poem":1},{"text":"“Demi kamu,","poem":2},{"text":"Aku mengutus ke Babel","poem":1},{"text":"dan membawa mereka semua sebagai pelarian,","poem":2},{"text":"bahkan orang-orang Kasdim, di dalam kapal-kapal","poem":1},{"text":"yang di dalamnya mereka bersukacita.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Akulah TUHAN, Yang Kudus milikmu,","poem":1},{"text":"Pencipta Israel, Rajamu.”","poem":2}]},{"type":"heading","content":["Allah Akan Menyelamatkan Umat-Nya Kembali"]},{"type":"verse","number":16,"content":[{"text":"Beginilah firman TUHAN,","poem":1},{"text":"yang membuat jalan di laut","poem":2},{"lineBreak":true},{"text":"dan jalan perintis di perairan yang deras,","poem":2}]},{"type":"verse","number":17,"content":[{"text":"yang membawa keluar kereta, kuda, pasukan dan pahlawan, mereka akan jatuh bersama-sama","poem":1},{"text":"dan tidak akan bangkit lagi,","poem":2},{"text":"mereka ditumpas","poem":1},{"text":"dan dipadamkan seperti sumbu.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Jangan mengingat hal-hal yang dahulu,","poem":1},{"text":"ataupun merenungkan hal-hal pada masa lalu.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Lihatlah, Aku akan melakukan satu hal baru.","poem":1},{"text":"Saat ini, hal itu sedang muncul.","poem":2},{"text":"Tidakkah kamu mengetahui hal itu?","poem":1},{"text":"Ya, Aku bahkan akan membuat jalan di padang belantara","poem":2},{"lineBreak":true},{"text":"dan sungai-sungai di padang gurun.","poem":2}]},{"type":"verse","number":20,"content":[{"text":"Binatang-binatang di padang akan memuliakan Aku,","poem":1},{"text":"serigala-serigala dan burung-burung unta. Sebab, Aku memberikan air di padang belantara","poem":2},{"lineBreak":true},{"text":"dan sungai-sungai di padang gurun,","poem":2},{"text":"untuk memberi minum kepada umat pilihan-Ku,","poem":1}]},{"type":"verse","number":21,"content":[{"text":"yaitu bangsa yang Kubentuk untuk diri-Ku sendiri,","poem":2},{"lineBreak":true},{"text":"supaya mereka menyatakan kemuliaan-Ku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":22,"content":[{"text":"Akan tetapi, kamu tidak berseru kepada-Ku, hai Yakub.","poem":1},{"text":"Kamu merasa lelah terhadap Aku, hai Israel.","poem":2}]},{"type":"verse","number":23,"content":[{"text":"Kamu tidak membawa kepada-Ku dombamu sebagai kurban bakaran,","poem":1},{"text":"ataupun memuliakan Aku dengan kurban-kurbanmu.","poem":2},{"text":"Aku tidak memaksamu melayani dengan persembahan sajian.","poem":1},{"text":"Aku tidak menyusahkanmu dengan kemenyan.","poem":2}]},{"type":"verse","number":24,"content":[{"text":"Kamu tidak membeli tebu wangi bagi-Ku dengan uang,","poem":1},{"text":"ataupun memuaskan Aku dengan lemak kurban-kurbanmu.","poem":2},{"text":"Sebaliknya, kamu membebani Aku dengan dosa-dosamu; kamu telah menyusahkan Aku dengan kejahatan-kejahatanmu.","poem":1}]},{"type":"line_break"},{"type":"verse","number":25,"content":[{"text":"Aku, Akulah Dia","poem":1},{"text":"yang menghapuskan pelanggaran-pelanggaranmu,","poem":2},{"text":"demi diri-Ku sendiri.","poem":1},{"text":"Aku tidak mengingat dosa-dosamu.","poem":2}]},{"type":"verse","number":26,"content":[{"text":"Ingatkanlah Aku.","poem":1},{"text":"Marilah kita beperkara bersama-sama;","poem":2},{"lineBreak":true},{"text":"ajukan perkaramu supaya kamu dapat dibuktikan benar.","poem":2}]},{"type":"verse","number":27,"content":[{"text":"Nenek moyangmu yang pertama telah berdosa,","poem":1},{"text":"dan para juru bicaramu telah memberontak terhadap Aku.","poem":2}]},{"type":"verse","number":28,"content":[{"text":"Dan Aku akan menajiskan para pemimpin tempat suci,","poem":1},{"text":"dan menyerahkan Yakub kepada penghancuran","poem":2},{"lineBreak":true},{"text":"dan Israel kepada caci maki.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/ISA/43.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/ISA/44.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/ISA/42.json","previousChapterAudioLinks":{},"numberOfVerses":28}