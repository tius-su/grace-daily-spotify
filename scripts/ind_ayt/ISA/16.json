{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"ISA","translationId":"ind_ayt","name":"YESAYA","commonName":"YESAYA","title":"Yesaya","order":23,"numberOfChapters":66,"sha256":"f891415032abc4205058a3f5640978e2960ef78dd8c37c7f0c7c220e7bbb2d1c","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/ISA/1.json","lastChapterNumber":66,"lastChapterApiLink":"/api/ind_ayt/ISA/66.json","totalNumberOfVerses":1292},"chapter":{"number":16,"content":[{"type":"verse","number":1,"content":["“Kirimkanlah domba kepada pemimpin negeri itu, dari Sela melalui padang belantara ke gunung putri Sion."]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"Kemudian, seperti burung yang beterbangan,","poem":1},{"text":"seperti sarang yang diacak-acak,","poem":2},{"lineBreak":true},{"text":"demikianlah putri-putri Moab di tempat-tempat penyeberangan Sungai Arnon.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Dapatkan nasihat, buatlah keputusan.","poem":1},{"text":"Jadikan naunganmu bagai malam di puncak siang hari.","poem":2},{"text":"Sembunyikanlah orang-orang terbuang,","poem":1},{"text":"jangan serahkan orang-orang yang lari.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Biarkan orang-orang buangan dari Moab","poem":1},{"text":"tinggal di antaramu.","poem":2},{"lineBreak":true},{"text":"Jadilah tempat perlindungan bagi mereka dari para perusak.","poem":2},{"lineBreak":true},{"text":"Sebab, para pemeras sudah tiba pada penghabisan,","poem":1},{"text":"kekerasan telah berakhir.","poem":2},{"text":"Para penindas telah dilenyapkan","poem":1},{"text":"dari negeri itu.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Kemudian, takhta akan didirikan dalam kasih yang teguh,","poem":1},{"text":"dan di atasnya akan duduk dalam kesetiaan","poem":2},{"lineBreak":true},{"text":"di kemah Daud,","poem":2},{"text":"yang menghakimi dan menegakkan keadilan","poem":1},{"text":"dan cepat melakukan kebenaran.","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"Kami telah mendengar kesombongan Moab,","poem":1},{"text":"betapa sombongnya dia,","poem":2},{"text":"keangkuhannya, kecongkakannya, dan kegeramannya.","poem":1},{"text":"Bualannya itu tidak benar.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Karena itu, bangsa Moab akan meratap,","poem":1},{"text":"setiap orang akan meratap. Karena kue kismis Kir-Hareset,","poem":2},{"lineBreak":true},{"text":"mereka akan merintih dan sangat terpukul!","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Sungguh, ladang-ladang di Hesybon telah layu,","poem":1},{"text":"juga kebun-kebun anggur di Sibma.","poem":2},{"lineBreak":true},{"text":"Para penguasa bangsa-bangsa telah menghancurkan cabang-cabang pilihannya,","poem":2},{"text":"yang meluas sampai ke Yaezer dan menuju ke padang belantara;","poem":1},{"text":"carang-carangnya merambat dan menyeberangi laut.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Oleh karena itu, aku akan meratap bersama Yaezer","poem":1},{"text":"untuk pohon anggur di Sibma.","poem":2},{"text":"Aku akan membasahimu dengan air mataku,","poem":1},{"text":"hai Hesybon dan Eleale,","poem":2},{"text":"karena seruan terhadap buah-buah musim panas","poem":1},{"text":"dan terhadap panenmu telah sirna.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Sukacita dan kebahagiaan telah dilenyapkan dari ladang yang subur","poem":1},{"text":"dan di kebun-kebun anggur, tidak akan ada teriakan sukacita ataupun kegembiraan.","poem":2},{"text":"Tidak ada pemeras anggur di tempat pemerasan","poem":1},{"text":"karena Aku telah menghentikan sukacita itu.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Oleh karena itu, hatiku seperti kecapi untuk Moab,","poem":1},{"text":"dan perasaan batinku untuk Kir-Hareset.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Maka, ketika Moab datang menghadap,","poem":1},{"lineBreak":true},{"text":"ketika dia melelahkan dirinya sendiri ke tempat yang tinggi dan ke kuilnya untuk berdoa,","poem":1},{"text":"ia tidak akan berhasil.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":13,"content":["Itulah firman yang dahulu disampaikan oleh TUHAN mengenai Moab."]},{"type":"verse","number":14,"content":["Akan tetapi, sekarang TUHAN berfirman, kata-Nya, “Dalam waktu tiga tahun, sesuai tahun kerja orang upahan, kemuliaan Moab akan terhina bersama seluruh penduduknya yang banyak. Penduduknya yang tersisa akan sangat sedikit dan tidak berdaya.”"]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/ISA/16.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/ISA/17.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/ISA/15.json","previousChapterAudioLinks":{},"numberOfVerses":14}