{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"ISA","translationId":"ind_ayt","name":"YESAYA","commonName":"YESAYA","title":"Yesaya","order":23,"numberOfChapters":66,"sha256":"f891415032abc4205058a3f5640978e2960ef78dd8c37c7f0c7c220e7bbb2d1c","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/ISA/1.json","lastChapterNumber":66,"lastChapterApiLink":"/api/ind_ayt/ISA/66.json","totalNumberOfVerses":1292},"chapter":{"number":24,"content":[{"type":"heading","content":["Allah Menghancurkan Bumi"]},{"type":"verse","number":1,"content":[{"text":"Lihatlah, TUHAN mengosongkan negeri itu,","poem":1},{"text":"menghancurkannya, membalikkan permukaannya,","poem":2},{"lineBreak":true},{"text":"dan mencerai-beraikan penduduknya.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Maka, seperti keadaan umat, demikianlah keadaan imam,","poem":1},{"text":"seperti keadaan budak laki-laki, demikianlah keadaan tuannya,","poem":2},{"text":"seperti hamba perempuannya, demikianlah nyonyanya,","poem":1},{"text":"seperti penjual, demikianlah pembeli,","poem":2},{"lineBreak":true},{"text":"seperti peminjam, demikianlah si pemberi pinjaman,","poem":2},{"lineBreak":true},{"text":"seperti pengutang, demikianlah si pemberi utang.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Negeri itu akan benar-benar dikosongkan dan dirampas habis-habisan.","poem":1},{"text":"Sebab, TUHAN telah mengucapkan firman ini.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Negeri itu berduka dan merana,","poem":1},{"text":"dunia memudar dan layu,","poem":2},{"lineBreak":true},{"text":"yang ditinggikan penduduk bumi memudar.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Negeri itu dinajiskan oleh penduduknya","poem":1},{"text":"karena mereka telah melanggar hukum,","poem":2},{"text":"melanggar undang-undang,","poem":1},{"text":"melanggar perjanjian yang kekal.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Oleh karena itu, sebuah kutukan menelan negeri itu","poem":1},{"text":"dan mereka yang hidup di dalamnya akan menanggung kesalahan mereka.","poem":2},{"text":"Karena itu, penduduk negeri itu akan dibakar,","poem":1},{"text":"hanya sedikit orang saja yang tersisa.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Anggur baru berduka, pohon anggur merana,","poem":1},{"text":"semua yang bergembira merintih.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Keriangan bunyi rebana berhenti,","poem":1},{"text":"keriuhan orang-orang yang bersukaria berakhir, keriangan bunyi kecapi telah usai.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Mereka tidak lagi minum anggur dengan nyanyian.","poem":1},{"text":"Minuman keras itu akan terasa pahit bagi yang meminumnya.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Kota yang kacau itu dihancurkan,","poem":1},{"text":"setiap rumah ditutup supaya tidak seorang pun dapat masuk.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Terdengar jeritan meminta anggur di jalan-jalan,","poem":1},{"text":"semua sukacita berubah menjadi kesuraman,","poem":2},{"lineBreak":true},{"text":"keriangan negeri itu dilenyapkan.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Kehancuran ditinggalkan di kota itu,","poem":1},{"text":"pintu gerbangnya telah didobrak dan hancur.","poem":2}]},{"type":"line_break"},{"type":"verse","number":13,"content":[{"text":"Itulah yang akan terjadi di tengah-tengah negeri itu,","poem":1},{"text":"di antara bangsa-bangsa,","poem":2},{"text":"seperti saat penjolokan pada pohon zaitun,","poem":1},{"text":"seperti ceceran buah anggur setelah panen berakhir.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Mereka mengangkat suara mereka, mereka bersukacita.","poem":1},{"text":"Mereka berseru dari barat demi keagungan TUHAN.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Sebab itu, muliakanlah TUHAN di timur,","poem":1},{"text":"nama TUHAN,","poem":2},{"text":"Allah Israel,","poem":1},{"text":"di pesisir-pesisir laut.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Dari ujung bumi, kami mendengar nyanyian pujian,","poem":1},{"text":"“Kemuliaan bagi Yang Mahabenar.”","poem":2},{"text":"Akan tetapi, aku berkata, “Merana aku! Merana aku!","poem":1},{"text":"Celakalah aku!","poem":2},{"text":"Sebab, para pengkhianat telah mengkhianati,","poem":1},{"text":"bahkan semakin berkhianat.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":17,"content":[{"text":"Kengerian, lubang,","poem":1},{"text":"dan perangkap ada di atasmu, hai penduduk bumi.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Maka, dia yang melarikan diri karena suara kengerian,","poem":1},{"text":"akan jatuh ke dalam lubang itu.","poem":2},{"text":"Dia yang memanjat naik dari dalam lubang itu,","poem":1},{"text":"akan tertangkap dalam perangkap.","poem":2},{"text":"Sebab, jendela-jendela langit akan dibuka,","poem":1},{"text":"dan dasar-dasar bumi berguncang.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Bumi luluh lantak, bumi hancur lebur,","poem":1},{"text":"bumi berguncang luar biasa.","poem":2}]},{"type":"verse","number":20,"content":[{"text":"Bumi terhuyung-huyung seperti orang mabuk","poem":1},{"text":"dan bergoyang-goyang","poem":2},{"text":"seperti gubuk yang reyot.","poem":1},{"text":"Sebab, pelanggarannya memberatinya","poem":2},{"lineBreak":true},{"text":"sehingga dia roboh dan tidak akan bangkit lagi.","poem":2}]},{"type":"line_break"},{"type":"verse","number":21,"content":[{"text":"Pada waktu itu, TUHAN akan menghukum","poem":1},{"text":"tentara langit di langit","poem":2},{"lineBreak":true},{"text":"dan raja-raja bumi di atas bumi.","poem":2}]},{"type":"verse","number":22,"content":[{"text":"Mereka akan dikumpulkan bersama-sama,","poem":1},{"text":"seperti para tahanan dalam sebuah lubang,","poem":2},{"text":"dan akan dikurung di dalam penjara.","poem":1},{"text":"Setelah beberapa lama, mereka akan dihukum.","poem":2}]},{"type":"verse","number":23,"content":[{"text":"Bulan akan tersipu-sipu","poem":1},{"text":"dan matahari menjadi malu","poem":2},{"text":"karena TUHAN semesta alam akan memerintah di Gunung Sion dan di Yerusalem,","poem":1},{"text":"dan menunjukkan kemuliaan-Nya di hadapan para tua-tua-Nya.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/ISA/24.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/ISA/25.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/ISA/23.json","previousChapterAudioLinks":{},"numberOfVerses":23}