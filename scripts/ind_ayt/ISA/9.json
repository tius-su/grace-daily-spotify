{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"ISA","translationId":"ind_ayt","name":"YESAYA","commonName":"YESAYA","title":"Yesaya","order":23,"numberOfChapters":66,"sha256":"f891415032abc4205058a3f5640978e2960ef78dd8c37c7f0c7c220e7bbb2d1c","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/ISA/1.json","lastChapterNumber":66,"lastChapterApiLink":"/api/ind_ayt/ISA/66.json","totalNumberOfVerses":1292},"chapter":{"number":9,"content":[{"type":"heading","content":["Kelahiran Raja Damai"]},{"type":"verse","number":1,"content":["(8-23) Namun, tidak akan ada lagi kesuraman bagi dia yang dahulu berada dalam kesusahan. Dahulu, Dia memandang rendah tanah Zebulon dan tanah Naftali, tetapi pada kemudian hari, Dia akan memuliakan jalan dekat laut di seberang Sungai Yordan, yaitu Galilea, daerah bangsa-bangsa asing."]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"(9-1) Bangsa yang berjalan dalam kegelapan,","poem":1},{"text":"telah melihat terang yang besar.","poem":2},{"text":"Mereka yang tinggal di negeri yang gelap,","poem":1},{"text":"terang bercahaya atas mereka.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"(9-2) Engkau telah melipatgandakan bangsa itu,","poem":1},{"text":"Engkau menambahkan sukacita mereka.","poem":2},{"text":"Mereka akan bergembira di hadapan-Mu","poem":1},{"text":"seperti kegembiraan pada waktu panen,","poem":2},{"lineBreak":true},{"text":"seperti orang-orang bergirang saat mereka membagi-bagi barang jarahan.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"(9-3) Sebab, kuk yang ditanggungnya dan kayu pikulan di bahunya,","poem":1},{"text":"yaitu tongkat para penindas mereka,","poem":2},{"text":"telah Engkau patahkan","poem":1},{"text":"seperti pada zaman orang Midian.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"(9-4) Setiap sepatu bot pasukan yang berderap dalam kericuhan perang","poem":1},{"text":"dan setiap jubah yang berlumuran darah,","poem":2},{"lineBreak":true},{"text":"akan dibakar, menjadi bahan bakar untuk api.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"(9-5) Sesungguhnya,","poem":1},{"text":"seorang anak telah lahir bagi kita,","poem":2},{"text":"seorang putra telah dikaruniakan bagi kita,","poem":1},{"text":"dan pemerintahan akan ada di bahunya;","poem":2},{"text":"nama-Nya akan disebut: “Penasihat Ajaib”,","poem":1},{"text":"“Allah Yang Mahakuasa”, “Bapa Yang Kekal”, “Raja Damai”.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"(9-6) Peningkatan pemerintahan","poem":1},{"text":"dan perdamaian-Nya tidak akan berakhir,","poem":2},{"text":"atas takhta Daud dan atas kerajaan-Nya,","poem":1},{"text":"untuk mendirikan dan menopang kerajaan itu","poem":2},{"text":"dengan keadilan dan kebenaran,","poem":1},{"text":"mulai hari itu sampai selama-lamanya.","poem":2},{"text":"Kecemburuan TUHAN semesta alam","poem":1},{"text":"akan membuat hal ini terjadi!","poem":2}]},{"type":"heading","content":["Murka TUHAN terhadap Efraim"]},{"type":"verse","number":8,"content":[{"text":"(9-7) TUHAN menyampaikan firman kepada Yakub,","poem":1},{"text":"dan firman itu menimpa Israel.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"(9-8) Seluruh bangsa itu akan mengetahuinya, yaitu Efraim dan penduduk Samaria,","poem":1},{"text":"yang dengan sombong dan dengan hati yang congkak berkata,","poem":2}]},{"type":"verse","number":10,"content":[{"text":"(9-9) “Tembok bata telah runtuh,","poem":1},{"text":"tetapi kami akan membangunnya kembali dengan batu pahat.","poem":2},{"text":"Pohon-pohon ara telah ditebang,","poem":1},{"text":"tetapi kami akan menanam pohon-pohon cedar.”","poem":2}]},{"type":"verse","number":11,"content":[{"text":"(9-10) Karena itu, TUHAN akan membangkitkan lawan-lawan Rezin untuk melawan mereka","poem":1},{"text":"dan akan menggerakkan musuh-musuh mereka.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"(9-11) Orang Aram dari timur","poem":1},{"text":"dan orang Filistin dari barat.","poem":2},{"lineBreak":true},{"text":"Mereka akan melahap Israel dengan mulut yang terbuka.","poem":1},{"text":"Meski terjadi demikian, murka-Nya belumlah reda,","poem":2},{"lineBreak":true},{"text":"tangan-Nya masih terangkat.","poem":2}]},{"type":"line_break"},{"type":"verse","number":13,"content":[{"text":"(9-12) Namun, bangsa itu tidak berbalik kepada Dia yang memukul mereka,","poem":1},{"text":"ataupun mencari TUHAN semesta alam.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"(9-13) Oleh karena itu, TUHAN memotong ekor dan kepala Israel,","poem":1},{"text":"cabang dan ranting dalam sehari.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"(9-14) Orang-orang tua dan orang-orang terhormat, merekalah kepala;","poem":1},{"text":"dan nabi yang mengajarkan kebohongan, dialah ekor.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"(9-15) Sebab, mereka yang memimpin bangsa ini telah menyesatkan bangsa ini,","poem":1},{"text":"dan mereka yang dipimpin oleh orang-orang ini telah dibawa ke dalam kebingungan.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"(9-16) Karena itu, TUHAN tidak mendapat sukacita dari orang-orang muda mereka,","poem":1},{"text":"ataupun berbelaskasihan kepada anak yatim dan janda-janda mereka","poem":2},{"text":"karena mereka semua fasik dan seorang pelaku kejahatan,","poem":1},{"text":"semua mulut mereka mengucapkan kekejian.","poem":2},{"lineBreak":true},{"text":"Meski terjadi demikian,","poem":1},{"text":"murka-Nya belumlah reda,","poem":2},{"text":"tangan-Nya masih terangkat.","poem":1}]},{"type":"line_break"},{"type":"verse","number":18,"content":[{"text":"(9-17) Kejahatan itu membakar seperti sebuah api,","poem":1},{"text":"yang memakan habis onak dan belukar berduri,","poem":2},{"lineBreak":true},{"text":"bahkan membakar semak di hutan","poem":2},{"text":"dan membesar naik","poem":1},{"text":"dalam gumpalan asap.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"(9-18) Oleh murka TUHAN semesta alam,","poem":1},{"text":"negeri itu dihanguskan","poem":2},{"text":"dan penduduknya menjadi seperti bahan bakar untuk api,","poem":1},{"text":"tidak seorang pun menyayangkan saudaranya.","poem":2}]},{"type":"verse","number":20,"content":[{"text":"(9-19) Mereka merampas yang ada di sebelah kanan,","poem":1},{"text":"tetapi masih lapar.","poem":2},{"text":"Mereka melahap yang ada di sebelah kiri,","poem":1},{"text":"tetapi tidak kenyang.","poem":2},{"text":"Maka, mereka masing-masing memakan daging","poem":1},{"text":"dari lengan mereka sendiri.","poem":2}]},{"type":"verse","number":21,"content":[{"text":"(9-20) Manasye memakan Efraim,","poem":1},{"text":"dan Efraim memakan Manasye.","poem":2},{"lineBreak":true},{"text":"Kemudian, keduanya melawan Yehuda.","poem":2},{"lineBreak":true},{"text":"Meski terjadi demikian, murka-Nya belumlah reda,","poem":1},{"text":"tangan-Nya masih terangkat.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/ISA/9.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/ISA/10.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/ISA/8.json","previousChapterAudioLinks":{},"numberOfVerses":21}