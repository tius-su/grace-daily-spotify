{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"ISA","translationId":"ind_ayt","name":"YESAYA","commonName":"YESAYA","title":"Yesaya","order":23,"numberOfChapters":66,"sha256":"f891415032abc4205058a3f5640978e2960ef78dd8c37c7f0c7c220e7bbb2d1c","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/ISA/1.json","lastChapterNumber":66,"lastChapterApiLink":"/api/ind_ayt/ISA/66.json","totalNumberOfVerses":1292},"chapter":{"number":44,"content":[{"type":"heading","content":["TUHAN Adalah Satu-Satunya Allah"]},{"type":"verse","number":1,"content":[{"text":"Akan tetapi sekarang, dengarlah,","poem":1},{"text":"hai Yakub, hamba-Ku,","poem":2},{"lineBreak":true},{"text":"hai Israel, yang telah Kupilih!","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Beginilah perkataan TUHAN yang menjadikan kamu,","poem":1},{"text":"yang telah membentukmu sejak dalam kandungan,","poem":2},{"text":"yang akan menolongmu,","poem":1},{"text":"“Jangan takut, hai Yakub, hamba-Ku, hai Yesyurun, yang telah Kupilih.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Sebab, Aku akan mencurahkan air ke atas tanah yang haus,","poem":1},{"text":"dan aliran-aliran air ke atas tanah yang kering.","poem":2},{"text":"Aku akan mencurahkan Roh-Ku ke atas keturunanmu","poem":1},{"text":"dan berkat-Ku ke atas anak cucumu.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Mereka akan tumbuh di antara rerumputan,","poem":1},{"text":"seperti pohon-pohon gandarusa di tepi aliran air.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Yang satu akan berkata, ‘Aku milik TUHAN,’","poem":1},{"text":"yang lain akan menyebut dirinya dengan nama ‘Yakub’,","poem":2},{"text":"yang lain lagi akan menulis di tangannya ‘Milik TUHAN’","poem":1},{"text":"dan menamai diri dengan nama ‘Israel.’”","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"Beginilah perkataan TUHAN, raja Israel dan Penebusnya,","poem":1},{"text":"TUHAN semesta alam,","poem":2},{"text":"“Akulah Yang Awal dan Yang Akhir,","poem":1},{"text":"selain Aku, tidak ada Allah.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Siapakah yang seperti Aku?","poem":1},{"text":"Biarlah dia menyerukannya.","poem":2},{"text":"Biarlah dia menyatakannya dan memberitahukan hal itu kepada-Ku secara urut,","poem":1},{"text":"sejak Aku menetapkan umat purbakala.","poem":2},{"text":"Biarlah mereka menyerukan","poem":1},{"text":"yang akan datang","poem":2},{"lineBreak":true},{"text":"dan yang akan terjadi.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Jangan takut dan jangan ragu.","poem":1},{"text":"Bukankah Aku telah memberitahukan kepadamu sejak lama dan telah menyerukannya?","poem":2},{"lineBreak":true},{"text":"Kamu adalah saksi-saksi-Ku.","poem":2},{"text":"Adakah ilah lain selain Aku?","poem":1},{"text":"Tidak ada Gunung Batu yang lain,","poem":2},{"lineBreak":true},{"text":"Aku tahu tidak ada.”","poem":2}]},{"type":"heading","content":["Allah Palsu Tidak Berguna"]},{"type":"verse","number":9,"content":[{"text":"Mereka yang membuat patung-patung,","poem":1},{"text":"semua itu sia-sia.","poem":2},{"text":"Benda-benda yang mereka sukai, semua itu tidak memberikan faedah.","poem":1},{"text":"Saksi-saksi mereka tidak melihat ataupun mengetahui","poem":2},{"text":"sehingga mereka dipermalukan.","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Siapakah yang membuat ilah,","poem":1},{"text":"atau menuang patung yang tidak memberikan faedah itu?","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Sesungguhnya, semua kawannya akan dipermalukan.","poem":1},{"text":"Para pengrajinnya hanyalah manusia belaka.","poem":2},{"text":"Biarlah mereka berkumpul bersama-sama; biarlah mereka berdiri.","poem":1},{"text":"Mereka semua akan gemetar","poem":2},{"lineBreak":true},{"text":"dan mereka akan dipermalukan bersama-sama.","poem":2}]},{"type":"line_break"},{"type":"verse","number":12,"content":[{"text":"Tukang besi mengambil kapak","poem":1},{"text":"dan bekerja dengan bara.","poem":2},{"lineBreak":true},{"text":"Dia menempanya dengan palu dan membentuknya dengan kekuatan lengannya.","poem":2},{"text":"Dia menjadi lapar dan kekuatannya hilang,","poem":1},{"text":"dia tidak minum air sehingga menjadi letih.","poem":2}]},{"type":"line_break"},{"type":"verse","number":13,"content":[{"text":"Tukang kayu merentangkan tali pengukur","poem":1},{"text":"dan menandainya dengan kapur merah.","poem":2},{"text":"Dia membentuknya dengan pahat,","poem":1},{"text":"dan menandainya dengan jangka. Dia membentuknya menjadi bentuk manusia,","poem":2},{"lineBreak":true},{"text":"dengan semua keindahannya, untuk ditempatkan di satu rumah.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Dia menebang pohon-pohon aras,","poem":1},{"text":"atau memilih pohon cemara atau pohon tarbantin.","poem":2},{"text":"Dia memeliharanya di antara pohon-pohon hutan.","poem":1},{"text":"Dia menanam pohon aras","poem":2},{"lineBreak":true},{"text":"dan hujan membuatnya bertumbuh.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Kemudian, pohon itu menjadi bahan bakar bagi manusia,","poem":1},{"text":"dia mengambil sebagian untuk menghangatkan dirinya sendiri.","poem":2},{"lineBreak":true},{"text":"Dia menyalakan api dan membakar roti. Dia membuat ilah dan menyembahnya,","poem":2},{"text":"dia membuatnya menjadi patung ukiran","poem":1},{"text":"dan sujud menyembah di hadapannya!","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Setengah dari kayu itu dibakarnya dalam api.","poem":1},{"text":"Di atas yang setengah ini, dia mengolah daging.","poem":2},{"text":"Dipanggangnya daging itu, lalu dimakannya sampai kenyang.","poem":1},{"text":"Dia juga menghangatkan diri dan berkata,","poem":2},{"lineBreak":true},{"text":"“Aha, aku hangat, aku sudah melihat api.”","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Sisa kayunya dibuatnya menjadi satu allah, patung ukirannya,","poem":1},{"text":"dan dia sujud di hadapannya dan memujanya.","poem":2},{"text":"Dia berdoa kepadanya dan berkata,","poem":1},{"text":"“Selamatkan aku karena kamu adalah Allahku!”","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Mereka tidak tahu","poem":1},{"text":"ataupun mengerti","poem":2},{"text":"karena Dia telah menutup mata mereka sehingga mereka tidak dapat melihat","poem":1},{"text":"dan hati mereka, sehingga mereka tidak dapat mengerti.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Tidak ada yang memikirkannya,","poem":1},{"lineBreak":true},{"text":"adakah pengetahuan atau pengertian untuk berkata,","poem":1},{"text":"“Setengah dari kayu itu sudah aku bakar dalam api;","poem":2},{"text":"aku juga memanggang roti di atas baranya.","poem":1},{"text":"Aku telah memanggang daging dan memakannya.","poem":2},{"text":"Akankah aku membuat sisanya menjadi kekejian?","poem":1},{"text":"Akankah aku sujud di hadapan sebatang kayu?”","poem":2}]},{"type":"verse","number":20,"content":[{"text":"Dia hanya makan abu saja.","poem":1},{"text":"Hati yang tertipu telah membuatnya tersesat,","poem":2},{"text":"dan dia tidak dapat membebaskan dirinya sendiri ataupun berkata,","poem":1},{"text":"“Bukankah dusta ada di tangan kananku?”","poem":2}]},{"type":"heading","content":["TUHAN, Allah yang Benar, Menolong Israel"]},{"type":"verse","number":21,"content":[{"text":"“Ingatlah hal-hal ini, hai Yakub dan Israel,","poem":1},{"text":"karena kamu adalah hamba-Ku.","poem":2},{"text":"Aku telah membentukmu, kamu adalah hamba-Ku.","poem":1},{"text":"Hai Israel, kamu tidak akan Aku lupakan.","poem":2}]},{"type":"verse","number":22,"content":[{"text":"Aku telah menghapus pelanggaranmu seperti awan tebal","poem":1},{"text":"dan dosa-dosamu seperti kabut yang tebal.","poem":2},{"text":"Kembalilah kepada-Ku","poem":1},{"text":"karena Aku telah menebusmu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":23,"content":[{"text":"Bersukacitalah, hai langit, karena TUHAN telah melakukannya.","poem":1},{"text":"Bersoraklah, hai bagian-bagian bawah bumi.","poem":2},{"text":"Kumandangkanlah nyanyian, hai gunung-gunung,","poem":1},{"text":"hai hutan dan semua pohon di dalamnya!","poem":2},{"text":"Sebab, TUHAN telah menebus Yakub","poem":1},{"text":"dan menunjukkan kemuliaan-Nya di Israel.","poem":2}]},{"type":"verse","number":24,"content":[{"text":"Beginilah perkataan TUHAN, Penebusmu,","poem":1},{"text":"yang membentukmu sejak dalam kandungan,","poem":2},{"text":"“Akulah TUHAN, yang menjadikan segalanya,","poem":1},{"text":"yang membentangkan langit","poem":2},{"lineBreak":true},{"text":"dan menghamparkan bumi sendirian, siapakah yang bersama Aku?","poem":2}]},{"type":"line_break"},{"type":"verse","number":25,"content":[{"text":"Yang menggagalkan tanda-tanda para pembohong,","poem":1},{"text":"dan membuat bodoh para peramal;","poem":2},{"text":"yang membalikkan orang-orang bijak","poem":1},{"text":"dan mengubah pengetahuan mereka menjadi kebodohan;","poem":2}]},{"type":"verse","number":26,"content":[{"text":"yang meneguhkan perkataan hamba-Nya,","poem":1},{"text":"dan menggenapi nasihat para utusan-Nya,","poem":2},{"text":"yang berkata tentang Yerusalem,","poem":1},{"text":"‘Yerusalem akan ditinggali,’","poem":2},{"text":"dan kepada kota-kota Yehuda,","poem":1},{"text":"‘kota-kota itu akan dibangun. Aku akan membangun reruntuhannya.’","poem":2}]},{"type":"verse","number":27,"content":[{"text":"yang berkata kepada air yang dalam, ‘Mengeringlah!","poem":1},{"text":"dan Aku akan membuat sungai-sungaimu mengering;’","poem":2}]},{"type":"verse","number":28,"content":[{"text":"yang berkata kepada Koresh,","poem":1},{"text":"‘Dia adalah gembala-Ku","poem":2},{"lineBreak":true},{"text":"dan akan melakukan semua keinginan-Ku,","poem":2},{"text":"yang berkata tentang Yerusalem,","poem":1},{"text":"‘Yerusalem akan dibangun!’","poem":2},{"text":"dan tentang Bait Suci,","poem":1},{"text":"‘Fondasimu akan diletakkan!’”","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/ISA/44.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/ISA/45.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/ISA/43.json","previousChapterAudioLinks":{},"numberOfVerses":28}