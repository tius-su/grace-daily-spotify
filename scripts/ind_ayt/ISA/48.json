{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"ISA","translationId":"ind_ayt","name":"YESAYA","commonName":"YESAYA","title":"Yesaya","order":23,"numberOfChapters":66,"sha256":"f891415032abc4205058a3f5640978e2960ef78dd8c37c7f0c7c220e7bbb2d1c","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/ISA/1.json","lastChapterNumber":66,"lastChapterApiLink":"/api/ind_ayt/ISA/66.json","totalNumberOfVerses":1292},"chapter":{"number":48,"content":[{"type":"heading","content":["Nubuat tentang Israel"]},{"type":"verse","number":1,"content":[{"text":"Dengarkanlah ini, hai keluarga Yakub,","poem":1},{"lineBreak":true},{"text":"yang dipanggil dengan nama Israel,","poem":1},{"text":"dan yang datang dari keturunan Yehuda,","poem":2},{"text":"yang bersumpah demi nama TUHAN dan memanggil Allah Israel,","poem":1},{"text":"tetapi tidak dalam kebenaran dan keadilan.","poem":2}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"Sebab, mereka menyebut diri berasal dari kota kudus,","poem":1},{"text":"dan bersandar pada Allah Israel;","poem":2},{"lineBreak":true},{"text":"TUHAN semesta alam adalah nama-Nya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Aku telah menyatakan hal-hal terdahulu sejak dahulu kala.","poem":1},{"text":"Semua itu keluar dari mulut-Ku dan Aku telah mengabarkannya.","poem":2},{"lineBreak":true},{"text":"Lalu, tiba-tiba Aku bertindak dan hal-hal itu terjadi.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Karena Aku mengetahui bahwa kamu keras kepala,","poem":1},{"text":"lehermu berurat besi,","poem":2},{"lineBreak":true},{"text":"dan keningmu dari tembaga,","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Sebab, Aku telah menyatakan hal-hal itu kepadamu sejak dahulu kala,","poem":1},{"text":"sebelum hal-hal itu terjadi, Aku memberitahukannya kepadamu,","poem":2},{"text":"supaya kamu tidak akan berkata,","poem":1},{"text":"“Patungkulah yang telah melakukannya,","poem":2},{"lineBreak":true},{"text":"dan berhala pahatan dan patung tuangankulah yang memerintahkan hal-hal itu.”","poem":2}]},{"type":"heading","content":["Allah Berjanji untuk Memurnikan Israel"]},{"type":"verse","number":6,"content":[{"text":"“Kamu telah mendengar dan melihat semua ini.","poem":1},{"text":"Tidakkah kamu akan mengakuinya?","poem":2},{"lineBreak":true},{"text":"Mulai sekarang, Aku menyatakan kepadamu hal-hal baru,","poem":2},{"text":"hal-hal tersembunyi","poem":1},{"text":"yang belum kamu ketahui.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Hal-hal itu baru diciptakan sekarang, bukan sejak dahulu kala,","poem":1},{"text":"dan sebelum hari ini, kamu belum pernah mendengar hal-hal itu","poem":2},{"text":"supaya kamu tidak akan berkata, ‘Ah, aku sudah tahu hal-hal itu.’","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Kamu belum pernah mendengar;","poem":1},{"text":"kamu belum pernah mengetahui,","poem":2},{"lineBreak":true},{"text":"sejak dahulu kala, telingamu belum terbuka.","poem":2},{"text":"Sebab, Aku mengetahui bahwa kamu akan bertindak tidak setia,","poem":1},{"text":"dan bahwa kamu telah disebut pemberontak sejak lahir.","poem":2}]},{"type":"line_break"},{"type":"verse","number":9,"content":[{"text":"Demi nama-Ku, Aku menunda murka-Ku.","poem":1},{"text":"Demi kemasyhuran-Ku,","poem":2},{"text":"Aku menahannya bagimu","poem":1},{"text":"supaya Aku tidak melenyapkan kamu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"Sesungguhnya, Aku telah memurnikan kamu,","poem":1},{"text":"tetapi tidak seperti perak.","poem":2},{"lineBreak":true},{"text":"Aku telah memurnikan kamu dalam dapur api kesengsaraan.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Demi diri-Ku sendiri, ya demi diri-Ku sendiri, Aku melakukan hal ini.","poem":1},{"text":"Sebab, bagaimana mungkin nama-Ku dinajiskan?","poem":2},{"lineBreak":true},{"text":"Aku tidak akan memberikan kemuliaan-Ku kepada yang lain.","poem":2}]},{"type":"line_break"},{"type":"verse","number":12,"content":[{"text":"Dengarkan Aku, hai Yakub,","poem":1},{"lineBreak":true},{"text":"hai Israel, yang Aku panggil!","poem":1},{"lineBreak":true},{"text":"Akulah Dia.","poem":1},{"text":"Akulah yang Awal dan Akulah yang Akhir.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Tangan-Kulah yang meletakkan dasar bumi,","poem":1},{"text":"dan tangan kanan-Kulah yang membentangkan langit.","poem":2},{"text":"Ketika Aku memanggil mereka,","poem":1},{"text":"mereka akan datang bersama-sama.","poem":2}]},{"type":"line_break"},{"type":"verse","number":14,"content":[{"text":"“Berkumpullah kamu semua dan dengarkanlah!","poem":1},{"text":"Siapakah di antara mereka yang telah menyatakan hal-hal ini?","poem":2},{"text":"TUHAN mengasihi dia; dia akan melakukan kehendak-Nya atas Babel,","poem":1},{"text":"dan lengannya akan melawan orang-orang Kasdim.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":15,"content":[{"text":"“Aku, Akulah yang telah berfirman;","poem":1},{"text":"Akulah yang telah memanggil dia; Aku telah mendatangkan dia,","poem":2},{"lineBreak":true},{"text":"dan dia akan berhasil dalam jalannya.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Mendekatlah kepada-Ku, dengarkanlah ini:","poem":1},{"text":"Sejak semula, Aku tidak pernah berfirman dengan sembunyi-sembunyi,","poem":2},{"text":"pada waktu hal itu terjadi,","poem":1},{"text":"Aku ada di sana.”","poem":2},{"lineBreak":true},"Dan sekarang, TUHAN Allah mengutus aku dengan Roh-Nya."]},{"type":"verse","number":17,"content":["Beginilah perkataan TUHAN, Penebusmu, Yang Kudus dari Israel,",{"lineBreak":true},{"text":"“Akulah TUHAN, Allahmu,","poem":1},{"text":"yang mengajarmu untuk mendapatkan faedah,","poem":2},{"lineBreak":true},{"text":"yang menuntunmu di jalan yang harus kamu lalui.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Seandainya dahulu kamu memerhatikan perintah-perintah-Ku,","poem":1},{"text":"kesejahteraanmu akan seperti sungai,","poem":2},{"lineBreak":true},{"text":"dan kebenaranmu seperti ombak laut.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Keturunanmu akan seperti pasir,","poem":1},{"text":"dan anak cucumu seperti butiran-butirannya.","poem":2},{"text":"Nama mereka tidak akan dilenyapkan","poem":1},{"text":"atau dihancurkan dari hadapan-Ku.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":20,"content":[{"text":"Keluarlah dari Babel!","poem":1},{"text":"Larilah dari Kasdim!","poem":2},{"text":"Beritahukanlah hal ini dengan sorak-sorai,","poem":1},{"text":"kabarkanlah itu ke ujung bumi.","poem":2},{"text":"Katakanlah,","poem":1},{"text":"“TUHAN telah menebus hamba-Nya, Yakub.”","poem":2}]},{"type":"verse","number":21,"content":[{"text":"Mereka tidak akan haus saat Dia menuntun mereka melewati padang-padang gurun.","poem":1},{"text":"Dia membuat air mengalir dari bukit batu bagi mereka.","poem":2},{"text":"Dia membelah bukit batu itu","poem":1},{"text":"dan air memancar keluar.","poem":2}]},{"type":"line_break"},{"type":"verse","number":22,"content":[{"text":"“Tidak ada kesejahteraan,” kata TUHAN,","poem":1},{"text":"“bagi orang fasik.”","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/ISA/48.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/ISA/49.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/ISA/47.json","previousChapterAudioLinks":{},"numberOfVerses":22}