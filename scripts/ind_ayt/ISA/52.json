{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"ISA","translationId":"ind_ayt","name":"YESAYA","commonName":"YESAYA","title":"Yesaya","order":23,"numberOfChapters":66,"sha256":"f891415032abc4205058a3f5640978e2960ef78dd8c37c7f0c7c220e7bbb2d1c","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/ISA/1.json","lastChapterNumber":66,"lastChapterApiLink":"/api/ind_ayt/ISA/66.json","totalNumberOfVerses":1292},"chapter":{"number":52,"content":[{"type":"heading","content":["Israel Akan Diselamatkan"]},{"type":"verse","number":1,"content":[{"text":"Bangunlah! Bangunlah!","poem":1},{"text":"Kenakanlah kekuatanmu, hai Sion.","poem":2},{"text":"Kenakanlah pakaian kehormatanmu,","poem":1},{"text":"hai Yerusalem, kota yang kudus!","poem":2},{"lineBreak":true},{"text":"Sebab, orang-orang tak bersunat dan orang-orang yang najis tidak akan masuk lagi ke dalammu.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Kebaskanlah dirimu dari debu! Bangkitlah!","poem":1},{"lineBreak":true},{"text":"Duduklah, hai Yerusalem.","poem":1},{"text":"Lepaskanlah belenggu dari lehermu, hai putri Sion yang tertawan!","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Sebab, beginilah perkataan TUHAN,","poem":1},{"text":"“Kamu dijual secara cuma-cuma,","poem":2},{"lineBreak":true},{"text":"maka kamu akan ditebus tanpa menggunakan uang.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"Sebab, beginilah perkataan TUHAN Allah,","poem":1},{"lineBreak":true},{"text":"“Awalnya, umat-Ku pergi ke Mesir untuk tinggal di sana,","poem":1},{"text":"tetapi bangsa Asyur menindas mereka.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Maka sekarang, untuk apa lagi Aku di sini?” firman TUHAN,","poem":1},{"text":"“Umat-Ku dirampas tanpa alasan.”","poem":2},{"text":"“Mereka yang memerintah atas umat-Ku meratap,” firman TUHAN,","poem":1},{"text":"“dan nama-Ku terus dihujat sepanjang hari.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Karena itu, umat-Ku akan mengenal nama-Ku.","poem":1},{"text":"Pada waktu itu, mereka akan mengetahui","poem":2},{"text":"bahwa Akulah yang berfirman,","poem":1},{"text":"‘Inilah Aku.’”","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Betapa indahnya di atas gunung-gunung","poem":1},{"text":"kaki-kaki orang yang membawa berita,","poem":2},{"text":"yang mewartakan perdamaian, yang membawa kabar baik kebahagiaan,","poem":1},{"text":"yang menyatakan keselamatan, yang berkata kepada Sion,","poem":2},{"lineBreak":true},{"text":"“Allahmu memerintah!”","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Dengarlah!","poem":1},{"text":"Para penjagamu mengangkat suara mereka.","poem":2},{"text":"Mereka meneriakkan sukacita bersama-sama","poem":1},{"text":"karena mereka akan melihat dengan mata mereka sendiri ketika TUHAN mengembalikan Sion.","poem":2}]},{"type":"line_break"},{"type":"verse","number":9,"content":[{"text":"Bergembiralah dan bersorak-sorailah bersama-sama,","poem":1},{"text":"hai reruntuhan Yerusalem!","poem":2},{"text":"Sebab, TUHAN telah menghibur umat-Nya;","poem":1},{"text":"Dia telah menebus Yerusalem.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"TUHAN telah memperlihatkan tangan-Nya yang kudus","poem":1},{"text":"di mata semua bangsa,","poem":2},{"text":"dan semua ujung bumi","poem":1},{"text":"akan melihat keselamatan Allah kita.","poem":2}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"Pergilah, pergilah!","poem":1},{"text":"Keluarlah dari sana!","poem":2},{"text":"Jangan menyentuh sesuatu yang najis! Keluarlah dari tengah-tengahnya.","poem":1},{"text":"Tahirkanlah dirimu, hai orang-orang yang mengangkat perlengkapan Bait TUHAN.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Karena kamu tidak akan pergi dari sana dengan tergesa-gesa,","poem":1},{"text":"ataupun pergi sebagai pelarian.","poem":2},{"text":"Sebab, TUHAN akan berjalan di depanmu","poem":1},{"text":"dan Allah Israel akan menjadi penutup barisanmu.","poem":2}]},{"type":"heading","content":["Penderitaan Hamba Allah"]},{"type":"verse","number":13,"content":[{"text":"Sesungguhnya, hamba-Ku akan bertindak dengan bijaksana.","poem":1},{"text":"Dia akan ditinggikan,","poem":2},{"lineBreak":true},{"text":"disanjung dan sangat dimuliakan.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Sama seperti banyak orang takjub kepadamu,","poem":1},{"text":"penampilannya begitu rusak sehingga tidak seperti manusia lagi dan sosoknya tidak seperti anak manusia lagi.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Demikian Dia akan mengejutkan banyak bangsa.","poem":1},{"text":"Raja-raja akan mengatupkan mulutnya karena Dia.","poem":2},{"text":"Sebab, apa yang belum pernah diberitahukan kepada mereka akan mereka lihat,","poem":1},{"text":"dan apa yang tidak pernah mereka dengar akan mereka pahami!”","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/ISA/52.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/ISA/53.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/ISA/51.json","previousChapterAudioLinks":{},"numberOfVerses":15}