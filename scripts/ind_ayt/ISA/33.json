{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"ISA","translationId":"ind_ayt","name":"YESAYA","commonName":"YESAYA","title":"Yesaya","order":23,"numberOfChapters":66,"sha256":"f891415032abc4205058a3f5640978e2960ef78dd8c37c7f0c7c220e7bbb2d1c","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/ISA/1.json","lastChapterNumber":66,"lastChapterApiLink":"/api/ind_ayt/ISA/66.json","totalNumberOfVerses":1292},"chapter":{"number":33,"content":[{"type":"heading","content":["TUHAN Akan Membawa Keselamatan"]},{"type":"verse","number":1,"content":[{"text":"Celakalah kamu, hai perusak,","poem":1},{"lineBreak":true},{"text":"yang kamu sendiri belum pernah dirusak,","poem":1},{"text":"hai pengkhianat,","poem":2},{"text":"yang belum pernah dikhianati!","poem":1},{"text":"Ketika kamu berhenti menghancurkan, kamu akan dihancurkan,","poem":2},{"text":"dan ketika kamu sudah tidak lagi mengkhianati,","poem":1},{"text":"mereka akan mengkhianatimu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"“TUHAN, kasihanilah kami.","poem":1},{"text":"Kami telah menanti-nantikan Engkau.","poem":2},{"text":"Jadilah kekuatan kami setiap pagi,","poem":1},{"text":"keselamatan kami pada masa kesesakan.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Karena bunyi keributan, bangsa-bangsa melarikan diri.","poem":1},{"text":"Karena Engkau meninggikan diri-Mu, bangsa-bangsa tercerai-berai.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"Jarahanmu akan dikumpulkan","poem":1},{"text":"seperti mengumpulkan ulat.","poem":2},{"text":"Seperti belalang datang menyerbu,","poem":1},{"text":"demikianlah mereka datang menyerbunya.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"TUHAN ditinggikan","poem":1},{"text":"karena Dia bersemayam di tempat yang tinggi.","poem":2},{"lineBreak":true},{"text":"Dia memenuhi Sion dengan keadilan dan kebenaran.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Pada zamanmu akan ada keamanan,","poem":1},{"text":"kelimpahan, keselamatan,","poem":2},{"text":"kebijaksanaan, dan pengetahuan,","poem":1},{"text":"takut akan TUHAN adalah kekayaan Sion.","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Lihatlah, orang-orang mereka yang gagah perkasa menangis di jalan-jalan.","poem":1},{"text":"Para utusan perdamaian menangis dalam kepedihan.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Jalan raya menjadi sunyi,","poem":1},{"text":"orang-orang yang melintasinya tidak ada lagi.","poem":2},{"text":"Perjanjian telah diingkari,","poem":1},{"text":"kota-kota telah dihinakan,","poem":2},{"lineBreak":true},{"text":"dan manusia tidak dianggap.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Negeri itu berduka dan merana.","poem":1},{"text":"Lebanon menjadi malu dan layu.","poem":2},{"text":"Saron menjadi seperti padang gurun.","poem":1},{"text":"Basan dan Karmel berguncang.","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"“Sekarang, Aku akan bangkit,” firman TUHAN.","poem":1},{"text":"“Sekarang, Aku akan meninggikan diri-Ku. Sekarang, Aku akan ditinggikan”","poem":2}]},{"type":"verse","number":11,"content":[{"text":"“Kamu mengandung sekam,","poem":1},{"text":"dan akan melahirkan tunggul jerami.","poem":2},{"lineBreak":true},{"text":"Napasmu seperti api yang menghanguskan dirimu sendiri.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Bangsa-bangsa akan dibakar menjadi kapur,","poem":1},{"text":"seperti duri yang dipotong, kemudian dibakar dalam nyala api.","poem":2}]},{"type":"line_break"},{"type":"verse","number":13,"content":[{"text":"Hai kamu yang jauh,","poem":1},{"text":"dengarkanlah apa yang Kulakukan,","poem":2},{"text":"dan kamu yang dekat,","poem":1},{"text":"akuilah keperkasaan-Ku.”","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Orang-orang berdosa di Sion ketakutan.","poem":1},{"text":"Kegentaran telah mencekam orang-orang fasik.","poem":2},{"text":"“Siapa di antara kita dapat tinggal dalam api yang menghanguskan?","poem":1},{"text":"Siapa di antara kita dapat tinggal dalam perapian terus-menerus?”","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Orang yang hidup dalam kebenaran dan berbicara dengan ketulusan,","poem":1},{"text":"yang menghina hasil penindasan, yang mengibaskan tangan supaya tidak menerima suap,","poem":2},{"text":"yang menutup telinganya dari mendengar tentang pertumpahan darah,","poem":1},{"text":"yang menutup matanya dari melihat kejahatan,","poem":2}]},{"type":"verse","number":16,"content":[{"text":"orang itu akan tinggal di tempat yang tinggi.","poem":1},{"text":"Tempat perlindungannya adalah benteng-benteng di bukit batu.","poem":2},{"lineBreak":true},{"text":"Makanannya akan terpenuhi dan air minumnya akan terjamin.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Matamu akan melihat Sang Raja dalam keindahan-Nya.","poem":1},{"text":"Mereka akan melihat negeri yang jauh.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Hatimu akan merenungkan kengerian,","poem":1},{"text":"“Di manakah si juru hitung?","poem":2},{"text":"Di manakah si juru timbang?","poem":1},{"text":"Di manakah orang yang menghitung menara-menara?”","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Kamu tidak akan melihat lagi bangsa yang brutal itu,","poem":1},{"text":"bangsa yang bahasanya sulit sehingga tidak dapat dipahami,","poem":2},{"lineBreak":true},{"text":"yang gagap bicaranya sehingga kamu tidak dapat mengerti.","poem":2}]},{"type":"heading","content":["Allah Akan Melindungi Yerusalem"]},{"type":"verse","number":20,"content":[{"text":"Lihatlah Sion, kota tempat perayaan hari raya kita.","poem":1},{"text":"Matamu akan melihat Yerusalem,","poem":2},{"text":"tempat tinggal yang aman,","poem":1},{"text":"tenda yang tidak dapat dipindah-pindahkan.","poem":2},{"text":"Patok-patoknya tidak akan pernah dicabut, ataupun talinya terputus.","poem":1}]},{"type":"verse","number":21,"content":[{"text":"Di sanalah, TUHAN dalam kebesaran-Nya","poem":2},{"text":"akan menjadi tempat yang memiliki sungai-sungai dan kanal-kanal yang lebar bagi kita,","poem":1},{"text":"perahu dayung tidak dapat melintasinya dan kapal besar tidak dapat melewatinya.","poem":2}]},{"type":"verse","number":22,"content":[{"text":"Sebab, TUHAN adalah Hakim kita.","poem":1},{"text":"TUHAN adalah pemberi hukum kita.","poem":2},{"text":"TUHAN adalah Raja kita.","poem":1},{"text":"Dia akan menyelamatkan kita.","poem":2}]},{"type":"verse","number":23,"content":[{"text":"Tali-talimu sudah kendur, tidak dapat mengikat kuat tiang layar pada tempatnya","poem":1},{"text":"ataupun menjaga layarnya tetap terkembang.","poem":2},{"text":"Kemudian, rampasan dan jarahan yang berlimpah-limpah akan dibagi-bagi,","poem":1},{"text":"bahkan orang lumpuh pun akan mengambil jarahan.","poem":2}]},{"type":"verse","number":24,"content":[{"text":"Tidak seorang pun yang tinggal di sana akan berkata, “Aku sakit,”","poem":1},{"text":"setiap orang yang tinggal di sana akan diampuni dosanya.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/ISA/33.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/ISA/34.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/ISA/32.json","previousChapterAudioLinks":{},"numberOfVerses":24}