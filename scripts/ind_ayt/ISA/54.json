{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"ISA","translationId":"ind_ayt","name":"YESAYA","commonName":"YESAYA","title":"Yesaya","order":23,"numberOfChapters":66,"sha256":"f891415032abc4205058a3f5640978e2960ef78dd8c37c7f0c7c220e7bbb2d1c","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/ISA/1.json","lastChapterNumber":66,"lastChapterApiLink":"/api/ind_ayt/ISA/66.json","totalNumberOfVerses":1292},"chapter":{"number":54,"content":[{"type":"heading","content":["Allah Memulangkan Umat-Nya"]},{"type":"verse","number":1,"content":[{"text":"“Bersorak-sorailah,","poem":1},{"lineBreak":true},{"text":"hai yang mandul, yang tidak pernah melahirkan!","poem":1},{"text":"Bergembiralah dan berserulah dengan keras,","poem":2},{"lineBreak":true},{"text":"hai kamu yang belum pernah merasakan sakit bersalin!","poem":1},{"text":"Sebab, anak-anak dari perempuan yang ditinggalkan suaminya","poem":2},{"text":"akan lebih banyak daripada anak-anak dari perempuan yang bersuami,”","poem":1},{"text":"kata TUHAN.","poem":2}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"“Perluaslah tempat tendamu,","poem":1},{"text":"bentangkanlah tenda kediamanmu, jangan menyisakannya.","poem":2},{"text":"Panjangkanlah tali-talinya,","poem":1},{"text":"perkuatlah pasak kemahmu.","poem":2}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Sebab, kamu akan menyebar ke kanan dan ke kiri.","poem":2},{"text":"Keturunanmu akan menguasai bangsa-bangsa","poem":1},{"text":"dan menempati kota-kota sunyi.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Jangan takut,","poem":1},{"text":"karena kamu tidak akan dipermalukan.","poem":2},{"text":"Jangan malu,","poem":1},{"text":"karena kamu tidak akan dipermalukan.","poem":2},{"text":"Sebab, kamu akan melupakan rasa malu masa mudamu,","poem":1},{"text":"dan hinaan kejandaanmu tidak akan kamu ingat lagi.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Sebab, suamimu adalah Dia yang menjadikanmu,","poem":1},{"text":"TUHAN semesta alam adalah nama-Nya;","poem":2},{"text":"Yang Kudus dari Israel Penebusmu,","poem":1},{"text":"yang disebut Allah seluruh bumi!","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"Sebab, TUHAN telah memanggilmu,","poem":1},{"text":"seperti istri yang ditinggalkan dan bersusah hati,","poem":2},{"text":"seperti wanita yang baru menikah dan ditolak,”","poem":1},{"text":"kata Allahmu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"“Untuk sesaat saja","poem":1},{"text":"Aku meninggalkanmu,","poem":2},{"text":"tetapi dengan kasih sayang yang besar,","poem":1},{"text":"Aku akan mengumpulkan kamu kembali.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Dalam murka yang meluap, Aku menyembunyikan wajah-Ku darimu untuk sesaat.","poem":1},{"text":"Akan tetapi, dengan kebaikan yang kekal Aku akan berbelas kasihan kepadamu.”","poem":2},{"lineBreak":true},{"text":"kata TUHAN, Penebusmu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":9,"content":[{"text":"“Ini seperti zaman Nuh bagi-Ku,","poem":1},{"text":"ketika Aku berjanji bahwa air bah pada zaman Nuh tidak akan meliputi bumi lagi;","poem":2},{"text":"demikianlah Aku berjanji, bahwa Aku tidak akan lagi murka terhadap kamu,","poem":1},{"text":"dan tidak akan menghardik kamu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"Sebab, sekalipun gunung-gunung berpindah,","poem":1},{"text":"dan bukit-bukit akan bergoyang,","poem":2},{"text":"tetapi kasih setia-Ku","poem":1},{"text":"tidak akan beralih darimu.","poem":2},{"text":"Perjanjian perdamaian-Ku","poem":1},{"text":"tidak akan pernah dipindahkan,”","poem":2},{"text":"kata TUHAN","poem":1},{"text":"yang berbelas kasihan kepadamu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"“Hai kamu yang tertindas,","poem":1},{"text":"yang diterjang badai,","poem":2},{"lineBreak":true},{"text":"dan yang tidak dihiburkan!","poem":2},{"text":"Lihatlah, Aku akan meletakkan alasmu dari batu hitam","poem":1},{"text":"dan fondasimu dari batu safir.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Aku akan membuat puncak-puncak bentengmu dari batu mulia,","poem":1},{"text":"pintu-pintu gerbangmu dari kristal,","poem":2},{"lineBreak":true},{"text":"dan seluruh tembokmu dari batu-batu indah.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Semua anakmu akan diajarkan tentang TUHAN,","poem":1},{"text":"maka besarlah kesejahteraan anak-anakmu.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Dalam kebenaran kamu akan ditegakkan.","poem":1},{"text":"Kamu akan jauh dari penindasan","poem":2},{"text":"karena kamu tidak akan takut;","poem":1},{"text":"atau dari kengerian karena hal itu tidak akan datang mendekat kepadamu.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Jika ada siapa pun yang menyerangmu, itu bukan dari-Ku.","poem":1},{"text":"Siapa pun yang melawanmu","poem":2},{"lineBreak":true},{"text":"akan jatuh olehmu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":16,"content":[{"text":"Sesungguhnya, Akulah yang telah menciptakan tukang besi,","poem":1},{"text":"yang meniup bara api,","poem":2},{"lineBreak":true},{"text":"dan menghasilkan senjata sesuai kegunaannya.","poem":2},{"text":"Dan, Akulah yang menciptakan pemusnah","poem":1},{"text":"untuk menghancurkan.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Tidak ada senjata yang ditempa untuk melawanmu akan berhasil,","poem":1},{"text":"dan setiap lidah yang akan mengucapkan tuduhan terhadap kamu di pengadilan akan kamu buktikan salah.","poem":2},{"text":"Inilah warisan para pelayan TUHAN","poem":1},{"text":"dan pembenaran mereka berasal dari-Ku,”","poem":2},{"text":"firman TUHAN.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/ISA/54.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/ISA/55.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/ISA/53.json","previousChapterAudioLinks":{},"numberOfVerses":17}