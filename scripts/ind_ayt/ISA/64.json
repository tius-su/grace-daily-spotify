{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"ISA","translationId":"ind_ayt","name":"YESAYA","commonName":"YESAYA","title":"Yesaya","order":23,"numberOfChapters":66,"sha256":"f891415032abc4205058a3f5640978e2960ef78dd8c37c7f0c7c220e7bbb2d1c","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/ISA/1.json","lastChapterNumber":66,"lastChapterApiLink":"/api/ind_ayt/ISA/66.json","totalNumberOfVerses":1292},"chapter":{"number":64,"content":[{"type":"verse","number":1,"content":[{"text":"Sekiranya Engkau mengoyakkan langit","poem":1},{"text":"dan turun","poem":2},{"text":"sehingga gunung-gunung luruh di hadirat-Mu,","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"seperti saat api membakar semak-semak","poem":1},{"text":"dan sebagaimana api menyebabkan air mendidih,","poem":2},{"text":"untuk membuat nama-Mu dikenal oleh musuh-musuh-Mu,","poem":1},{"text":"sehingga bangsa-bangsa akan gemetar di hadirat-Mu.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Ketika Engkau melakukan hal-hal mengagumkan yang tidak kami harapkan,","poem":1},{"text":"Engkau turun, gunung-gunung gemetar di hadapan-Mu.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Sejak dahulu, tidak ada yang pernah mendengar atau menangkap dengan telinga,","poem":1},{"text":"tidak ada mata yang telah melihat","poem":2},{"text":"Allah selain Engkau,","poem":1},{"text":"yang bertindak bagi mereka yang menanti-nantikan Dia.","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"Engkau menemui dia yang bersukacita dalam melakukan kebenaran,","poem":1},{"text":"yang mengingat Engkau di jalan-jalan-Mu.","poem":2},{"text":"Sesungguhnya, Engkau murka karena kami berbuat dosa,","poem":1},{"text":"kami telah berada di dalamnya sejak lama,","poem":2},{"lineBreak":true},{"text":"dan mungkinkah kami diselamatkan?","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Kami semua seperti orang cemar","poem":1},{"text":"dan semua kesalehan kami seperti kain cemar.","poem":2},{"text":"Kami semua layu seperti daun,","poem":1},{"text":"dan kesalahan-kesalahan kami menerbangkan kami","poem":2},{"lineBreak":true},{"text":"seperti angin.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Tidak ada seorang pun yang memanggil nama-Mu,","poem":1},{"lineBreak":true},{"text":"yang bangkit untuk berpegang kepada-Mu.","poem":1},{"text":"Sebab, Engkau telah menyembunyikan wajah-Mu dari kami,","poem":2},{"text":"dan membuat kami luruh","poem":1},{"text":"di tangan kesalahan-kesalahan kami.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Akan tetapi, Ya TUHAN, Engkaulah Bapa kami.","poem":1},{"text":"Kami adalah tanah liat dan Engkau adalah Penjunan kami.","poem":2},{"lineBreak":true},{"text":"Kami semua adalah buatan tangan-Mu.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Janganlah murka sedemikian hebat, Ya TUHAN,","poem":1},{"text":"dan janganlah mengingat-ingat kesalahan selamanya.","poem":2},{"text":"Sesungguhnya, lihatlah kami!","poem":1},{"text":"Kami semua adalah umat-Mu.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Kota-kota kudus-Mu telah menjadi padang belantara,","poem":1},{"text":"Sion telah menjadi padang belantara.","poem":2},{"lineBreak":true},{"text":"Yerusalem menjadi sunyi sepi.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Rumah kami yang kudus dan indah, tempat nenek moyang kami memuji Engkau,","poem":1},{"text":"telah terbakar oleh api,","poem":2},{"lineBreak":true},{"text":"dan semua barang berharga kami telah menjadi reruntuhan.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Akankah Engkau menahan diri terhadap semua ini, ya TUHAN?","poem":1},{"text":"Akankah Engkau tetap diam","poem":2},{"lineBreak":true},{"text":"dan menghukum kami sedemikian hebat?","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/ISA/64.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/ISA/65.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/ISA/63.json","previousChapterAudioLinks":{},"numberOfVerses":12}