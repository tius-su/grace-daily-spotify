{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"ISA","translationId":"ind_ayt","name":"YESAYA","commonName":"YESAYA","title":"Yesaya","order":23,"numberOfChapters":66,"sha256":"f891415032abc4205058a3f5640978e2960ef78dd8c37c7f0c7c220e7bbb2d1c","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/ISA/1.json","lastChapterNumber":66,"lastChapterApiLink":"/api/ind_ayt/ISA/66.json","totalNumberOfVerses":1292},"chapter":{"number":57,"content":[{"type":"heading","content":["Israel Tidak Mengikut Allah"]},{"type":"verse","number":1,"content":[{"text":"Orang benar binasa,","poem":1},{"text":"tetapi tidak seorang pun menaruhnya di dalam hatinya.","poem":2},{"text":"Orang-orang saleh kehilangan nyawa,","poem":1},{"text":"tetapi tidak seorang pun memahami","poem":2},{"lineBreak":true},{"text":"karena orang benar diambil","poem":1},{"text":"untuk dihindarkan dari kejahatan.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Dia masuk ke dalam kedamaian.","poem":1},{"text":"Orang-orang yang jalannya lurus akan mendapat peristirahatan di tempat tidur mereka.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"“Akan tetapi kamu, mendekatlah kemari,","poem":1},{"text":"hai anak-anak peramal,","poem":2},{"lineBreak":true},{"text":"keturunan pezina dan pelacur.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Siapakah yang kamu ejek?","poem":1},{"text":"Terhadap siapakah kamu membuka mulut dan menjulurkan lidah?","poem":2},{"text":"Bukankah kamu anak-anak pemberontak,","poem":1},{"text":"keturunan pendusta,","poem":2}]},{"type":"verse","number":5,"content":[{"text":"yang terbakar nafsu","poem":1},{"text":"di antara pohon-pohon tarbantin dan di bawah setiap pohon yang rimbun,","poem":2},{"text":"yang menyembelih anak-anakmu di lembah-lembah,","poem":1},{"text":"di bawah celah-celah bukit batu.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Di antara batu-batu licin lembah itulah bagianmu, merekalah bagianmu.","poem":1},{"text":"Bahkan, bagi mereka kamu mencurahkan persembahan minuman,","poem":2},{"text":"kamu telah membawa persembahan makanan.","poem":1},{"text":"Akankah Aku disenangkan dengan semua ini?","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Di atas gunung tinggi dan menjulang, kamu telah menata tempat tidurmu.","poem":1},{"text":"Dan, ke sanalah kamu naik untuk mempersembahkan kurban sembelihan.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Di belakang pintu dan tiang pintu,","poem":1},{"text":"kamu telah memasang berhalamu.","poem":2},{"text":"Untuk meninggalkan Aku,","poem":1},{"text":"kamu membuka tempat tidurmu,","poem":2},{"text":"kamu menaikinya, dan memperluasnya.","poem":1},{"text":"Kamu membuat perjanjian dengan mereka,","poem":2},{"text":"yang tempat tidurnya kamu sukai,","poem":1},{"text":"dan kamu melihat ketelanjangan mereka.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Kamu datang menghadap raja","poem":1},{"text":"dengan membawa minyak dan menambahkan wewangianmu.","poem":2},{"text":"Kamu mengirim utusan-utusan ke tempat yang sangat jauh,","poem":1},{"text":"dan menyuruh mereka sampai ke dunia orang mati.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Kamu lelah karena perjalananmu yang jauh,","poem":1},{"text":"tetapi kamu tidak berkata,","poem":2},{"text":"“Ini sia-sia!”","poem":1},{"text":"Kamu mendapat kekuatan baru dan karena itu, kamu tidak letih.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Terhadap siapakah kamu takut dan khawatir","poem":1},{"text":"sehingga kamu berbohong dan tidak mengingat Aku ataupun memperhatikan Aku?","poem":2},{"text":"Bukankah Aku telah berdiam diri lama sekali","poem":1},{"text":"sehingga kamu tidak takut kepada-Ku?","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Aku akan menyatakan kebenaranmu dan pekerjaan-pekerjaanmu,","poem":1},{"text":"tetapi semuanya itu tidak akan memberikan manfaat bagimu.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"“Jika kamu berseru,","poem":1},{"text":"biarlah berhala-berhalamu melepaskan kamu.","poem":2},{"lineBreak":true},{"text":"Namun, angin akan menerbangkan mereka semua, satu embusan napas akan melenyapkan mereka.","poem":2},{"text":"Akan tetapi, orang yang berlindung kepada-Ku","poem":1},{"text":"akan mewarisi negeri dan akan memiliki gunung-Ku yang kudus.”","poem":2}]},{"type":"heading","content":["TUHAN Akan Menyelamatkan Umat-Nya"]},{"type":"verse","number":14,"content":[{"text":"Ada yang berkata, “Membangunlah, membangunlah, persiapkanlah jalan!","poem":1},{"text":"Singkirkan setiap rintangan dari jalan umat-Ku!","poem":2}]},{"type":"line_break"},{"type":"verse","number":15,"content":[{"text":"Sebab, beginilah firman Dia yang tinggi dan dimuliakan,","poem":1},{"text":"yang mendiami kekekalan,","poem":2},{"lineBreak":true},{"text":"yang nama-Nya adalah Kudus,","poem":2},{"text":"“Aku bersemayam di tempat yang tinggi dan kudus,","poem":1},{"text":"dan juga bersemayam bersama orang yang hancur hati","poem":2},{"lineBreak":true},{"text":"dan rendah hati;","poem":2},{"text":"untuk membangkitkan kembali semangat","poem":1},{"text":"orang yang rendah hati,","poem":2},{"text":"dan untuk membangkitkan kembali","poem":1},{"text":"hati orang yang remuk hatinya.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Sebab, Aku tidak akan menentang untuk selamanya,","poem":1},{"text":"ataupun terus-menerus murka.","poem":2},{"text":"Sebab, semangat itu akan semakin lesu di hadapan-Ku,","poem":1},{"text":"dan juga napas kehidupan yang Aku ciptakan.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Karena kejahatan ketamakannya Aku murka,","poem":1},{"text":"dan memukul dia.","poem":2},{"text":"Aku menyembunyikan wajah-Ku","poem":1},{"text":"dan murka,","poem":2},{"text":"tetapi, mereka tetap berpaling","poem":1},{"text":"ke jalan yang dipilih hatinya.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Aku telah melihat jalan-jalannya,","poem":1},{"text":"tetapi Aku akan menyembuhkannya.","poem":2},{"text":"Aku akan menuntun dia dan memulihkan penghiburan kepadanya,","poem":1},{"text":"dan kepada orang-orangnya yang berkabung,","poem":2}]},{"type":"verse","number":19,"content":[{"text":"untuk menciptakan puji-pujian.","poem":1},{"text":"Damai sejahtera, damai sejahtera bagi mereka yang jauh","poem":2},{"lineBreak":true},{"text":"dan yang dekat,”","poem":2},{"text":"berkatalah TUHAN,","poem":1},{"text":"“dan Aku akan menyembuhkannya.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":20,"content":[{"text":"Akan tetapi, orang fasik akan seperti laut yang berombak,","poem":1},{"text":"yang tidak dapat tenang.","poem":2},{"lineBreak":true},{"text":"Airnya melemparkan lanyau dan lumpur.","poem":2}]},{"type":"verse","number":21,"content":[{"lineBreak":true},{"text":"“Tidak ada damai sejahtera,” kata Allahku, “bagi orang fasik.”","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/ISA/57.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/ISA/58.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/ISA/56.json","previousChapterAudioLinks":{},"numberOfVerses":21}