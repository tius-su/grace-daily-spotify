{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"ISA","translationId":"ind_ayt","name":"YESAYA","commonName":"YESAYA","title":"Yesaya","order":23,"numberOfChapters":66,"sha256":"f891415032abc4205058a3f5640978e2960ef78dd8c37c7f0c7c220e7bbb2d1c","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/ISA/1.json","lastChapterNumber":66,"lastChapterApiLink":"/api/ind_ayt/ISA/66.json","totalNumberOfVerses":1292},"chapter":{"number":60,"content":[{"type":"heading","content":["Allah Akan Datang"]},{"type":"verse","number":1,"content":[{"text":"“Bangkitlah, bersinarlah!","poem":1},{"text":"Sebab, terangmu telah datang!","poem":2},{"text":"dan kemuliaan TUHAN bangkit atasmu.","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Sebab, sesungguhnya, kegelapan akan melingkupi bumi","poem":1},{"text":"dan kegelapan yang pekat melingkupi bangsa-bangsa.","poem":2},{"text":"Akan tetapi, TUHAN akan terbit atasmu","poem":1},{"text":"dan kemuliaan-Nya akan terlihat atasmu.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Bangsa-bangsa akan datang kepada terangmu,","poem":1},{"text":"dan raja-raja kepada cahaya yang terbit padamu.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Angkatlah matamu ke sekeliling dan lihatlah.","poem":1},{"text":"Mereka semua berkumpul bersama dan datang kepadamu.","poem":2},{"text":"Anak-anakmu laki-laki akan datang dari tempat yang jauh,","poem":1},{"text":"dan anak-anakmu perempuan akan digendong.","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"Maka, kamu akan melihat dan menjadi berseri-seri,","poem":1},{"text":"hatimu akan bergetar dan bersukacita","poem":2},{"text":"karena kelimpahan laut akan dialihkan kepadamu,","poem":1},{"text":"dan kekayaan bangsa-bangsa akan datang kepadamu.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Sejumlah besar unta akan menutupi kamu,","poem":1},{"text":"unta-unta muda dari Midian dan Efa.","poem":2},{"text":"Semua yang dari Seba akan datang.","poem":1},{"text":"Mereka akan membawa emas dan kemenyan,","poem":2},{"text":"dan akan memberitakan kemasyhuran TUHAN.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Semua ternak bani Kedar akan dikumpulkan bersama kepadamu.","poem":1},{"text":"Domba-domba jantan Nebayot akan melayanimu;","poem":2},{"text":"domba-domba itu akan naik dalam perkenanan","poem":1},{"text":"ke atas mazbah-Ku.","poem":2},{"text":"Dan, Aku akan memuliakan","poem":1},{"text":"rumah kemuliaan-Ku.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Siapakah mereka ini yang terbang seperti awan,","poem":1},{"text":"dan seperti burung merpati ke pintu kandangnya?","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Sesungguhnya, pulau-pulau akan menantikan Aku,","poem":1},{"text":"dan kapal-kapal Tarsis yang pertama,","poem":2},{"text":"untuk membawa anak-anakmu laki-laki dari jauh,","poem":1},{"text":"perak dan emas mereka ada bersama mereka,","poem":2},{"text":"bagi nama TUHAN, Allahmu, dan bagi Yang Kudus dari Israel","poem":1},{"text":"karena Dia telah memuliakan kamu.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Orang-orang asing akan membangun tembok-tembokmu,","poem":1},{"text":"raja-raja mereka akan melayanimu.","poem":2},{"lineBreak":true},{"text":"Sebab, dalam murka-Ku, Aku telah memukulmu,","poem":1},{"text":"tetapi dalam perkenanan-Ku, Aku telah berbelas kasihan kepadamu.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Pintu-pintu gerbangmu akan selalu terbuka,","poem":1},{"text":"tidak akan ditutup, baik siang ataupun malam,","poem":2},{"text":"sehingga orang dapat masuk membawa kekayaan bangsa-bangsa kepadamu,","poem":1},{"text":"diiringi oleh raja-raja mereka.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Sebab, bangsa dan kerajaan yang tidak melayanimu akan binasa,","poem":1},{"text":"bangsa-bangsa itu akan benar-benar dihancurkan.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Kemuliaan Lebanon akan datang kepadamu,","poem":1},{"text":"juga pohon sanobar, pohon berangan, dan pohon cemara,","poem":2},{"text":"untuk memperindah tempat bait kudus-Ku.","poem":1},{"text":"dan Aku akan membuat tempat pijakan kaki-Ku masyhur.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Anak-anak laki-laki mereka yang menindas kamu akan datang","poem":1},{"text":"dan tunduk kepadamu.","poem":2},{"text":"Semua yang merendahkanmu","poem":1},{"text":"akan sujud di kakimu.","poem":2},{"text":"Mereka akan menyebutmu ‘Kota TUHAN, Sion, milik Yang Kudus Israel.’","poem":1}]},{"type":"line_break"},{"type":"verse","number":15,"content":[{"text":"“Meskipun kamu telah diabaikan dan dibenci,","poem":1},{"text":"dan tidak seorang pun lewat,","poem":2},{"text":"Aku akan menjadikanmu kebanggaan kekal,","poem":1},{"text":"sebuah sukacita dari generasi ke generasi.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Kamu akan mengisap air susu bangsa-bangsa,","poem":1},{"text":"kamu akan meminum susu raja-raja.","poem":2},{"text":"Maka, kamu akan tahu","poem":1},{"text":"bahwa Aku, TUHAN,","poem":2},{"lineBreak":true},{"text":"adalah Juru Selamatmu","poem":2},{"text":"dan Penebusmu,","poem":1},{"text":"Yang Mahakuasa dari Yakub.","poem":2}]},{"type":"line_break"},{"type":"verse","number":17,"content":[{"text":"Sebagai ganti tembaga,","poem":1},{"text":"Aku akan membawa emas.","poem":2},{"text":"Sebagai ganti besi,","poem":1},{"text":"Aku akan membawa perak.","poem":2},{"text":"Sebagai ganti kayu, tembaga.","poem":1},{"lineBreak":true},{"text":"Sebagai ganti batu, besi,","poem":1},{"text":"Aku akan menjadikan kedamaian sebagai pengawasmu","poem":2},{"lineBreak":true},{"text":"dan kebenaran sebagai penjagamu.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Kekerasan tidak akan terdengar lagi di negerimu,","poem":1},{"text":"ataupun kehancuran dan keruntuhan di daerahmu.","poem":2},{"text":"Kamu akan menyebut tembok-tembokmu ‘Keselamatan’","poem":1},{"text":"dan pintu-pintu gerbangmu ‘Pujian.’","poem":2}]},{"type":"line_break"},{"type":"verse","number":19,"content":[{"text":"Matahari tidak akan lagi menjadi terangmu pada siang hari,","poem":1},{"text":"ataupun cahaya bulan memberimu terang pada malam hari.","poem":2},{"text":"TUHAN akan menjadi terangmu yang abadi","poem":1},{"text":"dan Allahmu akan menjadi kemuliaanmu.","poem":2}]},{"type":"verse","number":20,"content":[{"text":"Mataharimu tidak akan terbenam lagi,","poem":1},{"text":"ataupun bulanmu akan lenyap.","poem":2},{"text":"Sebab, TUHAN yang menjadi terangmu yang abadi,","poem":1},{"text":"dan hari-hari perkabunganmu akan diakhiri.","poem":2}]},{"type":"line_break"},{"type":"verse","number":21,"content":[{"text":"Seluruh rakyatmu akan menjadi benar.","poem":1},{"text":"Mereka akan memiliki negeri itu selamanya.","poem":2},{"text":"Mereka adalah tunas yang Kutanam, buatan tangan-Ku,","poem":1},{"text":"untuk menunjukkan kemuliaan-Ku.","poem":2}]},{"type":"verse","number":22,"content":[{"text":"Yang paling sedikit akan menjadi suatu kaum,","poem":1},{"text":"yang paling kecil menjadi bangsa yang kuat.","poem":2},{"text":"Akulah TUHAN,","poem":1},{"text":"yang akan melaksanakannya segera pada waktunya.”","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/ISA/60.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/ISA/61.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/ISA/59.json","previousChapterAudioLinks":{},"numberOfVerses":22}