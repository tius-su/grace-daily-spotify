{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"AMO","translationId":"ind_ayt","name":"AMOS","commonName":"AMOS","title":"Amos","order":30,"numberOfChapters":9,"sha256":"7c1718bece7d0241959ada8bf360aa6caab7f9745fc8fc00c8e9736b5402568d","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/AMO/1.json","lastChapterNumber":9,"lastChapterApiLink":"/api/ind_ayt/AMO/9.json","totalNumberOfVerses":146},"chapter":{"number":9,"content":[{"type":"heading","content":["Penglihatan tentang Perintah TUHAN"]},{"type":"verse","number":1,"content":["Aku melihat Tuhan berdiri di dekat mazbah, dan Dia berfirman,",{"lineBreak":true},{"text":"“Pukullah kepala tiang utama dengan keras","poem":1},{"text":"sehingga serambi depan berguncang,","poem":2},{"text":"runtuhkanlah semuanya itu","poem":1},{"text":"ke atas kepala semua orang,","poem":2},{"text":"dan orang-orang yang tinggal","poem":1},{"text":"akan Kubunuh dengan pedang.","poem":2},{"text":"Tidak satu pun akan melarikan diri,","poem":1},{"text":"tidak satu pun akan terluput.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Sekalipun mereka menggali sampai ke dunia orang mati,","poem":1},{"text":"tangan-Ku akan mengambil mereka dari sana.","poem":2},{"text":"Sekalipun mereka naik sampai ke langit,","poem":1},{"text":"Aku akan menurunkan mereka dari sana.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Sekalipun mereka menyembunyikan diri di puncak Gunung Karmel,","poem":1},{"text":"Aku akan mencari dan mengambil mereka dari sana.","poem":2},{"text":"Sekalipun mereka bersembunyi dari hadapan mata-Ku di dasar laut,","poem":1},{"text":"Aku akan memerintahkan ular untuk memagut mereka di sana.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Sekalipun mereka pergi menjadi tawanan bagi musuh mereka,","poem":1},{"text":"Aku akan memerintahkan pedang yang akan membunuh mereka di sana.","poem":2},{"text":"Aku akan mengarahkan mata-Ku kepada mereka,","poem":1},{"text":"untuk malapetaka","poem":2},{"lineBreak":true},{"text":"dan bukan untuk kebaikan mereka.”","poem":2}]},{"type":"heading","content":["Allah Menolak Bangsa Israel"]},{"type":"verse","number":5,"content":[{"text":"TUHAN, Allah semesta alam, Dia yang menjamah bumi","poem":1},{"text":"dan membuatnya meleleh,","poem":2},{"text":"dan seluruh penduduk yang diam di dalamnya berkabung,","poem":1},{"text":"dan seluruhnya akan pasang seperti sungai,","poem":2},{"text":"dan akan surut seperti sungai Mesir.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Dia yang membangun takhta tinggi-Nya di langit,","poem":1},{"text":"dan membuat dasar-dasar kubah-Nya di atas bumi.","poem":2},{"text":"Dia memanggil air laut","poem":1},{"text":"dan mencurahkannya ke atas permukaan bumi,","poem":2},{"lineBreak":true},{"text":"TUHAN itulah nama-Nya.","poem":2}]},{"type":"heading","content":["Bangsa Pilihan Ditolak Allah"]},{"type":"verse","number":7,"content":["“Bukankah kamu seperti orang-orang Kus bagi-Ku, hai orang-orang Israel?”",{"lineBreak":true},{"text":"kata firman TUHAN.","poem":1},{"text":"“Bukankah Aku yang telah menuntun orang Israel keluar dari tanah Mesir,","poem":2},{"lineBreak":true},{"text":"orang Filistin dari Kaftor,","poem":2},{"lineBreak":true},{"text":"dan orang Aram dari Kir?”","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"“Lihat, mata TUHAN Allah ada atas kerajaan yang berdosa ini:","poem":1},{"lineBreak":true},{"text":"Aku akan memusnahkannya","poem":1},{"lineBreak":true},{"text":"dari muka bumi!","poem":1},{"text":"Akan tetapi, Aku takkan memusnahkan seluruh keturunan Yakub,”","poem":2},{"text":"kata firman TUHAN.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"“Sebab sesungguhnya, Aku akan memerintah","poem":1},{"text":"dan mengguncang-guncangkan kaum Israel dari antara segala bangsa","poem":2},{"text":"seperti orang yang menampi ayakan,","poem":1},{"text":"tetapi tidak ada sebutir gandum kecil pun yang akan jatuh ke tanah.","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"Semua orang berdosa dari umat-Ku","poem":1},{"text":"akan mati oleh pedang,","poem":2},{"text":"yaitu mereka yang berkata","poem":1},{"text":"‘malapetaka tidak akan mengejar atau menghadapi kami.’”","poem":2}]},{"type":"heading","content":["Allah Berjanji Memulihkan Kerajaan"]},{"type":"verse","number":11,"content":[{"text":"“Pada hari itu,","poem":1},{"text":"Aku akan membangkitkan pondok Daud yang sudah roboh.","poem":2},{"text":"dan memperbaiki kerusakannya,","poem":1},{"text":"dan membangun reruntuhannya,","poem":2},{"lineBreak":true},{"text":"Aku akan membangun kembali seperti pada zaman dahulu kala","poem":2}]},{"type":"verse","number":12,"content":[{"text":"supaya mereka mengambil sisa-sisa kepunyaan orang Edom,","poem":1},{"text":"dan semua bangsa yang dipanggil oleh nama-Ku,”","poem":2},{"text":"kata firman TUHAN","poem":1},{"text":"yang melakukan semua ini.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"“Lihat, saatnya akan datang,”","poem":1},{"text":"kata firman TUHAN,","poem":2},{"text":"“ketika pembajak akan digantikan oleh penuai,","poem":1},{"text":"dan yang menanam buah anggur oleh yang menabur benih; gunung-gunung akan meneteskan anggur manis,","poem":2},{"lineBreak":true},{"text":"dan mengalir ke semua bukit.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Aku akan membawa kembali tawanan umat-Ku Israel,","poem":1},{"text":"mereka akan membangun kembali","poem":2},{"text":"kota-kota yang telah hancur","poem":1},{"text":"dan diam di sana.","poem":2},{"text":"Mereka akan menanam kebun-kebun anggur","poem":1},{"text":"dan minum air anggur darinya.","poem":2},{"text":"Mereka akan membuat kebun","poem":1},{"text":"dan makan buah-buahnya.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Aku akan menanam mereka di tanah mereka,","poem":1},{"text":"dan mereka tidak akan lagi dicabut dari tanah yang telah Kuberikan kepada mereka,”","poem":2},{"lineBreak":true},{"text":"kata firman TUHAN, Allahmu.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/AMO/9.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/OBA/1.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/AMO/8.json","previousChapterAudioLinks":{},"numberOfVerses":15}