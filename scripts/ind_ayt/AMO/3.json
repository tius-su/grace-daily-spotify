{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"AMO","translationId":"ind_ayt","name":"AMOS","commonName":"AMOS","title":"Amos","order":30,"numberOfChapters":9,"sha256":"7c1718bece7d0241959ada8bf360aa6caab7f9745fc8fc00c8e9736b5402568d","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/AMO/1.json","lastChapterNumber":9,"lastChapterApiLink":"/api/ind_ayt/AMO/9.json","totalNumberOfVerses":146},"chapter":{"number":3,"content":[{"type":"heading","content":["Peringatan terhadap Israel"]},{"type":"verse","number":1,"content":["Dengarlah firman, yang TUHAN ucapkan mengenai kamu, hai orang Israel, mengenai seluruh kaum keluarga yang telah Aku bawa keluar dari tanah Mesir, firman-Nya:"]},{"type":"verse","number":2,"content":["“Hanya kamu yang Aku kenal dari seluruh kaum keluarga di muka bumi. Sebab itu, Aku akan menghukum kamu atas semua kesalahanmu.”"]},{"type":"verse","number":3,"content":[{"text":"Akankah dua orang berjalan bersama-sama","poem":1},{"text":"kecuali jika mereka sudah setuju?","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Mengaumkah singa di hutan","poem":1},{"text":"bila tidak ada mangsa?","poem":2},{"text":"Berteriakkah singa muda dari liangnya","poem":1},{"text":"bila belum menangkap apa-apa?","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Jatuhkah burung ke dalam perangkap di tanah","poem":1},{"text":"bila tidak ada jerat atasnya?","poem":2},{"text":"Munculkah perangkap dari tanah,","poem":1},{"text":"bila tidak menangkap apa-apa?","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Jika trompet ditiup di kota,","poem":1},{"text":"tidakkah penduduknya gemetar?","poem":2},{"text":"Kalau malapetaka menimpa kota,","poem":1},{"text":"bukankah TUHAN yang melakukannya?","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Sesungguhnya, Tuhan ALLAH tidak melakukan apa-apa","poem":1},{"text":"tanpa menyatakan rencana-Nya kepada para hamba-Nya, nabi-nabi.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Singa telah mengaum,","poem":1},{"text":"siapa yang tidak takut?","poem":2},{"text":"Tuhan ALLAH telah berfirman,","poem":1},{"text":"siapakah yang tidak bernubuat?","poem":2}]},{"type":"heading","content":["Berita Keruntuhan Israel"]},{"type":"verse","number":9,"content":[{"text":"Serukan ke istana-istana di Asdod","poem":1},{"text":"dan ke istana-istana di tanah Mesir, katakan,","poem":2},{"text":"“Berkumpullah di gunung-gunung Samaria.","poem":1},{"text":"Lihatlah kegemparan besar di dalamnya,","poem":2},{"lineBreak":true},{"text":"dan penindasan di tengah-tengahnya.”","poem":2}]},{"type":"verse","number":10,"content":[{"text":"“Mereka tidak tahu bagaimana berbuat benar,”","poem":1},{"text":"demikianlah firman TUHAN,","poem":2},{"lineBreak":true},{"text":"“mereka menimbun kekerasan dan penganiayaan","poem":2},{"lineBreak":true},{"text":"di istana-istana mereka.”","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Oleh sebab itu, inilah firman Tuhan ALLAH,","poem":1},{"text":"“Musuhmu akan berada di sekeliling negeri,","poem":2},{"text":"Ia akan mengambil kekuatan darimu,","poem":1},{"text":"dan istana-istanamu akan dirampas!”","poem":2}]},{"type":"line_break"},{"type":"verse","number":12,"content":["Inilah firman TUHAN:",{"lineBreak":true},{"text":"“Seperti seorang gembala","poem":1},{"text":"mengambil dari mulut singa","poem":2},{"text":"dua tulang betis atau sepotong telinga,","poem":1},{"text":"demikian juga orang Israel yang tinggal di Samaria","poem":2},{"text":"akan diambil keluar di sudut tempat tidurnya,","poem":1},{"text":"dan ujung kursinya.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":13,"content":["“Dengarlah dan jadilah saksi untuk melawan keturunan Yakub,”",{"text":"firman Tuhan Allah, Allah semesta alam.","poem":2}]},{"type":"line_break"},{"type":"verse","number":14,"content":[{"text":"“Pada hari Aku menghukum Israel","poem":1},{"text":"karena pelanggaran-pelanggaran mereka,","poem":2},{"text":"Aku juga akan menghukum mazbah-mazbah di Betel","poem":1},{"text":"dan tanduk-tanduk mazbah akan dipatahkan dan jatuh ke tanah.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Aku akan meruntuhkan rumah musim dingin","poem":1},{"text":"bersama-sama dengan rumah musim panas,","poem":2},{"text":"rumah-rumah gading akan binasa","poem":1},{"text":"dan rumah-rumah besar akan dihancurkan,”","poem":2},{"lineBreak":true},{"text":"firman TUHAN.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/AMO/3.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/AMO/4.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/AMO/2.json","previousChapterAudioLinks":{},"numberOfVerses":15}