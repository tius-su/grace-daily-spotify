{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"AMO","translationId":"ind_ayt","name":"AMOS","commonName":"AMOS","title":"Amos","order":30,"numberOfChapters":9,"sha256":"7c1718bece7d0241959ada8bf360aa6caab7f9745fc8fc00c8e9736b5402568d","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/AMO/1.json","lastChapterNumber":9,"lastChapterApiLink":"/api/ind_ayt/AMO/9.json","totalNumberOfVerses":146},"chapter":{"number":2,"content":[{"type":"verse","number":1,"content":["Inilah firman TUHAN:",{"lineBreak":true},{"text":"“Untuk tiga pelanggaran Moab, bahkan empat,","poem":1},{"text":"Aku takkan menarik kembali hukumannya.","poem":2},{"text":"Sebab, ia telah membakar tulang-tulang Raja Edom","poem":1},{"text":"menjadi kapur.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Aku akan mengirimkan api ke atas Moab,","poem":1},{"text":"yang akan melahap istana-istana Keriot.","poem":2},{"text":"Moab akan mati dengan keributan,","poem":1},{"text":"diiringi sorak-sorai dan suara trompet.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Aku akan melenyapkan hakim dari tengah-tengah mereka","poem":1},{"text":"dan membunuh semua pemimpin yang bersama-sama dengannya,”","poem":2},{"lineBreak":true},{"text":"firman TUHAN.","poem":2}]},{"type":"heading","content":["Hukuman bagi Yehuda"]},{"type":"verse","number":4,"content":["Inilah firman TUHAN,",{"lineBreak":true},{"text":"“Untuk tiga pelanggaran Yehuda, bahkan empat,","poem":1},{"text":"Aku takkan menarik kembali hukumannya.","poem":2},{"text":"Sebab, mereka menghina hukum Taurat TUHAN,","poem":1},{"text":"dan tidak berpegang pada ketetapan-ketetapan-Nya,","poem":2},{"text":"dan kebohongan-kebohongan mereka membuat mereka tersesat,","poem":1},{"text":"kebohongan yang mereka ikuti dari nenek moyang mereka.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Aku akan mengirimkan api ke atas Yehuda,","poem":1},{"text":"yang akan melahap istana-istana Yerusalem.”","poem":2}]},{"type":"heading","content":["Hukuman bagi Israel"]},{"type":"verse","number":6,"content":["Inilah firman TUHAN,",{"lineBreak":true},{"text":"“Untuk tiga pelanggaran Israel, bahkan empat,","poem":1},{"text":"Aku takkan menarik kembali hukumannya.","poem":2},{"text":"Sebab, mereka menjual orang benar demi perak","poem":1},{"text":"dan orang miskin demi sepasang sandal.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Mereka yang menginjak-injak kepala orang miskin atas debu tanah,","poem":1},{"text":"dan membelokkan jalan orang-orang yang tertindas.","poem":2},{"text":"Anak dan ayah pergi kepada perempuan yang sama,","poem":1},{"text":"sehingga mencemari nama-Ku yang kudus.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Mereka membaringkan diri di samping setiap mazbah","poem":1},{"text":"dia atas pakaian yang diambil dari tempat orang-orang miskin menggadaikan pakaiannya","poem":2},{"text":"dan minum anggur orang-orang hukuman","poem":1},{"text":"di rumah ilah mereka.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Akulah yang membinasakan orang Amori di hadapan mereka,","poem":1},{"text":"yang tingginya seperti tinggi pohon Aras dan kuatnya seperti pohon Tarbantin.","poem":2},{"text":"Namun, Aku telah membinasakan buah yang di atas","poem":1},{"text":"dan akar-akar yang di bawah.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Juga, Akulah yang membawa kamu keluar dari tanah Mesir","poem":1},{"text":"dan memimpin kamu melalui padang gurun empat puluh tahun lamanya,","poem":2},{"lineBreak":true},{"text":"untuk menduduki tanah orang Amori;","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Akulah yang mengangkat beberapa anak-anakmu menjadi nabi,","poem":1},{"text":"dan beberapa pemuda-pemudamu menjadi nazir-nazir.","poem":2},{"text":"Bukankah begitu, hai orang Israel?”","poem":1},{"text":"firman TUHAN.","poem":2}]},{"type":"line_break"},{"type":"verse","number":12,"content":[{"text":"“Akan tetapi, kamu membuat orang-orang nazir minum anggur,","poem":1},{"text":"dan memerintahkan kepada para nabi,","poem":2},{"lineBreak":true},{"text":"“Jangan bernubuat!”","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Lihatlah, Aku akan menekan kamu di tempatmu,","poem":1},{"text":"seperti kereta yang penuh dibebani dengan timbunan berkas gandum.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Orang gesit takkan dapat luput,","poem":1},{"text":"orang kuat takkan dapat menguatkan kekuatannya,","poem":2},{"lineBreak":true},{"text":"Juga, pahlawan takkan meloloskan dirinya.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Pemanah takkan dapat bertahan,","poem":1},{"text":"pelari cepat takkan dapat luput,","poem":2},{"lineBreak":true},{"text":"dan penunggang kuda tidak dapat meloloskan dirinya.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Bahkan, pahlawan yang paling berani akan melarikan diri","poem":1},{"text":"dengan telanjang pada hari itu,”","poem":2},{"lineBreak":true},{"text":"kata firman TUHAN.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/AMO/2.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/AMO/3.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/AMO/1.json","previousChapterAudioLinks":{},"numberOfVerses":16}