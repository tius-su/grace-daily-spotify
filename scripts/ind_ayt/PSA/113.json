{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":113,"content":[{"type":"heading","content":["Siapakah yang Seperti TUHAN, Allah Kita?"]},{"type":"verse","number":1,"content":[{"text":"Haleluya!","poem":1},{"lineBreak":true},{"text":"Pujilah, hai hamba-hamba TUHAN!","poem":1},{"text":"Pujilah nama TUHAN!","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Nama TUHAN dipuji,","poem":1},{"text":"dari sekarang ini sampai selamanya.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Dari tempat matahari terbit sampai terbenamnya,","poem":1},{"text":"nama TUHAN dipuji-puji.","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"TUHAN itu tinggi mengatasi segala bangsa,","poem":1},{"text":"kemuliaan-Nya mengatasi langit.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Siapa seperti TUHAN, Allah kita,","poem":1},{"text":"yang bertakhta di tempat tinggi,","poem":2}]},{"type":"verse","number":6,"content":[{"text":"yang merendah,","poem":1},{"text":"untuk melihat ke langit dan bumi?","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Dia membangkitkan orang miskin dari debu,","poem":1},{"text":"dan mengangkat orang melarat dari tumpukan sampah,","poem":2}]},{"type":"verse","number":8,"content":[{"text":"untuk mendudukkan mereka bersama para penguasa,","poem":1},{"text":"bersama para penguasa umat-Nya.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Dia menjadikan perempuan mandul di dalam rumah,","poem":1},{"text":"sebagai ibu dari anak-anak, yang berbahagia.","poem":2},{"lineBreak":true},{"text":"Haleluya!","poem":1}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/113.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/114.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/112.json","previousChapterAudioLinks":{},"numberOfVerses":9}