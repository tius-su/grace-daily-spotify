{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":116,"content":[{"type":"heading","content":["Selamat dari Kematian"]},{"type":"verse","number":1,"content":[{"text":"Aku mengasihi TUHAN karena Dia mendengar","poem":1},{"text":"suaraku, permohonanku.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Sebab, Dia menyendengkan telinga-Nya kepadaku,","poem":1},{"text":"maka aku akan berseru kepada-Nya pada hari-hariku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Tali-tali maut telah membelitku,","poem":1},{"text":"dan kengerian dunia orang mati menimpaku;","poem":2},{"lineBreak":true},{"text":"aku ditimpa kesesakan dan kedukaan.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Lalu, aku berseru kepada nama TUHAN:","poem":1},{"text":"“Ya TUHAN, aku berdoa, lepaskanlah jiwaku!”","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"TUHAN itu murah hati dan adil,","poem":1},{"text":"Allah kita itu berbelaskasihan.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"TUHAN melindungi yang sederhana;","poem":1},{"text":"aku lemah, dan Dia menyelamatkan aku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Hai jiwaku, kembalilah beristirahat,","poem":1},{"text":"karena TUHAN telah membalasmu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"Sebab, Engkau telah melepaskan jiwaku dari maut,","poem":1},{"text":"mataku dari air mata,","poem":2},{"lineBreak":true},{"text":"kakiku dari sandungan.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Aku akan berjalan di hadapan TUHAN,","poem":1},{"text":"di negeri orang-orang hidup.","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"Aku percaya, walaupun pada saat aku berkata,","poem":1},{"text":"“Aku sangat menderita.”","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Aku berkata dalam ketergesaanku,","poem":1},{"text":"“Semua orang adalah pembohong.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":12,"content":[{"text":"Bagaimana aku harus membalas kepada TUHAN","poem":1},{"text":"atas semua kebaikan-Nya padaku?","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Aku akan mengangkat piala keselamatan,","poem":1},{"text":"dan menyerukan nama TUHAN.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Aku akan membayar nazarku kepada TUHAN,","poem":1},{"text":"di hadapan semua umat-Nya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":15,"content":[{"text":"Berharga dalam pandangan TUHAN,","poem":1},{"text":"kematian orang-orang kudus-Nya.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Ya TUHAN, aku ini hamba-Mu.","poem":1},{"text":"Aku ini anak hamba-Mu, anak hamba perempuan-Mu.","poem":2},{"lineBreak":true},{"text":"Engkau telah melepaskan belenggu-belengguku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":17,"content":[{"text":"Aku akan mempersembahkan kurban syukur kepada-Mu,","poem":1},{"text":"dan menyerukan nama TUHAN.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Aku akan membayar nazarku kepada TUHAN,","poem":1},{"text":"di hadapan seluruh umat-Nya,","poem":2}]},{"type":"verse","number":19,"content":[{"text":"di pelataran rumah TUHAN,","poem":1},{"text":"di tengah-tengahmu, hai Yerusalem.","poem":2},{"lineBreak":true},{"text":"Haleluya!","poem":1}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/116.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/117.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/115.json","previousChapterAudioLinks":{},"numberOfVerses":19}