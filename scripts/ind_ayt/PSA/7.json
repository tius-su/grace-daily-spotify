{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":7,"content":[{"type":"verse","number":1,"content":[{"text":"Syigayon Daud yang dinyanyikannya kepada TUHAN karena Kush, suku Benyamin.","descriptive":true},{"lineBreak":true},{"text":"(7-2) Ya TUHAN, Allahku,","poem":1},{"text":"di dalam Engkau, aku berlindung.","poem":2},{"text":"Selamatkan aku dari semua orang yang mengejarku,","poem":1},{"text":"dan bebaskan aku;","poem":2}]},{"type":"verse","number":2,"content":[{"text":"(7-3) supaya mereka jangan menerkam jiwaku","poem":1},{"text":"layaknya seekor singa,","poem":2},{"text":"mencabik-cabiknya,","poem":1},{"text":"dan tidak ada seorang pun yang dapat melepaskan aku.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"(7-4) Ya TUHAN, Allahku, jika aku telah melakukan ini,","poem":1},{"text":"jika ada ketidakadilan pada tanganku,","poem":2}]},{"type":"verse","number":4,"content":[{"text":"(7-5) jika aku sudah membalaskan yang jahat kepada dia yang berdamai denganku,","poem":1},{"text":"atau merampasinya, yang tanpa alasan menjadi musuhku,","poem":2}]},{"type":"verse","number":5,"content":[{"text":"(7-6) biarlah musuh mengejar jiwaku dan meraihnya;","poem":1},{"text":"biarlah dia menginjak-injak hidupku sampai ke tanah,","poem":2},{"text":"dan meletakkan kemuliaanku di dalam debu. Sela","poem":1}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"(7-7) Bangkitlah, ya TUHAN, dalam amarah-Mu!","poem":1},{"text":"Berdirilah melawan amukan musuh-musuhku.","poem":2},{"lineBreak":true},{"text":"Dan, bangkitlah bagi aku.","poem":2},{"lineBreak":true},{"text":"Engkau telah memerintahkan keadilan bagi mereka.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"(7-8) Biarlah kumpulan bangsa mengelilingi-Mu,","poem":1},{"text":"dan kembali ke atas mereka di tempat yang tinggi.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"(7-9) TUHAN mengadili bangsa-bangsa.","poem":1},{"text":"Hakimi aku, ya TUHAN,","poem":2},{"text":"menurut kebenaranku,","poem":1},{"text":"dan menurut ketulusanku.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"(7-10) Kiranya, kejahatan orang fasik berakhir,","poem":1},{"text":"tetapi orang benar ditegakkan.","poem":2},{"text":"Sebab, Allah yang adil,","poem":1},{"text":"yang menguji hati dan batin.","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"(7-11) Perisaiku adalah Allah,","poem":1},{"text":"yang menyelamatkan orang yang lurus dalam hati.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"(7-12) Allah adalah Hakim yang adil;","poem":1},{"text":"Allah merasa marah sepanjang hari.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"(7-13) Jika seseorang tidak berbalik,","poem":1},{"text":"Dia akan menajamkan pedang-Nya.","poem":2},{"text":"Dia telah melenturkan busur-Nya dan membuatnya siap.","poem":1}]},{"type":"verse","number":13,"content":[{"lineBreak":true},{"text":"(7-14) Dia telah mempersiapkan bagi diri-Nya senjata-senjata mematikan;","poem":1},{"text":"Dia telah membuat panah-Nya berkobar.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"(7-15) Sesungguhnya, orang yang hamil kefasikan,","poem":1},{"text":"dia mengandung kesusahan,","poem":2},{"lineBreak":true},{"text":"dan melahirkan dusta.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"(7-16) Dia membuat sebuah lubang dan menggalinya,","poem":1},{"text":"lalu jatuh ke dalam lubang yang telah dibuatnya.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"(7-17) Kejahatannya akan kembali ke kepalanya,","poem":1},{"text":"kekejamannya akan turun ke atas tempurung kepalanya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":17,"content":[{"text":"(7-18) Aku akan bersyukur kepada TUHAN karena kebenaran-Nya,","poem":1},{"text":"dan akan bermazmur bagi nama TUHAN Yang Mahatinggi.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/7.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/8.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/6.json","previousChapterAudioLinks":{},"numberOfVerses":17}