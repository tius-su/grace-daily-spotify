{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":120,"content":[{"type":"heading","content":["Doa Melawan Lidah Penipu"]},{"type":"verse","number":1,"content":[{"text":"Nyanyian Ziarah.","descriptive":true},{"lineBreak":true},{"text":"Dalam kesesakanku, aku berseru kepada TUHAN,","poem":1},{"text":"dan Dia menjawab aku.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"“Lepaskan aku, ya TUHAN, dari bibir pendusta,","poem":1},{"text":"dari lidah pengkhianat.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Apa yang akan diberikan bagimu,","poem":1},{"text":"dan apa yang akan ditambahkan bagimu, hai kamu lidah penipu?","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Anak-anak panah tajam milik seorang pahlawan,","poem":1},{"text":"dengan bara api kayu arar.","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"Celakalah aku karena aku orang yang tinggal sementara di Mesekh,","poem":1},{"text":"aku tinggal di antara tenda-tenda Kedar!","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Sudah lama aku tinggal di antara orang-orang yang membenci kedamaian.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Aku suka kedamaian, tetapi saat aku berbicara,","poem":1},{"text":"mereka berperang.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/120.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/121.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/119.json","previousChapterAudioLinks":{},"numberOfVerses":7}