{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":56,"content":[{"type":"heading","content":["Percaya kepada TUHAN"]},{"type":"verse","number":1,"content":[{"text":"Kepada pemimpin pujian: Dengan nada “Merpati bisu di tempat-tempat yang jauh.” Miktam Daud ketika orang Filistin menangkapnya di Gat.","descriptive":true},{"lineBreak":true},{"text":"(56-2) Kasihanilah aku, ya Allah, karena orang-orang menginjak-injakku;","poem":1},{"text":"sepanjang hari, mereka memerangi dan menindas.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"(56-3) Musuh-musuhku menginjak-injakku sepanjang hari,","poem":1},{"text":"dan banyak orang menyerangku dengan sombong.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"(56-4) Saat aku takut,","poem":1},{"text":"aku percaya kepada-Mu.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"(56-5) Dalam Allah yang firman-Nya kupuji;","poem":1},{"text":"Dalam Allah yang kupercaya; aku takkan ketakutan.","poem":2},{"lineBreak":true},{"text":"Apa yang bisa diperbuat manusia?","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"(56-6) Sepanjang hari, mereka memutarbalikkan ketetapanku;","poem":1},{"text":"segala pikirannya adalah untuk menjahatiku.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"(56-7) Mereka berhimpun dan bersembunyi,","poem":1},{"text":"mengawasi langkah-langkahku","poem":2},{"lineBreak":true},{"text":"seakan-akan mengharapkan nyawaku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"(56-8) Selamatkah mereka dari kefasikan?","poem":1},{"text":"Dalam kemarahan-Mu, runtuhkanlah bangsa-bangsa, ya Allah!","poem":2}]},{"type":"verse","number":8,"content":[{"text":"(56-9) Engkau telah menghitung sengsara-sengsaraku.","poem":1},{"text":"Taruhlah air mataku di dalam kantong-kantong kulit-Mu.","poem":2},{"lineBreak":true},{"text":"Bukankah itu ada di dalam kitab-Mu?","poem":2}]},{"type":"line_break"},{"type":"verse","number":9,"content":[{"text":"(56-10) Dengan demikian, musuh-musuhku akan berbalik mundur","poem":1},{"text":"pada hari aku berseru.","poem":2},{"lineBreak":true},{"text":"Ini yang aku tahu bahwa Allah besertaku!","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"(56-11) Dalam Allah yang firman-Nya kupuji;","poem":1},{"text":"Dalam TUHAN yang firman-Nya kupuji.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"(56-12) Allah yang kupercaya; aku takkan ketakutan.","poem":1},{"text":"Apa yang bisa diperbuat manusia?","poem":2}]},{"type":"line_break"},{"type":"verse","number":12,"content":[{"text":"(56-13) Perjanjian-Mu, ya Allah, ada padaku;","poem":1},{"text":"akan kubalas dengan ucapan syukur.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"(56-14) Sebab, Engkau telah menyelamatkan jiwaku dari maut;","poem":1},{"text":"kakiku pun tidak tersandung,","poem":2},{"text":"sehingga aku dapat berjalan di hadapan Allah","poem":1},{"text":"dalam terang kehidupan.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/56.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/57.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/55.json","previousChapterAudioLinks":{},"numberOfVerses":13}