{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":123,"content":[{"type":"heading","content":["Ketergantungan pada TUHAN"]},{"type":"verse","number":1,"content":[{"text":"Nyanyian Ziarah.","descriptive":true},{"lineBreak":true},{"text":"Aku mengangkat mataku kepada-Mu,","poem":1},{"text":"ya Engkau yang bertakhta di surga.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Lihat, seperti mata para pelayan laki-laki","poem":1},{"text":"memandang tangan tuannya,","poem":2},{"lineBreak":true},{"text":"seperti mata para pelayan perempuan","poem":2},{"lineBreak":true},{"text":"memandang tangan nyonyanya,","poem":2},{"text":"begitu juga mata kita memandang kepada TUHAN, Allah kita,","poem":1},{"text":"hingga Dia berbelaskasihan kepada kita.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Kasihani kami, ya TUHAN, kasihani kami.","poem":1},{"text":"Sebab, kami sudah kenyang dengan hinaan.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Jiwa kami sudah kenyang dengan ejekan orang-orang congkak,","poem":1},{"text":"dengan hinaan orang-orang sombong.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/123.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/124.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/122.json","previousChapterAudioLinks":{},"numberOfVerses":4}