{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":126,"content":[{"type":"heading","content":["Mazmur Kebebasan"]},{"type":"verse","number":1,"content":[{"text":"Nyanyian Ziarah.","descriptive":true},{"lineBreak":true},{"text":"Ketika TUHAN mengembalikan keadaan Sion,","poem":1},{"text":"kita menjadi orang-orang yang bermimpi.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Kemudian, mulut kita penuh dengan tawa, dan lidah kita dengan sorak-sorai,","poem":1},{"text":"lalu mereka berbicara di antara bangsa-bangsa,","poem":2},{"lineBreak":true},{"text":"“TUHAN telah melakukan hal-hal besar bersama dengan mereka ini!”","poem":2}]},{"type":"verse","number":3,"content":[{"text":"TUHAN telah melakukan hal-hal besar bagi kita;","poem":1},{"text":"kita bersukacita.","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"Kembalikan keadaan kami, ya TUHAN,","poem":1},{"text":"seperti alur-alur sungai di selatan.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Orang-orang yang menabur dengan air mata,","poem":1},{"text":"akan menuai dengan sorak-sorai.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Orang yang pergi dengan menangis sambil membawa kantong benih,","poem":1},{"text":"akan kembali dengan sorak-sorai sambil membawa berkas-berkasnya.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/126.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/127.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/125.json","previousChapterAudioLinks":{},"numberOfVerses":6}