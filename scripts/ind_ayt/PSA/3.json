{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":3,"content":[{"type":"heading","content":["Percaya Meski Terancam"]},{"type":"verse","number":1,"content":[{"text":"Nyanyian Daud yang ditulis ketika dia melarikan diri dari Absalom, anaknya.","descriptive":true},{"lineBreak":true},{"text":"(3-2) O TUHAN, betapa banyaknya musuhku;","poem":1},{"text":"banyak orang yang bangkit melawan aku.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"(3-3) Banyak yang berkata kepada diriku,","poem":1},{"text":"“Tidak ada pertolongan dalam Allah untuknya!” Sela","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"(3-4) Namun Engkau, TUHAN, adalah perisai yang melindungiku;","poem":1},{"text":"Engkau adalah kemuliaanku,","poem":2},{"lineBreak":true},{"text":"dan yang mengangkat kepalaku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"(3-5) Aku memanggil TUHAN dengan suaraku,","poem":1},{"text":"dan Dia menjawab aku dari gunung-Nya yang kudus. Sela","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"(3-6) Aku berbaring dan tidur;","poem":1},{"text":"aku bangun karena TUHAN sandaranku.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"(3-7) Aku tidak takut terhadap beribu-ribu orang","poem":1},{"text":"yang bersiap di sekelilingku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"(3-8) Bangkitlah, ya TUHAN!","poem":1},{"text":"Selamatkan aku, ya Allah!","poem":2},{"text":"Sebab, Engkau telah memukul semua rahang musuhku,","poem":1},{"text":"dan Engkau telah meremukkan gigi orang fasik.","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"(3-9) Keselamatan adalah milik TUHAN!","poem":1},{"text":"Berkat-Mu ada pada umat-Mu. Sela","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/3.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/4.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/2.json","previousChapterAudioLinks":{},"numberOfVerses":8}