{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":143,"content":[{"type":"heading","content":["Doa untuk Belas Kasihan dalam Penganiayaan"]},{"type":"verse","number":1,"content":[{"text":"Mazmur Daud.","descriptive":true},{"lineBreak":true},{"text":"Dengar doaku, ya TUHAN,","poem":1},{"text":"berilah telinga kepada permohonanku!","poem":2},{"lineBreak":true},{"text":"Jawab aku dalam kesetiaan-Mu, dalam keadilan-Mu!","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Jangan masuk ke dalam pengadilan bersama hamba-Mu ini","poem":1},{"text":"karena tidak ada seorang pun yang hidup","poem":2},{"lineBreak":true},{"text":"benar di hadapan-Mu.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Sebab, musuh telah mengejar jiwaku,","poem":1},{"text":"menghancurkannya sampai ke tanah;","poem":2},{"text":"mereka telah membuatku duduk dalam kegelapan,","poem":1},{"text":"seperti orang-orang yang sudah lama mati.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Karena itu, semangatku undur dariku,","poem":1},{"text":"hatiku terkejut dalamku.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Aku ingat akan hari-hari yang lalu,","poem":1},{"text":"aku merenungkan semua perbuatan-Mu,","poem":2},{"lineBreak":true},{"text":"aku memikir-mikirkan pekerjaan tangan-Mu.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Aku menadahkan tanganku kepada-Mu,","poem":1},{"text":"jiwaku haus kepada-Mu","poem":2},{"lineBreak":true},{"text":"seperti tanah gersang. Sela","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Jawab aku secepatnya, ya TUHAN!","poem":1},{"text":"Semangatku habis.","poem":2},{"text":"Jangan sembunyikan wajah-Mu dariku,","poem":1},{"text":"atau aku menjadi seperti mereka yang turun ke lubang kubur.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Biarlah aku mendengarkan kasih setia-Mu pada waktu pagi,","poem":1},{"text":"karena kepada-Mu aku percaya.","poem":2},{"text":"Beritahukan aku jalan yang harus kutempuh,","poem":1},{"text":"karena kepada-Mu aku mengangkat jiwaku.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Lepaskan aku dari musuh-musuhku, ya TUHAN,","poem":1},{"text":"pada-Mu aku bersembunyi.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Ajari aku untuk melakukan kehendak-Mu,","poem":1},{"text":"karena Engkau adalah Allahku.","poem":2},{"text":"Biarlah Roh-Mu yang baik,","poem":1},{"text":"memimpinku di atas permukaan tanah.","poem":2}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"Oleh karena nama-Mu, ya TUHAN, hidupkan aku!","poem":1},{"text":"Dalam kebenaran-Mu, bawa jiwaku keluar dari kesusahan!","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Dan, dalam kasih setia-Mu,","poem":1},{"text":"tumpaslah musuh-musuhku,","poem":2},{"text":"dan musnahkan semua penekan jiwaku,","poem":1},{"text":"karena aku ini hamba-Mu.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/143.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/144.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/142.json","previousChapterAudioLinks":{},"numberOfVerses":12}