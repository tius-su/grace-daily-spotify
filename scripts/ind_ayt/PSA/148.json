{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":148,"content":[{"type":"heading","content":["Segala Pujian dari Semua Penciptaan"]},{"type":"verse","number":1,"content":[{"text":"Haleluya!","poem":1},{"lineBreak":true},{"text":"Pujilah TUHAN dari surga,","poem":1},{"text":"pujilah Dia di tempat tinggi!","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Pujilah Dia, semua malaikat-Nya,","poem":1},{"text":"Pujilah Dia, semua bala tentara-Nya!","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Pujilah Dia, matahari dan bulan,","poem":1},{"text":"pujilah Dia, semua bintang yang bersinar!","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Pujilah Dia, langit yang tertinggi,","poem":1},{"text":"dan air di atas langit!","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Biarlah mereka memuji nama TUHAN,","poem":1},{"text":"karena Dia memerintahkan,","poem":2},{"lineBreak":true},{"text":"dan mereka tercipta.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Dia telah menegakkan mereka untuk selama-lamanya,","poem":1},{"text":"Dia memberi ketetapan yang takkan dilanggar.","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Pujilah TUHAN dari bumi,","poem":1},{"text":"kamu makhluk-makhluk laut dan seluruh samudra!","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Api dan hujan es, salju dan kabut,","poem":1},{"text":"angin badai melakukan firman-Nya!","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Pegunungan dan segala bukit,","poem":1},{"text":"pohon-pohon berbuah dan semua pohon aras!","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Binatang-binatang liar dan segala ternak,","poem":1},{"text":"binatang-binatang melata dan burung-burung bersayap!","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Raja-raja bumi dan semua suku bangsa,","poem":1},{"text":"para penguasa dan semua pemimpin dunia!","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Pemuda-pemuda dan anak-anak dara,","poem":1},{"text":"orang-orang tua dan anak-anak!","poem":2}]},{"type":"line_break"},{"type":"verse","number":13,"content":[{"text":"Biarlah mereka memuji nama TUHAN,","poem":1},{"text":"karena hanya nama-Nya yang ditinggikan,","poem":2},{"lineBreak":true},{"text":"kemuliaan-Nya mengatasi bumi dan langit.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Dia telah meninggikan tanduk umat-Nya,","poem":1},{"text":"puji-pujian bagi semua orang kudus-Nya,","poem":2},{"lineBreak":true},{"text":"bagi orang Israel yang ada di dekat-Nya.","poem":2},{"lineBreak":true},{"text":"Haleluya!","poem":1}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/148.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/149.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/147.json","previousChapterAudioLinks":{},"numberOfVerses":14}