{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":127,"content":[{"type":"heading","content":["Keselamatan dalam TUHAN"]},{"type":"verse","number":1,"content":[{"text":"Nyanyian Ziarah Salomo.","descriptive":true},{"lineBreak":true},{"text":"Seandainya bukan TUHAN yang membangun rumah,","poem":1},{"text":"orang-orang yang membangunnya bekerja keras dalam kesia-siaan.","poem":2},{"text":"Seandainya bukan TUHAN yang mengawasi kota,","poem":1},{"text":"para pengawal berjaga-jaga dalam kesia-siaan.","poem":2}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"Sia-sia kamu bangun pagi-pagi dan tinggal duduk malam-malam,","poem":1},{"text":"memakan roti kerja kerasmu,","poem":2},{"lineBreak":true},{"text":"ya, karena Dia mengaruniakan bagi yang dikasihi-Nya saat tidurnya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Lihat, anak laki-laki adalah warisan dari TUHAN,","poem":1},{"text":"buah kandungan adalah suatu upah.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Seperti anak-anak panah di tangan seorang pahlawan,","poem":1},{"text":"begitu juga anak-anak pada masa mudanya.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Diberkatilah orang yang telah memenuhi tabung panahnya,","poem":1},{"text":"dia takkan malu ketika berbicara dengan musuh-musuhnya di pintu gerbang.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/127.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/128.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/126.json","previousChapterAudioLinks":{},"numberOfVerses":5}