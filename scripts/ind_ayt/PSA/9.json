{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":9,"content":[{"type":"heading","content":["Pujian untuk Penghakiman yang Benar"]},{"type":"verse","number":1,"content":[{"text":"Kepada pemimpin pujian: Dengan memakai Mut-Laben. Nyanyian Daud.","descriptive":true},{"lineBreak":true},{"text":"(9-2) Aku akan bersyukur kepada TUHAN, dengan segenap hatiku;","poem":1},{"text":"aku akan menceritakan semua perbuatan-Mu","poem":2},{"lineBreak":true},{"text":"yang ajaib.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"(9-3) Aku akan bergembira dan bersukacita di dalam Engkau;","poem":1},{"text":"aku akan menyanyikan pujian bagi nama-Mu, ya Yang Mahatinggi.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"(9-4) Ketika musuh-musuhku mundur,","poem":1},{"text":"mereka tersandung dan binasa di hadapan-Mu.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"(9-5) Sebab, Engkau telah membela keadilan bagi perkaraku;","poem":1},{"text":"Engkau telah duduk di takhta-Mu dan menghakimi dengan benar.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"(9-6) Engkau telah menegur bangsa-bangsa;","poem":1},{"text":"Engkau telah membinasakan orang fasik.","poem":2},{"text":"Engkau telah menghapuskan nama mereka","poem":1},{"text":"untuk selama-lamanya.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"(9-7) Musuh telah habis dalam reruntuhan selama-selamanya;","poem":1},{"text":"Engkau telah mencabut kota-kota mereka;","poem":2},{"lineBreak":true},{"text":"ingatan akan mereka pun lenyap.","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"(9-8) Namun, TUHAN bersemayam selama-lamanya;","poem":1},{"text":"Dia telah mendirikan takhta-Nya untuk penghakiman.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"(9-9) Lalu, Dia akan menghakimi dunia dengan keadilan;","poem":1},{"text":"Dia mengadili bangsa-bangsa dengan kebenaran.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"(9-10) TUHAN adalah tempat perlindungan yang tinggi bagi yang tertindas;","poem":1},{"text":"tempat perlindungan pada waktu kesusahan.","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"(9-11) Kemudian, mereka yang mengenal nama-Mu,","poem":1},{"text":"akan menaruh percayanya kepada-Mu.","poem":2},{"text":"Sebab, Engkau, ya TUHAN,","poem":1},{"text":"tidak pernah meninggalkan mereka yang mencari Engkau.","poem":2}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"(9-12) Nyanyikanlah pujian bagi TUHAN, yang duduk di Sion!","poem":1},{"text":"Beritahukan di antara bangsa-bangsa perbuatan-perbuatan-Nya.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"(9-13) Sebab, Dia yang membalas penumpahan darah,","poem":1},{"text":"mengingat mereka.","poem":2},{"text":"Dia tidak melupakan jeritan orang-orang yang tertindas.","poem":1}]},{"type":"line_break"},{"type":"verse","number":13,"content":[{"text":"(9-14) Kasihani aku, ya TUHAN;","poem":1},{"text":"lihatlah penderitaanku karena mereka yang membenci aku.","poem":2},{"text":"Engkau yang mengangkat aku dari pintu gerbang kematian","poem":1}]},{"type":"verse","number":14,"content":[{"lineBreak":true},{"text":"(9-15) supaya aku dapat menceritakan segala kemuliaan-Mu","poem":1},{"text":"di pintu gerbang putri Sion;","poem":2},{"text":"aku akan bersukacita","poem":1},{"text":"dalam keselamatan-Mu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":15,"content":[{"text":"(9-16) Bangsa-bangsa telah terperosok di pelubang yang mereka buat;","poem":1},{"text":"Kaki mereka terjerat","poem":2},{"lineBreak":true},{"text":"ke dalam jaring yang sudah mereka sembunyikan.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"(9-17) TUHAN telah membuat diri-Nya dikenal, Dia telah mengadakan penghakiman;","poem":1},{"text":"Orang fasik terjerat","poem":2},{"lineBreak":true},{"text":"dalam perbuatan tangannya sendiri. Higayon Sela","poem":2}]},{"type":"line_break"},{"type":"verse","number":17,"content":[{"text":"(9-18) Orang yang fasik akan kembali ke dunia orang mati,","poem":1},{"text":"bahkan bangsa-bangsa yang melupakan Allah.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"(9-19) Sebab, orang yang melarat","poem":1},{"text":"tidak untuk seterusnya dilupakan,","poem":2},{"text":"dan pengharapan orang yang miskin","poem":1},{"text":"takkan lenyap.","poem":2}]},{"type":"line_break"},{"type":"verse","number":19,"content":[{"text":"(9-20) Bangkitlah, ya TUHAN,","poem":1},{"text":"jangan biarkan manusia menjadi kuat.","poem":2},{"text":"Biarlah bangsa-bangsa,","poem":1},{"text":"dihakimi di hadapan-Mu.","poem":2}]},{"type":"verse","number":20,"content":[{"text":"(9-21) Letakkan ketakutan pada mereka, ya TUHAN.","poem":1},{"text":"Biarlah bangsa-bangsa tahu bahwa mereka hanyalah manusia. Sela","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/9.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/10.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/8.json","previousChapterAudioLinks":{},"numberOfVerses":20}