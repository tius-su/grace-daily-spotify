{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":118,"content":[{"type":"heading","content":["TUHAN yang Ditinggikan"]},{"type":"verse","number":1,"content":[{"text":"Bersyukurlah kepada TUHAN karena Dia baik,","poem":1},{"text":"karena kasih setia-Nya selama-lamanya!","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Biarlah Israel berkata,","poem":1},{"text":"“Kasih setia-Nya untuk selama-lamanya.”","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Biarlah seisi rumah Harun berkata,","poem":1},{"text":"“Kasih setia-Nya untuk selama-lamanya!”","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Biarlah orang-orang yang takut akan TUHAN berkata,","poem":1},{"text":"“Kasih setia-Nya untuk selama-lamanya!”","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"Dalam kesesakanku, aku berseru kepada TUHAN;","poem":1},{"text":"TUHAN menjawab aku di tempat yang luas.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"TUHAN bersamaku, aku takkan takut.","poem":1},{"text":"Apa yang dapat diperbuat manusia kepadaku?","poem":2}]},{"type":"verse","number":7,"content":[{"text":"TUHAN bersamaku, menolong aku;","poem":1},{"text":"aku akan memandang orang-orang yang membenciku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"Lebih baik berlindung kepada TUHAN,","poem":1},{"text":"daripada memercayai manusia.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Lebih baik berlindung kepada TUHAN,","poem":1},{"text":"daripada memercayai para penguasa.","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"Semua bangsa mengepung aku,","poem":1},{"text":"di dalam nama TUHAN, sebenarnya aku akan menumpas mereka.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Mereka mengepung aku, ya, mereka mengepung aku,","poem":1},{"text":"di dalam nama TUHAN, sebenarnya aku akan menumpas mereka.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Mereka mengepung aku bagaikan lebah-lebah,","poem":1},{"text":"mereka dipadamkan seperti api semak duri,","poem":2},{"lineBreak":true},{"text":"di dalam nama TUHAN, sebenarnya aku akan menumpas mereka.","poem":2}]},{"type":"line_break"},{"type":"verse","number":13,"content":[{"text":"Aku didorong kuat hingga aku jatuh,","poem":1},{"text":"tetapi TUHAN menolongku.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"TUHAN adalah kekuatanku dan mazmurku,","poem":1},{"text":"Dia telah menjadi keselamatanku.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Bunyi sorak-sorai keselamatan ada di tenda orang-orang benar:","poem":1},{"text":"“Tangan kanan TUHAN melakukan keperkasaan,","poem":2}]},{"type":"verse","number":16,"content":[{"text":"tangan kanan TUHAN ditinggikan,","poem":1},{"text":"tangan kanan TUHAN melakukan keperkasaan!”","poem":2}]},{"type":"line_break"},{"type":"verse","number":17,"content":[{"text":"Aku takkan mati, tetapi hidup,","poem":1},{"text":"dan akan menceritakan perbuatan-perbuatan TUHAN.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"TUHAN telah menghajar aku,","poem":1},{"text":"tetapi Dia tidak menyerahkanku kepada maut.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Bukakan bagiku pintu-pintu gerbang kebenaran,","poem":1},{"text":"aku akan masuk melaluinya dan bersyukur kepada TUHAN.","poem":2}]},{"type":"verse","number":20,"content":[{"text":"Inilah pintu gerbang TUHAN,","poem":1},{"text":"orang-orang benar akan masuk melaluinya.","poem":2}]},{"type":"verse","number":21,"content":[{"text":"Aku akan bersyukur kepada-Mu karena Engkau telah menjawab aku,","poem":1},{"text":"dan telah menjadi keselamatanku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":22,"content":[{"text":"Batu yang ditolak oleh tukang-tukang bangunan","poem":1},{"text":"telah menjadi batu penjuru.","poem":2}]},{"type":"verse","number":23,"content":[{"text":"Ini adalah perbuatan TUHAN,","poem":1},{"text":"keajaiban-keajaiban di mata kita.","poem":2}]},{"type":"verse","number":24,"content":[{"text":"Inilah hari yang telah TUHAN jadikan,","poem":1},{"text":"mari kita bersorak dan bersuka di dalamnya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":25,"content":[{"text":"Ya TUHAN, selamatkanlah!","poem":1},{"text":"Ya TUHAN, sejahterakanlah!","poem":2}]},{"type":"verse","number":26,"content":[{"text":"Diberkatilah orang yang datang dalam nama TUHAN,","poem":1},{"text":"Kami memberkatimu dari rumah TUHAN.","poem":2}]},{"type":"line_break"},{"type":"verse","number":27,"content":[{"text":"TUHAN adalah Allah, dan Dia telah menerangi.","poem":1},{"text":"Ikatlah kurban hari raya dengan tali-tali,","poem":2},{"lineBreak":true},{"text":"pada tanduk-tanduk mazbah.","poem":2}]},{"type":"line_break"},{"type":"verse","number":28,"content":[{"text":"Engkau adalah Allahku, dan aku akan bersyukur kepada-Mu,","poem":1},{"text":"Engkau adalah Allahku, aku akan meninggikan-Mu!","poem":2}]},{"type":"verse","number":29,"content":[{"text":"Bersyukurlah kepada TUHAN karena Dia baik!","poem":1},{"text":"Kebaikan-Nya untuk selama-lamanya.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/118.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/119.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/117.json","previousChapterAudioLinks":{},"numberOfVerses":29}