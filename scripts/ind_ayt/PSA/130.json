{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":130,"content":[{"type":"heading","content":["Doa untuk Pengampunan dan Belas Kasih"]},{"type":"verse","number":1,"content":[{"text":"Nyanyian Ziarah.","descriptive":true},{"lineBreak":true},{"text":"Dari kedalaman aku berseru kepada-Mu, ya TUHAN.","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Tuhan, dengarlah suaraku!","poem":1},{"text":"Biarlah telinga-Mu memperhatikan suara permohonanku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Jika Engkau, ya TUHAN, mengawas-awasi kesalahan-kesalahan,","poem":1},{"text":"ya TUHAN, siapa yang bisa bertahan?","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Akan tetapi, ada pengampunan pada-Mu,","poem":1},{"text":"sehingga Engkau ditakuti.","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"Aku menantikan TUHAN, jiwaku menanti","poem":1},{"text":"dan pada firman-Nya, aku berharap.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Jiwaku menanti-nantikan Tuhan,","poem":1},{"text":"melebihi para pengawal menantikan pagi hari,","poem":2},{"lineBreak":true},{"text":"ya, para pengawal menantikan pagi hari.","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Hai Israel, berharaplah kepada TUHAN!","poem":1},{"text":"Sebab, pada TUHAN ada kasih setia,","poem":2},{"lineBreak":true},{"text":"dan bersama-Nya ada penebusan yang berlimpah.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Dia akan menebus Israel","poem":1},{"text":"dari segala kesalahannya.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/130.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/131.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/129.json","previousChapterAudioLinks":{},"numberOfVerses":8}