{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":99,"content":[{"type":"heading","content":["Sang Raja yang Kudus"]},{"type":"verse","number":1,"content":[{"text":"TUHAN memerintah,","poem":1},{"text":"biarlah suku-suku bangsa gemetar.","poem":2},{"text":"Dia bersemayam di atas kerub-kerub,","poem":1},{"text":"biarlah bumi berguncang.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"TUHAN itu besar di Sion,","poem":1},{"text":"Dia ditinggikan di atas segala suku bangsa.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Biarlah mereka memuji kebesaran-Mu","poem":1},{"text":"dan kedahsyatan nama-Mu!","poem":2},{"lineBreak":true},{"text":"Dia itu kudus!","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"Raja yang kuat, yang mencintai hukum;","poem":1},{"text":"Engkau telah menegakkan keadilan,","poem":2},{"lineBreak":true},{"text":"Engkau menjalankan hukum dan kebenaran kepada Yakub.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Tinggikanlah TUHAN, Allah kita,","poem":1},{"text":"dan menyembahlah pada tumpuan kaki-Nya!","poem":2},{"lineBreak":true},{"text":"Dia itu kudus!","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"Musa dan Harun ada di antara imam-imam-Nya,","poem":1},{"text":"Samuel adalah satu di antara orang-orang yang memanggil-manggil nama-Nya.","poem":2},{"text":"Mereka memanggil-manggil TUHAN, dan Dia menjawab mereka.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Dia berfirman kepada mereka dari tiang awan;","poem":1},{"text":"mereka menjaga kesaksian-kesaksian-Nya","poem":2},{"lineBreak":true},{"text":"dan ketetapan yang Dia berikan kepada mereka.","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"Ya TUHAN, Allah kami,","poem":1},{"text":"Engkau menjawab mereka;","poem":2},{"text":"Engkau adalah Allah yang mengampuni mereka,","poem":1},{"text":"tetapi juga yang membalas perbuatan-perbuatan mereka.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Tinggikanlah TUHAN, Allah kita,","poem":1},{"text":"dan menyembahlah di atas gunung-Nya yang kudus.","poem":2},{"lineBreak":true},{"text":"Sebab, TUHAN, Allah kita, adalah kudus.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/99.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/100.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/98.json","previousChapterAudioLinks":{},"numberOfVerses":9}