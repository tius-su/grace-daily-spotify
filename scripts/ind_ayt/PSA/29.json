{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":29,"content":[{"type":"heading","content":["TUHAN yang Mulia Diakui sebagai Raja Dunia"]},{"type":"verse","number":1,"content":[{"text":"Nyanyian Daud.","descriptive":true},{"lineBreak":true},{"text":"Persembahkan bagi TUHAN, hai anak-anak ilahi;","poem":1},{"text":"persembahkan bagi TUHAN kemuliaan dan kekuatan.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Persembahkan bagi TUHAN kemuliaan nama-Nya;","poem":1},{"text":"sujudlah kepada TUHAN dalam perhiasan kekudusan.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Suara TUHAN di atas air;","poem":1},{"text":"Allah kemuliaan mengguntur;","poem":2},{"lineBreak":true},{"text":"TUHAN di atas limpahan air.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Suara TUHAN itu berkuasa;","poem":1},{"text":"Suara TUHAN itu mulia.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Suara TUHAN mematahkan pohon-pohon aras;","poem":1},{"text":"Ya, TUHAN mematahkan pohon-pohon aras lebanon.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Dia membuat Lebanon melompat-lompat seperti seekor anak lembu,","poem":1},{"text":"dan Siryon seperti anak banteng.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Suara TUHAN menatah dengan api yang menyala-nyala.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Suara TUHAN menggetarkan padang belantara,","poem":1},{"text":"TUHAN menggetarkan padang belantara Kadesh.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Suara TUHAN membuat rusa melahirkan,","poem":1},{"text":"dan menelanjangi hutan.","poem":2},{"text":"Di dalam bait-Nya, setiap orang membicarakan kemuliaan-Nya.","poem":1}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"TUHAN duduk di atas air bah,","poem":1},{"text":"TUHAN duduk sebagai Raja selama-lamanya.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"TUHAN akan memberi kekuatan kepada umat-Nya;","poem":1},{"text":"TUHAN akan memberkati umat-Nya dengan damai sejahtera.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/29.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/30.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/28.json","previousChapterAudioLinks":{},"numberOfVerses":11}