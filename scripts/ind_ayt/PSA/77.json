{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":77,"content":[{"type":"heading","content":["Perbuatan TUHAN pada Masa Lampau"]},{"type":"verse","number":1,"content":[{"text":"Untuk pemimpin pujian. Menurut: Yedutun. Mazmur Asaf.","descriptive":true},{"lineBreak":true},{"text":"(77-2) Aku berseru kepada Allah;","poem":1},{"text":"aku berseru dengan nyaring kepada Allah, dan Dia mendengarkanku.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"(77-3) Pada hari kesusahanku, aku mencari Tuhan;","poem":1},{"text":"pada malam hari, kurentangkan tanganku tanpa menjadi lelah;","poem":2},{"lineBreak":true},{"text":"jiwaku menolak dihibur.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"(77-4) Ketika aku ingat akan Allah, aku gelisah;","poem":1},{"text":"ketika aku merenung, jiwaku berpaling. Sela","poem":2}]},{"type":"verse","number":4,"content":[{"text":"(77-5) Engkau membuat kelopak mataku terbuka;","poem":1},{"text":"aku terganggu sehingga tak dapat berbicara.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"(77-6) Aku memikirkan hari-hari yang lalu,","poem":1},{"text":"tahun-tahun pada masa silam.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"(77-7) Aku teringat nyanyianku pada malam hari;","poem":1},{"text":"biarlah aku merenungkan di dalam hatiku,","poem":2},{"lineBreak":true},{"text":"dan jiwaku menyelidiki.","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"(77-8) “Akankah Tuhan menolakku selama-lamanya,","poem":1},{"text":"dan takkan berkenan lagi?","poem":2}]},{"type":"verse","number":8,"content":[{"text":"(77-9) Apakah kasih setia-Nya telah berakhir selama-lamanya?","poem":1},{"text":"Apakah janji-Nya yang turun-temurun sudah berakhir?","poem":2}]},{"type":"verse","number":9,"content":[{"text":"(77-10) Apakah Allah sudah lupa mengasihani?","poem":1},{"text":"Apakah kemarahan-Nya telah menutupi belas kasih-Nya?” Sela","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"(77-11) Kemudian, aku berkata, “Inilah dukaku,","poem":1},{"text":"saat tangan kanan Yang Mahatinggi berpaling dariku.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"(77-12) Aku akan mengingat perbuatan-perbuatan TUHAN.","poem":1},{"text":"Ya, aku akan mengingat keajaiban-keajaiban-Mu pada zaman dahulu.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"(77-13) Aku akan merenungkan semua pekerjaan-Mu,","poem":1},{"text":"dan membicarakan perbuatan-perbuatan-Mu.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"(77-14) Jalan-Mu itu suci, ya Allah.","poem":1},{"text":"Siapa ilah yang besar seperti Allah kami?","poem":2}]},{"type":"verse","number":14,"content":[{"text":"(77-15) Engkau adalah Allah yang mengerjakan keajaiban-keajaiban;","poem":1},{"text":"Engkau telah memberitahukan kuasa-Mu di antara bangsa-bangsa.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"(77-16) Engkau menebus umat-Mu dengan lengan-Mu,","poem":1},{"text":"keturunan Yakub dan Yusuf. Sela","poem":2}]},{"type":"line_break"},{"type":"verse","number":16,"content":[{"text":"(77-17) Air melihat Engkau, ya Allah;","poem":1},{"text":"air melihat Engkau lalu ketakutan.","poem":2},{"lineBreak":true},{"text":"Samudra juga gemetar.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"(77-18) Awan tebal menuangkan air,","poem":1},{"text":"awan-awan menyatakan suara,","poem":2},{"lineBreak":true},{"text":"juga anak-anak panah-Mu melintas.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"(77-19) Suara gemuruh-Mu mengelilingi,","poem":1},{"text":"halilintar menerangi dunia,","poem":2},{"lineBreak":true},{"text":"bumi bergetar dan berguncang.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"(77-20) Jalan-Mu di dalam lautan,","poem":1},{"text":"jalur-Mu melewati air yang besar,","poem":2},{"lineBreak":true},{"text":"tetapi jejak-jejak-Mu tidak diketahui.","poem":2}]},{"type":"verse","number":20,"content":[{"text":"(77-21) Engkau memimpin umat-Mu seperti kawanan domba","poem":1},{"text":"melalui tangan Musa dan Harun.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/77.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/78.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/76.json","previousChapterAudioLinks":{},"numberOfVerses":20}