{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":47,"content":[{"type":"heading","content":["Penguasa Segala Bangsa"]},{"type":"verse","number":1,"content":[{"text":"Kepada pemimpin Pujian: Nyanyian anak-anak Korah.","descriptive":true},{"lineBreak":true},{"text":"(47-2) Bertepuk tanganlah, hai semua bangsa,","poem":1},{"text":"bersoraklah kepada Allah dengan suara sukacita!","poem":2}]},{"type":"verse","number":2,"content":[{"text":"(47-3) Sebab, TUHAN Yang Mahatinggi ditakuti;","poem":1},{"text":"Raja yang agung atas seluruh bumi.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"(47-4) Dia menundukkan suku-suku bangsa di bawah kita,","poem":1},{"text":"dan bangsa-bangsa di bawah kaki kita.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"(47-5) Dia memilih bagi kita milik pusaka kita,","poem":1},{"text":"kemuliaan Yakub yang Dia kasihi. Sela","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"(47-6) Allah sudah naik dengan sorak-sorai,","poem":1},{"text":"TUHAN di antara suara sangkakala.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"(47-7) Nyanyikanlah pujian kepada Allah, nyanyikanlah pujian!","poem":1},{"text":"Nyanyikanlah pujian kepada Raja kita, nyanyikanlah pujian!","poem":2}]},{"type":"verse","number":7,"content":[{"text":"(47-8) Sebab, Allah adalah Raja atas seluruh bumi;","poem":1},{"text":"nyanyikanlah pujian dengan pengertian!","poem":2}]},{"type":"verse","number":8,"content":[{"text":"(47-9) Allah adalah Raja atas bangsa-bangsa;","poem":1},{"text":"Allah duduk di takhta-Nya yang kudus.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"(47-10) Tokoh-tokoh bangsa berkumpul, umat Allah Abraham,","poem":1},{"lineBreak":true},{"text":"karena perisai-perisai bumi adalah milik Allah;","poem":1},{"text":"Dia amat ditinggikan.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/47.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/48.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/46.json","previousChapterAudioLinks":{},"numberOfVerses":9}