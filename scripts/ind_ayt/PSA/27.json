{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":27,"content":[{"type":"heading","content":["Aman dalam Lindungan TUHAN"]},{"type":"verse","number":1,"content":[{"text":"Nyanyian Daud.","descriptive":true},{"lineBreak":true},{"text":"TUHAN adalah terangku dan keselamatanku,","poem":1},{"text":"kepada siapa aku harus takut?","poem":2},{"text":"TUHAN adalah tempat perlindungan hidupku,","poem":1},{"text":"kepada siapa aku harus gemetar?","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Ketika para penjahat mendekat","poem":1},{"text":"untuk menghabisi tubuhku,","poem":2},{"text":"yaitu lawan-lawan dan musuh-musuhku,","poem":1},{"text":"merekalah yang akan tersandung dan jatuh.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Walaupun pasukan berkepung melawan aku,","poem":1},{"text":"hatiku tidak takut;","poem":2},{"text":"Walaupun peperangan bangkit melawan aku,","poem":1},{"text":"aku tetap percaya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"Satu hal sudah aku minta kepada TUHAN,","poem":1},{"text":"bahwa yang paling aku inginkan:","poem":2},{"lineBreak":true},{"text":"adalah tinggal di rumah TUHAN sepanjang hari kehidupanku,","poem":2},{"text":"untuk memandang keindahan TUHAN,","poem":1},{"text":"dan mencari-Nya di dalam bait-Nya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"Sebab, pada waktu kejahatan, Dia akan menyembunyikan aku di dalam pondok-Nya;","poem":1},{"text":"Dia menyembunyikan aku di tempat yang tersembunyi di kemah-Nya,","poem":2},{"lineBreak":true},{"text":"Dia akan mengangkat aku ke atas gunung batu.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Dan sekarang, kepalaku akan terangkat","poem":1},{"text":"atas musuh-musuhku di sekelilingku,","poem":2},{"text":"dan aku akan mempersembahkan kurban-kurban di tenda-Nya","poem":1},{"text":"dengan seruan sorak-sorai.","poem":2},{"lineBreak":true},{"text":"Aku akan bernyanyi dan bermazmur bagi TUHAN.","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Dengarlah, ya TUHAN, suara seruanku,","poem":1},{"text":"kasihani aku dan jawab aku.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"“Carilah Wajah-Ku!”,","poem":1},{"text":"hatiku berkata kepada-Mu, “Aku mencari wajah-Mu, ya TUHAN.”","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Jangan sembunyikan wajah-Mu dariku.","poem":1},{"text":"Jangan berpaling dari hamba-Mu dengan murka, ya, Engkau telah menjadi Penolongku.","poem":2},{"text":"Jangan sia-siakan dan jangan tinggalkan aku,","poem":1},{"text":"ya Allah Penyelamatku!","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Walaupun ayah dan ibuku meninggalkan aku,","poem":1},{"text":"TUHAN akan menyambutku.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Tunjukkanlah jalan-Mu, ya TUHAN,","poem":1},{"text":"tuntunlah aku di jalan yang rata oleh karena musuh-musuhku.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Jangan serahkan nyawaku kepada musuh-musuhku","poem":1},{"text":"karena saksi-saksi dusta telah bangkit melawan aku,","poem":2},{"lineBreak":true},{"text":"dan mereka bernapaskan kekejaman.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Jika tidak, aku percaya bahwa aku akan menyaksikan kebaikan TUHAN,","poem":1},{"text":"di negeri orang-orang hidup.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Nantikanlah TUHAN!","poem":1},{"text":"Jadilah kuat dan biarlah hatimu teguh!","poem":2},{"lineBreak":true},{"text":"Nantikanlah TUHAN.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/27.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/28.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/26.json","previousChapterAudioLinks":{},"numberOfVerses":14}