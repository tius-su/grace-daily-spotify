{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":97,"content":[{"type":"heading","content":["TUHAN, Sang Raja Semesta"]},{"type":"verse","number":1,"content":[{"text":"TUHAN memerintah; biarlah bumi bersukaria;","poem":1},{"text":"biarlah banyak pulau bergembira.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Awan-awan dan kekelaman mengelilingi-Nya,","poem":1},{"text":"kebenaran dan keadilan adalah dasar takhta-Nya.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Api berjalan di hadapan-Nya,","poem":1},{"text":"dan membakar musuh-musuh di sekeliling-Nya.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Kilat-kilat-Nya menerangi dunia,","poem":1},{"text":"bumi menyaksikannya dan gemetar.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Gunung-gunung meleleh seperti lilin di hadapan TUHAN,","poem":1},{"text":"di hadapan Tuhan atas seluruh bumi.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Langit memberitakan kebenaran-Nya,","poem":1},{"text":"dan semua bangsa menyaksikan kemuliaan-Nya.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Semua penyembah berhala akan malu;","poem":1},{"text":"mereka yang membanggakan berhala-berhala.","poem":2},{"lineBreak":true},{"text":"Sembahlah Dia, hai semua ilah!","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"Sion mendengar dan bersukaria,","poem":1},{"text":"putri-putri Yehuda bersorak","poem":2},{"lineBreak":true},{"text":"oleh karena penghakiman-Mu, ya TUHAN.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Sebab Engkau, ya TUHAN, adalah Yang Mahatinggi di atas seluruh bumi,","poem":1},{"text":"Engkau jauh ditinggikan mengatasi segala ilah.","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"Hai kamu yang mengasihi TUHAN, bencilah kejahatan!","poem":1},{"text":"Dia memelihara jiwa orang-orang kudus-Nya,","poem":2},{"lineBreak":true},{"text":"Dia melepaskan mereka dari tangan orang fasik.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Terang disebarkan bagi orang benar,","poem":1},{"text":"dan kegembiraan bagi orang yang lurus hati.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Bergembiralah di dalam TUHAN, hai orang benar,","poem":1},{"text":"bersyukurlah kepada nama-Nya yang kudus.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/97.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/98.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/96.json","previousChapterAudioLinks":{},"numberOfVerses":12}