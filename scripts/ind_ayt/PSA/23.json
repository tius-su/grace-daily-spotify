{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":23,"content":[{"type":"heading","content":["TUHAN adalah Gembalaku"]},{"type":"verse","number":1,"content":[{"text":"Nyanyian Daud.","descriptive":true},{"lineBreak":true},{"text":"TUHAN adalah gembalaku.","poem":1},{"text":"Aku tidak kekurangan apa pun.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Dia membaringkanku","poem":1},{"text":"di padang rumput hijau.","poem":2},{"text":"Dia menuntunku,","poem":1},{"text":"ke tepi air yang tenang.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Dia memulihkan jiwaku.","poem":1},{"text":"Dia menuntun aku di jalan-jalan kebenaran","poem":2},{"lineBreak":true},{"text":"oleh karena nama-Nya.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Walaupun aku berjalan melewati lembah bayang-bayang kematian,","poem":1},{"text":"aku takkan takut bahaya,","poem":2},{"text":"karena Engkau bersamaku;","poem":1},{"text":"gada-Mu dan tongkat-Mu, itu yang menghiburku.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Engkau mengatur meja di hadapanku,","poem":1},{"text":"di depan musuh-musuhku.","poem":2},{"text":"Engkau mengurapi kepalaku dengan minyak;","poem":1},{"text":"pialaku berlimpah-limpah.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Sesungguhnya, kebaikan dan kasih setia-Mu akan mengikutiku","poem":1},{"text":"pada segala masa,","poem":2},{"text":"dan aku akan tinggal di rumah TUHAN,","poem":1},{"text":"sepanjang hidup.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/23.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/24.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/22.json","previousChapterAudioLinks":{},"numberOfVerses":6}