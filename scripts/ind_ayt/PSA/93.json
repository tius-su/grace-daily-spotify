{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":93,"content":[{"type":"heading","content":["Raja dan Takhta-Nya"]},{"type":"verse","number":1,"content":[{"text":"TUHAN memerintah; Dia berpakaian kemuliaan;","poem":1},{"text":"TUHAN berpakaian dan berikatpinggangkan kekuatan.","poem":2},{"lineBreak":true},{"text":"Sesungguhnya, dunia teguh dan tidak terguncangkan.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Takhta-Mu teguh sejak zaman dahulu;","poem":1},{"text":"Engkau ada sejak kekekalan.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Sungai-sungai telah meninggi, ya TUHAN;","poem":1},{"text":"sungai-sungai telah meninggikan bunyinya;","poem":2},{"lineBreak":true},{"text":"sungai-sungai telah meninggikan ombaknya.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Dibandingkan gemuruh air yang besar, maupun kehebatan gelora lautan,","poem":1},{"text":"TUHAN di tempat tinggi lebih hebat.","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"Kesaksian-kesaksian-Mu teguh sepenuhnya,","poem":1},{"text":"kekudusan pantas berada di dalam rumah-Mu, ya TUHAN, untuk sepanjang masa.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/93.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/94.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/92.json","previousChapterAudioLinks":{},"numberOfVerses":5}