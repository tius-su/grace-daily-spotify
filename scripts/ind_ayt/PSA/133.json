{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":133,"content":[{"type":"heading","content":["Mazmur Persekutuan"]},{"type":"verse","number":1,"content":[{"text":"Nyanyian Ziarah Daud.","descriptive":true},{"lineBreak":true},{"text":"Lihatlah, betapa baik dan betapa indahnya,","poem":1},{"text":"jika saudara-saudara duduk bersama-sama!","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Itu seperti minyak yang baik di atas kepala, turun ke janggut,","poem":1},{"text":"ke janggut Harun, lalu turun ke leher jubahnya.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Itu seperti embun Hermon, yang jatuh ke bukit-bukit Sion.","poem":1},{"text":"Sebab, ke sana TUHAN memerintahkan berkat, hidup selama-lamanya.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/133.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/134.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/132.json","previousChapterAudioLinks":{},"numberOfVerses":3}