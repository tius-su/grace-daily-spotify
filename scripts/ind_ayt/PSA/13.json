{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":13,"content":[{"type":"heading","content":["Percaya pada Kasih Setia TUHAN"]},{"type":"verse","number":1,"content":[{"text":"Kepada pemimpin pujian: Nyanyian Daud.","descriptive":true},{"lineBreak":true},{"text":"(13-2) Berapa lama lagi, ya TUHAN? Apakah Engkau akan melupakanku selama-lamanya?","poem":1},{"text":"Berapa lama lagi Engkau menyembunyikan wajah-Mu dariku?","poem":2}]},{"type":"verse","number":2,"content":[{"text":"(13-3) Berapa lama aku harus menaruh nasihat di dalam jiwaku, dan kesedihan di dalam hatiku sepanjang hari?","poem":1},{"text":"Berapa lama lagi musuhku akan ditinggikan atas aku?","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"(13-4) Lihat dan jawablah aku, ya TUHAN, Allahku.","poem":1},{"text":"Terangi mataku, jangan sampai aku tidur dalam kematian.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"(13-5) Jangan sampai musuhku berkata, “Aku telah mengalahkan dia,”","poem":1},{"text":"lalu lawan-lawanku akan bersukacita ketika aku goyah.","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"(13-6) Namun, aku percaya pada kasih setia-Mu.","poem":1},{"text":"Hatiku bersukacita karena keselamatan-Mu.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"(13-7) Aku akan bernyanyi bagi TUHAN","poem":1},{"text":"karena Dia telah berbuat baik kepadaku.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/13.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/14.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/12.json","previousChapterAudioLinks":{},"numberOfVerses":6}