{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":121,"content":[{"type":"heading","content":["TUHAN Penjaga Israel"]},{"type":"verse","number":1,"content":[{"text":"Nyanyian Ziarah.","descriptive":true},{"lineBreak":true},{"text":"Aku mengangkat mataku ke bukit-bukit,","poem":1},{"text":"dari mana pertolonganku datang?","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Pertolonganku datang dari TUHAN,","poem":1},{"text":"yang menjadikan langit dan bumi.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Dia takkan membiarkan kakimu goyah,","poem":1},{"text":"yang menjagamu takkan tertidur.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Sebenarnya, Dia yang menjaga Israel,","poem":1},{"text":"takkan terkantuk ataupun tertidur.","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"TUHANlah penjagamu,","poem":1},{"text":"TUHAN adalah naunganmu, di sebelah kananmu.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Matahari takkan menyerangmu pada waktu siang,","poem":1},{"text":"begitu juga bulan pada waktu malam.","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"TUHAN akan menjagamu dari segala kejahatan,","poem":1},{"text":"Dia akan menjaga jiwamu.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"TUHAN akan menjaga kepergianmu dan kedatanganmu,","poem":1},{"text":"dari sekarang sampai selama-lamanya!","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/121.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/122.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/120.json","previousChapterAudioLinks":{},"numberOfVerses":8}