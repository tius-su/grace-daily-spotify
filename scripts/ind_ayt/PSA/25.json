{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":25,"content":[{"type":"heading","content":["Doa Mohon Pengampunan dan Perlindungan"]},{"type":"verse","number":1,"content":[{"text":"Nyanyian Daud.","descriptive":true},{"lineBreak":true},{"text":"Kepada-Mu, ya TUHAN, aku mengangkat jiwaku.","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Ya Allahku, di dalam Engkau aku percaya,","poem":1},{"text":"jangan biarkan aku dipermalukan.","poem":2},{"lineBreak":true},{"text":"Jangan biarkan musuh-musuhku bersukaria atas aku.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Sebenarnya, tidak ada orang yang menantikan Engkau akan dipermalukan,","poem":1},{"text":"mereka yang berkhianat tanpa alasan, akan dipermalukan.","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"Beritahukan cara-cara-Mu, ya TUHAN,","poem":1},{"text":"ajari aku jalan-jalan itu.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Pimpin aku dalam kebenaran-Mu,","poem":1},{"text":"dan ajari aku.","poem":2},{"text":"Sebab, Engkau adalah Allah keselamatanku,","poem":1},{"text":"oleh karena-Mu, aku menanti-nanti sepanjang hari.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Ingatlah belas kasihan dan kesetiaan-Mu, ya TUHAN,","poem":1},{"text":"karena semua itu sudah ada sejak dahulu kala.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Jangan mengingat dosa-dosa masa mudaku,","poem":1},{"text":"atau pelanggaran-pelanggaranku.","poem":2},{"text":"Sesuai dengan kesetiaan-Mu, ingatlah aku,","poem":1},{"text":"demi kebaikan-Mu, ya TUHAN.","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"TUHAN itu baik dan adil.","poem":1},{"text":"Karena itu, Dia mengajarkan jalan kepada orang berdosa.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Dia memimpin orang rendah hati menurut hukum,","poem":1},{"text":"dan mengajarkan jalan-Nya kepada orang yang rendah hati.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Semua jalan TUHAN adalah kasih setia dan kebenaran,","poem":1},{"text":"bagi mereka yang memegang kesaksian-kesaksian perjanjian-Nya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"Demi nama-Mu, ya TUHAN,","poem":1},{"text":"ampunilah kesalahan-kesalahanku karena kesalahan itu banyak.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Siapa orang yang takut akan TUHAN?","poem":1},{"text":"Dia akan menunjukkan jalan yang seharusnya dia pilih.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Jiwanya akan bermalam dalam kebahagiaan,","poem":1},{"text":"dan keturunannya akan mewarisi bumi.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Nasihat TUHAN adalah bagi mereka yang takut akan Dia,","poem":1},{"text":"dan Dia akan memberitahukan perjanjian-Nya.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Mataku terus-menerus kepada TUHAN","poem":1},{"text":"karena Dia akan mengeluarkan kakiku dari jerat.","poem":2}]},{"type":"line_break"},{"type":"verse","number":16,"content":[{"text":"Berpalinglah kepadaku dan kasihanilah","poem":1},{"text":"karena aku sendirian dan tertindas.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Kesusahan hatiku bertambah besar,","poem":1},{"text":"keluarkan aku dari kesesakanku.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Lihatlah penderitaanku dan kesusahanku,","poem":1},{"text":"ampuni semua dosaku.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Lihatlah betapa banyak musuhku.","poem":1},{"text":"Sebab, mereka bertambah banyak dan membenciku dengan kebencian yang kejam.","poem":2}]},{"type":"verse","number":20,"content":[{"text":"Jagalah jiwaku dan selamatkan aku,","poem":1},{"text":"jangan biarkan aku dipermalukan karena aku mencari perlindungan-Mu.","poem":2}]},{"type":"verse","number":21,"content":[{"text":"Kiranya ketulusan dan kebenaran menjagaku","poem":1},{"text":"karena aku menantikan-Mu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":22,"content":[{"text":"Tebuslah Israel, ya Allah, dari semua kesusahannya.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/25.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/26.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/24.json","previousChapterAudioLinks":{},"numberOfVerses":22}