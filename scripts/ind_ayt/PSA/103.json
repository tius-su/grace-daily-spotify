{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":103,"content":[{"type":"heading","content":["Pujilah TUHAN, Hai Jiwaku!"]},{"type":"verse","number":1,"content":[{"text":"Mazmur Daud.","descriptive":true},{"lineBreak":true},{"text":"Pujilah TUHAN, hai jiwaku!","poem":1},{"text":"Segenap batinku, pujilah nama-Nya yang kudus!","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Pujilah TUHAN, hai jiwaku,","poem":1},{"text":"dan jangan melupakan semua kebaikan-Nya;","poem":2}]},{"type":"verse","number":3,"content":[{"text":"yang mengampuni semua kesalahanmu,","poem":1},{"text":"yang menyembuhkan semua penyakitmu,","poem":2}]},{"type":"verse","number":4,"content":[{"text":"yang menebus hidupmu dari liang kubur,","poem":1},{"text":"yang memahkotaimu dengan kasih setia dan belas kasih,","poem":2}]},{"type":"verse","number":5,"content":[{"text":"yang memuaskanmu dengan hiasan-hiasan kebaikan,","poem":1},{"text":"sehingga masa mudamu diperbarui bagai burung rajawali.","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"TUHAN melakukan kebenaran dan keadilan","poem":1},{"text":"bagi semua orang yang tertindas.","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Dia memberitahukan jalan-jalan-Nya kepada Musa,","poem":1},{"text":"dan perbuatan-perbuatannya kepada orang-orang Israel.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"TUHAN itu berbelas kasih dan murah hati,","poem":1},{"text":"lambat untuk marah, dan berlimpah kasih setia.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Dia tidak senantiasa menuntut,","poem":1},{"text":"atau menyimpan amarah selamanya.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Dia tidak memperlakukan kita berdasarkan dosa-dosa kita,","poem":1},{"text":"atau membalas kita berdasarkan kesalahan-kesalahan kita.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Sebab, seperti tingginya langit di atas bumi,","poem":1},{"text":"demikian juga besar kasih setia-Nya kepada orang-orang yang takut akan Dia.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Seperti jauhnya timur dari barat,","poem":1},{"text":"demikian juga Dia menjauhkan kita dari pelanggaran-pelanggaran kita.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Seperti seorang ayah menyayangi anak-anaknya,","poem":1},{"text":"demikian juga TUHAN menyayangi orang-orang yang takut akan Dia.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Sebab, Dia tahu penciptaan kita;","poem":1},{"text":"Dia ingat bahwa kita adalah debu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":15,"content":[{"text":"Sebab, manusia itu hari-harinya seperti rumput;","poem":1},{"text":"ia merekah seperti bunga di padang.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Namun, ketika angin menerpanya,","poem":1},{"text":"ia lenyap,","poem":2},{"lineBreak":true},{"text":"dan tempatnya tidak mengenalnya lagi.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Namun, kasih setia TUHAN dari selamanya sampai selamanya","poem":1},{"text":"terhadap orang-orang yang takut akan Dia,","poem":2},{"lineBreak":true},{"text":"dan keadilan-Nya bagi anak cucu mereka;","poem":2}]},{"type":"verse","number":18,"content":[{"text":"bagi orang-orang yang menjaga perjanjian-Nya,","poem":1},{"text":"dan ingat untuk melakukan hukum-hukum-Nya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":19,"content":[{"text":"TUHAN menegakkan takhta-Nya di surga,","poem":1},{"text":"dan kerajaan-Nya memerintah atas segalanya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":20,"content":[{"text":"Pujilah TUHAN, hai para malaikat-Nya,","poem":1},{"text":"hai kamu yang perkasa dalam kekuatan,","poem":2},{"lineBreak":true},{"text":"yang melakukan perkataan-Nya dengan mendengarkan suara firman-Nya.","poem":2}]},{"type":"verse","number":21,"content":[{"text":"Pujilah TUHAN, hai semua bala tentara-Nya,","poem":1},{"text":"yang melayani-Nya, yang melakukan kehendak-Nya.","poem":2}]},{"type":"verse","number":22,"content":[{"text":"Pujilah TUHAN, hai semua ciptaan-Nya,","poem":1},{"text":"di segala tempat kekuasaan-Nya!","poem":2},{"lineBreak":true},{"text":"Pujilah TUHAN, hai jiwaku!","poem":1}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/103.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/104.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/102.json","previousChapterAudioLinks":{},"numberOfVerses":22}