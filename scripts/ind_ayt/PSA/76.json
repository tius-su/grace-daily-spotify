{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":76,"content":[{"type":"heading","content":["Allah Memerintah di Sion"]},{"type":"verse","number":1,"content":[{"text":"Untuk pemimpin pujian: Dengan alat-alat musik petik. Mazmur Asaf. Sebuah nyanyian.","descriptive":true},{"lineBreak":true},{"text":"(76-2) Allah dikenal di Yehuda;","poem":1},{"text":"nama-Nya besar di Israel.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"(76-3) Pondok-Nya ada di Salem;","poem":1},{"text":"tempat kediaman-Nya di Sion.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"(76-4) Di sana, Dia mematahkan anak-anak panah yang memelesat dari busur, perisai,","poem":1},{"text":"pedang, dan senjata-senjata perang. Sela","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"(76-5) Engkau bersinar","poem":1},{"text":"lebih mulia daripada gunung-gunung perburuan.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"(76-6) Orang-orang berhati berani dijarah;","poem":1},{"text":"mereka tenggelam dalam tidur;","poem":2},{"lineBreak":true},{"text":"semua orang yang gagah perkasa tidak bisa mengangkat tangannya.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"(76-7) Oleh karena kecaman-Mu, ya Allah Yakub,","poem":1},{"text":"baik pengendara maupun kuda tertidur nyenyak.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"(76-8) Engkau, Engkau ditakuti!","poem":1},{"text":"Siapa dapat berdiri di hadapan murka-Mu?","poem":2}]},{"type":"verse","number":8,"content":[{"text":"(76-9) Dari langit, Engkau memberitahukan penghakiman;","poem":1},{"text":"bumi takut dan terdiam","poem":2}]},{"type":"verse","number":9,"content":[{"text":"(76-10) ketika Allah bangkit untuk menghakimi,","poem":1},{"text":"dan untuk menyelamatkan semua orang tertindas di bumi. Sela","poem":2}]},{"type":"verse","number":10,"content":[{"text":"(76-11) Sebenarnya, murka manusia akan memuji-Mu;","poem":1},{"text":"Engkau akan berikatpinggangkan sisa murka itu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"(76-12) Bernazarlah kepada TUHAN, Allahmu, dan penuhi itu!","poem":1},{"text":"Biarlah semua yang ada di sekeliling-Nya membawa persembahan bagi Dia yang ditakuti.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"(76-13) Dia yang mematahkan semangat para pemimpin,","poem":1},{"text":"dan ditakuti oleh raja-raja di bumi.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/76.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/77.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/75.json","previousChapterAudioLinks":{},"numberOfVerses":12}