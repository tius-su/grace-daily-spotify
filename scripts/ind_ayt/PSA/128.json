{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":128,"content":[{"type":"heading","content":["Berkat di Bumi"]},{"type":"verse","number":1,"content":[{"text":"Nyanyian Ziarah.","descriptive":true},{"lineBreak":true},{"text":"Diberkatilah setiap orang yang takut akan TUHAN,","poem":1},{"text":"yang berjalan pada jalan-jalan-Nya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"Kamu akan makan hasil pekerjaan tanganmu,","poem":1},{"text":"kamu akan bahagia dan itu baik bagimu.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Istrimu akan menjadi seperti pohon anggur yang berbuah di dalam rumahmu,","poem":1},{"text":"anak-anakmu akan menjadi seperti tunas-tunas pohon zaitun sekeliling mejamu.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Lihat, begitulah akan diberkati orang yang takut akan TUHAN.","poem":1}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"TUHAN memberkatimu dari Sion.","poem":1},{"text":"Kiranya kamu melihat kesejahteraan Yerusalem di seluruh hari dalam hidupmu.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Kiranya kamu boleh melihat anak-anak dari anak-anakmu.","poem":1},{"lineBreak":true},{"text":"Sejahtera atas Israel!","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/128.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/129.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/127.json","previousChapterAudioLinks":{},"numberOfVerses":6}