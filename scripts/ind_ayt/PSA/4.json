{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":4,"content":[{"type":"heading","content":["Doa pada Masa Kesukaran"]},{"type":"verse","number":1,"content":[{"text":"Kepada pemimpin pujian: Dengan kecapi. Nyanyian Daud.","descriptive":true},{"lineBreak":true},{"text":"(4-2) Jawablah ketika aku memanggil,","poem":1},{"text":"ya Allah kebenaranku!","poem":2},{"text":"Engkau telah melegakan kesesakanku.","poem":1},{"text":"Kasihanilah dan dengarlah doaku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"(4-3) Hai anak-anak manusia, berapa lama","poem":1},{"text":"lagi kemuliaanku menjadi cela?","poem":2},{"text":"Berapa lama lagi kamu mencintai kesia-siaan,","poem":1},{"text":"dan mencari kepalsuan? Sela","poem":2}]},{"type":"verse","number":3,"content":[{"text":"(4-4) Ketahuilah bahwa TUHAN","poem":1},{"text":"memisahkan orang saleh;","poem":2},{"text":"TUHAN mendengar","poem":1},{"text":"ketika aku memanggil-Nya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"(4-5) Gemetarlah,","poem":1},{"text":"dan jangan berbuat dosa;","poem":2},{"text":"berbicaralah dalam hatimu,","poem":1},{"text":"di atas tempat tidurmu, dan tenanglah. Sela","poem":2}]},{"type":"verse","number":5,"content":[{"text":"(4-6) Persembahkanlah kurban yang benar,","poem":1},{"text":"dan percayalah kepada TUHAN!","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"(4-7) Banyak orang berkata,","poem":1},{"text":"“Siapa dapat menunjukkan yang baik kepada kami?”","poem":2},{"text":"Kiranya terang wajah-Mu menyinari kami, ya TUHAN.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"(4-8) Engkau telah menaruh sukacita dalam hatiku,","poem":1},{"text":"lebih dari gandum dan anggur mereka yang melimpah.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"(4-9) Aku akan berbaring dan tidur dengan damai sejahtera;","poem":1},{"text":"sebab, hanya Engkau, ya TUHAN, yang membuat aku tinggal dengan aman.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/4.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/5.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/3.json","previousChapterAudioLinks":{},"numberOfVerses":8}