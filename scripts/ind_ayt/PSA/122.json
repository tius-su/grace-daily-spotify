{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":122,"content":[{"type":"heading","content":["Doa Seorang Peziarah untuk Yerusalem"]},{"type":"verse","number":1,"content":[{"text":"Nyanyian Ziarah Daud.","descriptive":true},{"lineBreak":true},{"text":"Aku bergembira ketika mereka berkata padaku,","poem":1},{"text":"“Ayo kita pergi ke rumah TUHAN!”.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Kaki kami berdiri dalam pintu-pintu gerbangmu, hai Yerusalem.","poem":1}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Yerusalem, dibangun sebagai kota yang tersambung bersama-sama.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Ke sana suku-suku mendaki,","poem":1},{"text":"yaitu suku-suku TUHAN,","poem":2},{"text":"sesuai dengan peraturan Israel,","poem":1},{"text":"untuk bersyukur kepada nama TUHAN.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Sebab, di sana takhta-takhta pengadilan berada,","poem":1},{"text":"yaitu takhta-takhta seisi rumah Daud.","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"Berdoalah bagi kedamaian Yerusalem:","poem":1},{"text":"“Kiranya sejahtera bagi mereka yang mengasihimu.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Kiranya kedamaian ada dalam tembok-tembokmu,","poem":1},{"text":"dan sejahtera di dalam benteng-bentengmu.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"Demi saudara-saudaraku dan sahabat-sahabatku,","poem":1},{"text":"aku akan berkata, “Kiranya damai ada dalammu.”","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Demi rumah TUHAN, Allah kita,","poem":1},{"text":"aku akan mencari kebaikanmu.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/122.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/123.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/121.json","previousChapterAudioLinks":{},"numberOfVerses":9}