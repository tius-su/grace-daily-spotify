{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":136,"content":[{"type":"heading","content":["Mazmur Ucapan Syukur atas Kasih Setia TUHAN"]},{"type":"verse","number":1,"content":[{"text":"Mengucap syukurlah kepada TUHAN karena Dia itu baik,","poem":1},{"text":"karena kasih setia-Nya untuk selama-lamanya.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Mengucap syukurlah kepada Allah segala ilah,","poem":1},{"text":"karena kasih setia-Nya untuk selama-lamanya.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Mengucap syukurlah kepada Tuan segala tuan,","poem":1},{"text":"karena kasih setia-Nya untuk selama-lamanya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"Kepada Dia, yang melakukan keajaiban-keajaiban besar seorang diri,","poem":1},{"text":"karena kasih setia-Nya untuk selama-lamanya.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Kepada Dia, yang menciptakan langit dengan pengertian,","poem":1},{"text":"karena kasih setia-Nya untuk selama-lamanya.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Kepada Dia, yang membentangkan bumi di atas air,","poem":1},{"text":"karena kasih setia-Nya untuk selama-lamanya.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Kepada Dia, yang menjadikan penerang-penerang yang besar,","poem":1},{"text":"karena kasih setia-Nya untuk selama-lamanya.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Matahari memerintah siang,","poem":1},{"text":"karena kasih setia-Nya untuk selama-lamanya.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Bulan dan bintang-bintang memerintah malam,","poem":1},{"text":"karena kasih setia-Nya untuk selama-lamanya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"Kepada Dia, yang membunuh anak-anak sulung Mesir,","poem":1},{"text":"karena kasih setia-Nya untuk selama-lamanya.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Dan, membawa Israel keluar dari antara mereka,","poem":1},{"text":"karena kasih setia-Nya untuk selama-lamanya.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Dengan tangan yang kuat dan lengan yang terangkat,","poem":1},{"text":"karena kasih setia-Nya untuk selama-lamanya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":13,"content":[{"text":"Kepada Dia, yang membelah Laut Teberau menjadi dua,","poem":1},{"text":"karena kasih setia-Nya untuk selama-lamanya;","poem":2}]},{"type":"verse","number":14,"content":[{"text":"lalu menyeberangkan Israel melewati tengah-tengahnya,","poem":1},{"text":"karena kasih setia-Nya untuk selama-lamanya;","poem":2}]},{"type":"verse","number":15,"content":[{"text":"tetapi, mengebaskan Firaun dan pasukannya ke dalam Laut Teberau,","poem":1},{"text":"karena kasih setia-Nya untuk selama-lamanya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":16,"content":[{"text":"Kepada Dia, yang memimpin umat-Nya melewati padang belantara,","poem":1},{"text":"karena kasih setia-Nya untuk selama-lamanya.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Kepada Dia, yang mengalahkan raja-raja besar,","poem":1},{"text":"karena kasih setia-Nya untuk selama-lamanya;","poem":2}]},{"type":"verse","number":18,"content":[{"text":"dan membunuh raja-raja berkuasa,","poem":1},{"text":"karena kasih setia-Nya untuk selama-lamanya.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Sihon, Raja Amori,","poem":1},{"text":"karena kasih setia-Nya untuk selama-lamanya.","poem":2}]},{"type":"verse","number":20,"content":[{"text":"Dan, Og, Raja Basan,","poem":1},{"text":"karena kasih setia-Nya untuk selama-lamanya;","poem":2}]},{"type":"verse","number":21,"content":[{"text":"serta menyerahkan tanah mereka sebagai suatu warisan,","poem":1},{"text":"karena kasih setia-Nya untuk selama-lamanya;","poem":2}]},{"type":"verse","number":22,"content":[{"text":"suatu warisan kepada Israel, hamba-Nya,","poem":1},{"text":"karena kasih setia-Nya untuk selama-lamanya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":23,"content":[{"text":"Yang mengingat kita dalam kerendahan kita,","poem":1},{"text":"karena kasih setia-Nya untuk selama-lamanya,","poem":2}]},{"type":"verse","number":24,"content":[{"text":"dan menyelamatkan kita dari lawan-lawan kita,","poem":1},{"text":"karena kasih setia-Nya untuk selama-lamanya.","poem":2}]},{"type":"verse","number":25,"content":[{"text":"Yang memberi makanan kepada semua makhluk,","poem":1},{"text":"karena kasih setia-Nya untuk selama-lamanya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":26,"content":[{"text":"Mengucap syukurlah kepada Allah semesta langit,","poem":1},{"text":"karena kasih setia-Nya untuk selama-lamanya.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/136.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/137.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/135.json","previousChapterAudioLinks":{},"numberOfVerses":26}