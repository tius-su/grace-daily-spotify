{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"MIC","translationId":"ind_ayt","name":"MIKHA","commonName":"MIKHA","title":"Mikha","order":33,"numberOfChapters":7,"sha256":"f705f0f00178dca0d8eb3aa04c7bab906dce4818786c08c96eae2f7e00ff24da","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/MIC/1.json","lastChapterNumber":7,"lastChapterApiLink":"/api/ind_ayt/MIC/7.json","totalNumberOfVerses":105},"chapter":{"number":6,"content":[{"type":"heading","content":["Tuntutan TUHAN"]},{"type":"verse","number":1,"content":["“Maka sekarang, dengarkanlah apa yang diucapkan TUHAN,",{"lineBreak":true},{"text":"‘Bangkitlah, belalah perkaramu di hadapan gunung-gunung!","poem":1},{"text":"Biarlah bukit-bukit mendengar suaramu.’”","poem":2}]},{"type":"verse","number":2,"content":[{"text":"“Dengarlah, hai gunung-gunung, pengaduan TUHAN,","poem":1},{"lineBreak":true},{"text":"dan hai kamu, dasar-dasar bumi yang kukuh!","poem":1},{"text":"Sebab, TUHAN beperkara terhadap umat-Nya,","poem":2},{"text":"dan Dia akan beperkara dengan Israel.”","poem":1}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"“Umat-Ku, apakah yang telah Kuperbuat kepadamu?","poem":1},{"text":"Dan, bagaimanakah Aku membebanimu?","poem":2},{"lineBreak":true},{"text":"Jawablah Aku!”","poem":2}]},{"type":"verse","number":4,"content":[{"text":"“Sesungguhnya, Akulah yang telah menuntunmu","poem":1},{"text":"keluar dari tanah Mesir,","poem":2},{"text":"dan telah menebusmu dari rumah perbudakan.","poem":1},{"text":"Aku telah mengutus","poem":2},{"text":"Musa, Harun, dan Miryam kepadamu.”","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"“Umat-Ku, ingatlah sekarang apa yang dirancangkan oleh Balak, raja Moab,","poem":1},{"text":"dan apa yang dijawab oleh Bileam, anak lelaki Beor,","poem":2},{"text":"dan apa yang terjadi di Sitim sampai ke Gilgal,","poem":1},{"text":"supaya kamu mengetahui perbuatan-perbuatan kebenaran TUHAN.”","poem":2}]},{"type":"verse","number":6,"content":[{"text":"“Dengan apakah aku harus menghadap TUHAN,","poem":1},{"text":"dan tunduk menyembah kepada Allah di tempat tinggi?","poem":2},{"text":"Apakah aku harus menghadap Dia dengan kurban-kurban bakaran,","poem":1},{"text":"dengan anak lembu berumur setahun?”","poem":2}]},{"type":"verse","number":7,"content":[{"text":"“Apakah TUHAN berkenan kepada ribuan domba jantan,","poem":1},{"text":"kepada puluhan ribu curahan minyak?","poem":2},{"text":"Haruskah aku mempersembahkan anak sulungku karena pelanggaranku","poem":1},{"text":"dan buah kandunganku atas dosaku sendiri?”","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"“Dia telah memberitahukan kepadamu, hai manusia, apa yang baik.","poem":1},{"text":"Dan, apakah yang dituntut TUHAN darimu,","poem":2},{"text":"selain berlaku adil,","poem":1},{"text":"mencintai kesetiaan,","poem":2},{"lineBreak":true},{"text":"dan hidup rendah hati di hadapan Allahmu?”","poem":2}]},{"type":"heading","content":["Dosa-Dosa Israel dan Hukumannya"]},{"type":"verse","number":9,"content":[{"text":"“Suara TUHAN berseru kepada kota,","poem":1},{"lineBreak":true},{"text":"Adalah bijaksana untuk takut kepada nama-Nya.","poem":1},{"text":"“Dengarlah, hai suku-suku bangsa dan orang yang berkumpul di kota!”","poem":2}]},{"type":"verse","number":10,"content":[{"text":"“Adakah harta benda kefasikan","poem":1},{"text":"di rumah orang fasik,","poem":2},{"text":"dan takaran efa yang kurang","poem":1},{"text":"dan terkutuk itu?”","poem":2}]},{"type":"verse","number":11,"content":[{"text":"“Masakan Aku membiarkan orang yang membenarkan neraca palsu","poem":1},{"text":"tidak dihukum","poem":2},{"text":"atau pundi-pundi","poem":1},{"text":"berisi batu timbangan tipu daya?”","poem":2}]},{"type":"verse","number":12,"content":[{"text":"“Sebab, orang-orang kaya di kota itu penuh dengan kekerasan,","poem":1},{"text":"penduduknya mengucapkan dusta,","poem":2},{"lineBreak":true},{"text":"dan lidah dalam mulut mereka penuh tipu daya.”","poem":2}]},{"type":"verse","number":13,"content":[{"text":"“Sebab itu, aku akan membuatmu sakit dengan memukulmu,","poem":1},{"text":"membuatmu hancur karena dosa-dosamu.”","poem":2}]},{"type":"verse","number":14,"content":[{"text":"“Kamu akan makan, tetapi tidak menjadi kenyang.","poem":1},{"text":"Kekosonganmu akan ada di dalammu.","poem":2},{"text":"Kamu akan menyingkirkan sesuatu,","poem":1},{"text":"tetapi tidak dapat menyelamatkannya.","poem":2},{"text":"Apa yang kamu selamatkan, akan Kuserahkan kepada pedang.”","poem":1}]},{"type":"verse","number":15,"content":[{"lineBreak":true},{"text":"“Kamu akan menabur","poem":1},{"text":"tetapi tidak akan menuai,","poem":2},{"text":"Kamu akan mengirik buah zaitun,","poem":1},{"text":"tetapi tidak berurap dengan minyaknya,","poem":2},{"text":"mengirik buah anggur,","poem":1},{"text":"tetapi tidak meminum hasil anggurnya.”","poem":2}]},{"type":"verse","number":16,"content":[{"text":"“Kamu berpegang pada ketetapan-ketetapan Omri","poem":1},{"text":"dan pada segala perbuatan keluarga Ahab.","poem":2},{"text":"Dan, kamu hidup mengikuti rancangan mereka","poem":1},{"text":"sehingga Aku menjadikanmu tandus,","poem":2},{"lineBreak":true},{"text":"dan pendudukmu akan menjadi sasaran cemoohan.","poem":2},{"text":"Demikianlah kamu akan menanggung cela","poem":1},{"text":"dari bangsa-bangsa.”","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/MIC/6.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/MIC/7.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/MIC/5.json","previousChapterAudioLinks":{},"numberOfVerses":16}