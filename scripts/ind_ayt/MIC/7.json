{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"MIC","translationId":"ind_ayt","name":"MIKHA","commonName":"MIKHA","title":"Mikha","order":33,"numberOfChapters":7,"sha256":"f705f0f00178dca0d8eb3aa04c7bab906dce4818786c08c96eae2f7e00ff24da","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/MIC/1.json","lastChapterNumber":7,"lastChapterApiLink":"/api/ind_ayt/MIC/7.json","totalNumberOfVerses":105},"chapter":{"number":7,"content":[{"type":"heading","content":["Kemerosotan Moral Israel"]},{"type":"verse","number":1,"content":[{"text":"“Celakalah aku! Sebab, keadaanku seperti saat mereka mengumpulkan buah-buahan musim kemarau,","poem":1},{"text":"seperti pada waktu pemetikan susulan buah anggur.","poem":2},{"text":"Tidak ada buah anggur untuk dimakan,","poem":1},{"text":"tidak ada buah ara yang kusukai.”","poem":2}]},{"type":"verse","number":2,"content":[{"text":"“Orang saleh telah hilang dari bumi,","poem":1},{"text":"tidak ada lagi orang benar di antara manusia.","poem":2},{"text":"Mereka semua mengincar darah,","poem":1},{"text":"setiap orang memburu yang lain dengan jaring.”","poem":2}]},{"type":"verse","number":3,"content":[{"text":"“Tangan mereka terampil berbuat jahat.","poem":1},{"text":"Pemimpin menuntut,","poem":2},{"text":"hakim dapat disuap, pembesar memberi keputusan sesuka hatinya,","poem":1},{"text":"dan mereka menutupinya!”","poem":2}]},{"type":"verse","number":4,"content":[{"text":"“Yang terbaik di antara mereka seperti duri,","poem":1},{"text":"yang paling jujur di antara mereka seperti pagar duri,","poem":2},{"text":"hari bagi pengintai-pengintaimu,","poem":1},{"text":"hari penghukumanmu sudah datang.","poem":2},{"text":"Kegemparan akan terjadi di antara mereka!”","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"“Jangan percaya kepada teman,","poem":1},{"text":"jangan mengandalkan diri pada sahabat!","poem":2},{"text":"Jagalah pintu mulutmu terhadap perempuan","poem":1},{"text":"yang berbaring di pelukanmu!”","poem":2}]},{"type":"verse","number":6,"content":[{"text":"“Sebab, anak laki-laki akan menghina ayahnya,","poem":1},{"text":"anak perempuan bangkit melawan ibunya,","poem":2},{"text":"menantu perempuan melawan ibu mertuanya,","poem":1},{"text":"musuh seseorang adalah orang-orang seisi rumahnya.”","poem":2}]},{"type":"heading","content":["Pengharapan Sion kepada TUHAN"]},{"type":"verse","number":7,"content":[{"text":"“Akan tetapi, aku menanti-nantikan TUHAN,","poem":1},{"text":"aku berharap kepada Allah yang menyelamatkan aku,","poem":2},{"lineBreak":true},{"text":"Allahku akan mendengarkan aku!”","poem":2}]},{"type":"verse","number":8,"content":[{"text":"“Janganlah bersukacita atas aku, hai musuh-musuhku!","poem":1},{"text":"Sekalipun aku jatuh, aku akan berdiri,","poem":2},{"text":"sekalipun aku duduk dalam gelap,","poem":1},{"text":"TUHAN akan menjadi terangku.”","poem":2}]},{"type":"verse","number":9,"content":[{"text":"“Aku akan menanggung murka Allah,","poem":1},{"text":"sebab aku telah berbuat dosa kepada-Nya,","poem":2},{"text":"sampai Dia memperjuangkan perkaraku","poem":1},{"text":"dan menegakkan keadilan bagiku.","poem":2},{"text":"Dia akan membawa aku ke dalam terang","poem":1},{"text":"dan aku akan melihat kebenaran-Nya.”","poem":2}]},{"type":"verse","number":10,"content":[{"text":"“Musuhku akan melihatnya dan malu akan meliputi","poem":1},{"text":"dia yang berkata kepadaku, ‘Di manakah TUHAN Allahmu?’","poem":2},{"text":"Mataku akan melihatnya,","poem":1},{"text":"sekarang ia akan diinjak-injak seperti lumpur jalanan.”","poem":2}]},{"type":"verse","number":11,"content":[{"text":"“Pada hari pembangunan pagar tembokmu,","poem":1},{"text":"pada hari itu, perbatasanmu akan diperluas.”","poem":2}]},{"type":"verse","number":12,"content":[{"text":"“Pada hari itu, orang-orang akan datang kepadamu","poem":1},{"text":"dari Asyur dan ke kota-kota Mesir,","poem":2},{"text":"dari Mesir sampai ke Sungai Efrat,","poem":1},{"text":"dari laut ke laut,","poem":2},{"text":"dan dari gunung ke gunung.”","poem":1}]},{"type":"line_break"},{"type":"verse","number":13,"content":[{"text":"“Dan, bumi akan menjadi sunyi karena penduduknya,","poem":1},{"text":"karena hasil perbuatan-perbuatan mereka.”","poem":2}]},{"type":"heading","content":["Doa Memohon Belas Kasih Allah"]},{"type":"verse","number":14,"content":[{"text":"“Gembalakanlah umat-Mu dengan tongkat-Mu,","poem":1},{"text":"domba-domba milik pusaka-Mu,","poem":2},{"text":"yang terpencil mendiami hutan","poem":1},{"text":"di tengah-tengah Karmel.","poem":2},{"text":"Biarkan mereka makan rumput di Basan dan di Gilead,","poem":1},{"text":"seperti pada zaman dahulu kala.”","poem":2}]},{"type":"verse","number":15,"content":[{"text":"“Seperti pada waktu kamu keluar dari tanah Mesir,","poem":1},{"text":"Aku akan memperlihatkan kepadamu perbuatan-perbuatan yang ajaib.”","poem":2}]},{"type":"verse","number":16,"content":[{"text":"“Bangsa-bangsa akan melihat dan menjadi malu","poem":1},{"text":"atas semua kekuatan mereka,","poem":2},{"text":"mereka akan menutup mulutnya dengan tangan,","poem":1},{"text":"dan telinganya akan menjadi tuli.”","poem":2}]},{"type":"verse","number":17,"content":[{"text":"“Mereka akan menjilat debu seperti ular,","poem":1},{"text":"seperti binatang merayap di bumi.","poem":2},{"text":"Mereka akan keluar dengan gemetar","poem":1},{"text":"dari kubunya,","poem":2},{"lineBreak":true},{"text":"menghadap kepada TUHAN, Allah kita,","poem":2},{"text":"mereka akan datang dengan gentar.","poem":1},{"text":"Mereka akan takut terhadapmu!”","poem":2}]},{"type":"verse","number":18,"content":[{"text":"“Siapakah Allah yang seperti Engkau,","poem":1},{"text":"yang mengampuni dosa,","poem":2},{"text":"yang memaafkan pelanggaran dari","poem":1},{"text":"sisa-sisa milik pusaka-Nya?","poem":2},{"text":"Engkau tidak menahan murka-Nya untuk seterusnya,","poem":1},{"text":"sebab Engkau berkenan kepada kasih setia.”","poem":2}]},{"type":"verse","number":19,"content":[{"text":"“Dia akan kembali mengasihani kita,","poem":1},{"text":"menghapuskan kesalahan-kesalahan kita,","poem":2},{"lineBreak":true},{"text":"dan melemparkan segala dosa kita ke kedalaman laut.”","poem":2}]},{"type":"verse","number":20,"content":[{"text":"“Engkau akan menunjukkan kesetiaan-Mu kepada Yakub","poem":1},{"text":"dan belas kasih-Mu kepada Abraham,","poem":2},{"lineBreak":true},{"text":"seperti yang telah Kaujanjikan dengan bersumpah kepada nenek moyang kami sejak zaman dahulu.”","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/MIC/7.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/NAM/1.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/MIC/6.json","previousChapterAudioLinks":{},"numberOfVerses":20}