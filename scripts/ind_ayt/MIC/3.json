{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"MIC","translationId":"ind_ayt","name":"MIKHA","commonName":"MIKHA","title":"Mikha","order":33,"numberOfChapters":7,"sha256":"f705f0f00178dca0d8eb3aa04c7bab906dce4818786c08c96eae2f7e00ff24da","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/MIC/1.json","lastChapterNumber":7,"lastChapterApiLink":"/api/ind_ayt/MIC/7.json","totalNumberOfVerses":105},"chapter":{"number":3,"content":[{"type":"heading","content":["Teguran bagi Pemimpin dan Nabi Palsu di Israel"]},{"type":"verse","number":1,"content":[{"text":"“Aku berkata, ‘Hendaknya kamu mendengar, hai para pemimpin Yakub dan para pemimpin kaum Israel!","poem":1},{"text":"Bukankah seharusnya kamu mengetahui keadilan?’”","poem":2}]},{"type":"verse","number":2,"content":[{"text":"“Kamu yang membenci kebaikan dan mencintai kejahatan,","poem":1},{"text":"yang mencabik kulit dari bangsaku,","poem":2},{"lineBreak":true},{"text":"dan daging dari tulang-tulangnya,","poem":2}]},{"type":"verse","number":3,"content":[{"text":"yang memakan daging bangsaku,","poem":1},{"text":"mengupas kulit dari tubuhnya,","poem":2},{"text":"meremukkan tulang-tulangnya,","poem":1},{"text":"dan mencincangnya seperti daging dalam kuali,","poem":2},{"text":"seperti potongan-potongan daging dalam periuk.”","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"“Mereka akan berseru-seru kepada TUHAN,","poem":1},{"text":"tetapi Dia tidak akan menjawabnya.","poem":2},{"text":"Dia akan menyembunyikan wajah-Nya dari mereka pada waktu itu,","poem":1},{"text":"sebab perbuatan mereka jahat.”","poem":2}]},{"type":"verse","number":5,"content":["“Beginilah firman TUHAN kepada para nabi yang menyesatkan bangsaku:",{"lineBreak":true},{"text":"‘Jika mereka mendapat sesuatu untuk dikunyah,","poem":1},{"text":"mereka menyerukan damai,","poem":2},{"text":"tetapi terhadap orang-orang yang tidak memberikan apa pun ke dalam mulut mereka,","poem":1},{"text":"mereka akan siap berperang melawannya.’”","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"“Sebab itu, hari akan menjadi malam bagimu tanpa penglihatan,","poem":1},{"text":"dan kegelapan bagimu tanpa ramalan.","poem":2},{"lineBreak":true},{"text":"Matahari akan terbenam","poem":2},{"text":"bagi nabi-nabi itu,","poem":1},{"text":"dan hari akan menjadi kelam","poem":2},{"lineBreak":true},{"text":"bagi mereka.”","poem":2}]},{"type":"verse","number":7,"content":[{"text":"“Para pelihat akan dipermalukan,","poem":1},{"text":"dan para peramal akan dicela,","poem":2},{"text":"Ya, mereka semua akan menutupi mulutnya,","poem":1},{"text":"sebab tidak ada jawaban dari Allah.”","poem":2}]},{"type":"verse","number":8,"content":[{"text":"“Sebaliknya, aku ini penuh dengan kekuatan,","poem":1},{"text":"dengan Roh TUHAN, dengan keadilan dan keperkasaan,","poem":2},{"text":"untuk memberitahukan kepada Yakub pelanggarannya,","poem":1},{"text":"dan kepada orang Israel dosanya.”","poem":2}]},{"type":"verse","number":9,"content":[{"text":"“Baiklah, dengarkanlah ini, hai para kepala kaum Yakub dan para pemimpin kaum Israel,","poem":1},{"text":"yang merendahkan keadilan","poem":2},{"text":"dan membengkokkan segala yang lurus.","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Mereka membangun Sion dengan darah","poem":1},{"text":"dan Yerusalem dengan kejahatan.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Para pemimpinnya mengadili karena suap,","poem":1},{"text":"para imamnya mengajar karena bayaran,","poem":2},{"text":"para nabinya meramal karena uang,","poem":1},{"text":"padahal mereka bersandar kepada TUHAN dengan berkata,","poem":2},{"text":"‘Bukankah TUHAN ada di tengah-tengah kita?","poem":1},{"text":"Tidak akan ada malapetaka yang datang menimpa kita.’”","poem":2}]},{"type":"line_break"},{"type":"verse","number":12,"content":[{"text":"“Sebab itu, karena kamu,","poem":1},{"text":"Sion akan dibajak seperti ladang,","poem":2},{"text":"Yerusalem akan menjadi timbunan puing,","poem":1},{"text":"gunung Bait Suci akan menjadi bukit yang berhutan.”","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/MIC/3.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/MIC/4.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/MIC/2.json","previousChapterAudioLinks":{},"numberOfVerses":12}