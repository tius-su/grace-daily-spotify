{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"MIC","translationId":"ind_ayt","name":"MIKHA","commonName":"MIKHA","title":"Mikha","order":33,"numberOfChapters":7,"sha256":"f705f0f00178dca0d8eb3aa04c7bab906dce4818786c08c96eae2f7e00ff24da","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/MIC/1.json","lastChapterNumber":7,"lastChapterApiLink":"/api/ind_ayt/MIC/7.json","totalNumberOfVerses":105},"chapter":{"number":4,"content":[{"type":"heading","content":["Hukum Akan Datang dari Yerusalem"]},{"type":"verse","number":1,"content":[{"text":"“Akan terjadi pada hari-hari terakhir, gunung kediaman TUHAN","poem":1},{"text":"akan didirikan di puncak gunung-gunung","poem":2},{"text":"dan akan ditinggikan melebihi bukit-bukit.","poem":1},{"text":"Suku-suku bangsa akan beramai-ramai ke sana.”","poem":2}]},{"type":"verse","number":2,"content":[{"text":"“Banyak orang akan datang dan berkata,","poem":1},{"text":"“Mari, kita naik ke gunung TUHAN,","poem":2},{"lineBreak":true},{"text":"ke kediaman Allah Yakub.","poem":2},{"text":"Dia akan mengajarkan jalan-jalan-Nya kepada kita","poem":1},{"text":"sehingga kita akan berjalan di jalan-jalan-Nya.”","poem":2},{"lineBreak":true},{"text":"“Sebab, dari Sion akan keluar hukum,","poem":1},{"text":"dan firman TUHAN dari Yerusalem.”","poem":2}]},{"type":"verse","number":3,"content":[{"text":"“Dia akan menjadi hakim di antara banyak suku bangsa","poem":1},{"text":"dan memutuskan perkara bagi bangsa-bangsa yang besar sampai ke tempat yang jauh.","poem":2},{"text":"Mereka akan menempa pedang mereka menjadi mata bajak,","poem":1},{"text":"dan tombak mereka menjadi sabit.","poem":2},{"lineBreak":true},{"text":"Bangsa tidak akan mengangkat pedang melawan bangsa,","poem":2},{"text":"dan mereka tidak akan lagi belajar berperang.”","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"“Masing-masing orang akan duduk","poem":1},{"text":"di bawah pohon anggur dan di bawah pohon aranya,","poem":2},{"text":"dan tidak ada yang akan membuat mereka takut,","poem":1},{"text":"sebab mulut TUHAN semesta alam yang berfirman.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"“Sekali pun segala bangsa berjalan demi nama ilahnya masing-masing,","poem":1},{"text":"tetapi kita akan berjalan demi nama TUHAN Allah kita untuk seterusnya dan selama-lamanya.”","poem":2}]},{"type":"heading","content":["Putri Sion Diselamatkan"]},{"type":"verse","number":6,"content":["“Pada hari itu,” firman TUHAN,",{"lineBreak":true},{"text":"“Aku akan mengumpulkan mereka yang pincang","poem":1},{"text":"dan menghimpun orang-orang yang tercerai berai","poem":2},{"lineBreak":true},{"text":"dan yang telah Kucelakakan.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"“Aku akan menjadikan mereka yang pincang sebagai sisa-sisa bangsa,","poem":1},{"text":"dan mereka yang terbuang menjadi bangsa yang kuat.","poem":2},{"text":"TUHAN akan memerintah atas mereka di Gunung Sion,","poem":1},{"text":"mulai sekarang sampai selama-lamanya.”","poem":2}]},{"type":"verse","number":8,"content":[{"text":"“Engkau, hai Menara Kawanan Domba,","poem":1},{"text":"hai bukit putri Sion,","poem":2},{"text":"akan tiba kepadamu","poem":1},{"text":"dan akan datang pemerintahan yang semula,","poem":2},{"text":"kerajaan putri Yerusalem.”","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"“Sekarang, mengapa kamu menangis keras?","poem":1},{"text":"Tidak adakah raja di tengah-tengahmu?","poem":2},{"text":"Binasakah penasihatmu","poem":1},{"text":"sehingga kesakitan menimpamu seperti perempuan yang melahirkan?”","poem":2}]},{"type":"verse","number":10,"content":[{"text":"“Menggeliatlah dan mengeranglah, hai putri Sion,","poem":1},{"text":"seperti perempuan yang melahirkan.","poem":2},{"text":"Sebab, sekarang kamu harus keluar meninggalkan kota","poem":1},{"text":"dan tinggal di padang,","poem":2},{"text":"dan pergi ke Babel.","poem":1},{"text":"Di sanalah kamu akan diselamatkan,","poem":2},{"text":"di sanalah kamu akan ditebus TUHAN","poem":1},{"text":"dari tangan musuhmu.”","poem":2}]},{"type":"verse","number":11,"content":[{"text":"“Sekarang, banyak bangsa berkumpul melawan kamu,","poem":1},{"text":"yang berkata, ‘Biarlah ia dicemarkan,","poem":2},{"lineBreak":true},{"text":"biarlah mata kita memandangi Sion!’”","poem":2}]},{"type":"line_break"},{"type":"verse","number":12,"content":[{"text":"“Akan tetapi, mereka tidak mengetahui pikiran TUHAN,","poem":1},{"text":"mereka tidak mengerti rancangan-Nya,","poem":2},{"text":"bahwa Dia akan menghimpun mereka","poem":1},{"text":"seperti berkas gandum","poem":2},{"text":"ke tempat pengirikan.”","poem":1}]},{"type":"verse","number":13,"content":[{"lineBreak":true},{"text":"“Bangkitlah dan gasaklah mereka,","poem":1},{"lineBreak":true},{"text":"hai putri-putri Sion!","poem":1},{"text":"Sebab, Aku akan menjadikan tandukmu besi,","poem":2},{"lineBreak":true},{"text":"dan Aku akan membuat kukumu perunggu.","poem":2},{"text":"Kamu akan menghancurkan banyak bangsa,","poem":1},{"text":"kamu akan mengkhususkan rampasan mereka bagi TUHAN,","poem":2},{"text":"dan kekayaan mereka bagi Tuhan seluruh bumi!”","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/MIC/4.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/MIC/5.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/MIC/3.json","previousChapterAudioLinks":{},"numberOfVerses":13}