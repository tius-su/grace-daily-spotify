{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"SNG","translationId":"ind_ayt","name":"KIDUNG AGUNG","commonName":"KIDUNG AGUNG","title":"Kidung Agung","order":22,"numberOfChapters":8,"sha256":"d921ad878990af8ae19798395cb2d70e8f7236816f100359927e731bfdded114","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/SNG/1.json","lastChapterNumber":8,"lastChapterApiLink":"/api/ind_ayt/SNG/8.json","totalNumberOfVerses":117},"chapter":{"number":5,"content":[{"type":"heading","content":["Pengantin Laki-laki Berbicara"]},{"type":"verse","number":1,"content":[{"text":"Aku sudah masuk ke kebunku, dindaku, pengantin perempuanku.","poem":1},{"text":"Aku sudah mengumpulkan mur dan rempah-rempahku.","poem":2},{"text":"Aku sudah makan sarang maduku dan maduku.","poem":1},{"text":"Aku sudah minum anggurku dan susuku.","poem":2},{"lineBreak":true},{"text":"Makanlah, hai sahabat-sahabatku, dan minumlah.","poem":1},{"text":"Mabuklah dengan cinta!","poem":2}]},{"type":"line_break"},{"type":"heading","content":["Kerinduan Pengantin Perempuan"]},{"type":"verse","number":2,"content":[{"text":"Aku tidur,","poem":1},{"text":"tetapi hatiku bangun.","poem":2},{"text":"Ada suara! Kekasihku mengetuk,","poem":1},{"text":"“Bukakanlah bagiku, dindaku, sayangku, merpatiku, idamanku!","poem":2},{"text":"Sebab, kepalaku penuh dengan embun,","poem":1},{"text":"rambut ikalku dengan tetesan embun malam.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Aku telah menanggalkan jubahku,","poem":1},{"text":"bagaimana bisa aku mengenakannya kembali?","poem":2},{"text":"Aku sudah membasuh kakiku,","poem":1},{"text":"bagaimana bisa aku mengotorinya kembali?","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"Kekasihku mengulurkan tangannya melalui lubang pintu,","poem":1},{"text":"dan hatiku berdebar-debar karena dia.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Aku bangkit untuk membukakan pintu bagi kekasihku;","poem":1},{"text":"tanganku berteteskan mur,","poem":2},{"lineBreak":true},{"text":"dan jari-jariku beralirkan mur pada pegangan pengancing pintu.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Aku membukakan pintu bagi kekasihku,","poem":1},{"text":"tetapi kekasihku telah berbalik, dan pergi!","poem":2},{"text":"Jiwaku menghilang","poem":1},{"text":"ketika dia berbicara.","poem":2},{"text":"Aku mencarinya,","poem":1},{"text":"tetapi tidak menemukannya.","poem":2},{"text":"Aku memanggilnya,","poem":1},{"text":"tetapi dia tidak menjawabku.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Para penjaga menemukanku ketika mereka berkeliling kota.","poem":1},{"text":"Mereka memukuliku","poem":2},{"lineBreak":true},{"text":"dan melukaiku.","poem":2},{"text":"Para penjaga tembok mengambil tudungku.","poem":1}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"Aku menyumpahimu, hai putri-putri Yerusalem,","poem":1},{"text":"jika kamu menemukan kekasihku,","poem":2},{"lineBreak":true},{"text":"apa yang akan kamu katakan kepadanya? Bahwa aku sakit asmara!","poem":2}]},{"type":"line_break"},{"type":"heading","content":["Pengantin Perempuan Memuji Kekasihnya di Hadapan Putri-Putri Yerusalem"]},{"type":"verse","number":9,"content":[{"text":"Apakah kekasihmu melebihi kekasih lainnya,","poem":1},{"text":"hai yang tercantik di antara segala perempuan?","poem":2},{"text":"Apakah kekasihmu melebihi kekasih lainnya","poem":1},{"text":"sehingga kamu menyumpahi kami demikian?","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"Kekasihku berseri-seri dan kemerah-merahan,","poem":1},{"text":"mencolok di antara sepuluh ribu orang.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Kepalanya bagaikan emas murni.","poem":1},{"text":"Rambut ikalnya bergelombang,","poem":2},{"lineBreak":true},{"text":"hitam seperti gagak.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Matanya bagaikan merpati di samping aliran air,","poem":1},{"text":"yang mandi dengan susu,","poem":2},{"lineBreak":true},{"text":"dan duduk dalam kepenuhan.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Pipinya bagaikan petak rempah-rempah,","poem":1},{"text":"kumpulan rempah-rempah wangi.","poem":2},{"text":"Bibirnya bagaikan bunga-bunga bakung,","poem":1},{"text":"yang meneteskan titik-titik mur.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Tangannya bagaikan batang emas,","poem":1},{"text":"yang penuh dengan batu-batu permata.","poem":2},{"text":"Perutnya bagaikan gading ukir,","poem":1},{"text":"yang dilapisi dengan permata safir.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Kakinya bagaikan pilar-pilar marmer,","poem":1},{"text":"yang didasarkan pada alas emas murni.","poem":2},{"text":"Penampilannya bagaikan Lebanon, terpilih seperti pohon-pohon arasnya.","poem":1}]},{"type":"verse","number":16,"content":[{"lineBreak":true},{"text":"Mulutnya manis, segala sesuatu darinya diidamkan.","poem":1},{"text":"Inilah kekasihku! Inilah sahabatku, hai putri-putri Yerusalem.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/SNG/5.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/SNG/6.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/SNG/4.json","previousChapterAudioLinks":{},"numberOfVerses":16}