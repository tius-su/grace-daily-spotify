{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"SNG","translationId":"ind_ayt","name":"KIDUNG AGUNG","commonName":"KIDUNG AGUNG","title":"Kidung Agung","order":22,"numberOfChapters":8,"sha256":"d921ad878990af8ae19798395cb2d70e8f7236816f100359927e731bfdded114","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/SNG/1.json","lastChapterNumber":8,"lastChapterApiLink":"/api/ind_ayt/SNG/8.json","totalNumberOfVerses":117},"chapter":{"number":4,"content":[{"type":"heading","content":["Pengantin Laki-laki Memuji Pengantin Perempuan"]},{"type":"verse","number":1,"content":[{"text":"Lihat, cantiknya engkau, kekasihku!","poem":1},{"text":"Lihat, cantiknya engkau!","poem":2},{"text":"Matamu bagaikan merpati","poem":1},{"text":"di balik cadarmu.","poem":2},{"text":"Rambutmu bagaikan kawanan kambing yang menuruni Gunung Gilead.","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Gigimu bagaikan kawanan domba yang baru digunting,","poem":1},{"text":"yang keluar dari pencuciannya.","poem":2},{"text":"Semuanya itu beranak kembar,","poem":1},{"text":"dan tidak satu pun dari mereka kehilangan anaknya.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Bibirmu bagaikan seutas tali kirmizi,","poem":1},{"text":"dan mulutmu itu elok.","poem":2},{"text":"Pelipismu bagaikan irisan-irisan buah delima","poem":1},{"text":"di balik cadarmu.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Lehermu bagaikan menara Daud, yang dibangun dalam barisan-barisan batu,","poem":1},{"lineBreak":true},{"text":"yang padanya bergantungan seribu perisai,","poem":1},{"text":"semuanya perisai orang-orang perkasa.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Kedua buah dadamu","poem":1},{"text":"bagaikan dua anak rusa, anak kembar kijang,","poem":2},{"lineBreak":true},{"text":"yang merumput di antara bunga-bunga bakung.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Sampai siang hari berembus,","poem":1},{"text":"dan bayang-bayang menghilang,","poem":2},{"lineBreak":true},{"text":"aku akan pergi ke gunung mur, dan ke bukit kemenyan.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Engkau cantik seutuhnya, kekasihku.","poem":1},{"text":"Tidak ada cacat padamu.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Datanglah bersamaku dari Lebanon, pengantin perempuanku,","poem":1},{"text":"bersamaku dari Lebanon.","poem":2},{"text":"Pandanglah dari Puncak Amana,","poem":1},{"text":"dari Puncak Senir dan Hermon,","poem":2},{"text":"dari sarang-sarang singa,","poem":1},{"text":"dan dari bukit-bukit macan tutul.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Engkau telah mencuri hatiku,","poem":1},{"text":"dindaku, pengantin perempuanku.","poem":2},{"text":"Engkau telah mencuri hatiku","poem":1},{"text":"dengan sekejapan matamu,","poem":2},{"lineBreak":true},{"text":"dengan seuntai kalung di lehermu.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Betapa indahnya cintamu, dindaku, pengantin perempuanku!","poem":1},{"text":"Betapa lebih baik cintamu daripada anggur,","poem":2},{"text":"dan keharuman minyakmu","poem":1},{"text":"melebihi segala jenis rempah-rempah!","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Bibirmu meneteskan madu murni, pengantin perempuanku.","poem":1},{"text":"Madu dan susu ada di bawah lidahmu.","poem":2},{"lineBreak":true},{"text":"Keharuman pakaianmu seperti aroma Lebanon.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Dindaku, pengantin perempuanku, adalah taman yang terkunci,","poem":1},{"text":"mata air yang terkunci,","poem":2},{"lineBreak":true},{"text":"air mancur yang termeterai.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Tunas-tunasmu bagaikan kebun buah delima","poem":1},{"text":"dengan buah-buahnya terbaik, bunga pacar dan narwastu,","poem":2}]},{"type":"verse","number":14,"content":[{"text":"narwastu dan kunyit, tebu dan kayu manis,","poem":1},{"lineBreak":true},{"text":"dengan segala jenis pohon kemenyan,","poem":1},{"text":"mur, dan gaharu, dengan segala jenis rempah-rempah terpilih.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Engkau bagaikan mata air taman,","poem":1},{"text":"sumur air hidup,","poem":2},{"lineBreak":true},{"text":"yang mengalir dari Lebanon.","poem":2}]},{"type":"heading","content":["Kedua Pengantin Saling Menyapa"]},{"type":"verse","number":16,"content":[{"text":"Bangunlah, hai angin utara,","poem":1},{"text":"dan datanglah, hai angin selatan.","poem":2},{"text":"Bertiuplah di kebunku","poem":1},{"text":"supaya aroma rempah-rempahnya menyebar.","poem":2},{"text":"Biarlah kekasihku datang ke kebunnya,","poem":1},{"text":"dan makan buah-buah terbaiknya.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/SNG/4.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/SNG/5.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/SNG/3.json","previousChapterAudioLinks":{},"numberOfVerses":16}