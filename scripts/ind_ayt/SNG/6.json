{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"SNG","translationId":"ind_ayt","name":"KIDUNG AGUNG","commonName":"KIDUNG AGUNG","title":"Kidung Agung","order":22,"numberOfChapters":8,"sha256":"d921ad878990af8ae19798395cb2d70e8f7236816f100359927e731bfdded114","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/SNG/1.json","lastChapterNumber":8,"lastChapterApiLink":"/api/ind_ayt/SNG/8.json","totalNumberOfVerses":117},"chapter":{"number":6,"content":[{"type":"heading","content":["Putri-Putri Yerusalem Menjawab Pengantin Perempuan"]},{"type":"verse","number":1,"content":[{"text":"Ke mana kekasihmu pergi,","poem":1},{"text":"hai yang tercantik di antara para perempuan?","poem":2},{"text":"Ke mana kekasihmu berbelok,","poem":1},{"text":"supaya kami dapat mencarinya bersamamu?","poem":2}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"Kekasihku telah turun ke kebunnya,","poem":1},{"text":"ke petak-petak rempah-rempah,","poem":2},{"text":"untuk menggembala di kebun,","poem":1},{"text":"dan mengumpulkan bunga-bunga bakung.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Aku adalah milik kekasihku,","poem":1},{"text":"dan kekasihku adalah milikku.","poem":2},{"text":"Dia menggembala","poem":1},{"text":"di antara bunga-bunga bakung.","poem":2}]},{"type":"line_break"},{"type":"heading","content":["Pengantin Laki-laki Memuji Kekasihnya"]},{"type":"verse","number":4,"content":[{"text":"Engkau cantik seperti Tirza, kekasihku,","poem":1},{"text":"elok seperti Yerusalem,","poem":2},{"lineBreak":true},{"text":"dan menakjubkan seperti bala tentara dengan panji-panjinya.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Alihkan matamu dariku","poem":1},{"text":"karena mereka membingungkanku.","poem":2},{"text":"Rambutmu bagaikan kawanan kambing betina yang menuruni Gunung Gilead.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Gigimu bagaikan kawanan domba betina","poem":1},{"text":"yang keluar dari pencuciannya.","poem":2},{"text":"Semuanya itu beranak kembar,","poem":1},{"text":"dan tidak satu pun dari mereka kehilangan anaknya.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Pelipismu bagaikan irisan-irisan buah delima","poem":1},{"text":"di balik cadarmu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"Ada enam puluh permaisuri,","poem":1},{"text":"dan delapan puluh gundik,","poem":2},{"lineBreak":true},{"text":"dan gadis-gadis yang tidak terhitung.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Namun, dialah satu-satunya merpatiku, idamanku, putri tunggal ibunya,","poem":1},{"lineBreak":true},{"text":"anak kesayangan bagi orang yang melahirkannya.","poem":1},{"lineBreak":true},{"text":"Anak-anak perempuan memandangnya, dan menyebutnya berbahagia.","poem":1},{"text":"Permaisuri-permaisuri dan selir-selir memujinya.","poem":2}]},{"type":"line_break"},{"type":"heading","content":["Putri-Putri Yerusalem Memuji Pengantin Perempuan"]},{"type":"verse","number":10,"content":[{"text":"Siapakah ini, yang memandang ke bawah bagaikan fajar,","poem":1},{"lineBreak":true},{"text":"cantik bagaikan bulan,","poem":1},{"text":"bercahaya bagaikan matahari,","poem":2},{"lineBreak":true},{"text":"dan menakjubkan seperti bala tentara dengan panji-panjinya?","poem":2}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"Aku turun ke kebun kenari","poem":1},{"text":"untuk melihat tunas-tunas hijau di lembah,","poem":2},{"text":"dan untuk melihat apabila pohon-pohon anggur sudah bertunas,","poem":1},{"text":"dan pohon-pohon delima sudah berbunga.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Tanpa sadar, jiwaku menempatkanku di atas kereta-kereta","poem":1},{"text":"para bangsawan.","poem":2}]},{"type":"line_break"},{"type":"verse","number":13,"content":[{"text":"Kembalilah, kembalilah, hai gadis Sulam!","poem":1},{"text":"Kembalilah, kembalilah,","poem":2},{"lineBreak":true},{"text":"supaya kami dapat memandangmu.","poem":2},{"lineBreak":true},{"text":"Mengapa kamu menatap gadis Sulam,","poem":1},{"text":"seperti tarian Mahanaim?","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/SNG/6.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/SNG/7.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/SNG/5.json","previousChapterAudioLinks":{},"numberOfVerses":13}