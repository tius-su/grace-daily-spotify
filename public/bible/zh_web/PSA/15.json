{"translation":{"id":"zh_web","name":"和合本","shortName":"CUV","englishName":"Chinese Union Version","language":"zho","languageName":"繁體/简体中文"},"book":{"id":"PSA","translationId":"zh_web","name":"诗篇","commonName":"诗篇","title":"诗篇","order":19,"numberOfChapters":150},"chapter":{"number":15,"content":[{"type":"verse","number":1,"content":["耶和华啊，谁能寄居在你的圣所？ 谁能住在你的圣山？"]},{"type":"verse","number":2,"content":["就是行为正直、做公义的事， 心里说真话的人；"]},{"type":"verse","number":3,"content":["他不以舌头毁谤人， 不恶待朋友， 也不辱骂邻舍；"]},{"type":"verse","number":4,"content":["在他眼中，卑劣的人被藐视， 但他尊重敬畏耶和华的人； 他起了誓，即使自己受损，也不改变；"]},{"type":"verse","number":5,"content":["他不放债取利， 也不收受贿赂陷害无辜的人。 做这些事的人，必永不动摇。"]}]},"numberOfVerses":5}