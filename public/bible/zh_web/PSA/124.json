{"translation":{"id":"zh_web","name":"和合本","shortName":"CUV","englishName":"Chinese Union Version","language":"zho","languageName":"繁體/简体中文"},"book":{"id":"PSA","translationId":"zh_web","name":"诗篇","commonName":"诗篇","title":"诗篇","order":19,"numberOfChapters":150},"chapter":{"number":124,"content":[{"type":"verse","number":1,"content":["若不是耶和华帮助我们， 愿以色列现在说，"]},{"type":"verse","number":2,"content":["若不是耶和华帮助我们， 当人起来攻击我们的时候，"]},{"type":"verse","number":3,"content":["那时，他们向我们发怒，怒气燃起， 就把我们活活吞了。"]},{"type":"verse","number":4,"content":["那时，洪水就淹没我们， 急流就漫过我们的性命。"]},{"type":"verse","number":5,"content":["那时，狂傲的洪水就漫过我们的性命。"]},{"type":"verse","number":6,"content":["耶和华是应当称颂的， 祂没有把我们交给他们的牙齿作猎物。"]},{"type":"verse","number":7,"content":["我们的性命像鸟一样，从捕鸟人的网罗中逃脱； 网罗破裂，我们逃脱了。"]},{"type":"verse","number":8,"content":["我们的帮助在乎耶和华的名， 祂创造了天地。"]}]},"numberOfVerses":8}