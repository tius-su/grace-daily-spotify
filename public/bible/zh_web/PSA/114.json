{"translation":{"id":"zh_web","name":"和合本","shortName":"CUV","englishName":"Chinese Union Version","language":"zho","languageName":"繁體/简体中文"},"book":{"id":"PSA","translationId":"zh_web","name":"诗篇","commonName":"诗篇","title":"诗篇","order":19,"numberOfChapters":150},"chapter":{"number":114,"content":[{"type":"verse","number":1,"content":["以色列出埃及的时候， 雅各家离开说异族语言的民；"]},{"type":"verse","number":2,"content":["犹大成了祂的圣所， 以色列成了祂的领土。"]},{"type":"verse","number":3,"content":["海看见了，就逃跑； 约旦河也倒流。"]},{"type":"verse","number":4,"content":["群山跳跃如公羊， 小山跳跃如羊羔。"]},{"type":"verse","number":5,"content":["海啊，你为什么逃跑？ 约旦河啊，你为什么倒流？"]},{"type":"verse","number":6,"content":["群山啊，你们为什么跳跃如公羊？ 小山啊，你们为什么跳跃如羊羔？"]},{"type":"verse","number":7,"content":["大地啊，你要在主面前战栗， 在雅各的上帝面前战栗；"]},{"type":"verse","number":8,"content":["祂使磐石变为水池， 使坚石变为水泉。"]}]},"numberOfVerses":8}