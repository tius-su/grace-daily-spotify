{"translation":{"id":"zh_web","name":"和合本","shortName":"CUV","englishName":"Chinese Union Version","language":"zho","languageName":"繁體/简体中文"},"book":{"id":"PSA","translationId":"zh_web","name":"诗篇","commonName":"诗篇","title":"诗篇","order":19,"numberOfChapters":150},"chapter":{"number":67,"content":[{"type":"verse","number":1,"content":["愿上帝怜悯我们，赐福给我们， 使祂的脸光照我们。 细拉。"]},{"type":"verse","number":2,"content":["好让人在地上认识你的道路， 在万国中认识你的救恩。"]},{"type":"verse","number":3,"content":["上帝啊，愿万民称赞你； 愿万民都称赞你。"]},{"type":"verse","number":4,"content":["愿列国欢喜，欢呼歌唱， 因为你必按公正审判万民， 并治理地上的列国。 细拉。"]},{"type":"verse","number":5,"content":["上帝啊，愿万民称赞你； 愿万民都称赞你。"]},{"type":"verse","number":6,"content":["地已经产出土产； 上帝，就是我们的上帝，必赐福给我们。"]},{"type":"verse","number":7,"content":["上帝必赐福给我们； 地的四极都要敬畏祂。"]}]},"numberOfVerses":7}