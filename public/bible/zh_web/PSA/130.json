{"translation":{"id":"zh_web","name":"和合本","shortName":"CUV","englishName":"Chinese Union Version","language":"zho","languageName":"繁體/简体中文"},"book":{"id":"PSA","translationId":"zh_web","name":"诗篇","commonName":"诗篇","title":"诗篇","order":19,"numberOfChapters":150},"chapter":{"number":130,"content":[{"type":"verse","number":1,"content":["我从深处向你呼求，耶和华啊。"]},{"type":"verse","number":2,"content":["主啊，求你听我的声音。 愿你的耳朵留心听我恳求的声音。"]},{"type":"verse","number":3,"content":["耶和华啊，你若追究罪孽， 主啊，谁能站立得住呢？"]},{"type":"verse","number":4,"content":["但在你那里有赦免， 因此人敬畏你。"]},{"type":"verse","number":5,"content":["我等候耶和华。 我的灵魂等候。 我盼望祂的话。"]},{"type":"verse","number":6,"content":["我的灵魂切慕主，胜过守夜的人盼望早晨， 胜过守夜的人盼望早晨。"]},{"type":"verse","number":7,"content":["以色列啊，要仰望耶和华， 因为耶和华那里有慈爱； 祂那里有丰盛的救赎。"]},{"type":"verse","number":8,"content":["祂必救赎以色列脱离他们一切的罪。"]}]},"numberOfVerses":8}