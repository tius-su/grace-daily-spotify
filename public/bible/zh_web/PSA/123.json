{"translation":{"id":"zh_web","name":"和合本","shortName":"CUV","englishName":"Chinese Union Version","language":"zho","languageName":"繁體/简体中文"},"book":{"id":"PSA","translationId":"zh_web","name":"诗篇","commonName":"诗篇","title":"诗篇","order":19,"numberOfChapters":150},"chapter":{"number":123,"content":[{"type":"verse","number":1,"content":["我向你举目， 向坐在诸天之上的你举目。"]},{"type":"verse","number":2,"content":["看哪，仆人的眼睛怎样望着主人的手， 使女的眼睛怎样望着主母的手， 我们的眼睛也照样仰望耶和华我们的上帝， 直到祂怜悯我们。"]},{"type":"verse","number":3,"content":["耶和华啊，怜悯我们，怜悯我们， 因为我们已饱受藐视。"]},{"type":"verse","number":4,"content":["我们的灵魂饱受安逸之人的讥笑， 饱受骄傲人的藐视。"]}]},"numberOfVerses":4}