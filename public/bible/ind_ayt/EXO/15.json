{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"EXO","translationId":"ind_ayt","name":"KELUARAN","commonName":"KELUARAN","title":"Keluaran","order":2,"numberOfChapters":40,"sha256":"6700b178ec9a3ab9a604920f1616f148ccca73e8a56127e861ea99644c0cae2b","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/EXO/1.json","lastChapterNumber":40,"lastChapterApiLink":"/api/ind_ayt/EXO/40.json","totalNumberOfVerses":1213},"chapter":{"number":15,"content":[{"type":"heading","content":["Nyanyian Musa dan Israel"]},{"type":"verse","number":1,"content":["Kemudian Musa dan keturunan Israel menyanyikan lagu ini kepada TUHAN dengan perkataan yang berbunyi,",{"lineBreak":true},{"text":"“Aku akan bernyanyi bagi TUHAN,","poem":1},{"text":"sebab Dia ditinggikan mulia.","poem":2},{"text":"Kuda-kuda dan para penunggangnya","poem":1},{"text":"telah dicampakkan-Nya ke laut.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"TUHAN adalah kekuatanku dan nyanyianku,","poem":1},{"lineBreak":true},{"text":"Dia telah menjadi keselamatanku,","poem":1},{"text":"Dialah Allahku dan aku akan memuji-Nya,","poem":2},{"text":"Allah nenek moyangku,","poem":1},{"text":"dan Aku akan meninggikan-Nya.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"TUHAN adalah pahlawan perang,","poem":1},{"text":"TUHAN adalah nama-Nya.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Kereta-kereta Firaun dan pasukannya,","poem":1},{"text":"telah dicampakkan-Nya ke laut,","poem":2},{"text":"dan perwira-perwira pilihannya","poem":1},{"text":"telah ditenggelamkan ke dalam Laut Teberau.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Kedalaman menutupi mereka,","poem":1},{"text":"mereka tenggelam ke kedalaman bagaikan batu.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"“Tangan kanan-Mu, ya TUHAN, diagungkan dalam kekuatan,","poem":1},{"text":"tangan kanan-Mu, ya TUHAN, menghancurkan musuh.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Dalam kebesaran keagungan-Mu, Engkau merobohkan mereka","poem":1},{"text":"yang bangkit untuk menentang-Mu.","poem":2},{"text":"Engkau mengirim api murka-Mu yang melahap mereka","poem":1},{"text":"bagaikan tunggul jerami.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Dengan embusan dari lubang hidung-Mu,","poem":1},{"text":"air naik bertimbun-timbun,","poem":2},{"text":"Air yang mengalir menjadi seperti dinding,","poem":1},{"text":"menjadi padat di jantung laut.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":9,"content":[{"text":"“Musuh berkata,","poem":1},{"text":"‘Aku akan mengejar, aku akan menyusul,","poem":2},{"text":"aku akan membagi-bagi jarahan,","poem":1},{"text":"nafsuku akan terpuaskan atas mereka,","poem":2},{"text":"aku akan menghunus pedangku, tanganku akan","poem":1},{"text":"menghancurkan mereka.’","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Engkau meniup mereka dengan angin-MU,","poem":1},{"text":"maka laut meliputi mereka.","poem":2},{"text":"Mereka tenggelam bagaikan timah","poem":1},{"text":"ke dalam air yang kuat.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"“Siapakah yang seperti Engkau, ya TUHAN, di antara para ilah?","poem":1},{"lineBreak":true},{"text":"Siapakah yang seperti Engkau","poem":1},{"text":"agung dalam kekudusan,","poem":2},{"lineBreak":true},{"text":"mengagumkan dalam kemuliaan,","poem":2},{"lineBreak":true},{"text":"yang mengerjakan keajaiban-keajaiban?","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Engkau mengulurkan tangan kanan-Mu,","poem":1},{"text":"dan bumi menelan mereka.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Dalam kebaikan-Mu,","poem":1},{"text":"Engkau telah memimpin umat yang telah Engkau tebus.","poem":2},{"text":"Dalam kekuatan-MU,","poem":1},{"text":"Engkau telah membimbing mereka ke kediaman-Mu yang kudus.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":14,"content":[{"text":"“Bangsa-bangsa akan mendengar","poem":1},{"text":"dan akan gemetar.","poem":2},{"text":"Kegentaran akan mencekam penduduk Filistin.","poem":1}]},{"type":"verse","number":15,"content":[{"lineBreak":true},{"text":"Para pemimpin Edom akan cemas,","poem":1},{"lineBreak":true},{"text":"para pemimpin Moab dicekam kegentaran,","poem":1},{"lineBreak":true},{"text":"seluruh penduduk Kanaan tak berdaya.","poem":1}]},{"type":"verse","number":16,"content":[{"lineBreak":true},{"text":"Kengerian dan ketakutan menimpa mereka.","poem":1},{"text":"Oleh kedahsyatan tangan-Mu,","poem":2},{"text":"mereka tidak dapat bergerak seperti batu,","poem":1},{"text":"sampai umat-Mu menyeberang, ya TUHAN,","poem":2},{"lineBreak":true},{"text":"sampai umat yang telah Engkau dapatkan itu menyeberang.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Engkau akan membawa mereka","poem":1},{"text":"dan menanam mereka di gunung milik pusaka-MU,","poem":2},{"lineBreak":true},{"text":"di tempat yang telah Kaujadikan tempat kediaman-MU, ya TUHAN,","poem":2},{"lineBreak":true},{"text":"di tempat kudus yang telah didirikan oleh tangan-MU, ya TUHAN.","poem":2}]},{"type":"line_break"},{"type":"verse","number":18,"content":[{"text":"TUHAN akan memerintah kekal selama-lamanya!”","poem":1}]},{"type":"line_break"},{"type":"verse","number":19,"content":["Sebab, kuda-kuda Firaun beserta kereta-keretanya dan pasukan berkudanya masuk ke dalam laut dan TUHAN mengembalikan lagi air laut ke atas mereka. Namun, keturunan Israel berjalan di tanah yang kering di tengah-tengah laut."]},{"type":"verse","number":20,"content":["Kemudian Miryam, sang nabiah, adik Harun, memegang rebana di tangannya, dan semua perempuan keluar mengikutinya dengan rebana dan tari-tarian."]},{"type":"verse","number":21,"content":["Miryam menyahut mereka,",{"lineBreak":true},{"text":"“Bernyanyilah bagi TUHAN!","poem":1},{"text":"Sebab, Dia ditinggikan mulia.","poem":2},{"text":"Kuda dan penunggangnya telah dicampakkan-Nya","poem":1},{"text":"ke dalam laut.”","poem":2}]},{"type":"line_break"},{"type":"heading","content":["Orang Israel di Mara dan di Elim"]},{"type":"verse","number":22,"content":["Kemudian, Musa membawa Israel dari Laut Teberau dan mereka pergi ke Padang Belantara Syur. Mereka berjalan selama 3 hari di padang belantara dan tidak menemukan air."]},{"type":"verse","number":23,"content":["Ketika mereka tiba di Mara, mereka tidak dapat minum air di Mara itu karena rasanya pahit. Itulah sebabnya, tempat itu disebut Mara."]},{"type":"verse","number":24,"content":["Jadi, bangsa itu bersungut-sungut kepada Musa dan berkata, “Apa yang akan kita minum?”"]},{"type":"verse","number":25,"content":["Dia pun berseru kepada TUHAN dan TUHAN menunjukkan sepotong kayu kepadanya, dan ketika dia melemparkannya ke air, air itu menjadi manis. Di sana TUHAN membuat ketetapan dan peraturan bagi mereka, dan di sana Dia menguji mereka,"]},{"type":"verse","number":26,"content":["dan berfirman, “Jika kamu sungguh-sungguh mendengarkan suara TUHAN, Allahmu, melakukan yang benar dalam pandangan-Nya, memberikan telinga terhadap perintah-perintah-Nya, dan memelihara semua ketetapan-Nya, Aku tidak akan menimpakan satu pun penyakit yang telah Kutimpakan atas orang Mesir, sebab Akulah TUHAN yang menyembuhkanmu.”"]},{"type":"verse","number":27,"content":["Kemudian, mereka tiba di Elim. Di sana ada dua belas mata air dan tujuh puluh pohon kurma. Mereka berkemah di sana, di dekat air itu."]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/EXO/15.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/EXO/16.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/EXO/14.json","previousChapterAudioLinks":{},"numberOfVerses":27}