{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"SNG","translationId":"ind_ayt","name":"KIDUNG AGUNG","commonName":"KIDUNG AGUNG","title":"Kidung Agung","order":22,"numberOfChapters":8,"sha256":"d921ad878990af8ae19798395cb2d70e8f7236816f100359927e731bfdded114","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/SNG/1.json","lastChapterNumber":8,"lastChapterApiLink":"/api/ind_ayt/SNG/8.json","totalNumberOfVerses":117},"chapter":{"number":2,"content":[{"type":"verse","number":1,"content":[{"text":"Aku adalah bunga mawar Saron,","poem":1},{"text":"bunga bakung di lembah-lembah.","poem":2}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"Bagaikan bunga bakung di antara semak-semak berduri,","poem":1},{"text":"seperti itulah kekasihku di antara para gadis.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Bagaikan pohon apel di antara pohon-pohon di hutan,","poem":1},{"text":"seperti itulah kekasihku di antara para jejaka.","poem":2},{"lineBreak":true},{"text":"Aku senang duduk dalam naungannya,","poem":2},{"lineBreak":true},{"text":"dan buahnya manis bagi mulutku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"Dia membawaku ke rumah anggur,","poem":1},{"text":"dan panjinya di atasku adalah cinta.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Topanglah aku dengan kue kismis,","poem":1},{"text":"segarkanlah aku dengan buah-buah apel,","poem":2},{"lineBreak":true},{"text":"karena aku sakit asmara.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Tangan kirinya ada di bawah kepalaku,","poem":1},{"text":"dan tangan kanannya memelukku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Aku menyumpahimu, hai putri-putri Yerusalem, demi rusa-rusa betina atau kijang-kijang di padang.","poem":1},{"text":"Jangan membangunkan","poem":2},{"lineBreak":true},{"text":"dan jangan membangkitkan cinta sebelum ia menginginkannya.","poem":2}]},{"type":"line_break"},{"type":"heading","content":["Di Pintu Pengantin Perempuan"]},{"type":"verse","number":8,"content":[{"text":"Suara kekasihku!","poem":1},{"text":"Lihat, dia datang, melompat-lompat di atas gunung-gunung,","poem":2},{"lineBreak":true},{"text":"meloncat-loncat di atas bukit-bukit.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Kekasihku bagaikan seekor kijang,","poem":1},{"text":"atau anak rusa jantan.","poem":2},{"text":"Lihat, dia berdiri di balik tembok kita,","poem":1},{"text":"menatap melalui jendela-jendela,","poem":2},{"lineBreak":true},{"text":"mengintip melalui kisi-kisi.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Kekasihku menjawab aku, katanya,","poem":1},{"text":"“Bangunlah, sayangku, cantikku.","poem":2},{"lineBreak":true},{"text":"Marilah!","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Sebab, lihatlah bahwa musim dingin sudah lewat;","poem":1},{"text":"hujan sudah berhenti, dan sudah berlalu.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Bunga-bunga tampak di tanah.","poem":1},{"text":"Waktu untuk bernyanyi telah tiba;","poem":2},{"lineBreak":true},{"text":"suara tekukur terdengar di tanah kita.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Pohon ara telah mematangkan buah-buah aranya.","poem":1},{"text":"Pohon-pohon anggur yang berbunga memberikan keharumannya.","poem":2},{"text":"Bangunlah, marilah, sayangku, cantikku.","poem":1},{"text":"Marilah!”","poem":2}]},{"type":"line_break"},{"type":"verse","number":14,"content":[{"text":"Oh merpatiku, di celah-celah bukit batu,","poem":1},{"text":"di persembunyian di tempat-tempat yang curam,","poem":2},{"text":"biarkan aku memandang penampilanmu,","poem":1},{"text":"biarkan aku mendengar suaramu.","poem":2},{"text":"Sebab, suaramu itu merdu,","poem":1},{"text":"dan penampilanmu itu elok!","poem":2}]},{"type":"line_break"},{"type":"verse","number":15,"content":[{"text":"Tangkaplah rubah-rubah bagi kami,","poem":1},{"text":"rubah-rubah kecil yang merusak kebun-kebun anggur,","poem":2},{"text":"karena kebun-kebun anggur kami sedang berbunga!","poem":1}]},{"type":"line_break"},{"type":"verse","number":16,"content":[{"text":"Kekasihku adalah milikku,","poem":1},{"text":"dan aku miliknya.","poem":2},{"text":"Dia menggembala di antara bunga-bunga bakung.","poem":1}]},{"type":"verse","number":17,"content":[{"text":"Sampai siang hari berembus,","poem":2},{"lineBreak":true},{"text":"dan bayang-bayang menghilang,","poem":2},{"text":"kembalilah, kekasihku,","poem":1},{"text":"jadilah seperti seekor kijang, atau anak rusa jantan, di bukit-bukit terjal!","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/SNG/2.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/SNG/3.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/SNG/1.json","previousChapterAudioLinks":{},"numberOfVerses":17}