{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"SNG","translationId":"ind_ayt","name":"KIDUNG AGUNG","commonName":"KIDUNG AGUNG","title":"Kidung Agung","order":22,"numberOfChapters":8,"sha256":"d921ad878990af8ae19798395cb2d70e8f7236816f100359927e731bfdded114","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/SNG/1.json","lastChapterNumber":8,"lastChapterApiLink":"/api/ind_ayt/SNG/8.json","totalNumberOfVerses":117},"chapter":{"number":3,"content":[{"type":"heading","content":["Angan-Angan Pengantin Perempuan"]},{"type":"verse","number":1,"content":[{"text":"Di atas tempat tidurku, pada malam hari,","poem":1},{"text":"aku mencari-cari dia yang dicintai jiwaku.","poem":2},{"text":"Aku mencarinya,","poem":1},{"text":"tetapi tidak menemukannya.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Aku akan bangun sekarang,","poem":1},{"text":"dan pergi berkeliling kota,","poem":2},{"text":"di jalan-jalan dan di lapangan-lapangan;","poem":1},{"text":"aku akan mencari dia yang dicintai jiwaku.","poem":2},{"lineBreak":true},{"text":"Aku mencarinya,","poem":1},{"text":"tetapi tidak menemukannya.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Para penjaga yang berkeliling kota menemukanku.","poem":1},{"text":"“Apakah kamu melihat dia","poem":2},{"lineBreak":true},{"text":"yang dicintai jiwaku itu?”","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"Ketika aku baru saja aku melewati mereka,","poem":1},{"text":"aku menemukan dia yang dicintai jiwaku!","poem":2},{"lineBreak":true},{"text":"Aku memegangnya,","poem":2},{"text":"dan takkan membiarkannya pergi,","poem":1},{"text":"sampai aku membawanya ke rumah ibuku,","poem":2},{"lineBreak":true},{"text":"ke kamar orang yang mengandung aku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"Aku menyumpahimu, hai putri-putri Yerusalem, demi rusa-rusa betina atau kijang-kijang di padang.","poem":1},{"text":"Jangan membangunkan","poem":2},{"lineBreak":true},{"text":"dan jangan membangkitkan cinta sebelum ia menginginkannya.","poem":2}]},{"type":"line_break"},{"type":"heading","content":["Iring-iringan Pengantin"]},{"type":"verse","number":6,"content":[{"text":"Apakah itu, yang muncul dari padang belantara","poem":1},{"lineBreak":true},{"text":"bagaikan tiang-tiang asap yang wangi dengan mur dan kemenyan,","poem":1},{"text":"dengan segala serbuk harum dari pedagang?","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Lihat, inilah joli Salomo!","poem":1},{"text":"Yang mengelilinginya adalah enam puluh orang perkasa,","poem":2},{"lineBreak":true},{"text":"dari antara orang-orang perkasa Israel.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Mereka semua memegang pedang,","poem":1},{"text":"dan terlatih dalam peperangan;","poem":2},{"lineBreak":true},{"text":"setiap orang dengan pedang di pinggangnya untuk berjaga-jaga terhadap kengerian pada waktu malam.","poem":2}]},{"type":"line_break"},{"type":"verse","number":9,"content":[{"text":"Raja Salomo membuat baginya sendiri sebuah tandu","poem":1},{"text":"dari kayu lebanon.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Dia membuat tiang-tiangnya dari perak,","poem":1},{"text":"dan sandarannya dari emas.","poem":2},{"text":"Tempat duduknya berwarna ungu;","poem":1},{"text":"bagian dalamnya dihiasi dengan cinta oleh putri-putri Yerusalem.","poem":2}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"Keluarlah, putri-putri Sion,","poem":1},{"text":"dan pandanglah Raja Salomo,","poem":2},{"text":"dengan mahkota yang dikenakan kepadanya oleh ibunya,","poem":1},{"text":"pada hari pernikahannya,","poem":2},{"lineBreak":true},{"text":"pada hari kegembiraan hatinya!","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/SNG/3.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/SNG/4.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/SNG/2.json","previousChapterAudioLinks":{},"numberOfVerses":11}