{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"SNG","translationId":"ind_ayt","name":"KIDUNG AGUNG","commonName":"KIDUNG AGUNG","title":"Kidung Agung","order":22,"numberOfChapters":8,"sha256":"d921ad878990af8ae19798395cb2d70e8f7236816f100359927e731bfdded114","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/SNG/1.json","lastChapterNumber":8,"lastChapterApiLink":"/api/ind_ayt/SNG/8.json","totalNumberOfVerses":117},"chapter":{"number":1,"content":[{"type":"verse","number":1,"content":[{"text":"Nyanyian di atas segala nyanyian dari Salomo.","poem":1}]},{"type":"heading","content":["Pengantin Perempuan dan Putri-Putri Yerusalem"]},{"type":"verse","number":2,"content":[{"text":"Biarlah dia menciumku dengan kecupan mulutnya!","poem":1},{"text":"Sebab, cintamu lebih baik daripada anggur.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Aroma minyak wangimu harum; namamu seperti minyak yang tercurah;","poem":1},{"text":"karena itulah gadis-gadis mencintaimu.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Tariklah aku di belakangmu.","poem":1},{"text":"Ayo cepat lari!","poem":2},{"text":"Raja telah membawaku masuk ke kamar tidurnya.","poem":1},{"lineBreak":true},{"text":"Kami akan bersukacita dan bergembira karena engkau.","poem":1},{"text":"Kami akan mengingat cintamu melebihi anggur.","poem":2},{"lineBreak":true},{"text":"Pantaslah mereka mencintaimu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"Aku hitam, tetapi cantik, hai putri-putri Yerusalem,","poem":1},{"text":"seperti kemah-kemah Kedar, seperti tirai-tirai Salomo.","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"Jangan memandangiku karena aku hitam,","poem":1},{"text":"karena matahari telah menatapku.","poem":2},{"text":"Putra-putra ibuku marah kepadaku.","poem":1},{"text":"Mereka menjadikanku penjaga kebun-kebun anggur,","poem":2},{"lineBreak":true},{"text":"tetapi kebun anggurku sendiri tidak kujaga.","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Beri tahu aku, hai kekasih jiwaku, di mana engkau menggembalakan kawanan dombamu?","poem":1},{"lineBreak":true},{"text":"Di mana engkau membaringkan mereka pada waktu tengah hari?","poem":1},{"text":"Sebab, mengapa aku harus seperti orang yang berselubung di samping kawanan domba teman-temanmu?","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"Jika engkau tidak tahu,","poem":1},{"text":"hai yang tercantik dari segala perempuan,","poem":2},{"text":"ikutilah jejak-jejak kawanan itu,","poem":1},{"text":"dan gembalakan kambing-kambing mudamu di dekat kemah-kemah para gembala.","poem":2}]},{"type":"line_break"},{"type":"verse","number":9,"content":[{"text":"Aku mengumpamakan engkau, kekasihku,","poem":1},{"text":"dengan kuda betina","poem":2},{"lineBreak":true},{"text":"di antara kereta-kereta kuda Firaun.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Pipimu elok dengan perhiasan-perhiasan,","poem":1},{"text":"dan lehermu dengan untaian permata.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Kami akan membuatkanmu perhiasan-perhiasan emas","poem":1},{"text":"bertatah perak.","poem":2}]},{"type":"line_break"},{"type":"verse","number":12,"content":[{"text":"Sementara Raja berada di mejanya,","poem":1},{"text":"narwastuku menebarkan keharumannya.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Bagiku, kekasihku seperti sekantong mur","poem":1},{"text":"yang terletak di antara buah dadaku.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Bagiku, kekasihku seperti serumpun bunga pacar","poem":1},{"text":"di kebun anggur En-Gedi.","poem":2}]},{"type":"line_break"},{"type":"verse","number":15,"content":[{"text":"Lihat, cantiknya engkau, kekasihku!","poem":1},{"text":"Lihat, cantiknya engkau!","poem":2},{"lineBreak":true},{"text":"Matamu bagaikan merpati.","poem":2}]},{"type":"line_break"},{"type":"verse","number":16,"content":[{"text":"Lihat, tampannya engkau, kekasihku!","poem":1},{"text":"Sungguh menyenangkan!","poem":2},{"text":"Sungguh, tempat tidur kita hijau.","poem":1}]},{"type":"verse","number":17,"content":[{"lineBreak":true},{"text":"Kasau rumah kita adalah pohon aras;","poem":1},{"text":"dinding-dinding kita adalah pohon cemara.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/SNG/1.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/SNG/2.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/ECC/12.json","previousChapterAudioLinks":{},"numberOfVerses":17}