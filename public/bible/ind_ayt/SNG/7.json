{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"SNG","translationId":"ind_ayt","name":"KIDUNG AGUNG","commonName":"KIDUNG AGUNG","title":"Kidung Agung","order":22,"numberOfChapters":8,"sha256":"d921ad878990af8ae19798395cb2d70e8f7236816f100359927e731bfdded114","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/SNG/1.json","lastChapterNumber":8,"lastChapterApiLink":"/api/ind_ayt/SNG/8.json","totalNumberOfVerses":117},"chapter":{"number":7,"content":[{"type":"heading","content":["Pengantin Laki-laki Memuji Kecantikan Kekasihnya"]},{"type":"verse","number":1,"content":[{"text":"Betapa indahnya kakimu dengan kasut-kasut itu, hai putri bangsawan.","poem":1},{"text":"Lekuk pinggangmu bagaikan perhiasan, karya tangan seniman.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Pusarmu bagaikan cawan bulat,","poem":1},{"text":"yang tidak pernah kekurangan anggur campuran.","poem":2},{"text":"Perutmu bagaikan timbunan gandum,","poem":1},{"text":"yang berpagarkan bunga-bunga bakung.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Kedua buah dadamu bagaikan dua anak rusa,","poem":1},{"text":"anak kembar kijang.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Lehermu bagaikan menara gading.","poem":1},{"text":"Matamu bagaikan telaga-telaga di Hesybon,","poem":2},{"lineBreak":true},{"text":"dekat pintu gerbang Batrabim.","poem":2},{"text":"Hidungmu bagaikan menara Lebanon,","poem":1},{"text":"yang menghadap ke Damsyik.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Kepalamu bagaikan Bukit Karmel,","poem":1},{"text":"dan rambut kepalamu merah lembayung.","poem":2},{"text":"Raja tertawan oleh rambut ikalmu.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Betapa cantiknya, dan betapa manisnya engkau,","poem":1},{"text":"kekasih, dalam kesenanganmu!","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Perawakanmu bagaikan pohon kurma,","poem":1},{"lineBreak":true},{"text":"dan buah dadamu","poem":1},{"text":"seperti tandan-tandannya.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Aku berkata, “Aku akan memanjat pohon kurma itu,","poem":1},{"text":"dan memegang tangkai-tangkai buahnya.”","poem":2},{"lineBreak":true},{"text":"Kiranya buah dadamu menjadi seperti tandan-tandan buah anggur,","poem":1},{"text":"dan keharuman hidungmu seperti buah apel.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Mulutmu bagaikan anggur terbaik,","poem":1},{"text":"yang mengalir dengan lancar bagi kekasihku,","poem":2},{"lineBreak":true},{"text":"meluncur dengan lembut ke bibir orang-orang yang sedang tidur.","poem":2}]},{"type":"line_break"},{"type":"heading","content":["Pengantin Perempuan kepada Kekasihnya"]},{"type":"verse","number":10,"content":[{"text":"Aku adalah milik kekasihku,","poem":1},{"text":"dan hasratnya adalah bagiku.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Marilah, kekasihku,","poem":1},{"text":"kita pergi ke padang,","poem":2},{"lineBreak":true},{"text":"dan bermalam di desa-desa.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Mari kita pergi pagi-pagi ke kebun anggur","poem":1},{"text":"untuk melihat apabila pohon-pohon anggur sudah bertunas,","poem":2},{"text":"dan bunga-bunganya sudah mekar,","poem":1},{"text":"dan apabila pohon-pohon delima sudah berbunga.","poem":2},{"lineBreak":true},{"text":"Di sana, aku akan memberikan kasihku kepadamu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":13,"content":[{"text":"Buah dudaim memberikan keharumannya,","poem":1},{"text":"dan di pintu-pintu masuk kita,","poem":2},{"text":"terdapat semua yang terbaik,","poem":1},{"text":"yang baru maupun yang lama,","poem":2},{"lineBreak":true},{"text":"yang telah aku simpan bagimu, kekasihku.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/SNG/7.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/SNG/8.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/SNG/6.json","previousChapterAudioLinks":{},"numberOfVerses":13}