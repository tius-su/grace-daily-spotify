{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"JDG","translationId":"ind_ayt","name":"HAKIM-HAKIM","commonName":"HAKIM-HAKIM","title":"Hakim-hakim","order":7,"numberOfChapters":21,"sha256":"7897436266af044a3e790c2aa4d974fa29d550d065337c3c37b98d41692e5a91","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/JDG/1.json","lastChapterNumber":21,"lastChapterApiLink":"/api/ind_ayt/JDG/21.json","totalNumberOfVerses":618},"chapter":{"number":5,"content":[{"type":"heading","content":["Nyanyian Debora"]},{"type":"verse","number":1,"content":["Pada hari itu, Debora dan Barak, anak Abinoam, bernyanyi."]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"“Pujilah TUHAN!","poem":1},{"text":"Karena pemimpin-pemimpin Israel telah berperang,","poem":2},{"lineBreak":true},{"text":"yang dengan sukarela menyerahkan dirinya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Dengarlah, hai raja-raja!","poem":1},{"text":"Pasanglah telinga, hai penguasa-penguasa!","poem":2},{"text":"Aku mau bernyanyi;","poem":1},{"text":"aku akan bermazmur bagi TUHAN,","poem":2},{"lineBreak":true},{"text":"Allah Israel.","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"TUHAN, ketika Engkau keluar dari Seir,","poem":1},{"text":"ketika Engkau melangkah maju dari tanah Edom,","poem":2},{"text":"bumi berguncang,","poem":1},{"text":"langit pun tiris,","poem":2},{"lineBreak":true},{"text":"bahkan awan meneteskan airnya.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Gunung-gunung bergoyang di hadapan TUHAN,","poem":1},{"text":"bahkan Sinai, dari hadapan TUHAN, Allah Israel!","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"Pada zaman Samgar, anak Anat, pada zaman Yael,","poem":1},{"text":"tidak ada lagi jalan,","poem":2},{"lineBreak":true},{"text":"dan kafilah pergi berjalan dalam jalan yang berliku-liku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Diamlah orang-orang pedusunan di Israel,","poem":1},{"text":"diam sampai Debora bangkit,","poem":2},{"lineBreak":true},{"text":"bangkit sebagai ibu bagi Israel.","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"Mereka memilih ilah-ilah baru,","poem":1},{"text":"maka terjadilah perang di pintu gerbang.","poem":2},{"text":"Apakah terlihat tombak dan perisai","poem":1},{"text":"di antara empat puluh ribu orang Israel?","poem":2}]},{"type":"line_break"},{"type":"verse","number":9,"content":[{"text":"Hatiku tertuju kepada para panglima Israel","poem":1},{"text":"yang dengan sukarela telah menyerahkan dirinya.","poem":2},{"text":"Pujilah TUHAN!","poem":1}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"Kamu, penunggang keledai betina putih,","poem":1},{"text":"yang duduk di atas permadani,","poem":2},{"lineBreak":true},{"text":"yang sedang berjalan di sepanjang jalan, ceritakanlah!","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Suara orang berdendang,","poem":1},{"text":"di tempat-tempat penimbaan air.","poem":2},{"text":"Di sana, mereka menyanyikan perbuatan TUHAN,","poem":1},{"text":"perbuatan-Nya atas pedusunan di Israel.","poem":2},{"lineBreak":true},{"text":"Pada saat itu, umat TUHAN turun ke pintu gerbang!","poem":2}]},{"type":"line_break"},{"type":"verse","number":12,"content":[{"text":"Bangunlah, bangunlah, hai Debora!","poem":1},{"text":"Bangunlah, bangunlah, nyanyikanlah nyanyian!","poem":2},{"text":"Bangkitlah, Barak!","poem":1},{"text":"Giringlah tawananmu, hai anak Abinoam!","poem":2}]},{"type":"line_break"},{"type":"verse","number":13,"content":[{"text":"Kemudian, turunlah para bangsawan yang terluput,","poem":1},{"text":"dan umat TUHAN memerintah atas orang-orang yang gagah perkasa.","poem":2}]},{"type":"line_break"},{"type":"verse","number":14,"content":[{"text":"Dari suku Efraim,","poem":1},{"text":"yang akarnya dari suku Amalek,","poem":2},{"text":"mengikuti engkau, ya suku Benyamin.","poem":1},{"text":"bersama rakyatmu.","poem":2},{"text":"Dari suku Makhir,","poem":1},{"text":"turunlah para panglima.","poem":2},{"text":"Dan, dari suku Zebulon,","poem":1},{"text":"mereka yang membawa tongkat pembilang.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Para pemimpin suku Isakhar bersama-sama dengan Debora,","poem":1},{"text":"demikianlah suku Isakhar menyertai Barak.","poem":2},{"text":"Dia diutus ke lembah dengan berjalan.","poem":1},{"lineBreak":true},{"text":"Di antara pasukan suku Ruben, ada banyak pertimbangan dalam hatinya.","poem":1}]},{"type":"verse","number":16,"content":[{"lineBreak":true},{"text":"Mengapa engkau diam di antara kandang-kandang domba","poem":1},{"text":"untuk mendengarkan seruling kawanan domba?","poem":2},{"text":"Di antara pasukan suku Ruben","poem":1},{"text":"ada banyak pertimbangan.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Orang Gilead tinggal di seberang Sungai Yordan;","poem":1},{"text":"dan mengapa suku Dan tinggal di dalam kapal-kapal?","poem":2},{"text":"Suku Asyer menetap di tepi pantai,","poem":1},{"text":"di teluk-teluknya mereka tinggal diam.","poem":2}]},{"type":"line_break"},{"type":"verse","number":18,"content":[{"text":"Suku Zebulon adalah bangsa yang berani mempertaruhkan nyawanya;","poem":1},{"text":"dan suku Naftali di atas tempat-tempat yang tinggi di ladang.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Raja-raja datang untuk berperang.","poem":1},{"text":"Pada waktu itu, berperanglah raja-raja Kanaan di Taanakh, dekat mata air Megido.","poem":2},{"text":"tetapi mereka tidak menerima rampasan perak.","poem":1}]},{"type":"verse","number":20,"content":[{"lineBreak":true},{"text":"Dari langit, bintang-bintang berperang.","poem":1},{"text":"Dari peredarannya, mereka berperang melawan Sisera.","poem":2}]},{"type":"verse","number":21,"content":[{"text":"Sungai Kison, menghanyutkan mereka, sungai yang terkenal sejak dahulu itu, Sungai Kison.","poem":1},{"text":"Majulah sekuat tenaga, hai jiwaku!","poem":2}]},{"type":"verse","number":22,"content":[{"text":"Pada waktu itu, telapak kuda mengentak,","poem":1},{"text":"kuda-kudanya berpacu lari dengan kuat.","poem":2}]},{"type":"line_break"},{"type":"verse","number":23,"content":[{"text":"‘Terkutuklah Meros!’ firman Malaikat TUHAN.","poem":1},{"text":"‘Kutukilah penduduknya dengan keras,","poem":2},{"text":"sebab mereka tidak datang untuk membantu TUHAN,","poem":1},{"text":"membantu TUHAN melawan pahlawan.’","poem":2}]},{"type":"verse","number":24,"content":[{"text":"Diberkatilah di antara perempuan-perempuan lain, Yael, istri Heber, orang Keni;","poem":1},{"text":"Diberkatilah dia dari antara perempuan-perempuan di tenda.","poem":2}]},{"type":"verse","number":25,"content":[{"text":"Air dimintanya, tetapi susu diberikan kepadanya;","poem":1},{"text":"dalam mangkuk yang indah disuguhkannya dadih.","poem":2}]},{"type":"verse","number":26,"content":[{"text":"Tangannya mengulurkan patok,","poem":1},{"text":"tangan kanannya mengambil palu tukang.","poem":2},{"text":"Lalu, dipalunya Sisera dan dihancurkannya kepalanya.","poem":1},{"text":"Diremukkan dan ditembusnya pelipisnya.","poem":2}]},{"type":"verse","number":27,"content":[{"text":"Di antara kakinya, dia membungkuk,","poem":1},{"lineBreak":true},{"text":"dia jatuh, dan rebah.","poem":1},{"text":"Di antara kakinya, dia membungkuk, dia jatuh,","poem":2},{"lineBreak":true},{"text":"di tempat dia membungkuk, dia tewas.","poem":2},{"text":"Di sanalah, dia tewas dibinasakan.","poem":1}]},{"type":"line_break"},{"type":"verse","number":28,"content":[{"text":"Dari jendela, ibu Sisera menjenguk;","poem":1},{"text":"dari celah jendela dia berseru,","poem":2},{"text":"‘Mengapa keretanya tidak kunjung datang?","poem":1},{"text":"Mengapa kereta-keretanya belum terdengar?’","poem":2}]},{"type":"line_break"},{"type":"verse","number":29,"content":[{"text":"Dayang-dayangnya yang bijaksana menjawabnya,","poem":1},{"text":"dia sendiri juga menjawab perkataannya:","poem":2}]},{"type":"verse","number":30,"content":[{"text":"‘Bukankah mereka mendapat dan membagi-bagi jarahan,","poem":1},{"text":"satu dua orang gadis untuk setiap orang?","poem":2},{"text":"Jarahan kain berwarna untuk Sisera,","poem":1},{"lineBreak":true},{"text":"jarahan kain berwarna yang bersulam,","poem":1},{"text":"dua helai kain berwarna-warni","poem":2},{"lineBreak":true},{"text":"untuk lehernya penjarah?’","poem":2}]},{"type":"line_break"},{"type":"verse","number":31,"content":[{"text":"Demikianlah akan binasa semua musuh-Mu, ya TUHAN.","poem":1},{"text":"Akan tetapi, orang yang mengasihi-Nya akan terbit seperti matahari timur dalam kemegahannya!”","poem":2},{"lineBreak":true},"Kemudian, negeri itu aman selama 40 tahun."]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/JDG/5.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/JDG/6.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/JDG/4.json","previousChapterAudioLinks":{},"numberOfVerses":31}