{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PRO","translationId":"ind_ayt","name":"AMSAL","commonName":"AMSAL","title":"Amsal","order":20,"numberOfChapters":31,"sha256":"65a4ef8addfe0e5a23791e9de69059bdf59b7737711d7aa061f88bace1fb26fa","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PRO/1.json","lastChapterNumber":31,"lastChapterApiLink":"/api/ind_ayt/PRO/31.json","totalNumberOfVerses":915},"chapter":{"number":8,"content":[{"type":"heading","content":["Hikmat Menceritakan Kisahnya"]},{"type":"verse","number":1,"content":[{"text":"Bukankah hikmat berseru-seru,","poem":1},{"text":"dan pengertian mengangkat suaranya?","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Di atas tempat-tempat tinggi di tepi-tepi jalan,","poem":1},{"text":"di persimpangan-persimpangan jalan,","poem":2},{"lineBreak":true},{"text":"di sanalah ia berdiri.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Di samping gerbang-gerbang di depan kota,","poem":1},{"text":"di pintu-pintu masuk,","poem":2},{"lineBreak":true},{"text":"ia berseru-seru.","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"“Kepadamu, hai semua manusia, aku memanggil,","poem":1},{"text":"dan suaraku kepada anak-anak manusia.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Hai orang-orang naif, pahamilah kecerdasan;","poem":1},{"text":"hai orang-orang bodoh, pahamilah akal budi.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Dengarkanlah, karena aku akan mengatakan perkara-perkara yang mulia,","poem":1},{"text":"dan dari mulutku yang terbuka adalah perkara-perkara yang lurus.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Sebab, mulutku akan mengucapkan kebenaran;","poem":1},{"text":"kefasikan adalah kekejian bagi bibirku.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Segala perkataan mulutku adalah kebenaran;","poem":1},{"text":"tidak ada yang berbelit-belit atau serong.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Semua itu jelas bagi dia yang bijak,","poem":1},{"text":"dan benar bagi mereka yang menemukan pengetahuan.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Terimalah didikanku melebihi perak,","poem":1},{"text":"dan pengetahuan daripada emas pilihan.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Sebab, hikmat lebih baik daripada batu-batu permata,","poem":1},{"text":"dan segala sesuatu yang diinginkan orang tidak dapat dibandingkan dengannya.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":12,"content":[{"text":"“Aku, hikmat, tinggal bersama dengan kecerdasan,","poem":1},{"text":"dan aku menemukan pengetahuan dan kebijaksanaan.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Takut akan TUHAN adalah membenci kejahatan.","poem":1},{"text":"Kesombongan dan kecongkakan,","poem":2},{"lineBreak":true},{"text":"jalan kejahatan dan mulut yang menentang, aku membencinya.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Nasihat dan suara hikmat adalah milikku;","poem":1},{"text":"aku memiliki pengertian; aku memiliki kekuatan.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Oleh karena aku, raja-raja memerintah,","poem":1},{"text":"dan penguasa-penguasa menetapkan keadilan.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Oleh karena aku, pemimpin-pemimpin berkuasa,","poem":1},{"text":"begitu juga para bangsawan dan semua hakim di bumi.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Aku mengasihi mereka yang mengasihiku,","poem":1},{"text":"dan mereka yang mencariku dengan tekun akan mendapatkanku.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Kekayaan dan kehormatan ada bersama denganku,","poem":1},{"text":"juga kemakmuran yang abadi dan keadilan.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Buahku lebih baik daripada emas, bahkan emas murni,","poem":1},{"text":"dan hasilku melebihi perak pilihan.","poem":2}]},{"type":"verse","number":20,"content":[{"text":"Aku menempuh jalan kebenaran,","poem":1},{"text":"di tengah jalan-jalan keadilan,","poem":2}]},{"type":"verse","number":21,"content":[{"text":"mengaruniakan harta bagi mereka yang mengasihiku,","poem":1},{"text":"dan memenuhi perbendaharaan mereka.","poem":2}]},{"type":"line_break"},{"type":"verse","number":22,"content":[{"text":"TUHAN menciptakanku sebagai permulaan jalan-Nya,","poem":1},{"text":"sebagai perbuatan-Nya yang pertama dahulu kala.","poem":2}]},{"type":"verse","number":23,"content":[{"text":"Aku ditegakkan sejak kekekalan,","poem":1},{"text":"sejak awal, sebelum permulaan bumi.","poem":2}]},{"type":"verse","number":24,"content":[{"text":"Ketika belum ada samudra, aku dilahirkan,","poem":1},{"text":"ketika belum ada sumber-sumber yang melimpah dengan air.","poem":2}]},{"type":"verse","number":25,"content":[{"text":"Sebelum gunung-gunung ditempatkan,","poem":1},{"text":"sebelum bukit-bukit, aku dilahirkan,","poem":2}]},{"type":"verse","number":26,"content":[{"lineBreak":true},{"text":"sebelum Dia membuat bumi dan padang-padangnya,","poem":2},{"lineBreak":true},{"text":"ataupun debu yang pertama di bumi.","poem":2}]},{"type":"verse","number":27,"content":[{"text":"Ketika Dia mendirikan langit, aku ada di sana,","poem":1},{"text":"ketika Dia menggaris kaki langit di atas permukaan samudra,","poem":2}]},{"type":"verse","number":28,"content":[{"text":"ketika Dia menetapkan awan-awan di atas,","poem":1},{"text":"ketika Dia menderaskan pancuran mata air samudra,","poem":2}]},{"type":"verse","number":29,"content":[{"text":"ketika Dia menetapkan batas-batas kepada lautan","poem":1},{"text":"supaya air jangan melanggar titah-Nya,","poem":2},{"text":"dan ketika Dia menentukan dasar-dasar bumi.","poem":1}]},{"type":"verse","number":30,"content":[{"lineBreak":true},{"text":"Aku ada di sisi-Nya, seperti seorang kepala pekerja,","poem":1},{"text":"dan hari demi hari, aku menjadi kesenangan-Nya,","poem":2},{"lineBreak":true},{"text":"senantiasa bersukaria di hadapan-Nya,","poem":2}]},{"type":"verse","number":31,"content":[{"text":"bersenang-senang di atas dunia, bumi-Nya,","poem":1},{"text":"dan bersukacita bersama anak-anak manusia.","poem":2}]},{"type":"line_break"},{"type":"verse","number":32,"content":[{"text":"Sekarang, hai anak-anak, perhatikanlah aku;","poem":1},{"text":"berbahagialah mereka yang memelihara jalan-jalanku.","poem":2}]},{"type":"verse","number":33,"content":[{"text":"Dengarkanlah didikan, dan jadilah bijak;","poem":1},{"text":"jangan mengabaikannya.","poem":2}]},{"type":"verse","number":34,"content":[{"text":"Berbahagialah orang yang mendengarkanku,","poem":1},{"text":"yang berjaga-jaga hari demi hari di gerbang-gerbangku,","poem":2},{"lineBreak":true},{"text":"dan menanti di samping tiang-tiang pintuku.","poem":2}]},{"type":"verse","number":35,"content":[{"text":"Sebab, siapa yang menemukanku menemukan hidup,","poem":1},{"text":"dan memperoleh perkenanan dari TUHAN.","poem":2}]},{"type":"verse","number":36,"content":[{"text":"Akan tetapi, dia yang berdosa terhadap aku, mencelakakan dirinya sendiri;","poem":1},{"text":"semua yang membenciku mencintai maut.”","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PRO/8.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PRO/9.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PRO/7.json","previousChapterAudioLinks":{},"numberOfVerses":36}