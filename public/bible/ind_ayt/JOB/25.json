{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"JOB","translationId":"ind_ayt","name":"AYUB","commonName":"AYUB","title":"Ayub","order":18,"numberOfChapters":42,"sha256":"b9bae911b0ef8e8b19b3a726b1638177d115bb4026e627cebc9d465f7bff9f30","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/JOB/1.json","lastChapterNumber":42,"lastChapterApiLink":"/api/ind_ayt/JOB/42.json","totalNumberOfVerses":1070},"chapter":{"number":25,"content":[{"type":"heading","content":["Tidak Seorang pun Benar di Hadapan Allah"]},{"type":"verse","number":1,"content":["Kemudian, Bildad, orang Suah, menjawab, katanya,"]},{"type":"verse","number":2,"content":[{"text":"“Kekuasaan dan kedahsyatan adalah milik Allah.","poem":1},{"text":"Dia menegakkan kedamaian di tempat-Nya yang tinggi.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Dapatkah jumlah pasukan-Nya dihitung?","poem":1},{"text":"Kepada siapakah terang-Nya tidak bersinar?","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Lalu, bagaimana manusia bisa di sisi yang benar di hadapan Allah?","poem":1},{"text":"Bagaimana dia yang lahir dari seorang perempuan bisa suci?","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Lihatlah, bahkan bulan pun tidak bersinar terang,","poem":1},{"text":"dan bintang-bintang pun tidak suci di mata-Nya,","poem":2}]},{"type":"verse","number":6,"content":[{"text":"lebih lagi manusia, yang hanya belatung,","poem":1},{"text":"dan manusia fana, yang hanya cacing.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/JOB/25.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/JOB/26.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/JOB/24.json","previousChapterAudioLinks":{},"numberOfVerses":6}