{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"EZK","translationId":"ind_ayt","name":"YEHEZKIEL","commonName":"YEHEZKIEL","title":"YEHEZKIEL","order":26,"numberOfChapters":48,"sha256":"b1498d19c6cfc2306ef7606f1625b10d1e010ce92e741b3520fe3d5d3494a579","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/EZK/1.json","lastChapterNumber":48,"lastChapterApiLink":"/api/ind_ayt/EZK/48.json","totalNumberOfVerses":1273},"chapter":{"number":19,"content":[{"type":"heading","content":["Nyanyian Duka tentang Raja Israel"]},{"type":"verse","number":1,"content":["“Dan kamu, naikkanlah ratapan untuk para pemimpin Israel,"]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"dan katakan, ‘Siapakah ibumu? Seekor singa betina,","poem":1},{"text":"di antara singa-singa ia berbaring.","poem":2},{"text":"Di antara singa-singa muda,","poem":1},{"text":"ia mengasuh anak-anaknya.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Ia membesarkan salah satu dari anak-anaknya,","poem":1},{"text":"anaknya itu menjadi singa muda.","poem":2},{"text":"Anaknya itu belajar menerkam mangsa,","poem":1},{"text":"ia melahap manusia.’”","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"“Bangsa-bangsa mendengar tentang dirinya,","poem":1},{"text":"ia tertangkap dalam jerat mereka,","poem":2},{"text":"dan mereka membawanya dengan kait","poem":1},{"text":"ke negeri Mesir.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"“Ketika induk singa itu mengetahui bahwa ia menanti dengan sia-sia,","poem":1},{"text":"bahwa pengharapannya lenyap,","poem":2},{"text":"ia mengambil anaknya yang lain","poem":1},{"text":"dan membesarkannya menjadi singa muda.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Anaknya ini berjalan di antara singa-singa,","poem":1},{"text":"ia menjadi singa muda,","poem":2},{"text":"dan belajar menerkam mangsa,","poem":1},{"text":"ia melahap manusia,","poem":2}]},{"type":"verse","number":7,"content":[{"text":"dan menghampiri janda-janda mereka, menghancurkan kota-kota mereka,","poem":1},{"text":"dan negeri itu terkejut, juga semua yang tinggal di dalamnya, karena suara aumannya.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Lalu, bangsa-bangsa bersiap menyerangnya dari provinsi-provinsi di segala penjuru.","poem":1},{"text":"Mereka menebarkan jaring ke atasnya, ia tertangkap dalam liang mereka.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Mereka mengurungnya dalam sebuah kandang","poem":1},{"lineBreak":true},{"text":"dengan kait,","poem":1},{"text":"dan membawanya kepada raja Babel.","poem":2},{"text":"Mereka membawanya ke dalam penjara","poem":1},{"text":"sehingga suaranya takkan terdengar lagi di gunung-gunung Israel.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"“Ibumu seperti pohon anggur","poem":1},{"text":"yang ditanam dekat air.","poem":2},{"text":"Ia berbuah,","poem":1},{"text":"dan penuh dengan cabang karena air yang melimpah.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Ia mempunyai cabang-cabang yang kuat,","poem":1},{"text":"yang cocok untuk tongkat-tongkat kerajaan,","poem":2},{"lineBreak":true},{"text":"milik para penguasa,","poem":2},{"text":"pohon itu naik tinggi di antara cabang-cabang yang lebat,","poem":1},{"text":"sehingga ia terlihat dalam ketinggiannya dengan banyaknya cabangnya.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Namun, pohon anggur itu dicabut dalam kemarahan,","poem":1},{"text":"ia dilemparkan ke tanah.","poem":2},{"text":"Angin timur mengeringkan buahnya,","poem":1},{"text":"cabangnya yang kuat dihancurkan dan menjadi layu; api melahapnya.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":13,"content":[{"text":"“Sekarang, pohon anggur itu ditanam di padang belantara,","poem":1},{"text":"di tanah yang kering dan gersang.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Api telah keluar dari cabangnya","poem":1},{"text":"dan telah memakan habis buahnya,","poem":2},{"text":"sehingga tidak ada cabang yang kuat padanya,","poem":1},{"text":"untuk dijadikan tongkat kerajaan.”","poem":2},{"lineBreak":true},"“Ini adalah sebuah ratapan, dan telah menjadi sebuah ratapan.”"]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/EZK/19.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/EZK/20.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/EZK/18.json","previousChapterAudioLinks":{},"numberOfVerses":14}