{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"NAM","translationId":"ind_ayt","name":"NAHUM","commonName":"NAHUM","title":"Nahum","order":34,"numberOfChapters":3,"sha256":"d27ed7cf9206ac956232c418416b436f843443b2c51a05441aed264fd0b8550c","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/NAM/1.json","lastChapterNumber":3,"lastChapterApiLink":"/api/ind_ayt/NAM/3.json","totalNumberOfVerses":47},"chapter":{"number":3,"content":[{"type":"heading","content":["Hukuman bagi Niniwe"]},{"type":"verse","number":1,"content":[{"text":"Celakalah kota penumpah darah!","poem":1},{"text":"Seluruhnya kebohongan belaka,","poem":2},{"text":"penuh dengan rampasan,","poem":1},{"text":"yang mangsanya tidak pernah lolos!","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Suara cambukan","poem":1},{"text":"dan derak-derik roda!","poem":2},{"text":"Kuda lari menderap","poem":1},{"text":"dan kereta melompat-lompat!","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Pasukan berkuda maju menyerang,","poem":1},{"text":"dengan pedang menyala-nyala","poem":2},{"lineBreak":true},{"text":"dan tombak yang berkilat-kilat.","poem":2},{"text":"Banyak yang terbunuh","poem":1},{"text":"dan bangkainya bertimbun-timbun.","poem":2},{"text":"Tidak ada habisnya mayat-mayat,","poem":1},{"text":"orang tersandung pada mayat-mayat!","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Semua itu karena banyaknya persundalan si perempuan sundal,","poem":1},{"text":"yang cantik parasnya dan pandai sihir,","poem":2},{"lineBreak":true},{"text":"yang memperdaya bangsa-bangsa","poem":2},{"text":"dengan persundalannya","poem":1},{"text":"dan kaum-kaum dengan sihirnya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"“Lihatlah, Aku akan menjadi lawanmu,”","poem":1},{"text":"firman TUHAN semesta alam.","poem":2},{"text":"“Aku akan mengangkat ujung kainmu sampai ke wajahmu,","poem":1},{"text":"dan akan memperlihatkan ketelanjanganmu kepada bangsa-bangsa,","poem":2},{"text":"serta kemaluanmu kepada kerajaan-kerajaan.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Aku akan membuang ke atasmu benda-benda kekejian,","poem":1},{"text":"dan membuatmu tercemar,","poem":2},{"text":"serta membuatmu menjadi tontonan.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Oleh sebab itu, setiap orang yang melihatmu akan lari meninggalkanmu,","poem":1},{"lineBreak":true},{"text":"sambil berkata, ‘Niniwe telah rusak!","poem":1},{"text":"Siapakah yang akan meratap baginya?","poem":2},{"text":"Dari mana aku akan mencari penghiburan-penghiburan baginya?’”","poem":1}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"Apakah kamu lebih baik daripada Tebe,","poem":1},{"text":"kota Dewa Amon,","poem":2},{"text":"yang terletak di Sungai Nil","poem":1},{"text":"dengan air di sekelilingnya,","poem":2},{"text":"yang bentengnya adalah laut,","poem":1},{"text":"dan temboknya adalah air?","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Kush adalah kekuatannya","poem":1},{"text":"dan Mesir, yang tanpa batas;","poem":2},{"text":"Put dan Libia adalah penolongnya.","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Akan tetapi, ia sendiri pergi ke dalam pembuangan,","poem":1},{"text":"sebagai tawanan.","poem":2},{"text":"Anak-anaknya diremukkan kepalanya","poem":1},{"text":"di ujung setiap jalan.","poem":2},{"text":"Orang membuang undi atas orang-orang yang dihormati,","poem":1},{"text":"dan semua pembesarnya dibelenggu dengan rantai.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Kamu juga akan menjadi mabuk,","poem":1},{"text":"kamu akan bersembunyi,","poem":2},{"lineBreak":true},{"text":"engkau juga akan mencari tempat perlindungan terhadap musuh.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Semua kubumu seperti pohon ara","poem":1},{"text":"dengan buah ara pertama. Jika diayunkan,","poem":2},{"text":"jatuhlah buahnya","poem":1},{"text":"ke dalam mulut pemakannya.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Sesungguhnya, pasukan yang berada di tengah-tengahmu adalah perempuan,","poem":1},{"text":"pintu-pintu gerbang negerimu terbuka lebar","poem":2},{"text":"bagi musuh-musuhmu,","poem":1},{"text":"api melalap palang-palang pintumu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":14,"content":[{"text":"Timbalah air untuk menghadapi pengepungan,","poem":1},{"text":"kuatkanlah kubu-kubumu!","poem":2},{"text":"Pijaklah tanah liat,","poem":1},{"text":"injak-injaklah lumpur, kuatkanlah cetakan batu bata!","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Di sana, api akan melalapmu,","poem":1},{"text":"pedang akan melahapmu,","poem":2},{"lineBreak":true},{"text":"dan memakanmu seperti belalang pelahap.","poem":2},{"text":"Perbesar jumlahmu seperti belalang pelahap,","poem":1},{"text":"perbanyak dirimu seperti belalang pindahan.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Kamu memperbanyak pedagang-pedagangmu melebihi bintang-bintang di langit.","poem":1},{"text":"Seperti belalang pelompat","poem":2},{"text":"yang mengembangkan sayap,","poem":1},{"text":"lalu terbang.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Para pembesarmu seperti belalang pindahan,","poem":1},{"text":"dan para panglimamu seperti kawanan belalang,","poem":2},{"text":"yang hinggap di tembok-tembok pada musim dingin.","poem":1},{"text":"Akan tetapi, ketika matahari terbit, mereka lari menghilang","poem":2},{"text":"dan tidak diketahui lagi tempatnya.","poem":1}]},{"type":"verse","number":18,"content":[{"lineBreak":true},{"text":"Para gembalamu mengantuk, hai raja Asyur!","poem":1},{"text":"Para pemukamu tertidur,","poem":2},{"text":"pasukanmu berserakan di gunung-gunung,","poem":1},{"text":"dan tidak seorang pun mengumpulkan.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Tidak ada kesembuhan untuk lukamu,","poem":1},{"text":"cederamu tidak tersembuhkan.","poem":2},{"text":"Semua orang yang mendengar kabar tentangmu akan bertepuk tangan atas dirimu,","poem":1},{"text":"sebab siapakah yang tidak tertimpa kejahatanmu yang terus-menerus itu?","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/NAM/3.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/HAB/1.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/NAM/2.json","previousChapterAudioLinks":{},"numberOfVerses":19}