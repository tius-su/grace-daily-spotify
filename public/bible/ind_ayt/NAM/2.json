{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"NAM","translationId":"ind_ayt","name":"NAHUM","commonName":"NAHUM","title":"Nahum","order":34,"numberOfChapters":3,"sha256":"d27ed7cf9206ac956232c418416b436f843443b2c51a05441aed264fd0b8550c","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/NAM/1.json","lastChapterNumber":3,"lastChapterApiLink":"/api/ind_ayt/NAM/3.json","totalNumberOfVerses":47},"chapter":{"number":2,"content":[{"type":"heading","content":["Niniwe Akan Dihancurkan"]},{"type":"verse","number":1,"content":[{"text":"Pembongkar telah maju melawan engkau,","poem":1},{"text":"berjagalah di benteng,","poem":2},{"lineBreak":true},{"text":"mengintailah di jalan-jalan,","poem":2},{"text":"kuatkanlah ikat pinggangmu,","poem":1},{"text":"kumpulkanlah semua kekuatan!","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Sesungguhnya, TUHAN memulihkan kebanggaan Yakub,","poem":1},{"text":"seperti kebanggaan Israel;","poem":2},{"text":"sebab perusak telah merusaknya","poem":1},{"text":"dan memusnahkan cabang-cabangnya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Perisai para pahlawan diwarnai merah,","poem":1},{"text":"prajurit-prajuritnya yang gagah perkasa berpakaian kirmizi.","poem":2},{"text":"Kereta berkilat-kilat seperti api obor","poem":1},{"text":"pada hari ia menetapkannya,","poem":2},{"lineBreak":true},{"text":"dan pepohonan sanobar akan terguncang hebat.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Kereta melaju di jalan, berkejaran di lapangan;","poem":1},{"text":"mereka terlihat","poem":2},{"text":"seperti obor,","poem":1},{"text":"mereka akan berlari seperti kilat.","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"Pasukan-pasukan istimewa dikerahkan,","poem":1},{"text":"mereka jatuh tersandung saat berjalan maju.","poem":2},{"text":"Mereka lari terburu-buru ke arah tembok kota,","poem":1},{"text":"dan alat pendobrak sudah disediakan.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Pintu-pintu gerbang di sungai sudah dibuka,","poem":1},{"text":"dan istana menjadi gempar.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Dan, Huzab akan dipindahkan dan dibawa,","poem":1},{"text":"dan dayang-dayangnya akan mengerang seperti suara burung merpati","poem":2},{"lineBreak":true},{"text":"sambil memukul-mukul dadanya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"Niniwe seperti telaga air,","poem":1},{"text":"yang airnya mengalir ke luar.","poem":2},{"text":"“Berhenti! Berhenti!” teriak orang-orang,","poem":1},{"text":"tetapi tidak ada yang berpaling.","poem":2}]},{"type":"line_break"},{"type":"verse","number":9,"content":[{"text":"Rampaslah perak,","poem":1},{"text":"rampaslah emas!","poem":2},{"text":"Sebab, tidak ada habisnya persediaan harta benda,","poem":1},{"text":"kelimpahan semua barang yang indah-indah!","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Ia menjadi kosong,","poem":1},{"text":"sunyi,","poem":2},{"text":"dan runtuh.","poem":1},{"text":"Hati menjadi hancur","poem":2},{"text":"dan lutut saling membentur!","poem":1},{"text":"Seluruh pinggang kesakitan,","poem":2},{"text":"dan wajah semua orang","poem":1},{"text":"bersama-sama menjadi pucat pasi.","poem":2}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"Di manakah liang singa,","poem":1},{"text":"tempat singa-singa muda mencari makan,","poem":2},{"text":"tempat singa jantan, betina,","poem":1},{"text":"dan anak-anaknya berjalan,","poem":2},{"text":"tanpa ada yang mengganggunya?","poem":1}]},{"type":"verse","number":12,"content":[{"lineBreak":true},{"text":"Singa menerkam","poem":1},{"text":"supaya anak-anaknya cukup makan,","poem":2},{"text":"mencekik mangsa untuk singa-singa betinanya,","poem":1},{"text":"dan memenuhi liangnya dengan mangsa,","poem":2},{"text":"dan persembunyiannya dengan binatang yang diterkamnya.","poem":1}]},{"type":"line_break"},{"type":"verse","number":13,"content":[{"text":"“Lihatlah,” firman TUHAN semesta alam,","poem":1},{"text":"“Aku akan menjadi lawanmu.”","poem":2},{"text":"“Aku akan membakar keretamu menjadi asap,","poem":1},{"text":"dan pedang akan memakan habis singa-singa mudamu.","poem":2},{"text":"Aku akan melenyapkan mangsamu dari bumi,","poem":1},{"text":"dan suara utusan-utusanmu","poem":2},{"text":"tidak akan terdengar lagi.”","poem":1}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/NAM/2.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/NAM/3.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/NAM/1.json","previousChapterAudioLinks":{},"numberOfVerses":13}