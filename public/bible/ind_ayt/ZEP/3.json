{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"ZEP","translationId":"ind_ayt","name":"ZEFANYA","commonName":"ZEFANYA","title":"Zefanya","order":36,"numberOfChapters":3,"sha256":"be82de0e7059c443f615f4b1fcf37ebb11487642473d8f0d2030bc031b39203c","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/ZEP/1.json","lastChapterNumber":3,"lastChapterApiLink":"/api/ind_ayt/ZEP/3.json","totalNumberOfVerses":53},"chapter":{"number":3,"content":[{"type":"heading","content":["Dosa Yerusalem dan Penyelamatan"]},{"type":"verse","number":1,"content":[{"text":"“Celakalah ia yang memberontak dan tercemar,","poem":1},{"text":"kota yang menindas!”","poem":2}]},{"type":"verse","number":2,"content":[{"text":"“Ia tidak mendengarkan teguran","poem":1},{"text":"dan tidak memedulikan didikan.","poem":2},{"text":"Ia tidak percaya kepada TUHAN","poem":1},{"text":"dan tidak mendekat kepada Allahnya.”","poem":2}]},{"type":"verse","number":3,"content":[{"text":"“Para pemimpin di tengah-tengahnya seperti singa yang mengaum;","poem":1},{"text":"para hakimnya seperti serigala malam","poem":2},{"lineBreak":true},{"text":"yang tidak meninggalkan apa pun untuk pagi hari.”","poem":2}]},{"type":"verse","number":4,"content":[{"text":"“Para nabinya ceroboh,","poem":1},{"text":"orang-orang pengkhianat,","poem":2},{"text":"para imamnya melanggar kekudusan;","poem":1},{"text":"mencemarkan Taurat.”","poem":2}]},{"type":"verse","number":5,"content":[{"text":"“TUHAN yang adil ada di tengah-tengahnya,","poem":1},{"text":"tidak berbuat kecurangan.","poem":2},{"text":"Setiap pagi, Dia memberikan keadilan-Nya","poem":1},{"text":"dan tidak pernah gagal pada waktu fajar.","poem":2},{"text":"Namun, orang-orang curang tidak tahu malu!”","poem":1}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"“Aku telah melenyapkan bangsa-bangsa,","poem":1},{"text":"menara-menara penjuru menjadi reruntuhan.","poem":2},{"text":"Aku telah merusakkan jalan-jalannya","poem":1},{"text":"sehingga tidak ada yang melintasinya.","poem":2},{"text":"Kota-kota mereka telah dihancurkan","poem":1},{"text":"sehingga tidak ada orang dan tidak ada penduduknya.”","poem":2}]},{"type":"verse","number":7,"content":[{"text":"“Pikir-Ku, ‘tentu, mereka akan takut kepada-Ku,","poem":1},{"text":"akan menerima pengajaran,","poem":2},{"text":"Maka, tempat perlindunganmu tidak akan dilenyapkan sesuai segala pembalasan-Ku terhadapnya.’","poem":1},{"lineBreak":true},{"text":"Akan tetapi, mereka semakin giat melakukan segala perbuatan busuk mereka.”","poem":1}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"“Sebab itu, nantikanlah Aku!”","poem":1},{"lineBreak":true},{"text":"firman TUHAN.","poem":1},{"text":"“Sampai pada hari saat Aku bangkit sebagai saksi.","poem":2},{"text":"Sebab, keputusan-Ku adalah untuk mengumpulkan bangsa-bangsa","poem":1},{"text":"dan menghimpun kerajaan-kerajaan","poem":2},{"text":"untuk mencurahkan ke atas mereka murka-Ku,","poem":1},{"text":"yaitu seluruh amarah-Ku yang menyala-nyala.","poem":2},{"lineBreak":true},{"text":"Sebab, seluruh bumi akan dilahap oleh api cemburu-Ku.”","poem":2}]},{"type":"heading","content":["Janji Keselamatan"]},{"type":"verse","number":9,"content":[{"text":"“Sesungguhnya, pada waktu itu, Aku akan mengaruniakan bibir bangsa-bangsa menjadi bersih","poem":1},{"text":"supaya mereka semua dapat menyerukan nama TUHAN","poem":2},{"text":"dan beribadah kepada-Nya dengan bahu-membahu.”","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"“Dari seberang Sungai Kush,","poem":1},{"text":"orang-orang yang memuji-Ku,","poem":2},{"text":"putri yang terserak-serak,","poem":1},{"text":"akan membawa persembahan-Ku.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"“Pada hari itu, kamu tidak akan lagi mendapat malu","poem":1},{"text":"karena segala perbuatanmu yang memberontak terhadap Aku,","poem":2},{"text":"sebab pada waktu itu, Aku akan menyingkirkan dari tengah-tengahmu","poem":1},{"text":"orang-orang yang bersukaria dalam kecongkakan","poem":2},{"text":"dan kamu tidak akan lagi meninggikan dirimu di atas gunung-Ku yang kudus.”","poem":1}]},{"type":"verse","number":12,"content":[{"lineBreak":true},{"text":"“Akan kubiarkan hidup di tengah-tengahmu suatu umat yang rendah hati dan lemah,","poem":1},{"text":"dan mereka akan berlindung dalam nama TUHAN.”","poem":2}]},{"type":"verse","number":13,"content":[{"text":"“Sisa-sisa Israel tidak akan melakukan kejahatan atau berbicara bohong,","poem":1},{"text":"atau ditemukan dalam mulut mereka lidah penipu.","poem":2},{"text":"Sebab, mereka semua akan digembalakan dan berbaring,","poem":1},{"text":"dan tidak ada yang akan mengganggu mereka.”","poem":2}]},{"type":"heading","content":["Sukacita Israel dan Pemulihan"]},{"type":"verse","number":14,"content":[{"text":"“Bersorak-sorailah, hai Putri Sion,","poem":1},{"text":"bergembiralah hai Israel!","poem":2},{"text":"Bersukacitalah dan bersukarialah dengan segenap hatimu, hai Putri Yerusalem!”","poem":1}]},{"type":"verse","number":15,"content":[{"lineBreak":true},{"text":"“TUHAN telah menyingkirkan hukumanmu;","poem":1},{"text":"Dia telah melenyapkan musuh-musuhmu.","poem":2},{"text":"Raja Israel, yaitu TUHAN, ada di tengah-tengahmu,","poem":1},{"text":"kamu tidak akan takut lagi kepada malapetaka.”","poem":2}]},{"type":"verse","number":16,"content":[{"text":"“Pada hari itu, akan dikatakan kepada Yerusalem,","poem":1},{"text":"“Jangan takut, hai Sion!","poem":2},{"text":"Jangan biarkan tanganmu menjadi lemah.”","poem":1}]},{"type":"verse","number":17,"content":[{"lineBreak":true},{"text":"“TUHAN Allahmu ada di tengah-tengahmu","poem":1},{"text":"sebagai pahlawan yang menyelamatkan.","poem":2},{"text":"Dia bergembira atasmu dengan bersukacita,","poem":1},{"text":"Dia akan tinggal dalam kasih-Nya,","poem":2},{"lineBreak":true},{"text":"Dia akan bersorak-sorai karenamu dengan sorak kegirangan.”","poem":2}]},{"type":"verse","number":18,"content":[{"text":"“Aku akan mengumpulkan mereka yang bersedih","poem":1},{"text":"untuk hari pertemuan raya","poem":2},{"lineBreak":true},{"text":"sehingga kamu tidak lagi menanggung cela.”","poem":2}]},{"type":"verse","number":19,"content":[{"text":"“Sesungguhnya pada waktu itu, Aku akan bertindak terhadap semua yang menindasmu.","poem":1},{"text":"Aku akan menyelamatkan yang timpang","poem":2},{"lineBreak":true},{"text":"mengumpulkan yang tercerai berai,","poem":2},{"text":"dan mengubah aib mereka","poem":1},{"text":"menjadi pujian dan dikenal di seluruh bumi.”","poem":2}]},{"type":"verse","number":20,"content":[{"text":"“Pada waktu itu, Aku akan membawa kamu pulang —","poem":1},{"text":"pada waktu aku mengumpulkanmu.","poem":2},{"text":"sebab, Aku akan memberikan kemasyhuran dan pujian kepadamu","poem":1},{"text":"di antara segala bangsa di bumi,","poem":2},{"lineBreak":true},{"text":"ketika memulihkan keadaanmu","poem":2},{"text":"di depan mata mereka,”","poem":1},{"text":"firman TUHAN.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/ZEP/3.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/HAG/1.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/ZEP/2.json","previousChapterAudioLinks":{},"numberOfVerses":20}