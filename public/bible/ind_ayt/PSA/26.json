{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":26,"content":[{"type":"heading","content":["Doa Tak Bersalah"]},{"type":"verse","number":1,"content":[{"text":"Nyanyian Daud.","descriptive":true},{"lineBreak":true},{"text":"Adili aku, ya TUHAN,","poem":1},{"text":"karena aku sudah berjalan dalam ketulusan.","poem":2},{"text":"Aku sudah percaya kepada TUHAN","poem":1},{"text":"dan tidak tergelincir.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Periksalah aku, ya TUHAN, dan uji aku.","poem":1},{"text":"Murnikan batinku dan hatiku.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Sebab, kasih setia-Mu ada di hadapan mataku,","poem":1},{"text":"dan aku berjalan dalam kebenaran-Mu.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Aku tidak duduk bersama para penipu,","poem":1},{"text":"dan tidak pergi bersama orang-orang munafik.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Aku membenci kumpulan penjahat,","poem":1},{"text":"dan tidak mau duduk bersama orang fasik.","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"Aku mencuci tanganku dalam ketidakbersalahan,","poem":1},{"text":"dan akan mengelilingi mazbah-Mu, ya TUHAN,","poem":2}]},{"type":"verse","number":7,"content":[{"text":"sambil menyatakan suara ucapan syukur,","poem":1},{"text":"dan menceritakan semua perbuatan-perbuatan-Mu yang ajaib.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Ya TUHAN, aku mencintai rumah kediaman-Mu,","poem":1},{"text":"tempat kemuliaan-Mu berdiam.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Jangan kumpulkan nyawaku bersama para pendosa,","poem":1},{"text":"atau hidupku bersama para penumpah darah,","poem":2}]},{"type":"verse","number":10,"content":[{"text":"yang tangannya adalah rencana jahat,","poem":1},{"text":"dan yang tangan kanannya penuh dengan suap.","poem":2}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"Namun, aku berjalan dalam ketulusan.","poem":1},{"text":"Tebuslah aku dan kasihani aku.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Kakiku berdiri di atas tanah yang datar.","poem":1},{"text":"Dalam perkumpulan, aku akan memuji TUHAN.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/26.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/27.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/25.json","previousChapterAudioLinks":{},"numberOfVerses":12}