{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":115,"content":[{"type":"heading","content":["Kasih setia TUHAN yang Kekal"]},{"type":"verse","number":1,"content":[{"text":"Bukan kepada kami, ya TUHAN, bukan kepada kami,","poem":1},{"text":"tetapi kepada nama-Mu kemuliaan diberi;","poem":2},{"text":"oleh karena kasih setia-Mu,","poem":1},{"text":"oleh karena kebenaran-Mu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"Mengapa bangsa-bangsa harus berkata,","poem":1},{"text":"“Di mana Allah mereka?”","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Allah kami ada di surga,","poem":1},{"text":"Dia melakukan semua yang disukai-Nya.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Berhala-berhala mereka adalah perak dan emas,","poem":1},{"text":"pekerjaan tangan manusia.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Bermulut, tetapi tidak bisa bicara;","poem":1},{"text":"bermata, tetapi tidak bisa melihat;","poem":2}]},{"type":"verse","number":6,"content":[{"text":"bertelinga, tetapi tidak bisa mendengar;","poem":1},{"text":"berhidung, tetapi tidak bisa mencium;","poem":2}]},{"type":"verse","number":7,"content":[{"text":"bertangan, tetapi tidak bisa meraba;","poem":1},{"text":"berkaki, tetapi tidak bisa berjalan;","poem":2},{"lineBreak":true},{"text":"dan mereka tidak bisa bersuara dengan kerongkongan mereka.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Orang-orang yang membuatnya menjadi seperti mereka,","poem":1},{"text":"begitu juga semua orang yang percaya kepada mereka.","poem":2}]},{"type":"line_break"},{"type":"verse","number":9,"content":[{"text":"Hai Israel, percayalah kepada TUHAN!","poem":1},{"text":"Dia adalah pertolongan mereka dan perisai mereka.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Hai seisi rumah Harun, percayalah kepada TUHAN!","poem":1},{"text":"Dia adalah pertolongan mereka dan perisai mereka.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Kamu, yang takut akan TUHAN,","poem":1},{"text":"percayalah kepada TUHAN!","poem":2},{"lineBreak":true},{"text":"Dia adalah pertolongan mereka dan perisai mereka.","poem":2}]},{"type":"line_break"},{"type":"verse","number":12,"content":[{"text":"TUHAN telah mengingat kita,","poem":1},{"text":"Dia akan memberkati kita.","poem":2},{"text":"Dia akan memberkati seisi rumah Israel,","poem":1},{"text":"Dia akan memberkati seisi rumah Harun,","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Dia akan memberkati mereka yang takut akan TUHAN,","poem":1},{"text":"baik kecil maupun besar.","poem":2}]},{"type":"line_break"},{"type":"verse","number":14,"content":[{"text":"Kiranya TUHAN menambahkanmu,","poem":1},{"text":"kamu dan anak-anakmu.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Kiranya kamu diberkati oleh TUHAN,","poem":1},{"text":"yang menjadikan langit dan bumi.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Langit adalah langit milik TUHAN,","poem":1},{"text":"tetapi bumi telah diberikan-Nya kepada anak-anak manusia.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Orang mati tidak memuji TUHAN,","poem":1},{"text":"tidak juga orang yang turun ke dalam kesunyian.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Akan tetapi, kita akan memuji TUHAN,","poem":1},{"text":"dari sekarang dan untuk selamanya-lamanya.","poem":2},{"lineBreak":true},{"text":"Haleluya!","poem":1}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/115.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/116.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/114.json","previousChapterAudioLinks":{},"numberOfVerses":18}