{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":104,"content":[{"type":"heading","content":["Pujilah TUHAN Sang Pencipta"]},{"type":"verse","number":1,"content":[{"text":"Pujilah TUHAN, hai jiwaku!","poem":1},{"lineBreak":true},{"text":"Ya TUHAN, Allahku, Engkau begitu besar!","poem":1},{"text":"Engkau yang berpakaian kemuliaan dan kehormatan;","poem":2}]},{"type":"verse","number":2,"content":[{"text":"yang diselimuti dengan cahaya seperti jubah,","poem":1},{"text":"yang membentangkan langit seperti tenda;","poem":2}]},{"type":"verse","number":3,"content":[{"text":"yang memasang tiang-tiang-Nya di atas air,","poem":1},{"text":"yang menjadikan awan-awan kereta perang-Nya,","poem":2},{"lineBreak":true},{"text":"dan berjalan-jalan di atas sayap angin;","poem":2}]},{"type":"verse","number":4,"content":[{"text":"yang menjadikan angin itu para utusan-Nya,","poem":1},{"text":"dan api yang menyala itu para pelayan-Nya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"Engkau yang menegakkan bumi di atas dasarnya,","poem":1},{"text":"sehingga ia takkan pernah terguncangkan selama-lamanya.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Engkau menyelubunginya dengan samudra sebagai jubah;","poem":1},{"text":"air meninggi melebihi gunung-gunung.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Oleh hardikan-Mu, air itu melarikan diri,","poem":1},{"text":"bergegas karena suara guntur-Mu,","poem":2}]},{"type":"verse","number":8,"content":[{"text":"naik ke gunung-gunung,","poem":1},{"text":"turun ke lembah-lembah, ke tempat yang Engkau tentukan bagi mereka.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Engkau menetapkan batas-batas yang tidak boleh dilewatinya,","poem":1},{"text":"sehingga tidak kembali menyelubungi bumi.","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"Engkau mengirimkan mata air ke lembah-lembah;","poem":1},{"text":"mereka mengalir di antara pegunungan,","poem":2}]},{"type":"verse","number":11,"content":[{"text":"memberi minum kepada semua binatang di padang;","poem":1},{"text":"keledai-keledai liar memuaskan dahaganya.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Di tepiannya, burung-burung di langit bersarang,","poem":1},{"text":"bernyanyi di antara cabang-cabang.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Engkau menyirami gunung-gunung dari ruang atas-Nya;","poem":1},{"text":"bumi dikenyangkan dari buah pekerjaan-Mu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":14,"content":[{"text":"Engkau menumbuhkan rumput untuk ternak,","poem":1},{"text":"dan tumbuh-tumbuhan untuk diusahakan manusia,","poem":2},{"lineBreak":true},{"text":"supaya mereka boleh menghasilkan makanan dari dalam tanah;","poem":2}]},{"type":"verse","number":15,"content":[{"text":"dan anggur untuk menyukakan hati manusia,","poem":1},{"text":"minyak untuk membuat wajahnya bersinar,","poem":2},{"lineBreak":true},{"text":"dan roti yang menopang hati manusia.","poem":2}]},{"type":"line_break"},{"type":"verse","number":16,"content":[{"text":"Pohon-pohon TUHAN dikenyangkan,","poem":1},{"text":"pohon-pohon aras di Lebanon yang ditanam-Nya.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Di situ, burung-burung bersarang,","poem":1},{"text":"burung ranggung yang rumahnya di pohon-pohon sanobar.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Gunung-gunung tinggi untuk kambing gunung liar,","poem":1},{"text":"bukit-bukit batu untuk perlindungan bagi pelanduk.","poem":2}]},{"type":"line_break"},{"type":"verse","number":19,"content":[{"text":"Engkau menjadikan bulan sebagai penanda musim;","poem":1},{"text":"matahari tahu kapan terbenam.","poem":2}]},{"type":"verse","number":20,"content":[{"text":"Engkau membuat kegelapan dan menjadikannya malam,","poem":1},{"text":"saat semua makhluk hutan berkeliaran.","poem":2}]},{"type":"verse","number":21,"content":[{"text":"Singa-singa muda mengaum untuk mangsanya,","poem":1},{"text":"dan mencari makanannya dari Allah.","poem":2}]},{"type":"verse","number":22,"content":[{"text":"Matahari pun terbit, maka mereka berkumpul,","poem":1},{"text":"dan berbaring dalam liangnya.","poem":2}]},{"type":"verse","number":23,"content":[{"text":"Lalu, manusia keluar untuk pekerjaannya,","poem":1},{"text":"dan kerja kerasnya berlangsung hingga petang.","poem":2}]},{"type":"line_break"},{"type":"verse","number":24,"content":[{"text":"Ya TUHAN, betapa banyaknya pekerjaan-Mu!","poem":1},{"text":"Dalam hikmat, Engkau telah menjadikan semuanya;","poem":2},{"lineBreak":true},{"text":"bumi penuh dengan milik-Mu.","poem":2}]},{"type":"verse","number":25,"content":[{"text":"Ada lautan, besar dan luas;","poem":1},{"text":"tak terhitung makhluk hidup yang berkeliaran di dalamnya,","poem":2},{"lineBreak":true},{"text":"baik kecil maupun besar.","poem":2}]},{"type":"verse","number":26,"content":[{"text":"Di sana, kapal-kapal berlayar,","poem":1},{"text":"dan Lewiatan,","poem":2},{"lineBreak":true},{"text":"yang Engkau bentuk untuk bermain-main di dalamnya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":27,"content":[{"text":"Mereka semua menanti-nantikan Engkau","poem":1},{"text":"untuk memberi mereka makan pada waktunya.","poem":2}]},{"type":"verse","number":28,"content":[{"text":"Saat Engkau memberikannya kepada mereka, mereka mengumpulkannya;","poem":1},{"text":"saat Engkau membuka tangan-Mu,","poem":2},{"lineBreak":true},{"text":"mereka akan dipuaskan dengan kebaikan.","poem":2}]},{"type":"verse","number":29,"content":[{"text":"Saat Engkau menyembunyikan wajah-Mu,","poem":1},{"text":"mereka terkejut.","poem":2},{"text":"Saat Engkau mengambil napas mereka,","poem":1},{"text":"mereka mati, dan kembali menjadi debu.","poem":2}]},{"type":"verse","number":30,"content":[{"text":"Saat Engkau mengutus Roh-Mu,","poem":1},{"text":"mereka semua tercipta,","poem":2},{"lineBreak":true},{"text":"dan Engkau membarui muka bumi.","poem":2}]},{"type":"line_break"},{"type":"verse","number":31,"content":[{"text":"Kiranya kemuliaan TUHAN bertahan selama-lamanya;","poem":1},{"text":"kiranya TUHAN bersukacita dalam pekerjaan-pekerjaan-Nya;","poem":2}]},{"type":"verse","number":32,"content":[{"text":"yang memandang bumi sehingga membuatnya gemetar,","poem":1},{"lineBreak":true},{"text":"dan menyentuh gunung-gunung sehingga membuatnya berasap.","poem":1}]},{"type":"line_break"},{"type":"verse","number":33,"content":[{"text":"Aku akan bernyanyi bagi TUHAN selama aku hidup;","poem":1},{"text":"aku akan bermazmur bagi Allah selama aku ada.","poem":2}]},{"type":"verse","number":34,"content":[{"text":"Kiranya renunganku menyenangkan-Nya,","poem":1},{"text":"dan aku akan bersukacita di dalam TUHAN.","poem":2}]},{"type":"verse","number":35,"content":[{"text":"Biarlah para pendosa dilenyapkan dari bumi,","poem":1},{"text":"dan biarlah orang-orang fasik tidak ada lagi!","poem":2},{"lineBreak":true},{"text":"Pujilah TUHAN, hai jiwaku!","poem":1},{"text":"Haleluya!","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/104.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/105.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/103.json","previousChapterAudioLinks":{},"numberOfVerses":35}