{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":101,"content":[{"type":"heading","content":["Norma Kehidupan untuk Penguasa"]},{"type":"verse","number":1,"content":[{"text":"Mazmur Daud.","descriptive":true},{"lineBreak":true},{"text":"Aku akan bernyanyi tentang kesetiaan dan keadilan;","poem":1},{"text":"kepada Engkau, ya TUHAN, aku akan bermazmur.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Aku akan berlaku bijak di jalan yang tak bercela.","poem":1},{"text":"Kapan Engkau akan datang kepadaku?","poem":2},{"lineBreak":true},{"text":"Aku akan hidup dengan ketulusan hati","poem":2},{"lineBreak":true},{"text":"di dalam rumahku.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Aku takkan menaruh perkara tak berharga","poem":1},{"text":"di hadapan mataku.","poem":2},{"lineBreak":true},{"text":"Aku membenci perbuatan orang-orang yang memberontak;","poem":1},{"text":"hal itu takkan melekat padaku.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Hati yang bengkok akan jauh dariku;","poem":1},{"text":"Aku tak mau mengenal kejahatan.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Siapa pun yang diam-diam mencaci sesamanya,","poem":1},{"text":"aku akan membinasakannya.","poem":2},{"text":"Aku takkan tahan","poem":1},{"text":"terhadap orang yang bermata congkak dan tinggi hati.","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"Mataku tertuju pada orang-orang yang setia di negeri","poem":1},{"text":"supaya mereka diam bersamaku;","poem":2},{"lineBreak":true},{"text":"dia yang berjalan di jalan yang tidak bercela akan melayani aku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Dia yang melakukan tipu daya","poem":1},{"text":"takkan diam di dalam rumahku;","poem":2},{"text":"dia yang mengucapkan kebohongan","poem":1},{"text":"takkan tegak di mataku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"Setiap pagi aku akan membinasakan","poem":1},{"text":"semua orang fasik di negeri;","poem":2},{"text":"aku akan melenyapkan semua pelaku kejahatan","poem":1},{"text":"dari kota TUHAN.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/101.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/102.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/100.json","previousChapterAudioLinks":{},"numberOfVerses":8}