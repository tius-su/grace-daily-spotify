{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":22,"content":[{"type":"heading","content":["Doa Orang yang Tidak Bersalah"]},{"type":"verse","number":1,"content":[{"text":"Kepada pemimpin pujian: Dengan lagu “Rusa pada waktu fajar.” Nyanyian Daud.","descriptive":true},{"lineBreak":true},{"text":"(22-2) Allahku, Allahku,","poem":1},{"text":"mengapa Engkau meninggalkan aku?","poem":2},{"text":"Keselamatanku jauh dariku,","poem":1},{"text":"adalah kata-kata raunganku.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"(22-3) Ya Allahku, aku memanggil pada siang hari,","poem":1},{"text":"tetapi Engkau tidak menjawab.","poem":2},{"text":"Dan, pada malam hari,","poem":1},{"text":"tetapi aku tidak juga tenang.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"(22-4) Namun, Engkau itu kudus;","poem":1},{"text":"duduk di atas puji-pujian orang Israel.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"(22-5) Di dalam Engkau, nenek moyang kami percaya.","poem":1},{"text":"Mereka percaya dan Kauselamatkan mereka.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"(22-6) Kepada Engkau, mereka berseru-seru,","poem":1},{"text":"dan diselamatkan.","poem":2},{"text":"Di dalam Engkau mereka percaya,","poem":1},{"text":"dan tidak dipermalukan.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"(22-7) Namun, aku ini ulat, bukan manusia.","poem":1},{"lineBreak":true},{"text":"Orang-orang menghina dan membenciku.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"(22-8) Semua yang melihatku mengejekku;","poem":1},{"text":"Mereka membuka bibir, menggelengkan-gelengkan kepalanya.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"(22-9) “Gulirkan dirimu kepada TUHAN,","poem":1},{"text":"biarlah Dia melepaskannya.","poem":2},{"text":"Biarlah Dia menyelamatkannya","poem":1},{"text":"karena Dia berkenan kepadanya.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":9,"content":[{"text":"(22-10) Akan tetapi, Engkau yang menarik aku keluar dari kandungan.","poem":1},{"text":"Engkau membuat aku percaya pada buah dada ibuku.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"(22-11) Aku terlempar dari kandungan;","poem":1},{"text":"Engkau adalah Allahku sejak dalam kandungan ibuku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"(22-12) Jangan menjauh dariku karena kesesakan sudah dekat,","poem":1},{"text":"tetapi tidak ada yang menolong.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"(22-13) Banyak lembu jantan mengelilingi aku;","poem":1},{"text":"yang kuat dari Basan mengepung aku.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"(22-14) Mereka membuka lebar mulutnya kepadaku","poem":1},{"text":"seperti singa yang mengaum-aum dan menerkam.","poem":2}]},{"type":"line_break"},{"type":"verse","number":14,"content":[{"text":"(22-15) Aku tercurah seperti air,","poem":1},{"text":"semua tulangku lepas dari sendinya.","poem":2},{"text":"Hatiku seperti lilin,","poem":1},{"text":"meleleh di antara bagian dalam tubuhku.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"(22-16) Kekuatanku menjadi kering seperti pecahan periuk;","poem":1},{"text":"Lidahku melekat pada langit-langit mulutku.","poem":2},{"lineBreak":true},{"text":"Engkau meletakkan aku di dalam debu kematian.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"(22-17) Sebab, anjing-anjing mengepung aku.","poem":1},{"text":"Gerombolan penjahat mengelilingi aku;","poem":2},{"lineBreak":true},{"text":"mereka menusuk tangan dan kakiku.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"(22-18) Aku bisa menghitung seluruh tulangku;","poem":1},{"text":"Mereka mengamati-amati dan melihat.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"(22-19) Mereka membagi-bagikan pakaianku di antara mereka,","poem":1},{"text":"dan membuang undi atas jubahku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":19,"content":[{"text":"(22-20) Namun, Engkau, ya TUHAN, jangan menjauh!","poem":1},{"text":"ya Kekuatanku, segera tolong aku.","poem":2}]},{"type":"verse","number":20,"content":[{"text":"(22-21) Selamatkan jiwaku dari pedang,","poem":1},{"text":"dari cengkeraman anjing-anjing.","poem":2}]},{"type":"verse","number":21,"content":[{"text":"(22-22) Selamatkan aku dari mulut singa,","poem":1},{"text":"dari tanduk banteng liar;","poem":2},{"lineBreak":true},{"text":"Engkau telah menjawab aku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":22,"content":[{"text":"(22-23) Aku akan menceritakan nama-Mu","poem":1},{"text":"kepada saudara-saudaraku;","poem":2},{"text":"di tengah-tengah perkumpulan,","poem":1},{"text":"aku akan memuji Engkau.","poem":2}]},{"type":"verse","number":23,"content":[{"text":"(22-24) Kamu yang takut akan TUHAN, pujilah Dia!","poem":1},{"text":"Kamu semua keturunan Yakub, muliakan Dia!","poem":2},{"text":"Kamu semua keturunan Israel, takutlah akan Dia!","poem":1}]},{"type":"verse","number":24,"content":[{"lineBreak":true},{"text":"(22-25) Sebab, Dia tidak memandang rendah atau membenci","poem":1},{"text":"penderitaan orang yang tertindas.","poem":2},{"text":"Dia tidak menyembunyikan wajah-Nya dari orang itu,","poem":1},{"text":"dan telah mendengar seruan mereka.","poem":2}]},{"type":"line_break"},{"type":"verse","number":25,"content":[{"text":"(22-26) Dari Engkau, datang pujianku di dalam kumpulan yang besar;","poem":1},{"text":"aku akan membayar nazarku di hadapan mereka yang takut akan Dia.","poem":2}]},{"type":"verse","number":26,"content":[{"text":"(22-27) Orang-orang tertindas akan makan, dan dipuaskan.","poem":1},{"text":"Mereka yang mencari Dia akan memuji-muji TUHAN.","poem":2},{"lineBreak":true},{"text":"Kiranya hatimu akan hidup untuk selamanya!","poem":2}]},{"type":"verse","number":27,"content":[{"text":"(22-28) Semua ujung bumi akan ingat,","poem":1},{"text":"dan berbalik kepada TUHAN.","poem":2},{"text":"Dan, semua kaum bangsa-bangsa,","poem":1},{"text":"akan sujud menyembah di hadapan-Nya.","poem":2}]},{"type":"verse","number":28,"content":[{"text":"(22-29) Sebab, TUHAN adalah Raja,","poem":1},{"text":"dan Dia memerintah atas bangsa-bangsa.","poem":2}]},{"type":"verse","number":29,"content":[{"text":"(22-30) Semua orang gemuk di atas bumi akan makan dan menyembah.","poem":1},{"text":"Semua orang yang turun ke dalam debu akan berlutut di hadapan-Nya;","poem":2},{"text":"mereka yang tidak dapat menyambung hidup jiwanya.","poem":1}]},{"type":"verse","number":30,"content":[{"lineBreak":true},{"text":"(22-31) Satu keturunan akan melayani Dia,","poem":1},{"text":"mereka akan menceritakan tentang TUHAN kepada generasi yang akan datang.","poem":2}]},{"type":"verse","number":31,"content":[{"text":"(22-32) Mereka akan datang dan memberitahukan kebenaran-Nya","poem":1},{"text":"kepada bangsa yang akan dilahirkan,","poem":2},{"lineBreak":true},{"text":"bahwa Dia telah bertindak.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/22.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/23.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/21.json","previousChapterAudioLinks":{},"numberOfVerses":31}