{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":50,"content":[{"type":"heading","content":["TUHAN adalah Hakim"]},{"type":"verse","number":1,"content":[{"text":"Nyanyian Asaf.","descriptive":true},{"lineBreak":true},{"text":"Yang Mahakuasa, Allah, TUHAN,","poem":1},{"text":"berfirman dan memanggil bumi,","poem":2},{"lineBreak":true},{"text":"dari tempat terbitnya matahari hingga saat terbenamnya.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Dari Sion, yaitu keindahan yang sempurna,","poem":1},{"text":"Allah bersinar.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Allah kita datang dan tidak tinggal diam.","poem":1},{"text":"Api melalap di hadapan-Nya;","poem":2},{"lineBreak":true},{"text":"badai kencang di sekeliling-Nya.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Dia berseru kepada langit tinggi,","poem":1},{"text":"dan kepada bumi untuk mengadili umat-Nya.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"“Berkumpullah orang-orang yang Kukasihi,","poem":1},{"text":"yang mengikat perjanjian dengan-Ku melalui kurban.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"Langit menyatakan kebenaran-Nya","poem":1},{"text":"karena Allah adalah Hakim. Sela","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"“Dengarlah, hai umat-Ku, Aku hendak berfirman!","poem":1},{"text":"Hai orang Israel, Aku hendak bersaksi terhadap kamu:","poem":2},{"lineBreak":true},{"text":"Aku adalah Allah, Allahmu.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Bukan karena kurban sembelihanmu Aku mengadilimu,","poem":1},{"text":"atau karena kurban bakaranmu yang selalu ada di hadapan-Ku.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Aku takkan mengambil sapi jantan dari rumahmu,","poem":1},{"text":"ataupun kambing jantan dari kandang-kandangmu.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Sebab, segala yang hidup di hutan adalah milik-Ku,","poem":1},{"text":"begitu juga ternak di ribuan perbukitan.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Aku mengenal semua burung di bukit-bukit,","poem":1},{"text":"dan semua makhluk yang bergerak di ladang adalah milik-Ku.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Jika Aku lapar, Aku takkan memberitahumu","poem":1},{"text":"karena dunia dan segala isinya adalah milik-Ku.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Apakah Aku makan daging sapi jantan,","poem":1},{"text":"atau minum darah kambing jantan?","poem":2}]},{"type":"line_break"},{"type":"verse","number":14,"content":[{"text":"Persembahkanlah kepada Allah kurban syukur,","poem":1},{"text":"dan bayarlah nazarmu kepada Yang Mahatinggi!","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Berserulah kepada-Ku pada waktu kesusahan,","poem":1},{"text":"Aku akan menyelamatkanmu, dan kamu akan memuliakan Aku.” Sela","poem":2}]},{"type":"line_break"},{"type":"verse","number":16,"content":[{"text":"Namun, kepada orang fasik Allah berfirman,","poem":1},{"text":"“Apa urusanmu memperhitungkan ketetapan-ketetapan-Ku,","poem":2},{"lineBreak":true},{"text":"atau membawa perjanjian-Ku dengan mulutmu?","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Sebab, kamu membenci didikan,","poem":1},{"text":"dan membuang firman-Ku.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Saat kamu melihat pencuri, kamu berkenan padanya,","poem":1},{"text":"dan bagianmu adalah berzina.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Kamu mengumbar mulutmu pada kejahatan,","poem":1},{"text":"dan lidahmu terikat dengan tipu daya.","poem":2}]},{"type":"verse","number":20,"content":[{"text":"Kamu duduk dan berbicara melawan saudaramu;","poem":1},{"text":"kamu memfitnah anak-anak ibumu sendiri.","poem":2}]},{"type":"verse","number":21,"content":[{"text":"Semua itu telah kamu perbuat, dan Aku tetap diam.","poem":1},{"text":"Kamu mengira Aku seperti dirimu,","poem":2},{"text":"tetapi sekarang Aku akan mengadilimu,","poem":1},{"text":"dan menaruh perkara ini dengan teratur di hadapanmu.","poem":2}]},{"type":"verse","number":22,"content":[{"text":"Pertimbangkan ini, hai kamu yang melupakan Allah,","poem":1},{"text":"agar jangan Aku merobekmu dan tidak ada yang menyelamatkan.","poem":2}]},{"type":"verse","number":23,"content":[{"text":"Barang siapa mempersembahkan kurban syukur,","poem":1},{"text":"dia memuliakan Aku.","poem":2},{"lineBreak":true},{"text":"Barang siapa menetapkan jalannya,","poem":2},{"lineBreak":true},{"text":"kepadanya akan Kuperlihatkan keselamatan Allah.”","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/50.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/51.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/49.json","previousChapterAudioLinks":{},"numberOfVerses":23}