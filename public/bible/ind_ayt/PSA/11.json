{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":11,"content":[{"type":"heading","content":["Keyakinan akan Kehadiran TUHAN"]},{"type":"verse","number":1,"content":[{"text":"Kepada pemimpin pujian: Nyanyian Daud.","descriptive":true},{"lineBreak":true},{"text":"Dalam TUHAN, aku mencari perlindungan.","poem":1},{"text":"Bagaimana kamu dapat berkata kepada jiwaku,","poem":2},{"lineBreak":true},{"text":"“Terbanglah ke gunungmu seperti burung!”","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Sebab, lihat, orang fasik melenturkan busurnya;","poem":1},{"text":"Mereka menyiapkan panahnya pada tali busur,","poem":2},{"lineBreak":true},{"text":"untuk memanah dalam kegelapan orang-orang yang tulus hati.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Jika dasar-dasar diruntuhkan,","poem":1},{"text":"apa yang bisa orang benar lakukan?","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"TUHAN ada di bait kudus-Nya;","poem":1},{"text":"takhta TUHAN ada di surga.","poem":2},{"text":"Mata-Nya melihat,","poem":1},{"text":"dan kelopak mata-Nya menguji anak-anak manusia.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"TUHAN menguji orang benar,","poem":1},{"text":"tetapi Dia membenci orang fasik dan orang yang mencintai kekerasan.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Dia menghujani orang fasik dengan perangkap;","poem":1},{"text":"api, belerang, dan angin panas, akan menjadi bagian dari cawan mereka.","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Sebab, TUHAN itu benar,","poem":1},{"text":"Dia mencintai kebenaran.","poem":2},{"lineBreak":true},{"text":"Orang benar akan melihat wajah-Nya.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/11.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/12.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/10.json","previousChapterAudioLinks":{},"numberOfVerses":7}