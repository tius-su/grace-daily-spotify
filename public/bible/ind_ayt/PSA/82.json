{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":82,"content":[{"type":"heading","content":["Allah Adalah Sang Hakim"]},{"type":"verse","number":1,"content":[{"text":"Mazmur Asaf.","descriptive":true},{"lineBreak":true},{"text":"Allah berdiri dalam sidang ilahi;","poem":1},{"text":"Dia menghakimi di tengah-tengah para ilah.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"“Berapa lama lagi kamu akan menghakimi dengan tidak adil,","poem":1},{"text":"dan memihak orang fasik?” Sela","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"“Belalah orang miskin dan anak yatim,","poem":1},{"text":"berikanlah keadilan kepada orang yang tertindas dan melarat.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Selamatkan orang miskin dan tak berdaya,","poem":1},{"text":"lepaskan mereka dari tangan orang fasik.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"Mereka tidak tahu ataupun paham;","poem":1},{"text":"mereka berjalan dalam kegelapan;","poem":2},{"lineBreak":true},{"text":"semua dasar bumi terguncang.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Aku berkata, “Kamu adalah ilah-ilah;","poem":1},{"text":"anak-anak Yang Mahatinggilah kamu semua.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Akan tetapi, kamu akan mati seperti manusia,","poem":1},{"text":"dan rebah seperti salah satu pemimpin.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"Bangkitlah, ya Allah, hakimilah bumi;","poem":1},{"text":"sebab Engkau yang memiliki semua bangsa.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/82.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/83.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/81.json","previousChapterAudioLinks":{},"numberOfVerses":8}