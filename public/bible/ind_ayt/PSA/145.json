{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":145,"content":[{"type":"heading","content":["Kebesaran dan Kebaikan TUHAN"]},{"type":"verse","number":1,"content":[{"text":"Mazmur pujian Daud.","descriptive":true},{"lineBreak":true},{"text":"Aku akan meninggikan-Mu,","poem":1},{"text":"ya Allahku, ya Raja,","poem":2},{"lineBreak":true},{"text":"dan memuji nama-Mu selama-lamanya.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Setiap hari aku akan menyembah-Mu,","poem":1},{"text":"dan memuji-Mu selama-lamanya.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"TUHAN itu besar dan dipuji dengan berlimpah,","poem":1},{"text":"kebesaran-Nya itu tidak terselidiki.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Setiap generasi akan memuji pekerjaan-pekerjaan-Mu kepada yang lainnya,","poem":1},{"text":"dan akan memberitakan keperkasaan-Mu.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Kemuliaan keagungan-Mu yang gemilang dan pekerjaan-pekerjaan-Mu yang ajaib,","poem":1},{"text":"akan aku renungkan.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Mereka akan memperkatakan kuasa perbuatan-perbuatan-Mu yang luar biasa,","poem":1},{"text":"dan aku akan menceritakan kebesaran-Mu.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Mereka akan mencurahkan ingatan akan besarnya kebaikan-Mu,","poem":1},{"text":"dan akan menyorakkan kebenaran-Mu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"TUHAN itu murah hati dan belas kasih,","poem":1},{"text":"lambat untuk marah dan besar kebaikan-Nya.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"TUHAN itu baik kepada semua,","poem":1},{"text":"dan kemurahan-Nya ada atas semua yang telah dijadikan-Nya.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Semua karya-Mu akan bersyukur kepada-Mu, ya TUHAN,","poem":1},{"text":"dan orang-orang kudus-Mu akan memuji-Mu.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Mereka akan memperkatakan kemuliaan kerajaan-Mu,","poem":1},{"text":"dan membicarakan kuasa-Mu,","poem":2}]},{"type":"verse","number":12,"content":[{"text":"untuk memberitakan kepada anak-anak manusia perbuatan-perbuatan-Mu yang besar,","poem":1},{"text":"dan mulianya keagungan kerajaan-Mu.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Kerajaan-Mu adalah kerajaan kekal,","poem":1},{"text":"dan pemerintahan-Mu di segala generasi.","poem":2},{"lineBreak":true},{"text":"TUHAN itu setia dalam segala firman-Nya dan baik dalam segala pekerjaan-Nya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":14,"content":[{"text":"TUHAN menyokong semua yang jatuh,","poem":1},{"text":"dan membangkitkan semua yang tertunduk.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Mata semua orang menanti-nantikan Engkau,","poem":1},{"text":"dan Engkau memberi mereka makanan kepada mereka pada waktunya.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Engkau membuka tangan-Mu,","poem":1},{"text":"Engkau memuaskan hasrat semua makhluk hidup.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"TUHAN itu benar dalam segala jalan-Nya,","poem":1},{"text":"dan baik dalam segala perbuatan-Nya.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"TUHAN itu dekat kepada semua yang berseru kepada-Nya;","poem":1},{"text":"kepada semua yang berseru kepada-Nya dalam kesetiaan.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Dia memenuhi hasrat orang-orang","poem":1},{"text":"yang takut kepada-Nya,","poem":2},{"text":"Dia mendengar tangisan mereka minta tolong,","poem":1},{"text":"dan menyelamatkan mereka.","poem":2}]},{"type":"verse","number":20,"content":[{"text":"TUHAN melindungi semua yang mengasihi-Nya,","poem":1},{"text":"tetapi semua orang fasik akan Dia binasakan.","poem":2}]},{"type":"verse","number":21,"content":[{"text":"Mulutku akan memperkatakan pujian kepada TUHAN,","poem":1},{"text":"dan biarlah semua tubuh memuji nama-Nya yang kudus selama-lamanya!","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/145.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/146.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/144.json","previousChapterAudioLinks":{},"numberOfVerses":21}