{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":14,"content":[{"type":"heading","content":["Nyanyian tentang Si Bodoh"]},{"type":"verse","number":1,"content":[{"text":"Kepada pemimpin pujian: Nyanyian Daud.","descriptive":true},{"lineBreak":true},{"text":"Orang bodoh berkata dalam hatinya,","poem":1},{"text":"“Tidak ada Allah.”","poem":2},{"text":"Mereka rusak,","poem":1},{"text":"dan melakukan perbuatan keji;","poem":2},{"lineBreak":true},{"text":"tidak ada yang berbuat baik.","poem":2}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"TUHAN melihat ke bawah dari surga","poem":1},{"text":"kepada anak-anak manusia,","poem":2},{"text":"untuk melihat jika ada seseorang yang bijaksana","poem":1},{"text":"yang mencari Allah.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Mereka semua telah menyimpang;","poem":1},{"text":"Mereka bersama-sama telah menjadi keji.","poem":2},{"text":"Tidak ada seorang pun yang berbuat baik.","poem":1},{"text":"Seorang pun tidak!","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"Apakah semua orang yang berbuat fasik tidak tahu;","poem":1},{"text":"yang memakan habis umat-Ku seperti memakan roti,","poem":2},{"lineBreak":true},{"text":"dan tidak berseru kepada TUHAN?","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Di sana, mereka berada dalam ketakutan besar","poem":1},{"text":"karena Allah ada bersama dengan keturunan orang benar.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Kamu mempermalukan nasihat orang tertindas,","poem":1},{"text":"tetapi TUHAN ialah tempat perlindungannya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Kiranya keselamatan bagi orang Israel datang dari Sion!","poem":1},{"text":"Ketika TUHAN memulihkan keadaan umat-Nya,","poem":2},{"text":"Yakub akan bersukacita,","poem":1},{"text":"Israel akan bergembira.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/14.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/15.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/13.json","previousChapterAudioLinks":{},"numberOfVerses":7}