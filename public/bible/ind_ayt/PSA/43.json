{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":43,"content":[{"type":"heading","content":["Kirimlah Terang dan Kebenaran-Mu"]},{"type":"verse","number":1,"content":[{"text":"Belalah aku, ya Allah, dan perjuangkan perkaraku","poem":1},{"text":"melawan bangsa yang tidak beriman!","poem":2},{"lineBreak":true},{"text":"Lepaskan aku dari penipu dan orang-orang curang!","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Sebab, Engkau adalah Allah perlindunganku.","poem":1},{"text":"Mengapa Engkau menolak aku?","poem":2},{"text":"Mengapa aku pergi meratap oleh karena penindasan musuh?","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Utuslah terang-Mu dan kebenaran-Mu,","poem":1},{"text":"biarlah mereka menuntun dan membawaku ke gunung-Mu yang kudus,","poem":2},{"lineBreak":true},{"text":"dan ke tempat kediaman-Mu.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Kemudian, aku akan pergi ke mazbah Allah,","poem":1},{"text":"kepada Allah, sukacita kegembiraanku,","poem":2},{"text":"dan aku akan bersyukur dengan kecapi, kepada-Mu, ya Allah, Allahku.","poem":1}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"Mengapa kamu menunduk, hai jiwaku?","poem":1},{"text":"Mengapa kamu menggeram di dalamku?","poem":2},{"text":"Nantikanlah Allah!","poem":1},{"text":"Sebab, aku akan bersyukur lagi kepada Allah","poem":2},{"lineBreak":true},{"text":"karena keselamatan di hadapan-Nya.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/43.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/44.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/42.json","previousChapterAudioLinks":{},"numberOfVerses":5}