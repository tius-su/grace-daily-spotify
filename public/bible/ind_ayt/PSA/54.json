{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":54,"content":[{"type":"heading","content":["Doa Penuh Percaya Diri dalam Bahaya Besar"]},{"type":"verse","number":1,"content":[{"text":"Kepada pemimpin pujian: Dengan alat musik petik. Nyanyian perenungan Daud (54-2) sewaktu orang-orang Zifi datang dan berkata kepada Saul, “Bukankah ada Daud yang bersembunyi di tengah-tengah kita?”.","descriptive":true},{"lineBreak":true},{"text":"(54-3) Ya Allah, selamatkan aku oleh nama-Mu;","poem":1},{"text":"adililah aku oleh kekuatan-Mu.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"(54-4) Ya Allah, dengarkanlah doaku;","poem":1},{"text":"perhatikanlah perkataan mulutku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"(54-5) Sebab, orang-orang asing telah bangkit melawanku,","poem":1},{"text":"dan orang-orang yang menakutkan mengincar nyawaku,","poem":2},{"lineBreak":true},{"text":"yang tidak menempatkan Allah di hadapan mereka sendiri. Sela","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"(54-6) Sebenarnya, Allah adalah penolongku;","poem":1},{"text":"Tuhan adalah penopang jiwaku.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"(54-7) Dia akan membalaskan kejahatan kepada musuh-musuhku;","poem":1},{"text":"dalam kesetiaan-Mu, Engkau menghabisi mereka.","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"(54-8) Dengan sukarela, aku akan mempersembahkan kurban kepada-Mu;","poem":1},{"text":"aku akan bersyukur kepada nama-Mu, ya TUHAN,","poem":2},{"lineBreak":true},{"text":"karena ini baik.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"(54-9) Sebab, Dia akan melepaskanku dari segala kesusahan,","poem":1},{"text":"dan mataku memandang kepada musuh-musuhku.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/54.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/55.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/53.json","previousChapterAudioLinks":{},"numberOfVerses":7}