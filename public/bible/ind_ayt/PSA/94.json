{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":94,"content":[{"type":"heading","content":["Doa untuk Pembalasan"]},{"type":"verse","number":1,"content":[{"text":"Ya TUHAN, Allah Pembalas,","poem":1},{"text":"ya Allah Pembalas, bersinarlah!","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Bangkitlah, ya Hakim bumi,","poem":1},{"text":"balaslah orang-orang sombong!","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Berapa lama lagi orang-orang fasik, ya TUHAN,","poem":1},{"text":"berapa lama lagi orang-orang fasik akan bersukaria?","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Mereka menumpahkan kata-kata congkak;","poem":1},{"text":"semua pelaku kejahatan membanggakan diri.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Mereka meremukkan umat-Mu, ya TUHAN,","poem":1},{"text":"dan menindas milik pusaka-Mu.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Mereka membunuh janda dan orang yang tinggal sementara,","poem":1},{"text":"mereka pun menghabisi anak-anak yatim.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Mereka berkata, “TUHAN tidak melihat,","poem":1},{"text":"begitu juga Allah Yakub tidak memperhatikannya.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"Perhatikanlah,","poem":1},{"text":"hai orang-orang bebal di antara bangsa-bangsa;","poem":2},{"text":"hai kamu orang bodoh,","poem":1},{"text":"kapan kamu akan menjadi bijak?","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Dia yang menanam telinga,","poem":1},{"text":"tidakkah Dia mendengar?","poem":2},{"text":"Dia yang membentuk mata,","poem":1},{"text":"tidakkah Dia melihat?","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Dia yang mendidik bangsa-bangsa,","poem":1},{"text":"tidakkah Dia menegur?","poem":2},{"lineBreak":true},{"text":"Dia yang mengajari manusia tentang pengetahuan.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"TUHAN mengetahui rancangan-rancangan manusia,","poem":1},{"text":"mereka itu seembusan napas.","poem":2}]},{"type":"line_break"},{"type":"verse","number":12,"content":[{"text":"Diberkatilah orang yang Engkau didik, ya TUHAN,","poem":1},{"text":"dan yang Engkau ajari hukum-Mu,","poem":2}]},{"type":"verse","number":13,"content":[{"text":"untuk menenangkan dia dari hari-hari kesengsaraan,","poem":1},{"text":"sampai lubang digali bagi orang-orang fasik.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Sebab, TUHAN takkan membiarkan umat-Nya;","poem":1},{"text":"Dia takkan meninggalkan milik pusaka-Nya.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Sebab, keadilan akan kembali kepada kebenaran,","poem":1},{"text":"dan semua orang yang lurus hati akan mengikutinya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":16,"content":[{"text":"Siapa yang akan bangkit bagiku untuk melawan orang-orang jahat?","poem":1},{"text":"Siapa yang akan berdiri bagiku untuk melawan orang-orang yang melakukan kefasikan?","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Jika TUHAN tidak menjadi penolongku,","poem":1},{"text":"jiwaku akan segera berdiam di tempat sunyi.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Jika aku berkata, “Kakiku tergelincir,”","poem":1},{"text":"kasih setia-Mu, ya TUHAN, menopang aku.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Ketika pikiranku bertambah-tambah di dalam batinku,","poem":1},{"text":"penghiburan-penghiburan-Mu menyenangkan jiwaku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":20,"content":[{"text":"Dapatkah takhta penghancuran bersekutu dengan Engkau,","poem":1},{"text":"mereka yang merancangkan kesusahan sesuai dengan ketetapan?","poem":2}]},{"type":"verse","number":21,"content":[{"text":"Mereka berkomplot melawan hidup orang benar,","poem":1},{"text":"dan menghukum orang yang tidak bersalah.","poem":2}]},{"type":"verse","number":22,"content":[{"text":"Akan tetapi, TUHAN telah menjadi kota bentengku,","poem":1},{"text":"dan Allah gunung batu tempat perlindunganku.","poem":2}]},{"type":"verse","number":23,"content":[{"text":"Dia akan membalas kejahatan mereka kepada mereka sendiri,","poem":1},{"text":"dan akan membinasakan mereka dalam kejahatan mereka;","poem":2},{"text":"TUHAN, Allah kita, akan membinasakan mereka.","poem":1}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/94.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/95.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/93.json","previousChapterAudioLinks":{},"numberOfVerses":23}