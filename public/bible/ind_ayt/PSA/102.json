{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":102,"content":[{"type":"heading","content":["Doa pada Masa Penderitaan"]},{"type":"verse","number":1,"content":[{"text":"Doa orang yang menderita ketika dia lemah dan ingin mencurahkan semua keluhannya di hadapan TUHAN.","descriptive":true},{"lineBreak":true},{"text":"(102-2) Dengarkanlah doaku, ya TUHAN,","poem":1},{"text":"biarlah seruanku minta tolong sampai kepada-Mu.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"(102-3) Jangan sembunyikan wajah-Mu dariku","poem":1},{"text":"pada waktu kesesakanku;","poem":2},{"text":"pada hari aku berseru, sendengkanlah telinga-Mu kepadaku,","poem":1},{"text":"jawablah aku dengan segera.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"(102-4) Sebab, hari-hariku habis seperti asap,","poem":1},{"text":"dan tulang-tulangku terbakar seperti perapian.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"(102-5) Hatiku terpukul, dan menjadi kering seperti rumput,","poem":1},{"text":"sehingga aku lupa memakan rotiku.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"(102-6) Oleh karena suara eranganku,","poem":1},{"text":"tulang-tulangku melekat pada dagingku.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"(102-7) Aku seperti seekor burung pelikan di padang belantara,","poem":1},{"text":"seperti burung hantu di antara reruntuhan.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"(102-8) Aku terjaga;","poem":1},{"text":"aku menjadi seperti burung yang terasing di atas atap rumah.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"(102-9) Sepanjang hari, musuh-musuhku mencela aku;","poem":1},{"text":"mereka yang sombong menyumpahiku.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"(102-10) Sebab, aku memakan abu seperti roti,","poem":1},{"text":"dan mencampur minumanku dengan tangisan","poem":2}]},{"type":"verse","number":10,"content":[{"text":"(102-11) oleh karena amarah-Mu dan murka-Mu.","poem":1},{"text":"Sebab, Engkau telah mengangkat aku, dan membuang aku.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"(102-12) Hari-hariku seperti bayang-bayang yang memanjang,","poem":1},{"text":"dan aku kering seperti rumput.","poem":2}]},{"type":"line_break"},{"type":"verse","number":12,"content":[{"text":"(102-13) Akan tetapi, Engkau, ya TUHAN, bertakhta selamanya;","poem":1},{"text":"nama-Mu diingat dari generasi ke generasi.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"(102-14) Engkau akan bangkit, dan mengasihani Sion.","poem":1},{"text":"Sebab, waktu yang tepat untuk berbelas kasih kepadanya","poem":2},{"lineBreak":true},{"text":"sudah tiba.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"(102-15) Sebab, hamba-hamba-Mu berkenan kepada batu-batunya,","poem":1},{"text":"dan mengasihani debunya.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"(102-16) Bangsa-bangsa akan takut terhadap nama TUHAN,","poem":1},{"text":"dan semua raja bumi akan takut terhadap kemuliaan-Mu.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"(102-17) Sebab, TUHAN sudah membangun Sion,","poem":1},{"text":"dan menampakkan kemuliaan-Nya.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"(102-18) Dia akan berpaling kepada doa orang-orang melarat,","poem":1},{"text":"dan tidak merendahkan doa mereka.","poem":2}]},{"type":"line_break"},{"type":"verse","number":18,"content":[{"text":"(102-19) Biarlah ini dituliskan untuk generasi yang akan datang,","poem":1},{"text":"supaya bangsa yang diciptakan akan memuji TUHAN.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"(102-20) Sebab, Dia melihat ke bawah dari tempat kudus-Nya yang tinggi.","poem":1},{"text":"Dari surga, Dia memandang ke bumi","poem":2}]},{"type":"verse","number":20,"content":[{"text":"(102-21) untuk mendengar keluhan para tawanan,","poem":1},{"text":"untuk menyelamatkan anak-anak kematian,","poem":2}]},{"type":"verse","number":21,"content":[{"text":"(102-22) sehingga nama TUHAN diberitakan di Sion,","poem":1},{"text":"dan Dia dipuji-puji di Yerusalem,","poem":2}]},{"type":"verse","number":22,"content":[{"text":"(102-23) ketika bangsa-bangsa berkumpul bersama,","poem":1},{"text":"dan kerajaan-kerajaan berbakti kepada TUHAN.","poem":2}]},{"type":"line_break"},{"type":"verse","number":23,"content":[{"text":"(102-24) Dia telah melemahkan kekuatanku dalam perjalanan;","poem":1},{"text":"Dia telah memperpendek umurku.","poem":2}]},{"type":"verse","number":24,"content":[{"text":"(102-25) Aku berkata, “Ya Allahku, jangan ambil aku di pertengahan umurku.","poem":1},{"text":"Tahun-tahun-Mu tetap dari generasi ke generasi.”","poem":2}]},{"type":"verse","number":25,"content":[{"text":"(102-26) Dahulu, Engkau meletakkan dasar bumi;","poem":1},{"text":"langit itu pekerjaan tangan-Mu.","poem":2}]},{"type":"verse","number":26,"content":[{"text":"(102-27) Semua itu akan lenyap,","poem":1},{"text":"tetapi Engkau akan tetap ada.","poem":2},{"text":"Semua itu akan usang seperti pakaian;","poem":1},{"text":"seperti baju, Engkau akan mengubahnya, dan semua itu akan berubah.","poem":2}]},{"type":"verse","number":27,"content":[{"text":"(102-28) Namun, Engkau tetap sama,","poem":1},{"text":"dan tahun-tahun-Mu takkan berakhir.","poem":2}]},{"type":"verse","number":28,"content":[{"text":"(102-29) Anak-anak para hamba-Mu akan berdiam,","poem":1},{"text":"dan keturunan mereka akan ditetapkan di hadapan-Mu.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/102.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/103.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/101.json","previousChapterAudioLinks":{},"numberOfVerses":28}