{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":28,"content":[{"type":"heading","content":["Teriakan untuk Penghakiman"]},{"type":"verse","number":1,"content":[{"text":"Nyanyian Daud.","descriptive":true},{"lineBreak":true},{"text":"Kepada-Mu, ya TUHAN, aku memanggil.","poem":1},{"text":"Gunung batuku, jangan tuli terhadap aku.","poem":2},{"lineBreak":true},{"text":"Sebab, jika Engkau diam terhadap aku,","poem":2},{"lineBreak":true},{"text":"aku menyerupai mereka yang turun ke lubang kubur.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Dengarlah suara permohonanku,","poem":1},{"text":"ketika aku berseru minta tolong kepada-Mu,","poem":2},{"lineBreak":true},{"text":"ketika aku mengangkat tanganku,","poem":2},{"lineBreak":true},{"text":"ke ruang Mahakudus-Mu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Jangan menyeret aku bersama-sama orang fasik,","poem":1},{"text":"bersama orang-orang yang berlaku jahat,","poem":2},{"lineBreak":true},{"text":"yang berbicara ramah dengan sesamanya,","poem":2},{"lineBreak":true},{"text":"sementara hatinya jahat.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Serahkan mereka sesuai dengan perbuatan jahat mereka.","poem":1},{"text":"Serahkan mereka sesuai dengan perbuatan tangan mereka.","poem":2},{"lineBreak":true},{"text":"Balaslah mereka dengan setimpal.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Sebab, mereka tidak menganggap pekerjaan-pekerjaan TUHAN atau perbuatan tangan-Nya,","poem":1},{"text":"Dia akan meruntuhkan mereka dan tidak membangunnya lagi.","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"Pujilah TUHAN","poem":1},{"text":"karena Dia telah mendengarkan suara permohonanku.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"TUHAN adalah kekuatanku dan perisaiku.","poem":1},{"text":"Aku percaya kepada-Nya di dalam hatiku, aku pun tertolong,","poem":2},{"lineBreak":true},{"text":"karena itu hatiku bersukaria.","poem":2},{"lineBreak":true},{"text":"Dan, dengan nyanyianku, aku hendak bersyukur kepada-Nya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"TUHAN adalah kekuatan umat-Nya,","poem":1},{"text":"Dia adalah benteng keselamatan bagi yang diurapi-Nya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":9,"content":[{"text":"Selamatkanlah umat-Mu,","poem":1},{"text":"dan berkatilah milik pusaka-Mu;","poem":2},{"lineBreak":true},{"text":"Gembalakan mereka dan bawa mereka selama-lamanya.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/28.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/29.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/27.json","previousChapterAudioLinks":{},"numberOfVerses":9}