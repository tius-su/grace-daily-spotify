{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":110,"content":[{"type":"heading","content":["Kristus sebagai Raja dan Imam"]},{"type":"verse","number":1,"content":[{"text":"Mazmur Daud.","descriptive":true},{"lineBreak":true},{"text":"Firman TUHAN kepada tuanku,","poem":1},{"text":"“Duduklah di sebelah kanan-Ku,","poem":2},{"text":"sampai Aku menjadikan musuh-musuhmu pijakan kakimu.”","poem":1}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"TUHAN akan mengulurkan tongkat kekuatanmu dari Sion:","poem":1},{"text":"“Memerintahlah di tengah-tengah musuhmu.”","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Suku-suku bangsa-Mu akan merelakan dirinya,","poem":1},{"text":"pada hari kekuasaan-Mu,","poem":2},{"text":"dengan hiasan kekudusan.","poem":1},{"text":"Dari kandungan sang fajar,","poem":2},{"text":"kemudaanmu datang kepadamu seperti embun.","poem":1}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"TUHAN telah bersumpah,","poem":1},{"text":"dan takkan menyesal,","poem":2},{"text":"“Engkau adalah imam untuk selamanya-lamanya,","poem":1},{"text":"menurut Melkisedek.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"Tuhan ada di sebelah kananmu,","poem":1},{"text":"Dia akan menghancurkan raja-raja pada hari murka-Nya.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Dia akan mengadakan penghukuman di antara bangsa-bangsa,","poem":1},{"text":"Dia akan memenuhi mereka dengan mayat-mayat,","poem":2},{"text":"Dia akan menghancurkan para pimpinan atas negara yang luas.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Dia akan minum dari lembah-lembah di tepi jalan,","poem":1},{"text":"lalu Dia akan mengangkat kepalanya.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/110.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/111.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/109.json","previousChapterAudioLinks":{},"numberOfVerses":7}