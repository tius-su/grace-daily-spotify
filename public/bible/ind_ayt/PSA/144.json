{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":144,"content":[{"type":"heading","content":["Doa untuk Kemenangan dan Kemakmuran"]},{"type":"verse","number":1,"content":[{"text":"Mazmur Daud.","descriptive":true},{"lineBreak":true},{"text":"Pujilah TUHAN, gunung batuku,","poem":1},{"text":"yang mengajari tangan-tanganku dalam peperangan,","poem":2},{"lineBreak":true},{"text":"dan jari-jariku dalam pertempuran.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Kebaikanku dan kubu pertahananku,","poem":1},{"text":"kota bentengku dan penyelamatku,","poem":2},{"text":"perisaiku dan Dia adalah yang kepada-Nya aku berlindung,","poem":1},{"text":"yang menundukkan bangsa-bangsa di bawahku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Ya TUHAN, apakah itu manusia sehingga Engkau mengenalnya?","poem":1},{"text":"Atau, anak manusia, sehingga Engkau memikirkannya?","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Manusia itu seperti embusan napas,","poem":1},{"text":"hari-harinya seperti bayangan yang berlalu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"Bungkukkan langit-Mu, ya TUHAN, dan turunlah!","poem":1},{"text":"Sentuhlah gunung-gunung","poem":2},{"lineBreak":true},{"text":"sehingga mereka berasap.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Kilatkan cahaya-cahaya,","poem":1},{"text":"dan sebarkan mereka,","poem":2},{"text":"lepaskan anak-anak panah-Mu,","poem":1},{"text":"dan kacaukan mereka.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Ulurkanlah tangan-Mu dari tempat tinggi,","poem":1},{"text":"selamatkan dan lepaskan aku dari air bah,","poem":2},{"lineBreak":true},{"text":"dari tangan orang-orang asing.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Yang mulutnya mengucapkan dusta,","poem":1},{"text":"dan yang tangan kanannya adalah tangan kanan kebohongan.","poem":2}]},{"type":"line_break"},{"type":"verse","number":9,"content":[{"text":"Aku akan menyanyikan lagu baru kepada-Mu, ya Allah,","poem":1},{"text":"dengan kecapi sepuluh tali, aku akan bermazmur;","poem":2}]},{"type":"verse","number":10,"content":[{"text":"yang memberi keselamatan kepada raja-raja,","poem":1},{"text":"yang menyelamatkan Daud, hamba-Nya, dari pedang kejahatan.","poem":2}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"Selamatkan dan lepaskan aku dari tangan orang-orang asing,","poem":1},{"text":"yang mulutnya mengucapkan dusta,","poem":2},{"lineBreak":true},{"text":"dan yang tangan kanannya adalah tangan kanan kepalsuan.","poem":2}]},{"type":"line_break"},{"type":"verse","number":12,"content":[{"text":"Kiranya anak-anak laki-laki kita tumbuh di masa mudanya,","poem":1},{"text":"dan anak-anak perempuan kita seperti tiang-tiang penjuru yang dipahat untuk bangunan istana.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Kiranya lumbung-lumbung kita menjadi penuh, mengeluarkan semua jenis barang,","poem":1},{"text":"dan kawanan domba kita bertambah ribuan, bahkan puluhan ribu di atas padang-padang kita.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Kiranya kawanan kita sanggup menanggung beban,","poem":1},{"text":"tanpa pelanggaran atau kerugian.","poem":2},{"text":"Kiranya tidak ada jeritan di alun-alun kota kita.","poem":1}]},{"type":"line_break"},{"type":"verse","number":15,"content":[{"text":"Diberkatilah suku-suku bangsa yang seperti itu;","poem":1},{"text":"diberkatilah suku-suku bangsa yang Allahnya adalah TUHAN!","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/144.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/145.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/143.json","previousChapterAudioLinks":{},"numberOfVerses":15}