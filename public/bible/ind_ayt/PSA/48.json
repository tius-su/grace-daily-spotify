{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":48,"content":[{"type":"heading","content":["Kemegahan Kota yang Tak Terkalahkan"]},{"type":"verse","number":1,"content":[{"text":"Mazmur anak-anak Korah.","descriptive":true},{"lineBreak":true},{"text":"(48-2) Agunglah TUHAN!","poem":1},{"text":"Dia amat dipuji di kota Allah kita,","poem":2},{"lineBreak":true},{"text":"di gunung-Nya yang kudus.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"(48-3) Menjulang indah, kesukaan seluruh bumi,","poem":1},{"text":"adalah Gunung Sion yang jauh di utara,","poem":2},{"text":"kota Sang Raja Besar.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"(48-4) Allah, di dalam istana-istananya,","poem":1},{"text":"telah membuat diri-Nya dikenal sebagai benteng perlindungan.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"(48-5) Sebab, lihatlah, raja-raja berkumpul,","poem":1},{"text":"mereka melewatinya bersama-sama.","poem":2}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"(48-6) Segera setelah mereka melihatnya, mereka tercengang;","poem":2},{"lineBreak":true},{"text":"mereka terkejut lalu cepat-cepat lari.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"(48-7) Ketakutan menyergap mereka di sana;","poem":1},{"text":"kesakitan, seperti perempuan saat bersalin.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"(48-8) Dengan angin timur,","poem":1},{"text":"Engkau menghancurkan kapal-kapal Tarsis.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"(48-9) Seperti yang telah kami dengar, kami telah melihat","poem":1},{"text":"di kota TUHAN, Raja bala tentara, di kota Allah kita.","poem":2},{"lineBreak":true},{"text":"Allah telah menegakkannya untuk selama-lamanya. Sela","poem":2}]},{"type":"line_break"},{"type":"verse","number":9,"content":[{"text":"(48-10) Kami membandingkannya dengan kasih setia-Mu, ya Allah,","poem":1},{"text":"di tengah-tengah bait-Mu.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"(48-11) Seperti nama-Mu, ya Allah, demikian juga puji-pujian bagi-Mu sampai ke ujung bumi.","poem":1},{"lineBreak":true},{"text":"Tangan kanan-Mu dipenuhi dengan kebenaran.","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"(48-12) Biarlah Gunung Sion bergembira!","poem":1},{"text":"Biarlah anak-anak perempuan Yehuda bersorak oleh karena pengadilan-Mu.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"(48-13) Berjalanlah di seputar Sion dan pergilah mengelilinginya,","poem":1},{"text":"hitunglah menaranya.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"(48-14) Taruhlah hatimu pada kubu-kubunya,","poem":1},{"text":"berjalanlah di antara istana-istananya","poem":2},{"lineBreak":true},{"text":"supaya kamu dapat menceritakan kepada generasi selanjutnya.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"(48-15) Sebab Allah, Allah kita,","poem":1},{"text":"kekal dan untuk selama-lamanya.","poem":2},{"lineBreak":true},{"text":"Dia memimpin kita sampai akhir hayat!","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/48.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/49.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/47.json","previousChapterAudioLinks":{},"numberOfVerses":14}