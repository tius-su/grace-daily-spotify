{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":24,"content":[{"type":"heading","content":["Kemuliaan TUHAN dalam Prosesi ke Sion"]},{"type":"verse","number":1,"content":[{"text":"Nyanyian Daud.","descriptive":true},{"lineBreak":true},{"text":"Bumi dan seisinya adalah milik TUHAN,","poem":1},{"text":"dunia dan semua yang tinggal di dalamnya.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Sebab, Dia telah membangunnya di atas lautan,","poem":1},{"text":"dan menegakkannya di atas sungai-sungai.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Siapa boleh naik ke atas bukit TUHAN?","poem":1},{"text":"Siapa boleh berdiri di tempat-Nya yang kudus?","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Dia yang tangannya bersih dan hatinya murni,","poem":1},{"text":"yang tidak membawa jiwanya pada kesia-siaan,","poem":2},{"lineBreak":true},{"text":"dan tidak bersumpah palsu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"Dia akan menerima berkat dari TUHAN,","poem":1},{"text":"dan kebenaran dari Allah keselamatannya.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Inilah generasi orang-orang yang mencari Dia,","poem":1},{"text":"yang mencari wajah Allah Yakub. Sela","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Angkat kepalamu, hai pintu-pintu gerbang,","poem":1},{"text":"dan terangkatlah, hai pintu-pintu abadi,","poem":2},{"lineBreak":true},{"text":"supaya Raja Kemuliaan masuk!","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Siapa Raja Kemuliaan itu?","poem":1},{"text":"TUHAN yang kuat dan perkasa,","poem":2},{"lineBreak":true},{"text":"TUHAN yang perkasa di dalam peperangan.","poem":2}]},{"type":"line_break"},{"type":"verse","number":9,"content":[{"text":"Angkat kepalamu, hai pintu-pintu gerbang,","poem":1},{"text":"dan terangkatlah, hai pintu-pintu abadi,","poem":2},{"lineBreak":true},{"text":"supaya Raja Kemuliaan masuk!","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Siapa Raja Kemuliaan itu?","poem":1},{"text":"TUHAN semesta alam,","poem":2},{"lineBreak":true},{"text":"Dia adalah Raja Kemuliaan. Sela","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/24.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/25.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/23.json","previousChapterAudioLinks":{},"numberOfVerses":10}