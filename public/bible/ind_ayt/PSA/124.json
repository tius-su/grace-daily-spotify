{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":124,"content":[{"type":"heading","content":["TUHAN di Pihak Kita"]},{"type":"verse","number":1,"content":[{"text":"Nyanyian Ziarah Daud","descriptive":true},{"lineBreak":true},{"text":"“Seandainya TUHAN tidak di pihak kita,”","poem":1},{"text":"biarlah sekarang Israel berkata,","poem":2}]},{"type":"verse","number":2,"content":[{"text":"“Seandainya TUHAN tidak di pihak kita","poem":1},{"text":"ketika orang-orang bangkit melawan kita,","poem":2}]},{"type":"verse","number":3,"content":[{"text":"mereka sudah menelan kita hidup-hidup","poem":1},{"text":"saat amarah mereka menyala-nyala terhadap kita;","poem":2}]},{"type":"verse","number":4,"content":[{"text":"air sudah menghanyutkan kita,","poem":1},{"text":"arus-arus melanda atas kita.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Kemudian, amukan air,","poem":1},{"text":"sudah menenggelamkan kita.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"Pujilah TUHAN, yang tidak menyerahkan kita","poem":1},{"text":"sebagai mangsa bagi gigi-gigi mereka.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Jiwa kita telah terluput seperti burung","poem":1},{"text":"yang lepas dari jebakan perangkap burung.","poem":2},{"lineBreak":true},{"text":"Jebakan itu rusak, dan kita terluput.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Pertolongan kita adalah di dalam nama TUHAN,","poem":1},{"text":"yang menjadikan langit dan bumi!","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/124.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/125.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/123.json","previousChapterAudioLinks":{},"numberOfVerses":8}