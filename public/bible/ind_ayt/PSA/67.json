{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":67,"content":[{"type":"heading","content":["Syukur atas Berkat TUHAN"]},{"type":"verse","number":1,"content":[{"text":"Kepada pemimpin pujian: Dengan alat musik petik. Mazmur. Nyanyian.","descriptive":true},{"lineBreak":true},{"text":"(67-2) Kiranya Allah mengasihani dan memberkati kita;","poem":1},{"text":"kiranya Dia bersinar atas kita, (Sela)","poem":2}]},{"type":"verse","number":2,"content":[{"text":"(67-3) supaya jalan-Mu dikenal di atas bumi,","poem":1},{"text":"keselamatan-Mu di antara semua bangsa.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"(67-4) Biarlah bangsa-bangsa bersyukur kepada-Mu, ya Allah!","poem":1},{"text":"Biarlah bangsa-bangsa bersyukur kepada-Mu.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"(67-5) Biarlah suku-suku bangsa bergembira dan bersorak-sorai","poem":1},{"text":"karena Engkau menghakimi bangsa-bangsa dengan adil,","poem":2},{"lineBreak":true},{"text":"dan menuntun suku-suku bangsa di atas bumi. Sela","poem":2}]},{"type":"verse","number":5,"content":[{"text":"(67-6) Biarlah suku-suku bangsa bersyukur kepada-Mu, ya Allah!","poem":1},{"text":"Biarlah suku-suku bangsa bersyukur kepada-Mu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"(67-7) Bumi telah memberikan hasilnya;","poem":1},{"text":"kiranya Allah, Allah kita, memberkati kita.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"(67-8) Kiranya Allah memberkati kita;","poem":1},{"text":"kiranya segala ujung bumi akan takut kepada-Nya.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/67.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/68.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/66.json","previousChapterAudioLinks":{},"numberOfVerses":7}