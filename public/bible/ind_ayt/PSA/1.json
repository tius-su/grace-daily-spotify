{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":1,"content":[{"type":"heading","content":["Kebahagiaan Sejati dalam Hukum Allah"]},{"type":"verse","number":1,"content":[{"text":"Diberkatilah orang yang tidak berjalan menurut nasihat orang fasik,","poem":1},{"text":"tidak berdiri di jalan orang-orang berdosa,","poem":2},{"lineBreak":true},{"text":"dan tidak duduk di pertemuan para pencemooh.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Akan tetapi, yang kesenangannya ada dalam hukum TUHAN,","poem":1},{"text":"dan dia merenungkan hukum-Nya siang dan malam.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Dia seperti sebuah pohon yang ditanam di dekat aliran-aliran air,","poem":1},{"text":"yang menghasilkan buahnya pada musimnya,","poem":2},{"text":"dan daun-daunnya tidak layu.","poem":1},{"text":"Segala sesuatu yang dilakukannya berhasil.","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"Tidak demikian dengan orang fasik;","poem":1},{"text":"mereka seperti sekam yang diterbangkan angin.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Oleh karena itu, orang fasik takkan bertahan dalam penghakiman,","poem":1},{"text":"begitu juga orang-orang berdosa dalam kumpulan orang benar.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Sebab, TUHAN mengenal jalan orang benar,","poem":1},{"text":"tetapi jalan orang fasik akan binasa.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/1.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/2.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/JOB/42.json","previousChapterAudioLinks":{},"numberOfVerses":6}