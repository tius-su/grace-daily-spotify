{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":19,"content":[{"type":"heading","content":["Kesaksian tentang Penciptaan dan Pewahyuan"]},{"type":"verse","number":1,"content":[{"text":"Kepada pemimpin pujian: Nyanyian Daud.","descriptive":true},{"lineBreak":true},{"text":"(19-2) Langit menceritakan kemuliaan Allah,","poem":1},{"text":"dan cakrawala menyatakan perbuatan tangan-Nya.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"(19-3) Hari demi hari mengalirkan berita itu;","poem":1},{"text":"malam demi malam menyatakan pengetahuan itu.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"(19-4) Tidak ada berita, tidak ada kata-kata","poem":1},{"text":"yang suaranya tidak terdengar.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"(19-5) Tali-tali pengukur mereka sampai ke seluruh bumi,","poem":1},{"text":"dan perkataan mereka sampai ke ujung dunia.","poem":2},{"lineBreak":true},{"text":"Di langit, Dia meletakkan tenda bagi matahari","poem":1}]},{"type":"verse","number":5,"content":[{"text":"(19-6) seperti pengantin laki-laki yang keluar dari kamar tidurnya;","poem":2},{"lineBreak":true},{"text":"seperti pahlawan yang girang saat berlari dalam perjalanan.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"(19-7) Terbitnya dari ujung langit dan beredar sampai ke ujung yang lain;","poem":1},{"text":"tidak ada yang tersembunyi dari panasnya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"(19-8) Hukum TUHAN itu sempurna,","poem":1},{"text":"memulihkan jiwa.","poem":2},{"text":"Peringatan TUHAN itu teguh,","poem":1},{"text":"menjadi hikmat bagi orang naif.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"(19-9) Ajaran TUHAN itu baik,","poem":1},{"text":"menggembirakan hati.","poem":2},{"text":"Perintah TUHAN itu murni,","poem":1},{"text":"menerangi mata.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"(19-10) Takut akan TUHAN itu suci,","poem":1},{"text":"bertahan selama-lamanya.","poem":2},{"text":"Penghakiman TUHAN itu benar,","poem":1},{"text":"dan semuanya adil.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"(19-11) Lebih berharga daripada emas, melebihi banyak emas murni.","poem":1},{"text":"Juga, lebih manis daripada madu,","poem":2},{"lineBreak":true},{"text":"dan melebihi tetesan madu dari sarang lebah.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"(19-12) Lagi pula, olehnya hamba-Mu diperingatkan;","poem":1},{"text":"dengan memeliharanya, ada upah yang besar.","poem":2}]},{"type":"line_break"},{"type":"verse","number":12,"content":[{"text":"(19-13) Siapa dapat memahami kesalahannya?","poem":1},{"text":"Bersihkan aku dari kesalahanku yang tersembunyi.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"(19-14) Tahanlah hamba-Mu dari kesombongan;","poem":1},{"text":"jangan sampai mereka berkuasa atasku","poem":2},{"text":"sehingga aku tidak menjadi bercela,","poem":1},{"text":"dan bersih dari pelanggaran yang besar.","poem":2}]},{"type":"line_break"},{"type":"verse","number":14,"content":[{"text":"(19-15) Kiranya perkataan mulutku dan renungan hatiku,","poem":1},{"text":"berkenan di hadapan-Mu,","poem":2},{"lineBreak":true},{"text":"ya TUHAN, gunung batuku dan penebusku.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/19.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/20.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/18.json","previousChapterAudioLinks":{},"numberOfVerses":14}