{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":57,"content":[{"type":"heading","content":["Perlindungan dalam Kesulitan"]},{"type":"verse","number":1,"content":[{"text":"Kepada pemimpin pujian: Dengan nada “Jangan Binasakan.” Miktam Daud ketika dia melarikan diri dari Saul di gua.","descriptive":true},{"lineBreak":true},{"text":"(57-2) Kasihanilah, ya Allah;","poem":1},{"text":"kasihanilah karena di dalam Engkau, jiwaku berlindung.","poem":2},{"text":"Dalam bayangan sayap-Mu, aku akan berlindung","poem":1},{"text":"sampai penghancuran berlalu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"(57-3) Aku berseru kepada Allah Yang Mahatinggi,","poem":1},{"text":"kepada Allah yang menyelesaikan bagiku!","poem":2}]},{"type":"verse","number":3,"content":[{"text":"(57-4) Dia akan mengutus dari surga dan menyelamatkan aku;","poem":1},{"text":"Dia akan menghina orang yang menginjak-injakku. Sela","poem":2},{"lineBreak":true},{"text":"Allah akan mengulurkan kebaikan dan kesetiaan-Nya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"(57-5) Jiwaku ada di antara singa-singa;","poem":1},{"text":"aku berbaring di tengah-tengah orang yang hendak menghanguskan;","poem":2},{"text":"anak-anak manusia yang giginya adalah tombak-tombak dan anak-anak panah,","poem":1},{"text":"dan lidahnya adalah pedang yang tajam.","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"(57-6) Tinggilah mengatasi langit, ya Allah!","poem":1},{"text":"Kemuliaan-Mu mengatasi seluruh bumi.","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"(57-7) Mereka menegakkan jaring di kakiku,","poem":1},{"text":"jiwaku tertunduk.","poem":2},{"text":"Mereka menggali lubang di hadapanku;","poem":1},{"text":"mereka terjatuh di tengah-tengahnya. Sela","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"(57-8) Hatiku teguh, ya Allah, hatiku teguh;","poem":1},{"text":"aku akan menyanyi dan memuji.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"(57-9) Bangunlah, hai kemuliaanku!","poem":1},{"text":"Bangunlah, ya gambus dan kecapi;","poem":2},{"lineBreak":true},{"text":"aku akan membangunkan fajar!","poem":2}]},{"type":"line_break"},{"type":"verse","number":9,"content":[{"text":"(57-10) Aku akan bersyukur kepada-Mu, ya Tuhan, di antara suku-suku bangsa;","poem":1},{"text":"aku akan menyanyikan pujian bagi-Mu di antara bangsa-bangsa.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"(57-11) Sebab, kasih setia-Mu besar mengatasi langit,","poem":1},{"text":"keagungan-Mu mencapai awan-awan.","poem":2}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"(57-12) Tinggilah mengatasi langit, ya Allah!","poem":1},{"text":"kasih setia-Mu mengatasi seluruh bumi.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/57.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/58.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/56.json","previousChapterAudioLinks":{},"numberOfVerses":11}