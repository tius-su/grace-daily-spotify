{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":53,"content":[{"type":"heading","content":["Mazmur Si Bodoh"]},{"type":"verse","number":1,"content":[{"text":"Kepada pemimpin pujian: Sesuai dengan Mahalat. Nyanyian perenungan Daud.","descriptive":true},{"lineBreak":true},{"text":"(53-2) Orang bodoh berkata dalam hatinya, “Tidak ada Allah.”","poem":1},{"text":"Mereka rusak, berlaku keji dan curang;","poem":2},{"lineBreak":true},{"text":"tidak ada yang melakukan kebaikan.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"(53-3) Allah melihat ke bawah dari surga kepada anak-anak manusia,","poem":1},{"text":"untuk melihat jika ada seseorang yang bijaksana, yang mencari Allah.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"(53-4) Mereka semua telah menyimpang;","poem":1},{"text":"mereka bersama-sama telah menjadi keji.","poem":2},{"text":"Tidak ada yang berbuat baik.","poem":1},{"text":"Seorang pun tidak!","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"(53-5) Tidak tahukah mereka yang melakukan kejahatan,","poem":1},{"text":"yang melahap umat-Ku seperti memakan roti,","poem":2},{"lineBreak":true},{"text":"dan tidak berseru kepada Allah?","poem":2}]},{"type":"verse","number":5,"content":[{"text":"(53-6) Di sana, mereka dalam ketakutan,","poem":1},{"text":"padahal tidak ada ketakutan.","poem":2},{"text":"Allah telah menyerakkan tulang-tulang orang yang mengepungmu.","poem":1},{"text":"Kamu telah mempermalukan mereka karena Allah telah menolak mereka.","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"(53-7) Kiranya keselamatan bagi orang Israel datang dari Sion!","poem":1},{"text":"Ketika Allah memulihkan keadaan umat-Nya,","poem":2},{"text":"Yakub akan bersukacita,","poem":1},{"text":"Israel akan bergembira.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/53.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/54.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/52.json","previousChapterAudioLinks":{},"numberOfVerses":6}