{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":129,"content":[{"type":"heading","content":["Kenyamanan dalam Penderitaan"]},{"type":"verse","number":1,"content":[{"text":"Nyanyian Ziarah.","descriptive":true},{"lineBreak":true},{"text":"“Sering sekali mereka menekan aku sejak masa mudaku,”","poem":1},{"text":"Biarlah sekarang Israel berkata,","poem":2}]},{"type":"verse","number":2,"content":[{"text":"“Sering kali mereka menekan aku sejak masa mudaku,","poem":1},{"text":"tetapi mereka tidak mengalahkan aku.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Para pembajak membajak di atas punggungku,","poem":1},{"text":"mereka memperpanjang alur-alur bajaknya.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"TUHAN itu adil.","poem":1},{"text":"Dia telah memotong ikatan orang-orang fasik.","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"Biarlah semua yang membenci Sion,","poem":1},{"text":"malu dan berbalik mundur.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Biarlah mereka seperti rumput di atas atap rumah,","poem":1},{"text":"yang kering sebelum dicabut,","poem":2}]},{"type":"verse","number":7,"content":[{"text":"yang tidak dapat memenuhi tangan penyabit,","poem":1},{"text":"begitu juga pengikat berkas tidak dapat mendekapnya,","poem":2}]},{"type":"verse","number":8,"content":[{"text":"atau orang yang melewatinya berkata,","poem":1},{"text":"“Berkat TUHAN ada padamu.","poem":2},{"lineBreak":true},{"text":"Kami memberkatimu dalam nama TUHAN.”","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/129.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/130.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/128.json","previousChapterAudioLinks":{},"numberOfVerses":8}