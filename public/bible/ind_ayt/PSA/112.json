{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":112,"content":[{"type":"heading","content":["Orang Benar Takkan Tergantikan"]},{"type":"verse","number":1,"content":[{"text":"Haleluya!","poem":1},{"lineBreak":true},{"text":"Diberkatilah orang yang takut akan TUHAN,","poem":1},{"text":"yang sangat menyukai perintah-perintah-Nya.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Keturunannya akan menjadi perkasa di atas bumi,","poem":1},{"text":"generasi orang yang lurus hati akan diberkati.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Harta dan kekayaan ada di dalam rumahnya,","poem":1},{"text":"kebenarannya bertahan untuk selama-lamanya.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Terang terbit dalam kegelapan bagi orang-orang yang lurus hati;","poem":1},{"text":"Dia itu murah hati, belas kasih, dan benar.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Itu baik bagi orang yang berbelas kasih meminjamkan,","poem":1},{"text":"yang menangani urusannya dengan keadilan.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Sebab, dia takkan pernah tergoyahkan,","poem":1},{"text":"dia akan diingat selama-lamanya.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Dia tidak takut pada kabar buruk,","poem":1},{"text":"hatinya teguh, percaya di dalam TUHAN.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Hatinya ditopang, dia takkan takut,","poem":1},{"text":"sampai dia memandang musuh-musuhnya.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Dia menyebarkan dengan cuma-cuma kepada orang melarat,","poem":1},{"text":"kebenarannya bertahan selama-lamanya,","poem":2},{"lineBreak":true},{"text":"tanduknya ditinggikan dalam kehormatan.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Orang fasik melihatnya,","poem":1},{"text":"dan menjadi marah,","poem":2},{"text":"dia menggertakkan giginya lalu hancur;","poem":1},{"text":"keinginan orang fasik akan binasa.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/112.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/113.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/111.json","previousChapterAudioLinks":{},"numberOfVerses":10}