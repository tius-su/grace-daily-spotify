{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":61,"content":[{"type":"heading","content":["Doa Raja Saat Bahaya"]},{"type":"verse","number":1,"content":[{"text":"Kepada pemimpin pujian: Dengan iringan kecapi. Mazmur Daud.","descriptive":true},{"lineBreak":true},{"text":"(61-2) Dengarlah seruanku, ya Allah,","poem":1},{"text":"perhatikanlah doaku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"(61-3) Dari ujung bumi, aku memanggil Engkau saat hatiku sedang menyimpang;","poem":1},{"lineBreak":true},{"text":"tuntunlah aku ke gunung batu yang lebih tinggi dariku.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"(61-4) Sebab, Engkau telah menjadi tempat perlindunganku,","poem":1},{"text":"suatu menara yang kuat terhadap musuh.","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"(61-5) Biarlah aku menetap di dalam tenda-Mu selamanya!","poem":1},{"text":"Biarlah aku berlindung di dalam perlindungan sayap-Mu! Sela","poem":2}]},{"type":"verse","number":5,"content":[{"text":"(61-6) Sebab, Engkau, ya Allah, telah mendengar nazarku;","poem":1},{"text":"Engkau telah memberikan kepadaku warisan orang-orang yang takut akan nama-Mu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"(61-7) Engkau hendak menambahkan umur raja,","poem":1},{"text":"tahun-tahunnya seperti banyaknya generasi.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"(61-8) Kiranya dia bertakhta selama-lamanya di hadapan Allah;","poem":1},{"text":"tetapkanlah kasih setia dan kebenaran untuk menjaganya.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"(61-9) Pada waktu itu, aku akan menyanyikan pujian bagi nama-Mu selama-lamanya,","poem":1},{"text":"sehingga aku boleh membayar nazarku dari hari ke hari.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/61.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/62.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/60.json","previousChapterAudioLinks":{},"numberOfVerses":8}