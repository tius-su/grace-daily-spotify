{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":114,"content":[{"type":"heading","content":["Gemetar di Hadirat TUHAN"]},{"type":"verse","number":1,"content":[{"text":"Ketika Israel keluar dari Mesir,","poem":1},{"text":"dan seisi rumah Yakub dari bangsa yang berbahasa asing,","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Yehuda menjadi tempat kudus-Nya,","poem":1},{"text":"Israel kekuasaan-Nya.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Laut menyaksikan dan melarikan diri,","poem":1},{"text":"Sungai Yordan berbalik mundur.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Gunung-gunung melompat-lompat seperti domba-domba jantan,","poem":1},{"text":"bukit-bukit seperti anak-anak domba.","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"Mengapa gerangan, hai laut, sehingga kamu melarikan diri?","poem":1},{"text":"Hai Yordan, sehingga kamu berbalik mundur?","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Hai gunung-gunung, mengapa kamu melompat-lompat seperti domba-domba jantan?","poem":1},{"text":"Hai bukit-bukit, seperti anak-anak domba?","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Gemetarlah, hai bumi, di hadapan Tuhan,","poem":1},{"text":"di hadapan Allah Yakub,","poem":2}]},{"type":"verse","number":8,"content":[{"text":"yang mengubah gunung batu menjadi kolam air,","poem":1},{"text":"batu keras menjadi mata air.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/114.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/115.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/113.json","previousChapterAudioLinks":{},"numberOfVerses":8}