{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":12,"content":[{"type":"heading","content":["Keselamatan Datang dari TUHAN"]},{"type":"verse","number":1,"content":[{"text":"Kepada pemimpin pujian. Menurut syeminit. Nyanyian Daud.","descriptive":true},{"lineBreak":true},{"text":"(12-2) Ya TUHAN, selamatkanlah.","poem":1},{"text":"Sebab, orang saleh telah habis.","poem":2},{"lineBreak":true},{"text":"Sebab, orang-orang setia telah lenyap dari antara anak-anak manusia.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"(12-3) Mereka mengatakan yang tidak benar kepada sesamanya.","poem":1},{"text":"Dengan bibir yang manis dan hati yang bercabang mereka berbicara.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"(12-4) Kiranya TUHAN memotong semua bibir manis, dan lidah yang berbicara besar.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"(12-5) Mereka yang berkata,","poem":1},{"lineBreak":true},{"text":"“Dengan lidah, kami menjadi kuat.","poem":1},{"text":"Bibir kami adalah milik kami. Siapa tuan kami?”","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"(12-6) “Oleh karena kekerasan terhadap orang-orang tertindas,","poem":1},{"text":"oleh karena ratapan orang-orang melarat,","poem":2},{"text":"sekarang Aku akan bangkit,”","poem":1},{"text":"kata TUHAN.","poem":2},{"text":"“Aku akan menaruh keselamatan","poem":1},{"text":"yang mereka rindukan.”","poem":2}]},{"type":"verse","number":6,"content":[{"text":"(12-7) Perkataan TUHAN adalah perkataan yang murni,","poem":1},{"text":"seperti perak yang diuji dalam dapur peleburan bumi,","poem":2},{"lineBreak":true},{"text":"dimurnikan sampai tujuh kali.","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"(12-8) Engkau, ya TUHAN, akan menjaga mereka.","poem":1},{"text":"Engkau akan memelihara mereka dari generasi ini,","poem":2},{"lineBreak":true},{"text":"untuk selama-lamanya.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"(12-9) Orang fasik berjalan di sekeliling,","poem":1},{"text":"ketika kebusukan ditinggikan oleh anak-anak manusia.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/12.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/13.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/11.json","previousChapterAudioLinks":{},"numberOfVerses":8}