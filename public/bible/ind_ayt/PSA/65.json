{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":65,"content":[{"type":"heading","content":["Nyanyian Ucapan Syukur"]},{"type":"verse","number":1,"content":[{"text":"Kepada pemimpin pujian: Mazmur Daud.","descriptive":true},{"lineBreak":true},{"text":"(65-2) Pujian diam bagi-Mu, ya Allah, di Sion,","poem":1},{"text":"dan kepada-Mu nazar-nazar dibayarkan.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"(65-3) Ya, Engkau yang mendengar doa,","poem":1},{"text":"kepada-Mu semua manusia akan datang.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"(65-4) Kesalahan-kesalahan berkuasa atasku,","poem":1},{"text":"tetapi Engkau menutupi pelanggaranku.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"(65-5) Diberkatilah orang yang Kaupilih dan mendekat untuk diam di pelataran-Mu!","poem":1},{"lineBreak":true},{"text":"Kiranya kami dipuaskan dengan kebaikan-kebaikan rumah-Mu,","poem":1},{"text":"pada bait-Mu yang kudus.","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"(65-6) Dengan perkara yang ajaib, Engkau menjawab kami dalam kebenaran,","poem":1},{"text":"ya Allah, penyelamat kami,","poem":2},{"lineBreak":true},{"text":"kepercayaan segala ujung bumi dan lautan terjauh.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"(65-7) Engkau menegakkan gunung-gunung dengan kekuatan-Mu,","poem":1},{"text":"dan berikatpinggangkan keperkasaan,","poem":2}]},{"type":"verse","number":7,"content":[{"text":"(65-8) yang menenangkan deru lautan;","poem":1},{"text":"deru gelombangnya seperti keributan bangsa-bangsa.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"(65-9) Orang-orang yang diam di ujung bumi takut akan tanda-tanda-Mu;","poem":1},{"text":"Engkau membuat orang-orang bersorak-sorai pada pagi dan malam hari.","poem":2}]},{"type":"line_break"},{"type":"verse","number":9,"content":[{"text":"(65-10) Engkau memperhatikan bumi dan melimpahinya;","poem":1},{"text":"Engkau menjadikannya kaya.","poem":2},{"text":"Aliran-aliran Allah begitu penuh dengan air;","poem":1},{"text":"Engkau mempersiapkan gandum bagi mereka,","poem":2},{"lineBreak":true},{"text":"sungguh Engkau menyediakannya.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"(65-11) Engkau memenuhi alur-alurnya,","poem":1},{"text":"Engkau memperdalam gumpalan-gumpalan tanahnya.","poem":2},{"text":"Engkau menggemburkannya dengan guyuran hujan,","poem":1},{"text":"dan Engkau memberkati tunas-tunasnya.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"(65-12) Engkau memahkotai tahun dengan kebaikan,","poem":1},{"text":"dan jejak-Mu menitikkan lemak.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"(65-13) Tanah-tanah gembalaan di belantara menitik,","poem":1},{"text":"bukit-bukit berikatpinggangkan sorak-sorai.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"(65-14) Padang-padang rumput berpakaian kawanan domba,","poem":1},{"text":"lembah-lembah berselubung gandum;","poem":2},{"lineBreak":true},{"text":"mereka bersorak-sorai dan bernyanyi.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/65.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/66.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/64.json","previousChapterAudioLinks":{},"numberOfVerses":13}