{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":135,"content":[{"type":"heading","content":["Pujilah TUHAN, Penguasa dan Penolong Israel"]},{"type":"verse","number":1,"content":[{"text":"Haleluya!","poem":1},{"lineBreak":true},{"text":"Pujilah nama TUHAN!","poem":1},{"text":"Pujilah, hai hamba-hamba TUHAN,","poem":2}]},{"type":"verse","number":2,"content":[{"text":"yang melayani di rumah TUHAN,","poem":1},{"text":"di pelataran rumah Allah kita!","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Pujilah TUHAN karena TUHAN itu baik,","poem":1},{"text":"bermazmurlah bagi nama-Nya karena itu menyenangkan.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Sebab, TUHAN telah memilih Yakub bagi-Nya,","poem":1},{"text":"Israel sebagai kepunyaan-Nya yang istimewa.","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"Sebab, aku tahu bahwa TUHAN itu besar,","poem":1},{"text":"dan bahwa Tuhan kita mengatasi segala ilah.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Segala sesuatu yang TUHAN kehendaki, diperbuat-Nya","poem":1},{"text":"di langit dan di bumi, di laut dan di seluruh samudra.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Dia menaikkan kabut-kabut dari ujung bumi,","poem":1},{"text":"membuat kilat-kilat bagi hujan,","poem":2},{"lineBreak":true},{"text":"dan membawa angin keluar dari perbendaharaan-Nya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"Dia menyerang anak-anak sulung di Mesir,","poem":1},{"text":"baik manusia maupun binatang.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Dia mengirimkan tanda-tanda dan mukjizat-mukjizat di tengah-tengahmu, hai Mesir,","poem":1},{"text":"terhadap Firaun dan semua hambanya.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Dia mengalahkan banyak bangsa,","poem":1},{"text":"dan membunuh raja-raja yang berkuasa.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Sihon, raja orang Amori, dan Og, Raja Basan,","poem":1},{"text":"dan semua kerajaan Kanaan,","poem":2}]},{"type":"verse","number":12,"content":[{"text":"dan memberikan tanah mereka sebagai suatu warisan,","poem":1},{"text":"warisan bagi umat-Nya, Israel.","poem":2}]},{"type":"line_break"},{"type":"verse","number":13,"content":[{"text":"Nama-Mu, ya TUHAN, untuk selama-lamanya;","poem":1},{"text":"peringatan akan Engkau, ya TUHAN, dari generasi ke generasi.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Sebab, TUHAN akan menghakimi umat-Nya,","poem":1},{"text":"dan akan berbelaskasihan kepada hamba-hamba-Nya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":15,"content":[{"text":"Berhala bangsa-bangsa adalah emas dan perak,","poem":1},{"text":"pekerjaan tangan manusia.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Bermulut, tetapi tidak bisa bicara;","poem":1},{"text":"bermata, tetapi tidak bisa melihat;","poem":2}]},{"type":"verse","number":17,"content":[{"text":"bertelinga, tetapi tidak bisa mendengar;","poem":1},{"text":"begitu juga, tidak ada napas pada mulutnya.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Mereka yang membuatnya menjadi sepertinya,","poem":1},{"text":"juga semua yang percaya kepadanya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":19,"content":[{"text":"Hai keturunan Israel, pujilah TUHAN,","poem":1},{"text":"keturunan Harun, pujilah TUHAN!","poem":2}]},{"type":"verse","number":20,"content":[{"text":"Hai keturunan Lewi, pujilah TUHAN!","poem":1},{"text":"Kamu yang takut akan TUHAN, pujilah TUHAN!","poem":2}]},{"type":"verse","number":21,"content":[{"text":"Pujilah TUHAN dari Sion,","poem":1},{"text":"yang bersemayam di Yerusalem.","poem":2},{"lineBreak":true},{"text":"Haleluya!","poem":1}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/135.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/136.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/134.json","previousChapterAudioLinks":{},"numberOfVerses":21}