{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":17,"content":[{"type":"heading","content":["Penghakiman Datang dari TUHAN"]},{"type":"verse","number":1,"content":[{"text":"Doa Daud.","descriptive":true},{"lineBreak":true},{"text":"Dengarlah keadilan, ya TUHAN,","poem":1},{"text":"perhatikan seruanku.","poem":2},{"text":"Dengarkan doaku,","poem":1},{"text":"dari bibir yang tidak menipu.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Kiranya penghakiman datang dari hadapan-Mu.","poem":1},{"text":"Biarlah mata-Mu memandang kejujuran.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Engkau telah menguji hatiku,","poem":1},{"text":"Engkau mengunjungiku pada waktu malam.","poem":2},{"text":"Engkau memurnikanku dan Engkau tidak menemukan apa pun.","poem":1},{"text":"Aku sudah merancang bahwa mulutku takkan melanggar.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Tentang perbuatan manusia,","poem":1},{"text":"sesuai dengan firman dari bibir-Mu,","poem":2},{"lineBreak":true},{"text":"aku sudah awas dari jalan-jalan kekerasan.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Langkahku tetap berpegang pada jejak-jejak-Mu;","poem":1},{"text":"Kakiku tidak terpeleset.","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"Aku memanggil-Mu","poem":1},{"text":"karena Engkau akan menjawab aku, ya Allah.","poem":2},{"lineBreak":true},{"text":"Condongkan telinga-Mu kepadaku,","poem":2},{"lineBreak":true},{"text":"dengarlah kata-kataku.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Tunjukkanlah kasih setia-Mu dengan cara yang mengagumkan;","poem":1},{"text":"yang menyelamatkan mereka yang mencari perlindungan dengan tangan kanan-Mu dari mereka yang bangkit.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Jagalah aku seperti biji mata-Mu.","poem":1},{"text":"Sembunyikan aku di bawah naungan sayap-Mu,","poem":2}]},{"type":"verse","number":9,"content":[{"text":"dari orang fasik yang menghancurkan aku,","poem":1},{"text":"dari musuh-musuh mematikan yang mengelilingi aku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"Mereka tertutupi lemak mereka;","poem":1},{"text":"mereka berbicara dengan sombong dengan mulut mereka.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Sekarang, mereka mengepung langkah-langkahku;","poem":1},{"text":"mereka mengarahkan mata mereka untuk membuang aku ke tanah.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Mereka seperti seekor singa yang ingin sekali mencabik-cabik.","poem":1},{"text":"Dan, seperti singa muda yang diam di tempat tersembunyi.","poem":2}]},{"type":"line_break"},{"type":"verse","number":13,"content":[{"text":"Bangkitlah, ya TUHAN!","poem":1},{"text":"Hadapi dia dan tundukkan dia.","poem":2},{"lineBreak":true},{"text":"Selamatkan jiwaku dari orang-orang fasik, dengan pedang-Mu,","poem":2}]},{"type":"verse","number":14,"content":[{"text":"dari orang-orang dengan tangan-Mu, ya TUHAN,","poem":1},{"text":"dari orang-orang dunia yang bagiannya ada di kehidupan ini.","poem":2},{"text":"Engkau memenuhi perut mereka dengan harta;","poem":1},{"text":"mereka kenyang dengan anak-anak,","poem":2},{"lineBreak":true},{"text":"dan mereka meninggalkan sisa-sisanya kepada anak-anak mereka.","poem":2}]},{"type":"line_break"},{"type":"verse","number":15,"content":[{"text":"Akan tetapi, aku akan memandang wajah-Mu dalam kebenaran,","poem":1},{"text":"Ketika aku bangun, aku akan dipuaskan oleh rupa-Mu.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/17.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/18.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/16.json","previousChapterAudioLinks":{},"numberOfVerses":15}