{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":146,"content":[{"type":"heading","content":["Pujian dan Kepercayaan"]},{"type":"verse","number":1,"content":[{"text":"Haleluya!","poem":1},{"text":"Pujilah TUHAN, hai jiwaku!","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Aku akan memuji TUHAN selama aku hidup,","poem":1},{"text":"aku akan bermazmur kepada Allahku selagi aku ada.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Jangan percaya kepada para penguasa,","poem":1},{"text":"kepada anak manusia,","poem":2},{"lineBreak":true},{"text":"yang tidak punya keselamatan.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Ketika napasnya pergi, dia kembali sampai ke tanah,","poem":1},{"text":"pada hari itu juga, lenyap pikiran-pikirannya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"Diberkatilah dia yang penolongnya adalah Allah Yakub,","poem":1},{"text":"yang harapannya ada dalam TUHAN, Allahnya.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Yang menjadikan langit dan bumi,","poem":1},{"text":"laut dan semua yang ada di dalamnya,","poem":2},{"lineBreak":true},{"text":"yang tetap setia selama-lamanya.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Yang melaksanakan keadilan bagi yang tertindas,","poem":1},{"text":"yang memberi makanan kepada yang lapar.","poem":2},{"text":"TUHAN membebaskan para tahanan.","poem":1}]},{"type":"verse","number":8,"content":[{"text":"TUHAN mencelikkan yang buta,","poem":2},{"text":"TUHAN membangkitkan orang-orang yang tertunduk.","poem":1},{"text":"TUHAN mengasihi orang-orang benar.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"TUHAN melindungi orang-orang yang tinggal sementara,","poem":1},{"text":"Dia memulihkan anak-anak yatim dan janda,","poem":2},{"lineBreak":true},{"text":"tetapi jalan orang fasik Dia bengkokkan.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"TUHAN akan memerintah untuk selama-lamanya,","poem":1},{"text":"Allahmu, hai Sion, bagi segala generasi.","poem":2},{"lineBreak":true},{"text":"Haleluya!","poem":1}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/146.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/147.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/145.json","previousChapterAudioLinks":{},"numberOfVerses":10}