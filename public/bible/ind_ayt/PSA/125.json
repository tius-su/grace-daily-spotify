{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":125,"content":[{"type":"heading","content":["Pelindung Israel"]},{"type":"verse","number":1,"content":[{"text":"Nyanyian Ziarah.","descriptive":true},{"lineBreak":true},{"text":"Orang-orang yang percaya kepada TUHAN adalah seperti Gunung Sion,","poem":1},{"text":"yang tidak dapat goyah dan tetap untuk selama-lamanya.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Seperti gunung-gunung yang mengelilingi Yerusalem,","poem":1},{"text":"begitu pun TUHAN mengelilingi umat-Nya","poem":2},{"lineBreak":true},{"text":"dari sekarang sampai selama-lamanya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Sebab, tongkat orang fasik takkan tetap","poem":1},{"text":"di atas tanah undian orang benar,","poem":2},{"lineBreak":true},{"text":"karena orang benar takkan mengulurkan tangannya","poem":2},{"lineBreak":true},{"text":"untuk berbuat jahat.","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"Berbuatlah baik, ya TUHAN, kepada orang-orang yang baik,","poem":1},{"text":"dan kepada orang-orang yang lurus hatinya.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Akan tetapi, bagi mereka yang menyimpang ke jalan yang bengkok,","poem":1},{"text":"TUHAN akan membawa mereka pergi bersama dengan orang-orang yang berbuat fasik.","poem":2},{"lineBreak":true},{"text":"Sejahtera atas Israel!","poem":1}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/125.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/126.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/124.json","previousChapterAudioLinks":{},"numberOfVerses":5}