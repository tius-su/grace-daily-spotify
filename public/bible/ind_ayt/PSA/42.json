{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":42,"content":[{"type":"heading","content":["Kerinduan kepada Allah"]},{"type":"verse","number":1,"content":[{"text":"Kepada pemimpin pujian: Sebuah nyanyian dari anak-anak Korah.","descriptive":true},{"lineBreak":true},{"text":"(42-2) Seperti rusa yang rindu akan aliran-aliran sungai,","poem":1},{"text":"begitu juga jiwaku terhadap Engkau, ya Allah.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"(42-3) Jiwaku haus akan Allah,","poem":1},{"text":"akan Allah yang hidup.","poem":2},{"text":"Kapan aku boleh datang","poem":1},{"text":"dan muncul di hadapan Allah?","poem":2}]},{"type":"verse","number":3,"content":[{"text":"(42-4) Air mataku telah menjadi makananku","poem":1},{"text":"siang dan malam.","poem":2},{"text":"Sementara itu, sepanjang hari mereka berkata kepadaku,","poem":1},{"text":"“Di mana Allahmu?”","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"(42-5) Aku ingat, saat aku mencurahkan jiwaku,","poem":1},{"text":"aku berjalan bersama kumpulan orang,","poem":2},{"lineBreak":true},{"text":"dan bergerak perlahan ke rumah Allah,","poem":2},{"text":"sambil menyuarakan sukacita dan nyanyian syukur,","poem":1},{"text":"bersama dengan kerumunan yang mengadakan perayaan.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"(42-6) Mengapa kamu menunduk, hai jiwaku,","poem":1},{"text":"dan menggeram di dalam diriku?","poem":2},{"text":"Berharaplah di dalam Allah!","poem":1},{"text":"Sebab, aku akan bersyukur lagi kepada-Nya karena keselamatan di hadapan-Nya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"(42-7) Ya Allahku, jiwaku menunduk di dalamku.","poem":1},{"text":"Karena itu, aku ingat akan Engkau","poem":2},{"text":"dari tanah Yordan, Hermon,","poem":1},{"text":"dan Gunung Mizar.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"(42-8) Samudra memanggil samudra","poem":1},{"text":"dengan deru air terjun-Mu;","poem":2},{"lineBreak":true},{"text":"seluruh gelora dan gelombang-Mu melanda aku.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"(42-9) Pada siang hari TUHAN memerintahkan kasih setia-Nya,","poem":1},{"text":"dan pada malam hari nyanyian-Nya ada bersamaku,","poem":2},{"lineBreak":true},{"text":"suatu doa kepada Allah hidupku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":9,"content":[{"text":"(42-10) Aku berkata kepada Allah, gunung batuku,","poem":1},{"text":"“Mengapa Engkau melupakan aku?","poem":2},{"text":"Mengapa aku pergi meratap oleh karena penindasan musuh?”","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"(42-11) Seperti tikaman ke dalam tulang-tulangku,","poem":1},{"text":"musuh-musuhku mencela aku,","poem":2},{"text":"sementara itu sepanjang hari mereka berkata kepadaku,","poem":1},{"text":"“Di mana Allahmu?”","poem":2}]},{"type":"verse","number":11,"content":[{"text":"(42-12) Mengapa kamu menunduk, hai jiwaku?","poem":1},{"text":"Mengapa kamu menggeram di dalamku?","poem":2},{"text":"Nantikanlah Allah!","poem":1},{"text":"Sebab, aku akan bersyukur lagi kepada Allah","poem":2},{"lineBreak":true},{"text":"karena keselamatan di hadapan-Nya.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/42.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/43.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/41.json","previousChapterAudioLinks":{},"numberOfVerses":11}