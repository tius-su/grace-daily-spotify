{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":119,"content":[{"type":"heading","content":["Alef"]},{"type":"verse","number":1,"content":[{"text":"Diberkatilah orang-orang yang jalannya sempurna,","poem":1},{"text":"yang berjalan menurut taurat TUHAN.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Diberkatilah orang-orang yang menjaga kesaksian-kesaksian-Nya,","poem":1},{"text":"yang mencari-Nya dengan segenap hati,","poem":2}]},{"type":"verse","number":3,"content":[{"text":"juga tidak melakukan kejahatan,","poem":1},{"text":"tetapi pergi menurut jalan-jalan-Nya.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Engkau telah memerintahkan titah-titah-Mu,","poem":1},{"text":"agar benar-benar dipelihara.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Seandainya jalan-jalanku diteguhkan untuk memelihara ketetapan-ketetapan-Mu!","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Karena itu, aku takkan dipermalukan,","poem":1},{"text":"jika aku memperhatikan segala perintah-Mu.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Aku akan bersyukur kepada-Mu dengan ketulusan hati,","poem":1},{"text":"ketika aku mempelajari hukum-hukum-Mu yang benar.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Aku akan memelihara ketetapan-ketetapan-Mu,","poem":1},{"text":"jangan sama sekali pernah meninggalkanku.","poem":2}]},{"type":"heading","content":["Bet"]},{"type":"verse","number":9,"content":[{"text":"Bagaimana orang muda dapat memelihara jalannya yang bersih?","poem":1},{"text":"Dengan menjaganya sesuai dengan perkataan-Mu.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Dengan segenap hati aku mencari Engkau,","poem":1},{"text":"jangan biarkan aku tersesat dari perintah-perintah-Mu.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Di dalam hatiku, aku menyimpan firman-Mu,","poem":1},{"text":"sehingga aku takkan berdosa terhadap-Mu.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Terpujilah Engkau, ya TUHAN!","poem":1},{"text":"Ajarkan aku ketetapan-ketetapan-Mu.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Dengan bibirku, aku memberitakan semua hukum dari mulut-Mu.","poem":1}]},{"type":"verse","number":14,"content":[{"lineBreak":true},{"text":"Aku bersuka atas jalan kesaksian-Mu,","poem":1},{"text":"seperti atas segala harta.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Aku akan merenungkan titah-titah-Mu,","poem":1},{"text":"dan mengamati jalan-jalan-Mu.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Aku akan bergembira dalam ketetapan-ketetapan-Mu;","poem":1},{"text":"aku takkan melupakan perkataan-Mu.","poem":2}]},{"type":"heading","content":["Gimel"]},{"type":"verse","number":17,"content":[{"text":"Limpahkanlah karunia kepada hamba-Mu ini,","poem":1},{"text":"dengan begitu aku akan hidup dan memelihara firman-Mu.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Bukalah mataku,","poem":1},{"text":"sehingga aku boleh melihat hal-hal ajaib dari taurat-Mu.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Aku adalah orang yang tinggal sementara di dunia,","poem":1},{"text":"jangan sembunyikan perintah-perintah-Mu dariku.","poem":2}]},{"type":"verse","number":20,"content":[{"text":"Jiwaku hancur dengan kerinduan akan hukum-hukum-Mu di setiap waktu.","poem":1}]},{"type":"verse","number":21,"content":[{"lineBreak":true},{"text":"Engkau menghardik orang-orang congkak, orang-orang terkutuk,","poem":1},{"text":"yang menyimpang dari perintah-perintah-Mu.","poem":2}]},{"type":"verse","number":22,"content":[{"text":"Gulingkanlah celaan dan hinaan dariku,","poem":1},{"text":"karena aku memelihara kesaksian-kesaksian-Mu.","poem":2}]},{"type":"verse","number":23,"content":[{"text":"Sekalipun para pemimpin duduk membicarakan aku,","poem":1},{"text":"hamba-Mu ini akan merenungkan ketetapan-ketetapan-Mu.","poem":2}]},{"type":"verse","number":24,"content":[{"text":"Kesaksian-kesaksian-Mu adalah kegemaranku,","poem":1},{"text":"dan para penasihatku.","poem":2}]},{"type":"heading","content":["Dalet"]},{"type":"verse","number":25,"content":[{"text":"Jiwaku melekat pada debu,","poem":1},{"text":"pertahankan hidupku sesuai dengan firman-Mu.","poem":2}]},{"type":"verse","number":26,"content":[{"text":"Aku memberitahukan jalan-jalanku, dan Engkau menjawab aku,","poem":1},{"text":"ajari aku ketetapan-ketetapan-Mu.","poem":2}]},{"type":"verse","number":27,"content":[{"text":"Jadikan aku mengerti jalan titah-titah-Mu,","poem":1},{"text":"maka aku akan merenungkan pekerjaan-pekerjaan-Mu yang ajaib.","poem":2}]},{"type":"verse","number":28,"content":[{"text":"Jiwaku menangis oleh karena kedukaan,","poem":1},{"text":"kuatkan aku sesuai dengan firman-Mu.","poem":2}]},{"type":"verse","number":29,"content":[{"text":"Jauhkan aku dari jalan dusta,","poem":1},{"text":"dan karuniakan aku taurat-Mu.","poem":2}]},{"type":"verse","number":30,"content":[{"text":"Aku telah memilih jalan kebenaran,","poem":1},{"text":"aku telah menetapkan hukum-hukum-Mu di hadapanku.","poem":2}]},{"type":"verse","number":31,"content":[{"text":"Aku melekat pada kesaksian-kesaksian-Mu, ya TUHAN,","poem":1},{"text":"jangan biarkan aku dipermalukan.","poem":2}]},{"type":"verse","number":32,"content":[{"text":"Aku berlari di jalan perintah-perintah-Mu,","poem":1},{"text":"karena Engkau meluaskan hatiku.","poem":2}]},{"type":"heading","content":["He"]},{"type":"verse","number":33,"content":[{"text":"Ajari aku, ya TUHAN, jalan ketetapan-ketetapan-Mu,","poem":1},{"text":"dan aku akan memeliharanya sampai akhir.","poem":2}]},{"type":"verse","number":34,"content":[{"text":"Beri aku pengertian sehingga aku dapat menjaga taurat-Mu,","poem":1},{"text":"dan memeliharanya dengan segenap hati.","poem":2}]},{"type":"verse","number":35,"content":[{"text":"Pimpin aku menurut jalur perintah-perintah-Mu,","poem":1},{"text":"karena aku menyukainya.","poem":2}]},{"type":"verse","number":36,"content":[{"text":"Condongkan hatiku kepada kesaksian-kesaksian-Mu,","poem":1},{"text":"dan bukan kepada keuntungan yang tidak benar.","poem":2}]},{"type":"verse","number":37,"content":[{"text":"Belokkan mataku dari melihat kepada kesia-siaan,","poem":1},{"text":"dan pertahankan hidupku di jalan-jalan-Mu.","poem":2}]},{"type":"verse","number":38,"content":[{"text":"Teguhkan janji-Mu kepada hamba-Mu,","poem":1},{"text":"maka Engkau akan ditakuti.","poem":2}]},{"type":"verse","number":39,"content":[{"text":"Lewatkanlah hinaan yang aku takuti,","poem":1},{"text":"karena peraturan-peraturan-Mu itu baik.","poem":2}]},{"type":"verse","number":40,"content":[{"text":"Sebenarnya, aku rindu kepada titah-titah-Mu,","poem":1},{"text":"pertahankan hidupku dengan kebenaran-Mu.","poem":2}]},{"type":"heading","content":["Waw"]},{"type":"verse","number":41,"content":[{"text":"Kiranya kasih setia-Mu menghampiriku, ya TUHAN,","poem":1},{"text":"keselamatan-Mu menurut janji-Mu.","poem":2}]},{"type":"verse","number":42,"content":[{"text":"Dengan demikian, aku akan menjawab dia yang mencelaku,","poem":1},{"text":"karena aku percaya kepada firman-Mu.","poem":2}]},{"type":"verse","number":43,"content":[{"text":"Dan, jangan sama sekali mencabut firman kebenaran dari mulutku,","poem":1},{"text":"karena harapanku ada pada hukum-hukum-Mu.","poem":2}]},{"type":"verse","number":44,"content":[{"text":"Aku akan terus-menerus memelihara taurat-Mu,","poem":1},{"text":"untuk selama-lamanya.","poem":2}]},{"type":"verse","number":45,"content":[{"text":"Dan, aku akan berjalan dalam kelegaan,","poem":1},{"text":"karena aku mencari titah-titah-Mu.","poem":2}]},{"type":"verse","number":46,"content":[{"text":"Aku juga akan membicarakan kesaksian-Mu di hadapan raja-raja,","poem":1},{"text":"dan takkan dipermalukan.","poem":2}]},{"type":"verse","number":47,"content":[{"text":"Aku akan bersuka di dalam perintah-perintah-Mu,","poem":1},{"text":"yang aku cintai.","poem":2}]},{"type":"verse","number":48,"content":[{"text":"Aku akan mengangkat tanganku kepada perintah-perintah-Mu yang aku cintai,","poem":1},{"text":"dan aku akan merenungkan ketetapan-ketetapan-Mu.","poem":2}]},{"type":"heading","content":["Zain"]},{"type":"verse","number":49,"content":[{"text":"Ingatkanlah firman kepada hamba-Mu,","poem":1},{"text":"yang di dalamnya Engkau telah membuatku berharap.","poem":2}]},{"type":"verse","number":50,"content":[{"text":"Inilah penghiburanku dalam kesusahanku,","poem":1},{"text":"bahwa janji-Mu menghidupkan aku.","poem":2}]},{"type":"verse","number":51,"content":[{"text":"Orang-orang sombong bahkan mencelaku,","poem":1},{"text":"tetapi aku tidak menyimpang dari taurat-Mu.","poem":2}]},{"type":"verse","number":52,"content":[{"text":"Aku mengingat hukum-hukum-Mu sejak purbakala, ya TUHAN,","poem":1},{"text":"dan menghibur diriku sendiri.","poem":2}]},{"type":"verse","number":53,"content":[{"text":"Panas amarah menguasaiku oleh karena orang fasik, yang meninggalkan taurat-Mu.","poem":1}]},{"type":"verse","number":54,"content":[{"lineBreak":true},{"text":"Ketetapan-ketetapan-Mu telah menjadi laguku,","poem":1},{"text":"di rumah yang kudiami sebagai orang yang tinggal sementara.","poem":2}]},{"type":"verse","number":55,"content":[{"text":"Ya TUHAN, aku mengingat nama-Mu pada waktu malam,","poem":1},{"text":"dan memelihara taurat-Mu.","poem":2}]},{"type":"verse","number":56,"content":[{"text":"Ini yang telah terjadi padaku,","poem":1},{"text":"bahwa aku telah memelihara titah-titah-Mu.","poem":2}]},{"type":"heading","content":["Het"]},{"type":"verse","number":57,"content":[{"text":"TUHAN adalah bagianku;","poem":1},{"text":"aku telah berjanji untuk memelihara perkataan-perkataan-Mu.","poem":2}]},{"type":"verse","number":58,"content":[{"text":"Aku mencari perkenanan-Mu dengan segenap hati;","poem":1},{"text":"berbelaskasihlah kepadaku sesuai dengan janji-Mu.","poem":2}]},{"type":"verse","number":59,"content":[{"text":"Aku memikirkan jalan-jalanku,","poem":1},{"text":"dan mengarahkan kakiku kepada kesaksian-kesaksian-Mu.","poem":2}]},{"type":"verse","number":60,"content":[{"text":"Aku bergegas dan tidak menunda-nunda,","poem":1},{"text":"untuk memelihara perintah-perintah-Mu.","poem":2}]},{"type":"verse","number":61,"content":[{"text":"Tali-tali orang fasik membelit aku,","poem":1},{"text":"tetapi aku tidak melupakan taurat-Mu.","poem":2}]},{"type":"verse","number":62,"content":[{"text":"Di tengah malam, aku bangun untuk bersyukur kepada-Mu,","poem":1},{"text":"oleh karena hukum-hukum-Mu yang adil.","poem":2}]},{"type":"verse","number":63,"content":[{"text":"Aku adalah sekutu dari semua orang yang takut akan Engkau,","poem":1},{"text":"dan mereka yang memelihara titah-titah-Mu.","poem":2}]},{"type":"verse","number":64,"content":[{"text":"Bumi dipenuhi dengan kasih setia-Mu, ya TUHAN,","poem":1},{"text":"ajari aku ketetapan-ketetapan-Mu.","poem":2}]},{"type":"heading","content":["Tet"]},{"type":"verse","number":65,"content":[{"text":"Engkau telah berbuat baik kepada hamba-Mu, ya TUHAN,","poem":1},{"text":"sesuai dengan firman-Mu.","poem":2}]},{"type":"verse","number":66,"content":[{"text":"Ajari aku pertimbangan dan pengetahuan yang baik,","poem":1},{"text":"karena aku percaya akan perintah-perintah-Mu.","poem":2}]},{"type":"verse","number":67,"content":[{"text":"Sebelum tertindas, aku telah tersesat,","poem":1},{"text":"tetapi sekarang aku memelihara firman-Mu.","poem":2}]},{"type":"verse","number":68,"content":[{"text":"Engkau baik dan berbuat baik,","poem":1},{"text":"ajari aku ketetapan-ketetapan-Mu.","poem":2}]},{"type":"verse","number":69,"content":[{"text":"Orang sombong menodaiku dengan kebohongan,","poem":1},{"text":"tetapi dengan segenap hati aku memelihara titah-titah-Mu.","poem":2}]},{"type":"verse","number":70,"content":[{"text":"Hati mereka tebal seperti lemak,","poem":1},{"text":"tetapi aku menyukai taurat-Mu.","poem":2}]},{"type":"verse","number":71,"content":[{"text":"Baik bagiku bahwa aku tertindas,","poem":1},{"text":"sehingga aku boleh belajar ketetapan-ketetapan-Mu.","poem":2}]},{"type":"verse","number":72,"content":[{"text":"Taurat mulut-Mu lebih baik bagiku,","poem":1},{"text":"daripada ribuan keping emas dan perak.","poem":2}]},{"type":"heading","content":["Yod"]},{"type":"verse","number":73,"content":[{"text":"Tangan-Mu menjadikan aku dan membangun aku,","poem":1},{"text":"berikan pengertian kepadaku supaya aku dapat belajar perintah-perintah-Mu.","poem":2}]},{"type":"verse","number":74,"content":[{"text":"Orang-orang yang takut akan Engkau akan melihatku dan bersukacita,","poem":1},{"text":"karena aku berharap pada firman-Mu.","poem":2}]},{"type":"verse","number":75,"content":[{"text":"Aku tahu, ya TUHAN, bahwa hukum-hukum-Mu benar,","poem":1},{"text":"dan bahwa dalam kesetiaan Engkau telah menindas aku.","poem":2}]},{"type":"verse","number":76,"content":[{"text":"Biarlah kasih setia-Mu menghiburku,","poem":1},{"text":"sesuai dengan janji-Mu kepada hamba-Mu.","poem":2}]},{"type":"verse","number":77,"content":[{"text":"Biarlah belas kasihan-Mu menghampiriku supaya aku boleh hidup,","poem":1},{"text":"karena taurat-Mu adalah kesukaanku.","poem":2}]},{"type":"verse","number":78,"content":[{"text":"Biarlah orang-orang sombong dipermalukan,","poem":1},{"text":"karena mereka membengkokkanku dengan dusta,","poem":2},{"lineBreak":true},{"text":"tetapi aku akan merenungkan titah-titah-Mu.","poem":2}]},{"type":"verse","number":79,"content":[{"text":"Biarlah mereka yang takut akan Engkau berbalik kepadaku,","poem":1},{"text":"sehingga mereka mengenal kesaksian-kesaksian-Mu.","poem":2}]},{"type":"verse","number":80,"content":[{"text":"Kiranya hatiku sempurna dalam ketetapan-ketetapan-Mu,","poem":1},{"text":"supaya aku tidak akan dipermalukan.","poem":2}]},{"type":"heading","content":["Kaf"]},{"type":"verse","number":81,"content":[{"text":"Jiwaku habis oleh karena keselamatan-Mu;","poem":1},{"text":"aku berharap pada firman-Mu.","poem":2}]},{"type":"verse","number":82,"content":[{"text":"Mataku habis oleh karena firman-Mu;","poem":1},{"text":"aku berkata, “Kapan Engkau akan menghiburku?”","poem":2}]},{"type":"verse","number":83,"content":[{"text":"Sebab, aku telah menjadi kirbat di dalam asap,","poem":1},{"text":"tetapi aku tidak melupakan ketetapan-ketetapan-Mu.","poem":2}]},{"type":"verse","number":84,"content":[{"text":"Berapa lama lagi hari-hari hamba-Mu ini?","poem":1},{"text":"Kapan Engkau akan menghakimi mereka yang mengejar aku?","poem":2}]},{"type":"verse","number":85,"content":[{"text":"Orang-orang sombong telah menggali lubang bagiku,","poem":1},{"text":"mereka yang tidak taat pada taurat-Mu.","poem":2}]},{"type":"verse","number":86,"content":[{"text":"Segala perintah-Mu itu terpercaya,","poem":1},{"text":"mereka mengejarku dengan dusta,","poem":2},{"lineBreak":true},{"text":"tolonglah aku!","poem":2}]},{"type":"verse","number":87,"content":[{"text":"Sedikit lagi mereka menghabisiku di bumi,","poem":1},{"text":"tetapi aku tidak meninggalkan titah-titah-Mu.","poem":2}]},{"type":"verse","number":88,"content":[{"text":"Pertahankan hidupku menurut kasih setia-Mu,","poem":1},{"text":"supaya aku dapat memelihara kesaksian-kesaksian mulut-Mu.","poem":2}]},{"type":"heading","content":["Lamed"]},{"type":"verse","number":89,"content":[{"text":"Untuk selama-lamanya, ya TUHAN,","poem":1},{"text":"firman-Mu tetap teguh di surga.","poem":2}]},{"type":"verse","number":90,"content":[{"text":"Kesetiaan-Mu dari generasi ke generasi,","poem":1},{"text":"Engkau menegakkan bumi sehingga tetap berdiri.","poem":2}]},{"type":"verse","number":91,"content":[{"text":"Dengan peraturan-peraturan-Mu segalanya berdiri hari ini,","poem":1},{"text":"karena segala sesuatu adalah hamba-Mu.","poem":2}]},{"type":"verse","number":92,"content":[{"text":"Seandainya taurat-Mu tidak menjadi kesukaanku,","poem":1},{"text":"aku telah binasa dalam kesengsaraanku.","poem":2}]},{"type":"verse","number":93,"content":[{"text":"Aku takkan melupakan titah-titah-Mu selama-lamanya,","poem":1},{"text":"karena dengan semua itu Engkau telah menghidupkan aku.","poem":2}]},{"type":"verse","number":94,"content":[{"text":"Aku milik-Mu, selamatkan aku,","poem":1},{"text":"karena aku telah mencari titah-titah-Mu.","poem":2}]},{"type":"verse","number":95,"content":[{"text":"Orang-orang fasik menanti-nanti untuk membinasakan aku,","poem":1},{"text":"tetapi aku akan memahami kesaksian-kesaksian-Mu.","poem":2}]},{"type":"verse","number":96,"content":[{"text":"Aku telah melihat batas dari segala kesempurnaan,","poem":1},{"text":"tetapi perintah-Mu itu sangat luas.","poem":2}]},{"type":"heading","content":["Mem"]},{"type":"verse","number":97,"content":[{"text":"Oh, betapa aku mencintai taurat-Mu!","poem":1},{"text":"Inilah perenungkanku sepanjang hari.","poem":2}]},{"type":"verse","number":98,"content":[{"text":"Perintah-perintah-Mu membuatku lebih bijaksana daripada musuh-musuhku,","poem":1},{"text":"karena semua itu selalu bersamaku.","poem":2}]},{"type":"verse","number":99,"content":[{"text":"Aku memiliki lebih banyak pengertian daripada semua pengajarku,","poem":1},{"text":"karena kesaksian-kesaksian-Mu adalah perenunganku.","poem":2}]},{"type":"verse","number":100,"content":[{"text":"Aku mengerti melebihi orang-orang tua,","poem":1},{"text":"karena aku mengamati titah-titah-Mu.","poem":2}]},{"type":"verse","number":101,"content":[{"text":"Aku telah menahan kakiku dari setiap jalan kejahatan,","poem":1},{"text":"supaya aku dapat memelihara firman-Mu.","poem":2}]},{"type":"verse","number":102,"content":[{"text":"Aku tidak berbelok dari peraturan-peraturan-Mu,","poem":1},{"text":"karena Engkau telah mengajar aku.","poem":2}]},{"type":"verse","number":103,"content":[{"text":"Betapa lembut firman-Mu bagi langit-langitku!","poem":1},{"text":"Melebihi madu bagi mulutku!","poem":2}]},{"type":"verse","number":104,"content":[{"text":"Dari titah-titah-Mu, aku mendapat pengertian.","poem":1},{"text":"Karena itu, aku membenci setiap jalan kepalsuan.","poem":2}]},{"type":"heading","content":["Nun"]},{"type":"verse","number":105,"content":[{"text":"Firman-Mu adalah pelita bagi kakiku,","poem":1},{"text":"dan terang bagi jalanku.","poem":2}]},{"type":"verse","number":106,"content":[{"text":"Aku telah bersumpah dan akan menepatinya,","poem":1},{"text":"supaya aku memelihara kebenaran hukum-hukum-Mu.","poem":2}]},{"type":"verse","number":107,"content":[{"text":"Aku sangat menderita;","poem":1},{"text":"pertahankan hidupku, ya TUHAN, sesuai dengan firman-Mu.","poem":2}]},{"type":"verse","number":108,"content":[{"text":"Terimalah persembahan sukarela dari mulutku, ya TUHAN,","poem":1},{"text":"dan ajari aku hukum-hukum-Mu.","poem":2}]},{"type":"verse","number":109,"content":[{"text":"Jiwaku selalu ada di dalam genggaman tanganku,","poem":1},{"text":"tetapi aku tidak melupakan taurat-Mu.","poem":2}]},{"type":"verse","number":110,"content":[{"text":"Orang-orang fasik telah menaruh jebakan bagiku,","poem":1},{"text":"tetapi aku tidak menyimpang dari titah-titah-Mu.","poem":2}]},{"type":"verse","number":111,"content":[{"text":"Kesaksian-kesaksian-Mu adalah warisanku selama-lamanya,","poem":1},{"text":"karena itu adalah kesukaan hatiku.","poem":2}]},{"type":"verse","number":112,"content":[{"text":"Aku mencondongkan hatiku untuk melakukan ketetapan-ketetapan-Mu,","poem":1},{"text":"selama-lamanya, sampai akhir.","poem":2}]},{"type":"heading","content":["Samekh"]},{"type":"verse","number":113,"content":[{"text":"Aku membenci orang yang mendua hati,","poem":1},{"text":"tetapi aku mencintai taurat-Mu.","poem":2}]},{"type":"verse","number":114,"content":[{"text":"Engkau adalah tempat persembunyianku dan perisaiku,","poem":1},{"text":"aku berharap pada firman-Mu.","poem":2}]},{"type":"verse","number":115,"content":[{"text":"Pergi dariku, hai para penjahat,","poem":1},{"text":"supaya aku dapat memelihara perintah-perintah Allahku.","poem":2}]},{"type":"verse","number":116,"content":[{"text":"Topanglah aku sesuai dengan firman-Mu supaya aku hidup,","poem":1},{"text":"dan jangan biarkan aku dipermalukan dalam pengharapanku.","poem":2}]},{"type":"verse","number":117,"content":[{"text":"Kuatkan aku supaya aku diselamatkan,","poem":1},{"text":"aku akan senantiasa memandang ketetapan-ketetapan-Mu.","poem":2}]},{"type":"verse","number":118,"content":[{"text":"Engkau menolak semua orang sesat dari ketetapan-ketetapan-Mu,","poem":1},{"text":"karena kebohongan mereka adalah sia-sia.","poem":2}]},{"type":"verse","number":119,"content":[{"text":"Semua orang fasik di bumi Engkau buang seperti sanga,","poem":1},{"text":"karena itu aku mencintai kesaksian-kesaksian-Mu.","poem":2}]},{"type":"verse","number":120,"content":[{"text":"Dagingku gemetar karena takut akan Engkau,","poem":1},{"text":"dan aku takut kepada hukum-Mu.","poem":2}]},{"type":"heading","content":["Ain"]},{"type":"verse","number":121,"content":[{"text":"Aku telah melakukan keadilan dan kebenaran,","poem":1},{"text":"jangan tinggalkan aku pada para penindasku.","poem":2}]},{"type":"verse","number":122,"content":[{"text":"Jaminlah hamba-Mu untuk kebaikan,","poem":1},{"text":"jangan biarkan orang-orang sombong menindas aku.","poem":2}]},{"type":"verse","number":123,"content":[{"text":"Mataku habis oleh karena keselamatan-Mu dan oleh karena kebenaran perkataan-Mu.","poem":1}]},{"type":"verse","number":124,"content":[{"lineBreak":true},{"text":"Perlakukanlah hamba-Mu sesuai dengan kasih setia-Mu,","poem":1},{"text":"dan ajari aku ketetapan-ketetapan-Mu.","poem":2}]},{"type":"verse","number":125,"content":[{"text":"Aku ini hamba-Mu, berikan kepadaku pengertian,","poem":1},{"text":"supaya aku mengenal kesaksian-kesaksian-Mu.","poem":2}]},{"type":"verse","number":126,"content":[{"text":"Ini adalah waktunya bagi TUHAN untuk bertindak,","poem":1},{"text":"karena taurat-Mu telah dilanggar.","poem":2}]},{"type":"verse","number":127,"content":[{"text":"Karena itu, aku mencintai perintah-perintah-Mu melebihi emas,","poem":1},{"text":"melebihi emas murni.","poem":2}]},{"type":"verse","number":128,"content":[{"text":"Karena itu, aku membenarkan titah-titah-Mu,","poem":1},{"text":"aku membenci segala jalan kebohongan.","poem":2}]},{"type":"heading","content":["Pe"]},{"type":"verse","number":129,"content":[{"text":"Kesaksian-kesaksian-Mu itu ajaib,","poem":1},{"text":"karena itu jiwaku memeliharanya.","poem":2}]},{"type":"verse","number":130,"content":[{"text":"Firman-firman-Mu yang disingkapkan memberi terang,","poem":1},{"text":"itu memberi pengertian kepada orang-orang naif.","poem":2}]},{"type":"verse","number":131,"content":[{"text":"Aku membuka mulutku dan terengah-engah,","poem":1},{"text":"karena aku merindukan perintah-perintah-Mu.","poem":2}]},{"type":"verse","number":132,"content":[{"text":"Berpalinglah kepadaku dan kasihanilah aku,","poem":1},{"text":"sebagaimana kepada orang-orang yang mengasihi nama-Mu.","poem":2}]},{"type":"verse","number":133,"content":[{"text":"Tetapkan langkahku sesuai dengan firman-Mu,","poem":1},{"text":"dan jangan biarkan segala kefasikan menguasaiku.","poem":2}]},{"type":"verse","number":134,"content":[{"text":"Tebuslah aku dari penindasan manusia,","poem":1},{"text":"supaya aku dapat memelihara titah-titah-Mu.","poem":2}]},{"type":"verse","number":135,"content":[{"text":"Buatlah wajah-Mu bersinar atas hamba-Mu,","poem":1},{"text":"dan ajari aku ketetapan-ketetapan-Mu.","poem":2}]},{"type":"verse","number":136,"content":[{"text":"Mataku mengalirkan arus air,","poem":1},{"text":"karena mereka tidak memelihara taurat-Mu.","poem":2}]},{"type":"heading","content":["Tsade"]},{"type":"verse","number":137,"content":[{"text":"Engkau benar, ya TUHAN,","poem":1},{"text":"dan hukum-hukum-Mu itu benar.","poem":2}]},{"type":"verse","number":138,"content":[{"text":"Engkau telah menetapkan kesaksian-kesaksian-Mu,","poem":1},{"text":"dalam kebenaran dan dalam segala kesetiaan.","poem":2}]},{"type":"verse","number":139,"content":[{"text":"Kecemburuanku menghabisi aku,","poem":1},{"text":"karena lawan-lawanku melupakan firman-Mu.","poem":2}]},{"type":"verse","number":140,"content":[{"text":"Janji-Mu sangat teruji,","poem":1},{"text":"dan hamba-Mu mencintainya.","poem":2}]},{"type":"verse","number":141,"content":[{"text":"Aku ini kecil dan hina,","poem":1},{"text":"tetapi aku tidak melupakan titah-titah-Mu.","poem":2}]},{"type":"verse","number":142,"content":[{"text":"Kebenaran-Mu adalah kebenaran kekal,","poem":1},{"text":"dan taurat-Mu itu benar.","poem":2}]},{"type":"verse","number":143,"content":[{"text":"Kesesakan dan kesusahan telah menimpaku,","poem":1},{"text":"tetapi perintah-perintah-Mu adalah kesukaanku.","poem":2}]},{"type":"verse","number":144,"content":[{"text":"Kesaksian-kesaksian-Mu itu benar selama-lamanya,","poem":1},{"text":"berilah pengertian supaya aku boleh hidup.","poem":2}]},{"type":"heading","content":["Qof"]},{"type":"verse","number":145,"content":[{"text":"Aku berseru dengan segenap hati, jawab aku, ya TUHAN!","poem":1},{"text":"Aku akan memelihara ketetapan-ketetapan-Mu.","poem":2}]},{"type":"verse","number":146,"content":[{"text":"Aku berseru kepada-Mu, selamatkan aku,","poem":1},{"text":"dan aku akan memelihara kesaksian-kesaksian-Mu.","poem":2}]},{"type":"verse","number":147,"content":[{"text":"Aku bangun sebelum fajar dan berseru minta tolong,","poem":1},{"text":"aku berharap pada firman-Mu.","poem":2}]},{"type":"verse","number":148,"content":[{"text":"Mataku bangun sebelum jam jaga malam,","poem":1},{"text":"supaya aku dapat merenungkan firman-Mu.","poem":2}]},{"type":"verse","number":149,"content":[{"text":"Dengarlah suaraku menurut kasih setia-Mu,","poem":1},{"text":"pertahankan hidupku, ya TUHAN, menurut hukum-hukum-Mu.","poem":2}]},{"type":"verse","number":150,"content":[{"text":"Mereka yang mengejar dengan maksud fasik mendekat,","poem":1},{"text":"mereka jauh dari taurat-Mu.","poem":2}]},{"type":"verse","number":151,"content":[{"text":"Akan tetapi, Engkau dekat, ya TUHAN,","poem":1},{"text":"dan semua perintah-Mu adalah benar.","poem":2}]},{"type":"verse","number":152,"content":[{"text":"Sejak dahulu aku tahu dari kesaksian-kesaksian-Mu,","poem":1},{"text":"bahwa Engkau telah menetapkannya untuk selamanya.","poem":2}]},{"type":"heading","content":["Resh"]},{"type":"verse","number":153,"content":[{"text":"Lihatlah kesengsaraanku dan selamatkanlah aku,","poem":1},{"text":"karena aku tidak melupakan taurat-Mu.","poem":2}]},{"type":"verse","number":154,"content":[{"text":"Perjuangkan perkaraku dan tebuslah aku,","poem":1},{"text":"hidupkan aku sesuai dengan firman-Mu.","poem":2}]},{"type":"verse","number":155,"content":[{"text":"Keselamatan itu jauh dari orang-orang fasik,","poem":1},{"text":"karena mereka tidak mencari ketetapan-ketetapan-Mu.","poem":2}]},{"type":"verse","number":156,"content":[{"text":"Besar belas kasihan-Mu, ya TUHAN,","poem":1},{"text":"hidupkan aku sesuai dengan hukum-hukum-Mu.","poem":2}]},{"type":"verse","number":157,"content":[{"text":"Para pengejar dan lawanku itu banyak,","poem":1},{"text":"tetapi aku tidak menyimpang dari kesaksian-kesaksian-Mu.","poem":2}]},{"type":"verse","number":158,"content":[{"text":"Aku melihat para pengkhianat dan membenci mereka,","poem":1},{"text":"karena mereka tidak memelihara firman-Mu.","poem":2}]},{"type":"verse","number":159,"content":[{"text":"Lihatlah, betapa aku mencintai titah-titah-Mu!","poem":1},{"text":"hidupkan aku, ya TUHAN, sesuai kasih setia-Mu.","poem":2}]},{"type":"verse","number":160,"content":[{"text":"Inti firman-Mu adalah kebenaran,","poem":1},{"text":"dan setiap hukum kebenaran-Mu untuk selama-lamanya.","poem":2}]},{"type":"heading","content":["Shin"]},{"type":"verse","number":161,"content":[{"text":"Para pembesar mengejarku tanpa alasan,","poem":1},{"text":"tetapi hatiku gentar terhadap perkataan-perkataan-Mu.","poem":2}]},{"type":"verse","number":162,"content":[{"text":"Aku bersukacita atas firman-Mu,","poem":1},{"text":"seperti seseorang yang mendapat banyak jarahan.","poem":2}]},{"type":"verse","number":163,"content":[{"text":"Aku benci dan muak terhadap dusta,","poem":1},{"text":"tetapi aku mencintai taurat-Mu.","poem":2}]},{"type":"verse","number":164,"content":[{"text":"Tujuh kali sehari aku memuji-Mu,","poem":1},{"text":"karena kebenaran hukum-hukum-Mu.","poem":2}]},{"type":"verse","number":165,"content":[{"text":"Damai sejahtera yang besar dimiliki oleh mereka yang mencintai taurat-Mu,","poem":1},{"text":"tidak ada batu sandungan padanya.","poem":2}]},{"type":"verse","number":166,"content":[{"text":"Aku menantikan keselamatan-Mu, ya TUHAN,","poem":1},{"text":"dan aku melakukan perintah-perintah-Mu.","poem":2}]},{"type":"verse","number":167,"content":[{"text":"Jiwaku memelihara kesaksian-kesaksian-Mu.","poem":1},{"text":"Aku sangat mencintainya.","poem":2}]},{"type":"verse","number":168,"content":[{"text":"Aku memelihara titah-titah-Mu dan kesaksian-kesaksian-Mu,","poem":1},{"text":"karena seluruh jalanku ada di hadapan-Mu.","poem":2}]},{"type":"heading","content":["Taw"]},{"type":"verse","number":169,"content":[{"text":"Biarlah seruanku sampai ke hadapan-Mu, ya TUHAN,","poem":1},{"text":"beri aku pengertian sesuai dengan firman-Mu.","poem":2}]},{"type":"verse","number":170,"content":[{"text":"Biarlah permohonanku sampai di hadapan-Mu,","poem":1},{"text":"lepaskan aku sesuai dengan firman-Mu.","poem":2}]},{"type":"verse","number":171,"content":[{"text":"Bibirku akan mencurahkan pujian,","poem":1},{"text":"karena Engkau mengajari aku ketetapan-ketetapan-Mu.","poem":2}]},{"type":"verse","number":172,"content":[{"text":"Lidahku akan menyanyikan firman-Mu,","poem":1},{"text":"karena semua perintah-Mu itu benar.","poem":2}]},{"type":"verse","number":173,"content":[{"text":"Biarlah tangan-Mu menolong aku,","poem":1},{"text":"karena aku telah memilih titah-titah-Mu.","poem":2}]},{"type":"verse","number":174,"content":[{"text":"Aku merindukan keselamatan-Mu, ya TUHAN,","poem":1},{"text":"dan taurat-Mu adalah kesukaanku.","poem":2}]},{"type":"verse","number":175,"content":[{"text":"Biarlah jiwaku hidup supaya dapat memuji-Mu,","poem":1},{"text":"dan kiranya hukum-hukum-Mu menolongku.","poem":2}]},{"type":"verse","number":176,"content":[{"text":"Aku telah tersesat seperti domba yang hilang,","poem":1},{"text":"carilah hamba-Mu ini karena aku tidak melupakan perintah-perintah-Mu.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/119.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/120.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/118.json","previousChapterAudioLinks":{},"numberOfVerses":176}