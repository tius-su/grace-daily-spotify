{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":108,"content":[{"type":"heading","content":["Pujian untuk Kemenangan"]},{"type":"verse","number":1,"content":[{"text":"Sebuah nyanyian. Mazmur Daud.","descriptive":true},{"lineBreak":true},{"text":"(108-2) Hatiku teguh, ya Allah!","poem":1},{"text":"Aku akan bernyanyi dan bermazmur","poem":2},{"lineBreak":true},{"text":"dengan segenap jiwaku!","poem":2}]},{"type":"verse","number":2,"content":[{"text":"(108-3) Bangunlah, hai gambus dan kecapi!","poem":1},{"text":"Aku hendak membangunkan fajar!","poem":2}]},{"type":"verse","number":3,"content":[{"text":"(108-4) Aku hendak bersyukur kepada-Mu, ya TUHAN,","poem":1},{"text":"di antara suku-suku bangsa.","poem":2},{"text":"Aku hendak bermazmur bagi-Mu,","poem":1},{"text":"di antara bangsa-bangsa.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"(108-5) Sebab, kasih setia-Mu besar mengatasi langit,","poem":1},{"text":"kesetiaan-Mu mencapai awan-awan.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"(108-6) Tinggilah mengatasi langit, ya Allah!","poem":1},{"text":"Kemuliaan-Mu mengatasi seluruh bumi.","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"(108-7) Supaya orang-orang yang Engkau kasihi dapat dilepaskan,","poem":1},{"text":"selamatkanlah dengan tangan kanan-Mu dan jawablah!","poem":2}]},{"type":"verse","number":7,"content":[{"text":"(108-8) Allah telah berfirman dalam kekudusan-Nya:","poem":1},{"text":"“Aku hendak bersorak-sorai,","poem":2},{"text":"Aku akan membagi-bagi Sikhem","poem":1},{"text":"dan mengukur Lembah Sukot.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"(108-9) Gilead dan Manasye adalah milik-Ku,","poem":1},{"text":"Efraim adalah pelindung kepala-Ku,","poem":2},{"lineBreak":true},{"text":"Yehuda adalah tongkat kerajaan-Ku.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"(108-10) Moab adalah cawan pembasuhan-Ku;","poem":1},{"text":"kepada Edom, Aku akan melemparkan kasut-Ku;","poem":2},{"lineBreak":true},{"text":"kepada Filistea, Aku akan bersorak-sorai.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"(108-11) Siapa yang akan membawaku ke kota berbenteng?","poem":1},{"text":"Siapa yang akan memimpinku ke Edom?","poem":2}]},{"type":"verse","number":11,"content":[{"text":"(108-12) Bukankah Engkau menolak kami, ya Allah?","poem":1},{"text":"Dan, tidakkah Engkau akan maju bersama bala tentara kami, ya Allah?","poem":2}]},{"type":"verse","number":12,"content":[{"text":"(108-13) Berilah kami pertolongan terhadap musuh kami,","poem":1},{"text":"karena keselamatan dari manusia itu sia-sia.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"(108-14) Bersama Allah, kita akan melakukan kehebatan,","poem":1},{"text":"karena Dia akan menginjak-injak musuh-musuh kita.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/108.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/109.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/107.json","previousChapterAudioLinks":{},"numberOfVerses":13}