{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":66,"content":[{"type":"heading","content":["Ibadah yang Layak"]},{"type":"verse","number":1,"content":[{"text":"Kepada pemimpin pujian: Nyanyian. Mazmur.","descriptive":true},{"lineBreak":true},{"text":"Bersoraklah bagi Allah,","poem":1},{"text":"hai seluruh bumi!","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Nyanyikan pujian bagi kemuliaan nama-Nya,","poem":1},{"text":"berikanlah pujian yang mulia bagi Dia!","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Katakan kepada Allah,","poem":1},{"text":"“Betapa dahsyat perbuatan-Mu!","poem":2},{"text":"Oleh karena besar kekuatan-Mu sehingga musuh-musuh-Mu meringkuk ketakutan terhadap-Mu.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Seluruh bumi bersujud kepada-Mu,","poem":1},{"text":"dan menyanyikan pujian bagi nama-Mu.” Sela","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"Datang dan lihatlah pekerjaan-pekerjaan Allah;","poem":1},{"text":"perbuatan-perbuatan-Nya terhadap anak-anak manusia ditakuti.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Dia mengubah laut menjadi tanah kering;","poem":1},{"text":"mereka melewati sungai dengan berjalan kaki.","poem":2},{"lineBreak":true},{"text":"Karena itu, mari kita bersorak!","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Dia memerintah dengan keperkasaan selama-lamanya;","poem":1},{"text":"mata-Nya mengawasi bangsa-bangsa.","poem":2},{"lineBreak":true},{"text":"Para pemberontak takkan bangkit meninggikan dirinya sendiri. Sela","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"Pujilah Allah kami, hai suku-suku bangsa;","poem":1},{"text":"biarlah suara puji-pujian bagi-Nya terdengar!","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Yang telah menaruh nyawa dalam hidup,","poem":1},{"text":"dan tidak mengizinkan kaki kami gemetar.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Sebab, Engkau, ya Allah, menguji kami;","poem":1},{"text":"Engkau memurnikan kami seperti perak dimurnikan.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Engkau membawa kami ke dalam perangkap;","poem":1},{"text":"Engkau menaruh beban di pinggang kami.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Engkau membiarkan orang-orang menunggangi kepala kami;","poem":1},{"text":"kami melewati api dan air,","poem":2},{"lineBreak":true},{"text":"tetapi Engkau mengeluarkan kami menuju kelimpahan.","poem":2}]},{"type":"line_break"},{"type":"verse","number":13,"content":[{"text":"Aku akan masuk ke dalam rumah-Mu dengan kurban-kurban bakaran;","poem":1},{"text":"aku akan membayar nazarku kepada-Mu,","poem":2}]},{"type":"verse","number":14,"content":[{"text":"yang bibirku nyatakan dan","poem":1},{"text":"mulutku ucapkan saat aku sedang dalam kesesakan.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Aku akan pergi mempersembahkan bagi-Mu kurban-kurban bakaran binatang gemuk","poem":1},{"text":"dengan asap kurban domba-domba jantan;","poem":2},{"lineBreak":true},{"text":"aku akan mempersembahkan kawanan lembu dan kambing-kambing jantan. Sela","poem":2}]},{"type":"line_break"},{"type":"verse","number":16,"content":[{"text":"Datang dan dengarlah, kamu semua yang takut akan Allah!","poem":1},{"text":"Aku akan menceritakan apa yang Dia perbuat terhadap jiwaku.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Aku memanggil-Nya dengan mulutku;","poem":1},{"text":"pujian bagi-Nya ada pada lidahku.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Jika aku melihat kejahatan dalam hatiku,","poem":1},{"text":"Tuhan tidak akan mendengarkan.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Namun, Allah telah mendengar,","poem":1},{"text":"Dia memperhatikan suara doaku.","poem":2}]},{"type":"verse","number":20,"content":[{"text":"Terpujilah Allah","poem":1},{"text":"yang tidak berpaling dari doaku,","poem":2},{"lineBreak":true},{"text":"dan kasih setia-Nya padaku.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/66.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/67.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/65.json","previousChapterAudioLinks":{},"numberOfVerses":20}