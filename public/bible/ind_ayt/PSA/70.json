{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":70,"content":[{"type":"heading","content":["Memorial Mazmur"]},{"type":"verse","number":1,"content":[{"text":"Kepada pemimpin pujian: Mazmur Daud, sebagai peringatan.","descriptive":true},{"lineBreak":true},{"text":"(70-2) Ya Allah, selamatkan aku,","poem":1},{"text":"ya TUHAN, bergegaslah menolongku!","poem":2}]},{"type":"verse","number":2,"content":[{"text":"(70-3) Biarlah orang-orang yang mengincar nyawaku dipermalukan dan tersipu-sipu,","poem":1},{"text":"biarlah mereka berbalik mundur dan dipermalukan, yang menginginkan kecelakaanku.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"(70-4) Biarlah mereka berbalik oleh karena malunya, mereka yang berkata,","poem":1},{"text":"“Rasakan, rasakan!”","poem":2}]},{"type":"verse","number":4,"content":[{"text":"(70-5) Kiranya semua orang yang mencari-Mu","poem":1},{"text":"bersorak dan bergembira di dalam-Mu,","poem":2},{"text":"Kiranya mereka yang mencintai keselamatan-Mu tidak henti-hentinya berkata,","poem":1},{"text":"“Besarlah TUHAN!”","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"(70-6) Namun, aku ini sengsara dan melarat;","poem":1},{"text":"bersegeralah kepadaku, ya Allah!","poem":2},{"text":"Engkau adalah penolongku dan penyelamatku.","poem":1},{"text":"Ya TUHAN, janganlah berlama-lama.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/70.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/71.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/69.json","previousChapterAudioLinks":{},"numberOfVerses":5}