{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":142,"content":[{"type":"heading","content":["Mazmur Tawanan"]},{"type":"verse","number":1,"content":[{"text":"Nyanyian pengajaran Daud ketika dia berada di dalam gua. Sebuah Doa.","descriptive":true},{"lineBreak":true},{"text":"(142-2) Suaraku kepada TUHAN, aku berseru,","poem":1},{"text":"suaraku kepada TUHAN, kasihanilah.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"(142-3) Aku mencurahkan keluhanku di hadapan-Nya,","poem":1},{"text":"aku memberitahukan kesusahanku di hadapan-Nya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"(142-4) Ketika rohku undur dariku,","poem":1},{"text":"Engkau tahu jalanku.","poem":2},{"text":"Di jalan yang aku tempuh,","poem":1},{"text":"mereka telah menyembunyikan jebakan bagiku.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"(142-5) Lihatlah ke kanan dan pandanglah,","poem":1},{"text":"tak seorang pun yang mengenalku.","poem":2},{"text":"Lenyaplah tempat pelarian bagiku,","poem":1},{"text":"tidak ada yang memedulikan hidupku.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"(142-6) Aku berseru kepada-Mu, ya TUHAN, aku berkata,","poem":1},{"text":"“Engkau adalah perlindunganku,","poem":2},{"lineBreak":true},{"text":"bagianku di negeri orang-orang hidup.”","poem":2}]},{"type":"verse","number":6,"content":[{"text":"(142-7) Dengarkanlah tangisanku,","poem":1},{"text":"karena aku sangat lemah.","poem":2},{"text":"Lepaskan aku dari para pengejarku,","poem":1},{"text":"karena mereka terlalu kuat bagiku.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"(142-8) Keluarkan aku dari penjara,","poem":1},{"text":"supaya aku dapat bersyukur kepada nama-Mu.","poem":2},{"lineBreak":true},{"text":"Orang-orang benar akan mengelilingiku,","poem":1},{"text":"karena Engkau akan membalaskannya.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/142.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/143.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/141.json","previousChapterAudioLinks":{},"numberOfVerses":7}