{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PSA","translationId":"ind_ayt","name":"MAZMUR","commonName":"MAZMUR","title":"Mazmur","order":19,"numberOfChapters":150,"sha256":"62e8206373ca98528b93bc598b7ea4c8b1cf14298c9d81d1e3eb7331727af470","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/ind_ayt/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":15,"content":[{"type":"heading","content":["Orang-Orang yang Tinggal dengan TUHAN"]},{"type":"verse","number":1,"content":[{"text":"Nyanyian Daud.","descriptive":true},{"lineBreak":true},{"text":"Ya TUHAN, siapa yang boleh menumpang di dalam tenda-Mu?","poem":1},{"text":"Siapa yang boleh tinggal di gunung-Mu yang kudus?","poem":2}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"Dia yang berjalan dengan tidak bercela,","poem":1},{"text":"yang melakukan apa yang adil,","poem":2},{"lineBreak":true},{"text":"dan yang mengatakan kebenaran dalam hatinya.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Dia yang tidak memfitnah dengan lidahnya,","poem":1},{"text":"yang tidak melakukan kejahatan terhadap sesamanya,","poem":2},{"lineBreak":true},{"text":"dan tidak membuat celaan kepada kawannya.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Dia yang di mata-Nya merendahkan orang-orang tertolak,","poem":1},{"text":"tetapi yang menghormati mereka yang takut akan TUHAN;","poem":2},{"lineBreak":true},{"text":"yang berjanji sekalipun rugi dan tidak mengubahnya,","poem":2}]},{"type":"verse","number":5,"content":[{"text":"yang tidak meminjamkan uangnya dengan bunga,","poem":1},{"text":"dan tidak menerima suap untuk melawan orang tidak bersalah.","poem":2},{"lineBreak":true},{"text":"Dia yang melakukan semuanya itu,","poem":1},{"text":"takkan pernah goyah selama-lamanya.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/PSA/15.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/PSA/16.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/PSA/14.json","previousChapterAudioLinks":{},"numberOfVerses":5}