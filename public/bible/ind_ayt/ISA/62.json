{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"ISA","translationId":"ind_ayt","name":"YESAYA","commonName":"YESAYA","title":"Yesaya","order":23,"numberOfChapters":66,"sha256":"f891415032abc4205058a3f5640978e2960ef78dd8c37c7f0c7c220e7bbb2d1c","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/ISA/1.json","lastChapterNumber":66,"lastChapterApiLink":"/api/ind_ayt/ISA/66.json","totalNumberOfVerses":1292},"chapter":{"number":62,"content":[{"type":"heading","content":["Yerusalem Baru: Kota Penuh Kebaikan"]},{"type":"verse","number":1,"content":[{"text":"Demi Sion,","poem":1},{"text":"Aku tidak akan berdiam diri;","poem":2},{"text":"dan demi Yerusalem,","poem":1},{"text":"aku tidak akan diam","poem":2},{"text":"sampai kebenarannya memancar seperti cahaya,","poem":1},{"text":"dan keselamatannya seperti obor yang menyala.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Bangsa-bangsa akan melihat kebenaranmu","poem":1},{"text":"dan semua raja kemuliaanmu.","poem":2},{"text":"Kamu akan dipanggil dengan nama baru,","poem":1},{"text":"yang diberikan oleh mulut TUHAN sendiri.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Kamu akan menjadi mahkota keindahan di tangan TUHAN,","poem":1},{"text":"dan serban kerajaan di tangan Allahmu.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Kamu tidak akan lagi disebut “yang ditinggalkan”","poem":1},{"text":"dan negerimu tidak akan lagi disebut “sunyi”.","poem":2},{"text":"Akan tetapi, kamu akan disebut “yang Kuperkenan”","poem":1},{"text":"dan negerimu “yang menikah”","poem":2},{"text":"karena TUHAN berkenan kepadamu,","poem":1},{"text":"dan negerimu akan dinikahi.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Sebab, seperti seorang pemuda menikahi seorang perawan,","poem":1},{"text":"demikianlah anak-anakmu laki-laki akan menikahimu.","poem":2},{"text":"Seperti mempelai laki-laki bersukacita atas mempelai perempuan,","poem":1},{"text":"demikian juga Allah akan bersukacita atas kamu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"Di atas tembok-tembokmu, hai Yerusalem,","poem":1},{"text":"Aku telah menempatkan para penjaga.","poem":2},{"lineBreak":true},{"text":"Sepanjang siang dan sepanjang malam, mereka tidak akan berdiam diri.","poem":2},{"lineBreak":true},{"text":"Hai kamu yang mengingat TUHAN,","poem":1},{"text":"jangan beristirahat","poem":2}]},{"type":"verse","number":7,"content":[{"text":"dan jangan biarkan Dia beristirahat,","poem":1},{"text":"sampai Dia mendirikan dan menjadikan Yerusalem sebuah pujian di bumi.","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"TUHAN telah bersumpah dengan tangan kanan-Nya dan dengan lengan-Nya yang sangat kuat,","poem":1},{"text":"“Aku tidak akan lagi memberikan gandummu sebagai makanan bagi musuh-musuhmu,","poem":2},{"text":"dan orang-orang asing tidak akan minum air anggurmu,","poem":1},{"text":"yang untuknya kamu telah berjerih lelah.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Akan tetapi, mereka yang mengumpulkannya akan memakannya","poem":1},{"text":"dan memuji TUHAN, dan mereka yang mengumpulkannya akan meminumnya di pelataran-pelataran tempat kudus-Ku.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"Laluilah! Laluilah pintu-pintu gerbang;","poem":1},{"text":"persiapkanlah jalan bagi bangsa itu!","poem":2},{"text":"Bangunlah! Bangunlah jalan raya,","poem":1},{"text":"bersihkanlah itu dari batu-batu,","poem":2},{"text":"naikkanlah panji-panji atas bangsa-bangsa!","poem":1}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"Lihatlah, TUHAN telah menyatakan","poem":1},{"text":"sampai ke ujung bumi:","poem":2},{"text":"Katakanlah kepada putri Sion,","poem":1},{"text":"“Lihatlah, keselamatanmu datang;","poem":2},{"text":"lihatlah, upahnya ada bersamanya,","poem":1},{"text":"dan pahalanya di hadapannya.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Mereka akan dipanggil “bangsa yang kudus”,","poem":1},{"text":"“yang ditebus TUHAN”.","poem":2},{"text":"Dan, kamu akan disebut “yang dicari,","poem":1},{"text":"kota yang tidak akan ditinggalkan”.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/ISA/62.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/ISA/63.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/ISA/61.json","previousChapterAudioLinks":{},"numberOfVerses":12}