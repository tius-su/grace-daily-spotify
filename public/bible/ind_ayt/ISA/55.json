{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"ISA","translationId":"ind_ayt","name":"YESAYA","commonName":"YESAYA","title":"Yesaya","order":23,"numberOfChapters":66,"sha256":"f891415032abc4205058a3f5640978e2960ef78dd8c37c7f0c7c220e7bbb2d1c","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/ISA/1.json","lastChapterNumber":66,"lastChapterApiLink":"/api/ind_ayt/ISA/66.json","totalNumberOfVerses":1292},"chapter":{"number":55,"content":[{"type":"heading","content":["Allah Memberikan “Makanan” yang Sungguh Memuaskan"]},{"type":"verse","number":1,"content":[{"text":"“Hai, semua orang yang haus,","poem":1},{"text":"datanglah ke perairan;","poem":2},{"text":"dan kamu yang tidak memiliki uang,","poem":1},{"text":"Datanglah, belilah, dan makanlah.","poem":2},{"text":"Kemarilah, belilah anggur dan susu","poem":1},{"text":"tanpa uang dan bayaran.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Mengapa kamu menggunakan uangmu","poem":1},{"text":"untuk sesuatu yang bukan roti,","poem":2},{"text":"dan jerih payahmu","poem":1},{"text":"untuk sesuatu yang tidak mengenyangkan?","poem":2},{"text":"Dengarkan Aku baik-baik, dan makanlah apa yang baik.","poem":1},{"text":"senangkanlah jiwamu dalam hidangan berlemak.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Pasanglah telingamu dan datanglah kepada-Ku","poem":1},{"text":"dengarlah supaya jiwamu akan hidup.","poem":2},{"text":"Aku akan mengadakan perjanjian yang kekal denganmu,","poem":1},{"text":"menurut kebaikan-Ku yang teguh","poem":2},{"lineBreak":true},{"text":"kepada Daud.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Sesungguhnya, Aku telah menjadikan dia saksi bagi bangsa-bangsa,","poem":1},{"text":"seorang pemimpin dan panglima bagi bangsa-bangsa.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"“Sesungguhnya, kamu akan memanggil satu bangsa yang tidak kamu kenal,","poem":1},{"text":"suatu bangsa yang tidak mengenalmu","poem":2},{"lineBreak":true},{"text":"akan berlari kepadamu","poem":2},{"text":"karena TUHAN, Allahmu, Yang Kudus dari Israel.","poem":1},{"text":"Dia telah memuliakan kamu.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Carilah TUHAN","poem":1},{"text":"selagi Dia berkenan untuk ditemui.","poem":2},{"text":"Panggillah Dia","poem":1},{"text":"selagi Dia dekat.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Biarlah orang fasik meninggalkan jalannya","poem":1},{"text":"dan orang jahat pemikiran-pemikirannya.","poem":2},{"text":"Biarlah dia kembali kepada TUHAN,","poem":1},{"text":"dan Dia akan berbelas kasihan kepadanya,","poem":2},{"text":"dan kepada Allah kita","poem":1},{"text":"karena Dia akan mengampuni dengan berlimpah.”","poem":2}]},{"type":"heading","content":["Manusia Tidak Dapat Mengerti Allah"]},{"type":"verse","number":8,"content":[{"text":"“Sebab, pemikiran-Ku bukanlah pemikiranmu,","poem":1},{"text":"dan jalanmu bukanlah jalan-Ku,” firman TUHAN.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Seperti langit lebih tinggi dari bumi,","poem":1},{"text":"demikianlah jalan-Ku lebih tinggi daripada jalanmu,","poem":2},{"lineBreak":true},{"text":"dan pemikiran-Ku daripada pemikiranmu.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"“Sebab, seperti hujan dan salju turun dari langit,","poem":1},{"text":"dan tidak pernah kembali ke sana, tetapi mengairi bumi","poem":2},{"text":"dan membuatnya tumbuh dan bertunas,","poem":1},{"text":"menghasilkan benih bagi penabur dan roti bagi orang yang makan,","poem":2}]},{"type":"verse","number":11,"content":[{"text":"demikianlah juga firman-Ku yang keluar dari mulut-Ku,","poem":1},{"text":"itu tidak akan kembali kepada-Ku dengan sia-sia,","poem":2},{"text":"tetapi akan mengerjakan apa yang Aku maksudkan","poem":1},{"text":"dan akan berhasil dalam apa yang Kuperintahkan kepadanya.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":12,"content":[{"text":"“Sebab, kamu akan keluar dengan sukacita","poem":1},{"text":"dan akan dihantarkan dengan damai.","poem":2},{"text":"Gunung-gunung dan bukit-bukit akan menyambutmu","poem":1},{"text":"dan bersorak-sorai di hadapanmu,","poem":2},{"lineBreak":true},{"text":"dan semua pohon di padang akan bertepuk tangan.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Sebagai ganti semak duri, akan tumbuh pohon sanobar,","poem":1},{"text":"dan sebagai ganti jelatang akan tumbuh pohon murad.","poem":2},{"text":"Itu akan menjadi kemuliaan bagi nama TUHAN,","poem":1},{"text":"suatu tanda abadi yang tidak akan pernah dilenyapkan.”","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/ISA/55.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/ISA/56.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/ISA/54.json","previousChapterAudioLinks":{},"numberOfVerses":13}