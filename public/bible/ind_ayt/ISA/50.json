{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"ISA","translationId":"ind_ayt","name":"YESAYA","commonName":"YESAYA","title":"Yesaya","order":23,"numberOfChapters":66,"sha256":"f891415032abc4205058a3f5640978e2960ef78dd8c37c7f0c7c220e7bbb2d1c","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/ISA/1.json","lastChapterNumber":66,"lastChapterApiLink":"/api/ind_ayt/ISA/66.json","totalNumberOfVerses":1292},"chapter":{"number":50,"content":[{"type":"heading","content":["Israel Dihukum karena Dosa Mereka"]},{"type":"verse","number":1,"content":[{"text":"Beginilah perkataan TUHAN:","poem":1},{"lineBreak":true},{"text":"“Adakah surat cerai ibumu,","poem":1},{"text":"yang Aku gunakan untuk mengusir dia?","poem":2},{"text":"Kepada siapakah di antara orang-orang yang memiutangi Aku,","poem":1},{"text":"Aku telah menjual kamu?","poem":2},{"text":"Sesungguhnya, karena kesalahan-kesalahanmulah kamu dijual,","poem":1},{"text":"karena pelanggaran-pelanggaranmulah ibumu diusir.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Mengapa tidak ada orang ketika Aku datang?","poem":1},{"text":"Ketika Aku memanggil, mengapa tidak ada seorang pun yang menjawab?","poem":2},{"text":"Apakah tangan-Ku terlalu pendek","poem":1},{"text":"sehingga tidak dapat menebus?","poem":2},{"text":"Atau, tidak memiliki kuasa untuk membebaskanmu?","poem":1},{"text":"Lihatlah, dengan hardikan-Ku, Aku mengeringkan laut,","poem":2},{"text":"Aku membuat sungai-sungai menjadi padang belantara.","poem":1},{"text":"Ikan-ikannya membusuk karena kekurangan air dan mati karena kehausan.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Aku memberi pakaian pada langit dengan kegelapan","poem":1},{"text":"dan menjadikan kain berkabung sebagai penutupnya.”","poem":2}]},{"type":"heading","content":["Hamba Allah Bergantung pada Allah"]},{"type":"verse","number":4,"content":[{"text":"Tuhanku, TUHAN, telah memberiku","poem":1},{"text":"lidah seorang murid","poem":2},{"text":"supaya aku dapat","poem":1},{"text":"menopang yang letih dengan perkataan.","poem":2},{"text":"Dia membangunkan aku setiap pagi,","poem":1},{"text":"Dia membangunkan telingaku untuk mendengar seperti seorang murid.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Tuhanku, TUHAN, telah membuka telingaku,","poem":1},{"text":"dan aku tidak memberontak;","poem":2},{"lineBreak":true},{"text":"aku tidak akan berpaling membelakangi.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Aku memberikan punggungku kepada orang yang memukul aku,","poem":1},{"text":"dan pipiku kepada orang yang mencabut jenggotku.","poem":2},{"text":"Aku tidak akan menyembunyikan wajahku","poem":1},{"text":"dari penghinaan dan ludah.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Karena Tuhanku, TUHAN, menolongku,","poem":1},{"text":"aku tidak akan dipermalukan.","poem":2},{"text":"Karena itu, aku telah memasang wajahku seperti batu,","poem":1},{"text":"dan aku tahu bahwa aku tidak akan mendapat malu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"Dia yang membenarkan aku sudah dekat.","poem":1},{"text":"Siapakah yang akan melawan aku?","poem":2},{"lineBreak":true},{"text":"Mari kita berdiri berhadapan.","poem":2},{"text":"Siapakah lawanku beperkara?","poem":1},{"text":"Biarlah dia datang mendekat kepadaku.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Lihatlah, Tuhanku, TUHAN, menolong aku,","poem":1},{"text":"siapakah yang akan menghukum aku?","poem":2},{"text":"Lihatlah, mereka semua akan usang seperti pakaian,","poem":1},{"text":"ngengat akan memakannya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"Siapakah di antaramu yang takut akan TUHAN,","poem":1},{"text":"yang menaati perkataan hamba-Nya,","poem":2},{"text":"yang berjalan dalam kegelapan","poem":1},{"text":"dan tidak memiliki cahaya?","poem":2},{"text":"Biarlah dia percaya kepada nama TUHAN","poem":1},{"text":"dan mengandalkan Allahnya.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Hai kamu semua yang menyalakan api,","poem":1},{"text":"yang memperlengkapi diri dengan panah-panah api,","poem":2},{"text":"berjalanlah dalam cahaya apimu,","poem":1},{"text":"dan dalam cahaya panah-panah api yang telah kamu nyalakan.","poem":2},{"text":"Inilah yang akan kamu terima dari tangan-Ku:","poem":1},{"text":"Kamu akan berbaring dalam siksaan.”","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/ISA/50.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/ISA/51.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/ISA/49.json","previousChapterAudioLinks":{},"numberOfVerses":11}