{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"ISA","translationId":"ind_ayt","name":"YESAYA","commonName":"YESAYA","title":"Yesaya","order":23,"numberOfChapters":66,"sha256":"f891415032abc4205058a3f5640978e2960ef78dd8c37c7f0c7c220e7bbb2d1c","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/ISA/1.json","lastChapterNumber":66,"lastChapterApiLink":"/api/ind_ayt/ISA/66.json","totalNumberOfVerses":1292},"chapter":{"number":12,"content":[{"type":"heading","content":["Nyanyian Pujian bagi Allah"]},{"type":"verse","number":1,"content":[{"text":"Pada waktu itu, kamu akan berkata,","poem":1},{"text":"“Aku hendak bersyukur kepada Engkau, ya TUHAN!","poem":2},{"text":"Sebab, meskipun Engkau telah murka kepadaku,","poem":1},{"text":"murka-Mu telah reda","poem":2},{"lineBreak":true},{"text":"dan Engkau menghibur aku.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Sesungguhnya, Allah adalah keselamatanku.","poem":1},{"text":"Aku akan percaya dan aku tidak takut","poem":2},{"text":"karena TUHAN, TUHAN adalah kekuatanku","poem":1},{"text":"dan puji-pujianku.","poem":2},{"lineBreak":true},{"text":"Ia telah menjadi keselamatanku.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Kamu akan menimba air dari mata air keselamatan","poem":1},{"text":"dengan sukacita.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Pada waktu itu, kamu akan berkata,","poem":1},{"text":"“Bersyukurlah kepada TUHAN, serukanlah nama-Nya!","poem":2},{"text":"Beritahukanlah perbuatan-Nya di antara bangsa-bangsa,","poem":1},{"text":"nyatakanlah bahwa nama-Nya ditinggikan.”","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Bernyanyilah bagi TUHAN","poem":1},{"text":"karena Dia telah melakukan hal-hal yang sangat baik;","poem":2},{"text":"biarlah ini diberitahukan ke seluruh bumi.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Berteriak dan bersorak-sorailah, hai penduduk Sion,","poem":1},{"text":"karena yang agung di tengah-tengahmu adalah Yang Kudus dari Israel.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/ISA/12.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/ISA/13.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/ISA/11.json","previousChapterAudioLinks":{},"numberOfVerses":6}