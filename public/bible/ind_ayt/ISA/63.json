{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"ISA","translationId":"ind_ayt","name":"YESAYA","commonName":"YESAYA","title":"Yesaya","order":23,"numberOfChapters":66,"sha256":"f891415032abc4205058a3f5640978e2960ef78dd8c37c7f0c7c220e7bbb2d1c","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/ISA/1.json","lastChapterNumber":66,"lastChapterApiLink":"/api/ind_ayt/ISA/66.json","totalNumberOfVerses":1292},"chapter":{"number":63,"content":[{"type":"heading","content":["Hukuman TUHAN bagi Bangsa-bangsa"]},{"type":"verse","number":1,"content":[{"text":"Siapakah dia yang datang dari Edom,","poem":1},{"text":"dengan mengenakan pakaian berwarna merah dari Bozra?","poem":2},{"text":"Dia bersemarak dalam pakaiannya,","poem":1},{"text":"melangkah dalam kebesaran kekuatannya?","poem":2},{"text":"Dia berjalan dengan kuasanya yang besar.","poem":1},{"text":"“Akulah yang berbicara dalam kebenaran,","poem":2},{"lineBreak":true},{"text":"berkuasa untuk menyelamatkan.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"“Mengapa pakaian-Mu merah","poem":1},{"text":"dan baju-Mu seperti orang yang mengirik di pemerasan buah anggur?”","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"“Aku telah mengirik di tempat pemerasan anggur seorang diri,","poem":1},{"text":"dan dari bangsa-bangsa tidak ada seorang pun yang bersama dengan Aku.","poem":2},{"text":"Aku akan menginjak mereka dalam amarah-Ku dan menginjak-injak mereka dalam murka-Ku,","poem":1},{"text":"dan darah mereka memercik ke baju-baju-Ku dan mencemari semua pakaian-Ku.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Sebab, hari pembalasan ada di dalam hati-Ku,","poem":1},{"text":"dan tahun penebusan-Ku telah datang.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Aku melayangkan pandangan, tetapi tidak ada seorang pun yang menolong.","poem":1},{"text":"Aku terperanjat karena tidak ada yang mendukung.","poem":2},{"text":"Maka, tangan-Ku sendiri membawa keselamatan bagi-Ku,","poem":1},{"text":"dan murka-Ku mendukung Aku.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Aku menginjak-injak bangsa-bangsa dalam amarah-Ku,","poem":1},{"text":"dan membuat mereka mabuk dalam murka-Ku,","poem":2},{"lineBreak":true},{"text":"serta menumpahkan darah mereka ke bumi.”","poem":2}]},{"type":"heading","content":["Doa Pengakuan dan Permohonan Israel"]},{"type":"verse","number":7,"content":[{"text":"Aku akan mengingat teguhnya kasih TUHAN,","poem":1},{"text":"puji-pujian kepada TUHAN atas semua hal yang dianugerahkan TUHAN kepada kita","poem":2},{"text":"dan kebaikan-Nya yang besar kepada keluarga Israel,","poem":1},{"text":"yang telah Dia berikan menurut belas kasih-Nya,","poem":2},{"lineBreak":true},{"text":"dan keteguhan kasih-Nya yang sangat besar.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Dia berkata, “Sungguh, mereka adalah umat-Ku;","poem":1},{"text":"anak-anak yang tidak akan berdusta.”","poem":2},{"lineBreak":true},{"text":"Maka, Dia menjadi Juru Selamat mereka.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Dalam semua penderitaan mereka,","poem":1},{"text":"Dia juga menderita,","poem":2},{"text":"dan malaikat kehadiran-Nya menyelamatkan mereka.","poem":1},{"text":"Dalam kasih dan belas kasihan-Nya,","poem":2},{"text":"Dia menebus mereka.","poem":1},{"text":"Dia mengangkat mereka dan membawa mereka","poem":2},{"lineBreak":true},{"text":"selama zaman dahulu kala.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Akan tetapi, mereka memberontak","poem":1},{"text":"dan mendukakan Roh Kudus-Nya.","poem":2},{"text":"Karena itu, Dia berbalik menjadi musuh mereka","poem":1},{"text":"dan Dia sendiri berperang melawan mereka.","poem":2}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"Lalu, Dia mengingat zaman dahulu,","poem":1},{"text":"zaman Musa dan umat-Nya.","poem":2},{"text":"Di mana Dia yang membawa mereka keluar dari laut","poem":1},{"text":"beserta gembala kawanan domba-Nya.","poem":2},{"lineBreak":true},{"text":"Di mana Dia yang menaruh Roh Kudus-Nya di tengah-tengah mereka,","poem":2}]},{"type":"verse","number":12,"content":[{"text":"yang menjadikan lengan-Nya yang mulia","poem":1},{"text":"menyertai tangan kanan Musa,","poem":2},{"text":"yang membelah air di depan mereka,","poem":1},{"text":"untuk membuat bagi diri-Nya sendiri","poem":2},{"lineBreak":true},{"text":"sebuah nama yang abadi,","poem":2}]},{"type":"verse","number":13,"content":[{"text":"yang menuntun mereka melewati kedalaman laut.","poem":1},{"text":"Seperti kuda di padang belantara,","poem":2},{"lineBreak":true},{"text":"mereka tidak tersandung.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Seperti ternak yang turun ke lembah,","poem":1},{"text":"Roh TUHAN memberi mereka istirahat.","poem":2},{"text":"Demikianlah Engkau menuntun umat-Mu","poem":1},{"text":"untuk membuat bagi-Mu sendiri suatu nama yang mulia.","poem":2}]},{"type":"heading","content":["Doa kepada Allah untuk Menolong Umat-Nya"]},{"type":"verse","number":15,"content":[{"text":"Pandanglah dari surga","poem":1},{"text":"dan lihatlah dari kediaman-Mu yang kudus dan mulia.","poem":2},{"text":"Di manakah kecemburuan-Mu","poem":1},{"text":"dan keperkasaan-Mu?","poem":2},{"text":"Kepedulian-Mu dan kasih sayang-Mu?","poem":1},{"text":"Janganlah menahan itu dariku.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Sebab, Engkaulah Bapa kami.","poem":1},{"text":"Walaupun Abraham tidak mengenal kami","poem":2},{"lineBreak":true},{"text":"dan Israel tidak mengakui kami,","poem":2},{"text":"Engkau, ya TUHAN, Engkaulah Bapa kami,","poem":1},{"text":"Penebus kami sejak zaman dahulu adalah nama-Mu.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Ya TUHAN, mengapa Engkau membuat kami menyimpang dari jalan-jalan-Mu","poem":1},{"text":"dan mengeraskan hati kami dari rasa takut akan Engkau?","poem":2},{"text":"Kembalilah,","poem":1},{"text":"demi hamba-hamba-Mu,","poem":2},{"text":"suku-suku milik pusaka-Mu.","poem":1}]},{"type":"verse","number":18,"content":[{"lineBreak":true},{"text":"Umat-Mu memiliki tempat kudus-Mu hanya untuk sementara saja,","poem":1},{"text":"tetapi musuh-musuh kami telah menginjak-injak tempat kudus-Mu.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Kami telah menjadi seperti mereka yang tidak pernah berada di bawah pemerintahan-Mu,","poem":1},{"text":"seperti mereka yang tidak disebut dengan nama-Mu.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/ISA/63.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/ISA/64.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/ISA/62.json","previousChapterAudioLinks":{},"numberOfVerses":19}