{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"ISA","translationId":"ind_ayt","name":"YESAYA","commonName":"YESAYA","title":"Yesaya","order":23,"numberOfChapters":66,"sha256":"f891415032abc4205058a3f5640978e2960ef78dd8c37c7f0c7c220e7bbb2d1c","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/ISA/1.json","lastChapterNumber":66,"lastChapterApiLink":"/api/ind_ayt/ISA/66.json","totalNumberOfVerses":1292},"chapter":{"number":1,"content":[{"type":"verse","number":1,"content":["Penglihatan Yesaya, anak Amos, yang dia lihat tentang Yehuda dan Yerusalem pada masa Uzia, Yotam, Ahas, dan Hizkia, raja-raja Yehuda."]},{"type":"heading","content":["Keluhan tentang Bangsa-Bangsa yang Tidak Setia"]},{"type":"verse","number":2,"content":["Dengarlah, hai langit, dan berilah telinga, hai bumi, karena TUHAN berfirman:",{"lineBreak":true},{"text":"“Aku merawat dan membesarkan anak-anak,","poem":1},{"text":"tetapi mereka telah memberontak terhadap Aku.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Sapi mengenal pemiliknya,","poem":1},{"text":"dan keledai tahu palungan pemiliknya,","poem":2},{"text":"tetapi Israel tidak tahu,","poem":1},{"text":"umat-Ku tidak mengerti.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"Oh, bangsa yang berdosa,","poem":1},{"text":"umat yang sarat dengan kejahatan,","poem":2},{"lineBreak":true},{"text":"benih para pelaku kejahatan,","poem":2},{"lineBreak":true},{"text":"anak-anak yang jahat!","poem":2},{"text":"Mereka telah membenci TUHAN,","poem":1},{"text":"mereka telah menolak Yang Mahakudus, Allah Israel,","poem":2},{"lineBreak":true},{"text":"mereka telah berbalik membelakangi-Nya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"Mengapa kamu harus dipukul lagi?","poem":1},{"text":"Mengapa kamu terus-menerus memberontak?","poem":2},{"text":"Seluruh kepala sakit","poem":1},{"text":"dan seluruh hati terasa lemah.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Dari telapak kaki hingga kepalamu","poem":1},{"text":"tidak ada yang sehat,","poem":2},{"lineBreak":true},{"text":"yang ada hanya memar, bilur, dan luka yang masih terbuka,","poem":2},{"text":"tidak ditutup atau dibalut,","poem":1},{"text":"ataupun diobati dengan minyak.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Negerimu menjadi sunyi sepi,","poem":1},{"text":"kota-kotamu dibakar dengan api.","poem":2},{"text":"Di depan matamu, orang-orang asing melahap tanahmu;","poem":1},{"text":"dan tanahmu menjadi sunyi sepi,","poem":2},{"lineBreak":true},{"text":"karena digulingkan oleh orang-orang asing.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Putri Sion ditinggalkan","poem":1},{"text":"seperti pondok di kebun anggur,","poem":2},{"text":"seperti gubuk di ladang mentimun","poem":1},{"text":"dan seperti kota yang terkepung.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Seandainya TUHAN semesta alam tidak menyisakan sedikit orang yang selamat bagi kita,","poem":1},{"text":"kita pasti telah menjadi seperti Sodom dan kita telah menjadi seperti Gomora.","poem":2}]},{"type":"heading","content":["Panggilan Pertobatan"]},{"type":"verse","number":10,"content":[{"text":"Dengarlah firman TUHAN,","poem":1},{"text":"hai para penguasa Sodom;","poem":2},{"text":"berilah telinga pada perintah Allah,","poem":1},{"text":"hai penduduk Gomora!","poem":2}]},{"type":"verse","number":11,"content":[{"text":"“Untuk apa kurbanmu yang banyak itu bagi-Ku?”","poem":1},{"text":"firman TUHAN,","poem":2},{"text":"“Aku sudah kenyang dengan kurban-kurban bakaran domba jantanmu,","poem":1},{"text":"dan dengan lemak anak sapimu yang tambun.","poem":2},{"text":"Aku tidak menyukai darah sapi jantan,","poem":1},{"text":"atau domba atau kambing jantan.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Ketika kamu datang menghadap hadirat-Ku,","poem":1},{"text":"siapa yang memintamu menginjak-injak pelataran-Ku ini?","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Jangan lagi membawa kurban yang tidak berguna,","poem":1},{"text":"dupa adalah kekejian bagi-Ku.","poem":2},{"text":"Perayaan Bulan Baru dan hari Sabat, serta pertemuan-pertemuan kudus lainnya.","poem":1},{"text":"Aku tidak tahan melihatnya; itu adalah kejahatan.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Aku membenci perayaan-perayaan Bulan Baru","poem":1},{"text":"dan hari-hari rayamu.","poem":2},{"text":"Semuanya itu menjadi beban bagi-Ku,","poem":1},{"text":"Aku lelah memikulnya.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Ketika kamu menengadahkan tanganmu untuk berdoa,","poem":1},{"text":"Aku akan menyembunyikan mata-Ku darimu.","poem":2},{"text":"Meskipun kamu banyak berdoa,","poem":1},{"text":"Aku tidak akan mendengarkannya","poem":2},{"lineBreak":true},{"text":"karena tanganmu penuh dengan darah.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Basuhlah dirimu dan jadikan dirimu bersih.","poem":1},{"text":"Singkirkan perbuatan-perbuatan jahatmu dari pandangan mata-Ku.","poem":2},{"lineBreak":true},{"text":"Berhentilah melakukan yang jahat.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Belajarlah melakukan yang baik,","poem":1},{"text":"carilah keadilan,","poem":2},{"text":"tegurlah orang yang kejam,","poem":1},{"text":"belalah hak-hak anak yatim,","poem":2},{"lineBreak":true},{"text":"dan perjuangkanlah para janda.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":18,"content":[{"text":"“Datanglah sekarang, dan marilah kita beperkara bersama!”","poem":1},{"text":"firman TUHAN,","poem":2},{"text":"“Sekalipun dosa-dosamu seperti kirmizi,","poem":1},{"text":"itu akan menjadi seputih salju;","poem":2},{"text":"sekalipun dosa-dosamu merah seperti kesumba,","poem":1},{"text":"itu akan menjadi seperti bulu domba.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Jika kamu bersedia dan taat,","poem":1},{"text":"kamu akan memakan yang baik dari tanah ini.","poem":2}]},{"type":"verse","number":20,"content":[{"text":"Akan tetapi, jika kamu menolak dan membangkang,","poem":1},{"text":"kamu akan dilahap oleh pedang.”","poem":2},{"text":"Sungguh, mulut TUHANlah yang telah mengatakannya.","poem":1}]},{"type":"heading","content":["Hukuman atas Yerusalem"]},{"type":"verse","number":21,"content":[{"text":"Betapa kota yang setia telah menjadi pelacur!","poem":1},{"text":"Kota itu dahulu penuh dengan keadilan.","poem":2},{"lineBreak":true},{"text":"Kebenaran berdiam di dalamnya,","poem":2},{"lineBreak":true},{"text":"tetapi sekarang menjadi sarang para pembunuh.","poem":2}]},{"type":"verse","number":22,"content":[{"text":"Perakmu telah menjadi sampah,","poem":1},{"text":"air anggurmu telah bercampur dengan air.","poem":2}]},{"type":"verse","number":23,"content":[{"text":"Penguasa-penguasamu adalah para pemberontak","poem":1},{"text":"dan sahabat para pencuri.","poem":2},{"text":"Mereka semua menyukai suap","poem":1},{"text":"dan mengejar penghargaan.","poem":2},{"text":"Mereka tidak membela anak yatim,","poem":1},{"text":"pembelaan para janda tidak sampai kepada mereka.","poem":2}]},{"type":"verse","number":24,"content":[{"text":"Sebab itu, TUHAN, Allah semesta alam,","poem":1},{"text":"Yang Mahakuat dari Israel, berfirman,","poem":2},{"text":"“Ah, Aku akan meremehkan lawan-lawan-Ku","poem":1},{"text":"dan Aku akan membalas dendam pada musuh-musuh-Ku.","poem":2}]},{"type":"verse","number":25,"content":[{"text":"Aku akan membalikkan tangan-Ku terhadap kamu,","poem":1},{"text":"dan akan membersihkan perakmu dengan garam","poem":2},{"lineBreak":true},{"text":"serta membuang semua timahmu.","poem":2}]},{"type":"verse","number":26,"content":[{"text":"Kemudian, Aku akan memulihkan hakim-hakimmu seperti yang dahulu,","poem":1},{"text":"dan para penasihatmu seperti semula.","poem":2},{"text":"Sesudah itu, kamu akan disebut kota kebenaran, kota yang setia.”","poem":1}]},{"type":"line_break"},{"type":"verse","number":27,"content":[{"text":"Sion akan ditebus dengan keadilan,","poem":1},{"text":"dan yang bertobat ditebus dengan kebenaran.","poem":2}]},{"type":"verse","number":28,"content":[{"text":"Akan tetapi, para pemberontak dan orang-orang berdosa akan dihancurkan bersama-sama.","poem":1},{"text":"Semua orang yang mengabaikan TUHAN akan dilenyapkan.","poem":2}]},{"type":"line_break"},{"type":"verse","number":29,"content":[{"text":"Sungguh, mereka akan mendapat malu karena pohon tarbantin yang pernah kamu ingini,","poem":1},{"text":"dan akan mendapat malu karena kebun-kebun yang telah kamu pilih.","poem":2}]},{"type":"verse","number":30,"content":[{"text":"Sesungguhnya, kamu akan menjadi seperti sebuah pohon tarbantin yang daunnya layu","poem":1},{"text":"dan seperti kebun yang tidak berair.","poem":2}]},{"type":"verse","number":31,"content":[{"text":"Orang yang kuat akan menjadi seperti serbuk kayu,","poem":1},{"text":"dan perbuatannya seperti percikan api.","poem":2},{"text":"Keduanya akan terbakar bersama-sama,","poem":1},{"text":"dan tidak ada yang dapat memadamkannya.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/ISA/1.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/ISA/2.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/SNG/8.json","previousChapterAudioLinks":{},"numberOfVerses":31}