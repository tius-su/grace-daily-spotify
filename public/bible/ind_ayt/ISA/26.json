{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"ISA","translationId":"ind_ayt","name":"YESAYA","commonName":"YESAYA","title":"Yesaya","order":23,"numberOfChapters":66,"sha256":"f891415032abc4205058a3f5640978e2960ef78dd8c37c7f0c7c220e7bbb2d1c","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/ISA/1.json","lastChapterNumber":66,"lastChapterApiLink":"/api/ind_ayt/ISA/66.json","totalNumberOfVerses":1292},"chapter":{"number":26,"content":[{"type":"heading","content":["Nyanyian Pujian"]},{"type":"verse","number":1,"content":["Pada waktu itu, akan dinyanyikan nyanyian ini di tanah Yehuda:",{"lineBreak":true},{"text":"Kita mempunyai kota yang kuat.","poem":1},{"text":"Dia mendirikan tembok dan benteng untuk keselamatan.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Bukalah pintu-pintu gerbang","poem":1},{"text":"supaya masuk bangsa yang benar, yang memegang teguh kesetiaan.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Yang hatinya teguh Engkau jagai dengan kedamaian yang sempurna,","poem":1},{"text":"karena dia percaya kepada-Mu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"Percayalah kepada TUHAN untuk selama-lamanya,","poem":1},{"text":"karena di dalam TUHAN Allah ada batu karang yang kekal.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Sebab, Dia telah merendahkan mereka yang tinggal di tempat tinggi,","poem":1},{"text":"kota yang menjulang.","poem":2},{"text":"Dia merendahkannya sampai ke tanah,","poem":1},{"text":"dan melemparkannya ke dalam debu.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Kaki akan menginjak-injaknya,","poem":1},{"text":"kaki orang-orang miskin, telapak kaki orang lemah.","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Jalan orang benar itu lurus.","poem":1},{"text":"Yang Mahatulus,","poem":2},{"lineBreak":true},{"text":"ratakanlah jalan orang benar.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Di jalan keadilan-Mu, ya TUHAN, kami telah menantikan Engkau.","poem":1},{"text":"Nama-Mu dan kemasyhuran-Mu adalah kesukaan hati kami.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Jiwaku merindukan Engkau pada waktu malam,","poem":1},{"text":"roh di dalam diriku hendak sungguh-sungguh mencari Engkau.","poem":2},{"text":"Sebab, ketika penghakiman-Mu ada di bumi,","poem":1},{"text":"penduduk bumi belajar kebenaran.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Sekalipun orang fasik dikasihani,","poem":1},{"text":"dia tidak akan belajar kebenaran.","poem":2},{"text":"Di negeri orang jujur pun,","poem":1},{"text":"dia berlaku curang","poem":2},{"lineBreak":true},{"text":"dan tidak melihat keagungan TUHAN.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Ya TUHAN, tangan-Mu terangkat,","poem":1},{"text":"tetapi mereka tidak melihatnya.","poem":2},{"text":"Biarlah mereka melihat kecemburuan-Mu kepada umat-Mu","poem":1},{"text":"dan menjadi malu.","poem":2},{"lineBreak":true},{"text":"Sungguh, api akan melalap musuh-musuh-Mu.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"TUHAN, Engkau akan menetapkan damai sejahtera bagi kami,","poem":1},{"text":"karena Engkau jugalah yang mengerjakan bagi kami,","poem":2},{"lineBreak":true},{"text":"semua pekerjaan kami.","poem":2}]},{"type":"heading","content":["Allah Memberikan Hidup Baru"]},{"type":"verse","number":13,"content":[{"text":"Ya TUHAN, Allah kami,","poem":1},{"text":"tuan-tuan lain selain Engkau pernah memerintah kami.","poem":2},{"text":"Akan tetapi,","poem":1},{"text":"hanya nama-Mu saja yang kami sebut.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Mereka telah mati, tidak akan hidup lagi.","poem":1},{"text":"Mereka telah menjadi arwah, tidak akan bangkit lagi.","poem":2},{"text":"Demikianlah Engkau telah menghukum dan memusnahkan mereka,","poem":1},{"text":"serta menghapus segala ingatan tentang mereka.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Engkau telah meningkatkan jumlah bangsa ini, ya TUHAN.","poem":1},{"text":"Engkau menambah jumlah bangsa ini, Engkau dimuliakan, Engkau telah meluaskan batas-batas negeri itu.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Ya TUHAN,","poem":1},{"text":"mereka mencari Engkau dalam kesulitan.","poem":2},{"text":"Mereka menumpahkan doa","poem":1},{"text":"ketika hajaran-Mu ada pada mereka.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Seperti perempuan mengandung yang menggeliat kesakitan,","poem":1},{"text":"berteriak-teriak karena mendekati waktu melahirkan,","poem":2},{"lineBreak":true},{"text":"demikianlah kami dahulu di hadapan-Mu, ya TUHAN.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Kami mengandung, kami menggeliat kesakitan,","poem":1},{"text":"tetapi kami seolah-olah melahirkan angin.","poem":2},{"text":"Kami tidak dapat menghasilkan pembebasan bagi bumi,","poem":1},{"text":"tidak juga melahirkan penduduk bagi dunia.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Orang-orang mati-Mu","poem":1},{"text":"akan hidup lagi;","poem":2},{"text":"mayat mereka","poem":1},{"text":"akan bangkit.","poem":2},{"text":"Hai orang-orang yang terbaring di dalam debu,","poem":1},{"text":"bangunlah dan bersukacitalah!","poem":2},{"text":"Sebab, embun-Mu","poem":1},{"text":"seperti embun pagi hari;","poem":2},{"text":"dan bumi akan melahirkan","poem":1},{"text":"roh-roh orang mati.","poem":2}]},{"type":"verse","number":20,"content":[{"text":"Datanglah bangsaku,","poem":1},{"text":"masuklah ke dalam kamar-kamarmu.","poem":2},{"text":"Tutuplah pintu-pintu di belakangmu,","poem":1},{"text":"bersembunyilah sesaat, sampai murka berlalu.","poem":2}]},{"type":"verse","number":21,"content":[{"text":"Sebab lihatlah! TUHAN hendak keluar dari tempat-Nya,","poem":1},{"text":"untuk menghukum penduduk bumi karena kesalahan mereka.","poem":2},{"text":"Bumi akan memperlihatkan tumpahan darahnya,","poem":1},{"text":"dan tidak akan lagi menutupi orang-orangnya yang dibunuh.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/ISA/26.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/ISA/27.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/ISA/25.json","previousChapterAudioLinks":{},"numberOfVerses":21}