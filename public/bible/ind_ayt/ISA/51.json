{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"ISA","translationId":"ind_ayt","name":"YESAYA","commonName":"YESAYA","title":"Yesaya","order":23,"numberOfChapters":66,"sha256":"f891415032abc4205058a3f5640978e2960ef78dd8c37c7f0c7c220e7bbb2d1c","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/ISA/1.json","lastChapterNumber":66,"lastChapterApiLink":"/api/ind_ayt/ISA/66.json","totalNumberOfVerses":1292},"chapter":{"number":51,"content":[{"type":"heading","content":["Israel Harus seperti Abraham"]},{"type":"verse","number":1,"content":[{"text":"“Dengarkan aku, hai kamu yang mengejar kebenaran,","poem":1},{"text":"kamu yang mencari TUHAN.","poem":2},{"text":"Lihatlah ke gunung batu tempat kamu dipahat,","poem":1},{"text":"dan pada tambang tempat kamu digali.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Lihatlah Abraham, nenek moyangmu,","poem":1},{"lineBreak":true},{"text":"dan Sara yang telah melahirkanmu.","poem":1},{"text":"Sebab, dia masih seorang diri ketika Aku memanggilnya.","poem":2},{"lineBreak":true},{"text":"Aku memberkatinya dan membuatnya bertambah banyak.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Sungguh, TUHAN akan menghibur Sion.","poem":1},{"text":"Dia akan menghibur seluruh tempatnya yang terbengkalai;","poem":2},{"lineBreak":true},{"text":"membuat padang belantaranya seperti Taman Eden","poem":2},{"text":"dan padang gurunnya seperti taman TUHAN.","poem":1},{"text":"Sukacita dan kegembiraan akan ditemukan di sana,","poem":2},{"text":"ucapan syukur dan nyanyian pujian.","poem":1}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"“Perhatikanlah Aku, hai umat-Ku, berilah telinga kepada-Ku, hai bangsa-Ku.","poem":1},{"text":"Sebab, Taurat akan keluar dari-Ku dan Aku akan menetapkan keadilan-Ku sebagai terang bagi bangsa-bangsa.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Kebenaran-Ku sudah dekat, keselamatan-Ku sudah datang,","poem":1},{"text":"dan tangan-Ku akan menghakimi bangsa-bangsa.","poem":2},{"text":"Pulau-pulau menantikan Aku","poem":1},{"text":"dan untuk tangan-Ku mereka menunggu-nunggu.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Angkatlah matamu ke langit","poem":1},{"text":"dan lihatlah bumi di bawahnya!","poem":2},{"text":"Langit akan lenyap seperti asap,","poem":1},{"text":"bumi akan usang seperti pakaian,","poem":2},{"text":"dan penduduknya akan mati seperti nyamuk.","poem":1},{"text":"Akan tetapi, keselamatan-Ku akan tetap selama-lamanya","poem":2},{"lineBreak":true},{"text":"dan kebenaran-Ku tidak akan berakhir.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Dengarkanlah Aku, hai kamu yang mengetahui kebenaran,","poem":1},{"text":"bangsa yang menyimpan Taurat-Ku di dalam hatinya.","poem":2},{"text":"Jangan takut terhadap hinaan manusia,","poem":1},{"text":"ataupun kecewa terhadap hujatan mereka.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Sebab, ngengat akan memakan mereka seperti pakaian","poem":1},{"text":"dan gegat akan memakan mereka seperti bulu domba.","poem":2},{"text":"Akan tetapi, kebenaran-Ku akan tetap selama-lamanya","poem":1},{"text":"dan keselamatan-Ku dari generasi ke generasi.”","poem":2}]},{"type":"heading","content":["Kuasa Allah Sendiri Akan Menyelamatkan Umat-Nya"]},{"type":"verse","number":9,"content":[{"text":"Bangkitlah! Bangkitlah!","poem":1},{"text":"Kenakan kekuatanmu, hai tangan TUHAN.","poem":2},{"text":"Bangkitlah seperti pada zaman dahulu,","poem":1},{"text":"seperti pada generasi-generasi dahulu kala.","poem":2},{"text":"Bukankah Engkau yang meremukkan Rahab,","poem":1},{"text":"yang menikam naga itu?","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Bukankah Engkau yang mengeringkan laut,","poem":1},{"text":"perairan dalam yang besar; yang membuat lautan yang dalam menjadi jalan","poem":2},{"lineBreak":true},{"text":"bagi umat yang ditebus untuk menyeberanginya?","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Umat yang ditebus TUHAN akan kembali","poem":1},{"text":"dan masuk ke Sion dengan sorak-sorai.","poem":2},{"text":"Sukacita yang abadi akan ada di atas kepala mereka.","poem":1},{"text":"Mereka akan mendapatkan kegembiraan dan sukacita,","poem":2},{"text":"tetapi kesedihan dan keluhan akan menjauh.","poem":1}]},{"type":"line_break"},{"type":"verse","number":12,"content":[{"text":"“Aku, Akulah yang menghibur kamu.","poem":1},{"text":"Siapakah kamu sehingga kamu takut kepada manusia yang akan mati;","poem":2},{"lineBreak":true},{"text":"kepada anak manusia yang dijadikan hanya seperti rumput","poem":2}]},{"type":"line_break"},{"type":"verse","number":13,"content":[{"text":"sehingga kamu telah melupakan TUHAN, Penciptamu,","poem":1},{"lineBreak":true},{"text":"yang membentangkan langit","poem":1},{"text":"dan meletakkan dasar bumi,","poem":2},{"text":"sehingga kamu terus-menerus ketakutan sepanjang hari","poem":1},{"text":"karena kemarahan penindasmu,","poem":2},{"text":"seolah-olah dia siap menghancurkan?","poem":1},{"text":"Di manakah kemarahan si penindas itu?","poem":2}]},{"type":"line_break"},{"type":"verse","number":14,"content":[{"text":"Tawanan yang meringkuk akan segera dibebaskan.","poem":1},{"text":"Dia tidak akan mati di lubang,","poem":2},{"lineBreak":true},{"text":"ataupun akan kekurangan roti.","poem":2}]},{"type":"line_break"},{"type":"verse","number":15,"content":[{"text":"Sebab, Akulah TUHAN, Allahmu,","poem":1},{"text":"yang mengguncang air laut dan membuat ombak bergemuruh.”","poem":2},{"lineBreak":true},{"text":"TUHAN semesta alam nama-Nya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":16,"content":[{"text":"“Aku telah menaruh firman-Ku di dalam mulutmu","poem":1},{"text":"dan menaungimu dalam bayangan tangan-Ku","poem":2},{"text":"untuk menegakkan langit dan meletakkan dasar bumi;","poem":1},{"text":"dan berkata kepada Sion, “Kamu adalah umat-Ku.”","poem":2}]},{"type":"heading","content":["Allah Menghukum Israel"]},{"type":"verse","number":17,"content":[{"text":"Bangunlah! Bangunlah!","poem":1},{"text":"Berdirilah, hai Yerusalem!","poem":2},{"text":"Kamu telah meminum dari tangan TUHAN","poem":1},{"text":"cawan murka-Nya.","poem":2},{"text":"Kamu telah meminum sampai habis","poem":1},{"text":"isi cawan yang memabukkan itu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":18,"content":[{"text":"Tidak ada seorang pun yang membimbingnya,","poem":1},{"text":"dari antara semua anak yang dilahirkannya.","poem":2},{"text":"Tidak ada yang menggandeng tangannya","poem":1},{"text":"dari antara semua anak yang dibesarkannya.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Kedua hal ini telah menimpamu,","poem":1},{"text":"siapa yang akan berkabung untukmu?","poem":2},{"text":"Kemusnahan dan kehancuran, kelaparan dan pedang,","poem":1},{"text":"siapakah yang akan menghiburmu?","poem":2}]},{"type":"verse","number":20,"content":[{"text":"Anak-anakmu telah pingsan.","poem":1},{"text":"Mereka tergeletak di setiap ujung jalan","poem":2},{"lineBreak":true},{"text":"seperti kijang dalam jerat.","poem":2},{"text":"Mereka penuh dengan murka TUHAN,","poem":1},{"text":"dengan teguran Allahmu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":21,"content":[{"text":"Karena itu, sekarang dengarkanlah ini,","poem":1},{"text":"hai, kamu yang menderita,","poem":2},{"lineBreak":true},{"text":"yang mabuk, tetapi bukan oleh anggur:","poem":2}]},{"type":"verse","number":22,"content":[{"text":"Beginilah perkataan Tuhanmu,","poem":1},{"text":"TUHAN, Allahmu, yang memperjuangkan perkara umat-Nya,","poem":2},{"text":"“Lihatlah, Aku telah mengambil dari tanganmu cawan yang memabukkan itu,","poem":1},{"text":"cawan murka-Ku;","poem":2},{"lineBreak":true},{"text":"kamu tidak akan meminumnya lagi.","poem":2}]},{"type":"verse","number":23,"content":[{"text":"Aku akan meletakkannya","poem":1},{"text":"di tangan mereka yang menyiksamu,","poem":2},{"text":"yang telah berkata kepadamu, ‘Sujudlah","poem":1},{"text":"supaya kami bisa berjalan di atasmu.’","poem":2},{"text":"Kamu telah menjadikan punggungmu seperti tanah,","poem":1},{"text":"dan seperti jalan bagi mereka untuk berjalan di atasnya.”","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/ISA/51.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/ISA/52.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/ISA/50.json","previousChapterAudioLinks":{},"numberOfVerses":23}