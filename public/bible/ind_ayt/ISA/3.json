{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"ISA","translationId":"ind_ayt","name":"YESAYA","commonName":"YESAYA","title":"Yesaya","order":23,"numberOfChapters":66,"sha256":"f891415032abc4205058a3f5640978e2960ef78dd8c37c7f0c7c220e7bbb2d1c","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/ISA/1.json","lastChapterNumber":66,"lastChapterApiLink":"/api/ind_ayt/ISA/66.json","totalNumberOfVerses":1292},"chapter":{"number":3,"content":[{"type":"heading","content":["Hukuman TUHAN terhadap Penyesat"]},{"type":"verse","number":1,"content":["Lihatlah,",{"lineBreak":true},{"text":"TUHAN, Allah semesta alam,","poem":1},{"text":"akan mengambil dari Yerusalem dan Yehuda, semua persediaan dan dukungan,","poem":2},{"lineBreak":true},{"text":"semua persediaan roti dan semua persediaan air,","poem":2}]},{"type":"verse","number":2,"content":[{"text":"semua kesatria dan prajurit,","poem":1},{"text":"hakim dan nabi, peramal dan penatua,","poem":2}]},{"type":"verse","number":3,"content":[{"text":"kepala pasukan lima puluh dan orang-orang terhormat,","poem":1},{"text":"para penasihat dan tukang sihir,","poem":2},{"lineBreak":true},{"text":"serta para ahli mantra.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"“Aku akan membuat orang-orang muda menjadi pemimpin mereka,","poem":1},{"text":"dan anak-anak akan memerintah atas mereka.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Orang-orang itu akan menindas","poem":1},{"text":"satu sama lain dan oleh saudara mereka;","poem":2},{"lineBreak":true},{"text":"yang muda akan kurang ajar terhadap yang tua, dan yang hina terhadap yang mulia.”","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Ketika seorang laki-laki memegang saudaranya","poem":1},{"text":"dari keluarganya sendiri dan berkata kepadanya,","poem":2},{"text":"“Kamu masih punya sehelai baju, kamu harus menjadi pemimpin kami,","poem":1},{"text":"semua reruntuhan ini berada di bawah kekuasaanmu.”","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Namun, pada waktu itu, dia akan menolak dan berkata,","poem":1},{"text":"“Aku tidak dapat menjadi penyembuhmu,","poem":2},{"text":"di rumahku tidak ada roti ataupun pakaian.","poem":1},{"text":"Jangan buat aku menjadi pemimpin bangsa ini.”","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Sebab, Yerusalem telah tersandung,","poem":1},{"text":"dan Yehuda telah jatuh","poem":2},{"text":"karena kata-kata dan perbuatan mereka melawan TUHAN,","poem":1},{"text":"menentang hadirat-Nya yang mulia.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Raut wajah mereka memberikan bukti yang menentang mereka,","poem":1},{"lineBreak":true},{"text":"dan mereka memperlihatkan dosa mereka seperti Sodom;","poem":1},{"text":"bahkan mereka tidak menutup-nutupinya.","poem":2},{"lineBreak":true},{"text":"Celakalah mereka!","poem":2},{"text":"Sebab, mereka telah membawa malapetaka","poem":1},{"text":"ke atas diri mereka sendiri.","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"Katakan kepada orang-orang benar bahwa semua akan baik-baik saja bagi mereka.","poem":1},{"text":"Sebab, mereka akan makan buah dari perbuatan-perbuatan mereka.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Celakalah orang fasik!","poem":1},{"text":"Kesusahan besar akan menimpa mereka","poem":2},{"lineBreak":true},{"text":"karena perbuatan tangan mereka akan ditimpakan kepada mereka.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Oh, bangsaku! Anak-anaklah yang menjadi penindas mereka,","poem":1},{"text":"dan perempuan-perempuanlah yang memerintah atas mereka.","poem":2},{"text":"Oh, bangsaku, para pemimpinmu menyesatkan engkau,","poem":1},{"text":"dan mereka telah mengacaukan jalan yang seharusnya kamu lalui.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"TUHAN bangkit untuk melawan;","poem":1},{"text":"berdiri untuk mengadili bangsa itu.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"TUHAN memasuki pengadilan dan beperkara","poem":1},{"text":"dengan para penatua dan pemimpin umat-Nya.","poem":2},{"text":"“Kalianlah yang telah membakar kebun anggur;","poem":1},{"text":"hasil jarahan dari orang miskin ada di rumah-rumahmu.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Apa maksudmu menghancurkan umat-Ku","poem":1},{"text":"dan menindas orang miskin?”","poem":2},{"lineBreak":true},{"text":"firman TUHAN, Allah semesta alam.","poem":2}]},{"type":"heading","content":["Hukuman TUHAN terhadap Perempuan-Perempuan Sion"]},{"type":"verse","number":16,"content":[{"text":"TUHAN berfirman, “Karena putri-putri Sion menjadi sombong;","poem":1},{"text":"mereka berjalan dengan kepala terangkat","poem":2},{"lineBreak":true},{"text":"dan dengan mata yang menggoda.","poem":2},{"text":"Mereka berjalan dengan langkah yang dibuat-buat,","poem":1},{"text":"sambil membunyikan kerincing di gelang kakinya.”","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Karena itu, TUHAN akan menimpakan kudis pada kepala putri-putri Sion.","poem":1},{"text":"TUHAN akan menyingkapkan rahasia mereka.","poem":2}]},{"type":"line_break"},{"type":"verse","number":18,"content":["Pada hari itu, TUHAN akan menyingkirkan keindahan perhiasan mereka, yaitu gelang kaki, ikat kepala, kalung berbentuk bulan sabit;"]},{"type":"verse","number":19,"content":["anting-anting, gelang tangan, dan kerudung;"]},{"type":"verse","number":20,"content":["perhiasan kepala, gelang kaki, ikat pinggang, botol minyak wangi, dan jimat;"]},{"type":"verse","number":21,"content":["cincin dan anting-anting hidung,"]},{"type":"verse","number":22,"content":["pakaian pesta, baju hangat, selendang, dan tas tangan;"]},{"type":"verse","number":23,"content":["cermin, pakaian linen, ikat kepala, dan kerudung panjang."]},{"type":"line_break"},{"type":"verse","number":24,"content":[{"text":"Maka, akan ada bau busuk,","poem":1},{"text":"sebagai ganti wewangian yang harum.","poem":2},{"text":"Seutas tali,","poem":1},{"text":"sebagai ganti ikat pinggang.","poem":2},{"text":"Kepala botak,","poem":1},{"text":"sebagai ganti rambut yang tertata.","poem":2},{"text":"Kain kabung,","poem":1},{"text":"sebagai ganti jubah yang mahal.","poem":2},{"text":"Luka bakar,","poem":1},{"text":"sebagai ganti kecantikan.","poem":2}]},{"type":"verse","number":25,"content":[{"text":"Kaum lelaki akan tewas oleh pedang;","poem":1},{"text":"pahlawan-pahlawanmu mati dalam peperangan.","poem":2}]},{"type":"verse","number":26,"content":[{"text":"Pintu-pintu gerbang Sion akan meratap dan berkabung,","poem":1},{"text":"dan Sion akan duduk di tanah dalam kehampaan.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/ISA/3.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/ISA/4.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/ISA/2.json","previousChapterAudioLinks":{},"numberOfVerses":26}