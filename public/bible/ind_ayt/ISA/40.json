{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"ISA","translationId":"ind_ayt","name":"YESAYA","commonName":"YESAYA","title":"Yesaya","order":23,"numberOfChapters":66,"sha256":"f891415032abc4205058a3f5640978e2960ef78dd8c37c7f0c7c220e7bbb2d1c","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/ISA/1.json","lastChapterNumber":66,"lastChapterApiLink":"/api/ind_ayt/ISA/66.json","totalNumberOfVerses":1292},"chapter":{"number":40,"content":[{"type":"heading","content":["Hukuman Israel akan Berakhir"]},{"type":"verse","number":1,"content":[{"text":"“Hiburlah, hiburlah umat-Ku,”","poem":1},{"text":"demikianlah firman Allahmu.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Berbicaralah dengan hati lembut kepada Yerusalem, dan serukanlah kepadanya","poem":1},{"text":"bahwa peperangannya telah berakhir,","poem":2},{"lineBreak":true},{"text":"bahwa kesalahannya telah dihapus,","poem":2},{"text":"bahwa dia telah menerima dari tangan TUHAN dua kali lipat","poem":1},{"text":"atas semua dosanya.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Ada suara berseru-seru:","poem":1},{"lineBreak":true},{"text":"“Persiapkan jalan di padang belantara bagi TUHAN!","poem":1},{"text":"Ratakan jalan di padang gurun bagi Allah kita!","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Setiap lembah akan ditinggikan,","poem":1},{"text":"setiap gunung dan bukit akan direndahkan.","poem":2},{"text":"Tanah yang bergelombang akan diratakan;","poem":1},{"text":"yang berlekuk-lekuk dijadikan datar.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Kemuliaan TUHAN akan dinyatakan","poem":1},{"text":"dan semua orang akan melihatnya bersama-sama.","poem":2},{"text":"Sebab, mulut TUHAN telah mengatakannya!”","poem":1}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"Sebuah suara berkata, “Berserulah!”","poem":1},{"text":"Maka, dia bertanya, “Apa yang harus kuserukan?”","poem":2},{"text":"“Semua manusia seperti rumput","poem":1},{"text":"dan semua keindahannya seperti bunga di padang.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Rumput layu, bunga gugur","poem":1},{"text":"ketika napas TUHAN menerpanya.","poem":2},{"lineBreak":true},{"text":"Sedangkan semua manusia seperti rumput.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Rumput layu dan bunga gugur,","poem":1},{"text":"tetapi firman Allah kita tegak selama-lamanya.”","poem":2}]},{"type":"heading","content":["Keselamatan: Kabar Baik"]},{"type":"verse","number":9,"content":[{"text":"Naiklah ke atas gunung yang tinggi, hai Sion yang membawa kabar baik,","poem":1},{"text":"angkatlah suaramu dengan kekuatan.","poem":2},{"text":"Hai Yerusalem, pembawa kabar baik,","poem":1},{"text":"naikkan suaramu, jangan takut!","poem":2},{"text":"Katakanlah kepada kota-kota Yehuda,","poem":1},{"text":"“Lihat, itu Allahmu!”","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Lihatlah, TUHAN Allah akan datang dengan penuh kuasa,","poem":1},{"text":"Dia akan berkuasa dengan tangan-Nya.","poem":2},{"text":"Dia membawa upah-Nya,","poem":1},{"text":"dan ganjaran-Nya ada di hadapan-Nya.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Seperti seorang gembala, Dia akan menggembalakan kawanan-Nya.","poem":1},{"text":"Dia akan mengumpulkan anak-anak domba dengan lengan-Nya","poem":2},{"text":"dan membawa mereka di dada-Nya.","poem":1},{"text":"Dia akan memelihara dan membimbing mereka.","poem":2}]},{"type":"heading","content":["Allah Menciptakan dan Memerintah Dunia"]},{"type":"verse","number":12,"content":[{"text":"Siapakah yang telah menakar air dalam telapak tangan-Nya,","poem":1},{"text":"dan mengukur langit dengan jengkal,","poem":2},{"text":"yang menghitung debu tanah dengan ukuran,","poem":1},{"text":"dan menimbang gunung-gunung dengan timbangan dan bukit-bukit dengan neraca?","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Siapakah yang dapat mengatur Roh TUHAN?","poem":1},{"text":"Atau menjadi penasihat-Nya dan memberi tahu Dia?","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Kepada siapakah Dia meminta nasihat","poem":1},{"text":"dan siapakah yang dapat memberi-Nya pengertian?","poem":2},{"text":"Siapakah yang mengajari-Nya jalan keadilan dan mengajari-Nya pengetahuan,","poem":1},{"text":"serta menunjukkan kepada-Nya jalan pengertian?","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Sesungguhnya, bangsa-bangsa seperti setitik air dalam ember,","poem":1},{"text":"dan diperhitungkan seperti debu dalam timbangan.","poem":2},{"lineBreak":true},{"text":"Lihatlah, Tuhan mengangkat pulau-pulau","poem":2},{"lineBreak":true},{"text":"seperti debu halus.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Lebanon tidak cukup","poem":1},{"text":"untuk bahan bakar,","poem":2},{"text":"ataupun binatang-binatangnya","poem":1},{"text":"untuk kurban bakaran.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Semua bangsa seperti","poem":1},{"text":"bukan apa-apa di hadapan-Nya,","poem":2},{"text":"mereka dianggap seperti","poem":1},{"text":"kehampaan dan tidak berarti.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Jika demikian, dengan siapakah kamu akan menyamakan Allah?","poem":1},{"text":"Atau, kesamaan apa yang akan kamu bandingkan dengan Dia?","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Patungkah? Pengrajin menuangnya,","poem":1},{"text":"pandai besi melapisinya dengan emas,","poem":2},{"lineBreak":true},{"text":"dan membuat rantai-rantai perak untuknya.","poem":2}]},{"type":"verse","number":20,"content":[{"text":"Orang yang terlalu miskin untuk memberikan persembahan","poem":1},{"text":"memilih kayu yang tidak akan lapuk.","poem":2},{"text":"Dia berusaha mencari seorang pengrajin ahli","poem":1},{"text":"untuk membuat sebuah patung yang tidak akan goyah.","poem":2}]},{"type":"verse","number":21,"content":[{"text":"Tidakkah kamu tahu?","poem":1},{"text":"Tidakkah kamu dengar?","poem":2},{"text":"Apakah belum diberitahukan kepadamu sejak semula?","poem":1},{"text":"Apakah kamu belum memahami sejak dasar bumi diletakkan?","poem":2}]},{"type":"verse","number":22,"content":[{"text":"Dia yang duduk di atas bulatan bumi,","poem":1},{"text":"yang penduduknya seperti belalang,","poem":2},{"text":"Dialah yang membentangkan langit seperti tirai,","poem":1},{"text":"dan menghamparkannya seperti kemah untuk ditinggali,","poem":2}]},{"type":"verse","number":23,"content":[{"text":"yang menjadikan para penguasa bukan apa-apa,","poem":1},{"text":"dan membuat hakim-hakim dunia seperti kesia-siaan belaka.","poem":2}]},{"type":"verse","number":24,"content":[{"text":"Baru saja mereka ditanam,","poem":1},{"text":"baru saja mereka ditaburkan, dan baru saja mereka berakar ke dalam tanah,","poem":2},{"text":"Dia pun meniup mereka","poem":1},{"text":"sehingga mereka layu,","poem":2},{"lineBreak":true},{"text":"dan badai menerbangkan mereka seperti jerami.","poem":2}]},{"type":"verse","number":25,"content":[{"text":"“Dengan siapakah kamu hendak menyamakan Aku sehingga Aku sejajar dengannya?”","poem":1},{"text":"firman Yang Mahakudus.","poem":2}]},{"type":"line_break"},{"type":"verse","number":26,"content":[{"text":"Arahkan pandanganmu ke tempat tinggi dan lihatlah,","poem":1},{"text":"siapakah yang menciptakan semua itu,","poem":2},{"text":"yang mengeluarkan benda-benda angkasa menurut jumlahnya,","poem":1},{"text":"dan memanggil mereka menurut nama mereka","poem":2},{"text":"dengan kebesaran kekuasaan-Nya dan kekuatan kuasa-Nya","poem":1},{"text":"tidak ada satu pun dari mereka yang hilang.","poem":2}]},{"type":"line_break"},{"type":"verse","number":27,"content":[{"text":"Mengapa kamu berkata,","poem":1},{"text":"“Hai Yakub” dan berkata,","poem":2},{"text":"“Hai Israel, jalanku tersembunyi dari TUHAN,","poem":1},{"text":"dan keadilanku dijauhkan dari Allahku?”","poem":2}]},{"type":"line_break"},{"type":"verse","number":28,"content":[{"text":"Tidakkah kamu tahu,","poem":1},{"text":"tidakkah kamu dengar","poem":2},{"text":"bahwa Allah yang kekal, yaitu TUHAN,","poem":1},{"text":"Pencipta ujung-ujung bumi,","poem":2},{"text":"tidak menjadi letih dan lesu?","poem":1},{"text":"Pemahaman-Nya tidak dapat diduga.","poem":2}]},{"type":"verse","number":29,"content":[{"text":"Dia memberi kekuatan kepada yang letih,","poem":1},{"text":"dan kepada yang tak berdaya Dia menambahkan kuasa.","poem":2}]},{"type":"verse","number":30,"content":[{"text":"Orang-orang muda menjadi letih dan lesu,","poem":1},{"text":"dan anak-anak muda akan jatuh tersandung.","poem":2}]},{"type":"verse","number":31,"content":[{"text":"Akan tetapi, mereka yang menanti-nantikan TUHAN akan memperoleh kekuatan baru.","poem":1},{"text":"Mereka akan naik dengan sayap-sayap, seperti burung rajawali.","poem":2},{"text":"Mereka akan berlari, tetapi tidak menjadi lesu,","poem":1},{"text":"mereka akan berjalan, tetapi tidak menjadi letih.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/ISA/40.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/ISA/41.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/ISA/39.json","previousChapterAudioLinks":{},"numberOfVerses":31}