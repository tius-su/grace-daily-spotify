{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"JER","translationId":"ind_ayt","name":"YEREMIA","commonName":"YEREMIA","title":"Yeremia","order":24,"numberOfChapters":52,"sha256":"a01e12b3ecfc86d080f4c575bcc6c056c26bc7651d1f251c60d7480ffa6e11e5","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/JER/1.json","lastChapterNumber":52,"lastChapterApiLink":"/api/ind_ayt/JER/52.json","totalNumberOfVerses":1364},"chapter":{"number":15,"content":[{"type":"verse","number":1,"content":["Lalu, TUHAN berkata kepadaku, “Sekalipun Musa dan Samuel berdiri di hadapan-Ku, hati-Ku tidak akan tertuju kepada bangsa ini. Usirlah mereka dari hadapan-Ku dan biarkan mereka pergi!"]},{"type":"verse","number":2,"content":["Dan jika mereka bertanya kepadamu, ‘Ke mana kami akan pergi?’ katakanlah kepada mereka, ‘Beginilah firman TUHAN,",{"lineBreak":true},{"text":"Yang ke maut,","poem":1},{"text":"ke mautlah;","poem":2},{"text":"yang ke pedang,","poem":1},{"text":"ke pedanglah;","poem":2},{"text":"yang ke kelaparan,","poem":1},{"text":"ke kelaparanlah;","poem":2},{"text":"yang ke tawanan,","poem":1},{"text":"ke tawananlah.’”","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":["“Aku akan menentukan empat jenis perusak ke atas mereka,” firman TUHAN, “pedang untuk membunuh, anjing-anjing untuk menyeret, dan burung-burung di udara, dan binatang-binatang di bumi untuk melahap dan menghancurkan."]},{"type":"verse","number":4,"content":["Aku akan menjadikan mereka kengerian bagi semua kerajaan di bumi karena Manasye, anak Hizkia, raja Yehuda, karena apa yang dilakukannya di Yerusalem.”"]},{"type":"line_break"},{"type":"heading","content":["Kedahsyatan karena Perang"]},{"type":"verse","number":5,"content":[{"text":"“Siapakah yang akan berbelaskasihan kepadamu, oh Yerusalem?","poem":1},{"text":"Atau, siapakah yang akan berduka untukmu?","poem":2},{"lineBreak":true},{"text":"Siapakah yang akan mampir untuk menanyakan keadaanmu?","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Kamu telah meninggalkan Aku,”","poem":1},{"text":"firman TUHAN,","poem":2},{"text":"“kamu terus saja berjalan mundur.","poem":1},{"text":"Karena itu, Aku akan mengacungkan tangan-Ku melawan kamu dan menghancurkan kamu.","poem":2},{"lineBreak":true},{"text":"Aku lelah berbelaskasihan.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Aku akan menampi mereka","poem":1},{"text":"dengan alat penampi di pintu-pintu gerbang negeri.","poem":2},{"text":"Aku akan membuat mereka kehilangan anak-anak.","poem":1},{"text":"Aku akan menghancurkan jemaat-Ku","poem":2},{"lineBreak":true},{"text":"karena mereka tidak berbalik dari jalan-jalan mereka.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Janda-janda mereka akan Kubuat lebih banyak daripada pasir di laut.","poem":1},{"text":"Aku telah mendatangkan ke atas mereka","poem":2},{"text":"seorang perusak pada tengah hari,","poem":1},{"text":"yang menyerang ibu orang-orang muda.","poem":2},{"text":"Aku akan menimpakan penderitaan dan kengerian","poem":1},{"text":"ke atas mereka secara tiba-tiba.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Perempuan yang telah melahirkan tujuh anak merana,","poem":1},{"text":"dia sudah meregang nyawa.","poem":2},{"text":"Mataharinya terbenam ketika hari masih siang.","poem":1},{"text":"Ia telah dipermalukan dan dicela.","poem":2},{"text":"Mereka yang masih tersisa","poem":1},{"text":"akan Aku serahkan kepada pedang di hadapan musuh-musuh mereka,”","poem":2},{"lineBreak":true},{"text":"firman TUHAN.","poem":2}]},{"type":"heading","content":["Pergumulan Nabi Yeremia"]},{"type":"verse","number":10,"content":[{"text":"Celakalah aku, oh ibuku,","poem":1},{"text":"bahwa engkau telah melahirkan aku,","poem":2},{"text":"seorang pemicu perselisihan","poem":1},{"text":"dan seorang pemicu perdebatan di seluruh negeri.","poem":2},{"text":"Aku tidak mengutangi atau berutang,","poem":1},{"text":"tetapi semua orang mengutuk aku.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"TUHAN berkata, “Sesungguhnya, Aku akan membebaskan kamu dengan maksud yang baik.","poem":1},{"text":"Sesungguhnya, Aku akan membuat musuhmu memohon kepadamu pada masa bencana dan pada masa kesusahan.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Dapatkah seseorang","poem":1},{"text":"mematahkan besi,","poem":2},{"text":"besi dari utara,","poem":1},{"text":"atau tembaga?","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Kekayaanmu","poem":1},{"text":"dan harta bendamu","poem":2},{"text":"akan Aku berikan sebagai jarahan secara cuma-cuma","poem":1},{"text":"karena semua dosamu","poem":2},{"lineBreak":true},{"text":"di seluruh wilayahmu.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Aku akan membuat musuh-musuhmu membawanya","poem":1},{"text":"ke negeri yang tidak kamu kenal","poem":2},{"text":"karena api telah menyala","poem":1},{"text":"dalam kemarahan-Ku,","poem":2},{"lineBreak":true},{"text":"dan akan membakarmu.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":15,"content":[{"text":"Engkau tahu, ya TUHAN.","poem":1},{"text":"Ingatlah aku dan jenguklah aku.","poem":2},{"text":"Balaskan aku","poem":1},{"text":"terhadap penyiksa-penyiksaku.","poem":2},{"text":"Dalam panjangnya kesabaran-Mu,","poem":1},{"text":"janganlah membuangku.","poem":2},{"text":"Ketahuilah bahwa aku menanggung hinaan","poem":1},{"text":"karena Engkau.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Firman-firman-Mu ditemukan, dan aku memakannya.","poem":1},{"text":"Dan bagiku, firman-firman-Mu itu menjadi suatu sukacita dan kesukaan hatiku.","poem":2},{"text":"Sebab, aku dipanggil menurut nama-Mu, ya TUHAN, Tuhan semesta alam.","poem":1}]},{"type":"verse","number":17,"content":[{"lineBreak":true},{"text":"Aku tidak duduk","poem":1},{"text":"dalam kumpulan para pengejek, ataupun bersenang-senang.","poem":2},{"text":"Aku duduk sendirian","poem":1},{"text":"karena tangan-Mu.","poem":2},{"lineBreak":true},{"text":"Sebab, Engkau telah memenuhi aku dengan kemarahan.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Mengapa rasa sakitku tidak berkesudahan","poem":1},{"text":"dan lukaku tidak dapat disembuhkan, sulit disembuhkan?","poem":2},{"text":"Apakah bagiku","poem":1},{"text":"Engkau akan menjadi seperti aliran air yang menipu,","poem":2},{"lineBreak":true},{"text":"seperti air yang tidak dapat dipercaya?","poem":2}]},{"type":"line_break"},{"type":"verse","number":19,"content":[{"text":"Karena itu,","poem":1},{"text":"beginilah firman TUHAN,","poem":2},{"text":"“Jika kamu kembali, Aku akan memulihkanmu","poem":1},{"text":"dan kamu akan berdiri di hadapan-Ku.","poem":2},{"text":"Jika kamu mengucapkan apa yang berharga, dan bukan yang tidak berguna,","poem":1},{"text":"kamu akan menjadi seperti mulut-Ku.","poem":2},{"text":"Mereka akan kembali kepadamu,","poem":1},{"text":"tetapi kamu jangan kembali kepada mereka.","poem":2}]},{"type":"verse","number":20,"content":[{"text":"Terhadap bangsa ini,","poem":1},{"lineBreak":true},{"text":"Aku akan membuatmu","poem":1},{"text":"menjadi tembok tembaga yang berkubu.","poem":2},{"text":"Mereka akan berperang melawanmu,","poem":1},{"text":"tetapi mereka tidak akan mengalahkanmu karena Aku menyertaimu,","poem":2},{"text":"untuk menyelamatkanmu dan membebaskanmu,”","poem":1},{"lineBreak":true},{"text":"firman TUHAN.","poem":1}]},{"type":"verse","number":21,"content":[{"text":"“Aku akan membebaskanmu dari tangan orang-orang jahat,","poem":2},{"text":"dan Aku akan menebusmu","poem":1},{"text":"dari cengkeraman orang-orang kejam.”","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/JER/15.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/JER/16.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/JER/14.json","previousChapterAudioLinks":{},"numberOfVerses":21}