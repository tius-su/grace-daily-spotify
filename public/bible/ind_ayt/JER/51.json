{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"JER","translationId":"ind_ayt","name":"YEREMIA","commonName":"YEREMIA","title":"Yeremia","order":24,"numberOfChapters":52,"sha256":"a01e12b3ecfc86d080f4c575bcc6c056c26bc7651d1f251c60d7480ffa6e11e5","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/JER/1.json","lastChapterNumber":52,"lastChapterApiLink":"/api/ind_ayt/JER/52.json","totalNumberOfVerses":1364},"chapter":{"number":51,"content":[{"type":"verse","number":1,"content":["Beginilah firman TUHAN,",{"text":"“Ketahuilah, Aku akan membangkitkan terhadap Babel,","poem":1},{"text":"dan terhadap orang-orang yang tinggal di tengah-tengah mereka, suatu roh perusak.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Aku akan mengirimkan para penampi ke Babel,","poem":1},{"text":"dan mereka akan menampi dia dan akan mengosongkan negerinya.","poem":2},{"text":"Sebab, pada hari kemalangan,","poem":1},{"text":"mereka akan melawan dia dari segala arah.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Jangan biarkan pemanah melengkungkan busurnya,","poem":1},{"text":"dan jangan biarkan dia berdiri dengan baju zirahnya.","poem":2},{"text":"Jangan menyayangkan orang-orang mudanya,","poem":1},{"text":"hancurkan seluruh tentaranya!","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Mereka akan rebah terbunuh di negeri orang-orang Kasdim","poem":1},{"text":"dan tertusuk di jalan-jalannya.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"Sebab, Israel dan Yehuda","poem":1},{"text":"tidak ditinggalkan oleh Allah mereka,","poem":2},{"lineBreak":true},{"text":"TUHAN semesta alam,","poem":2},{"text":"meskipun negeri mereka penuh kesalahan","poem":1},{"text":"terhadap Yang Mahakudus dari Israel.","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"Larilah dari tengah-tengah Babel,","poem":1},{"text":"biarlah setiap orang menyelamatkan nyawanya!","poem":2},{"lineBreak":true},{"text":"Janganlah diam saja dengan kesalahannya.","poem":2},{"text":"Sebab, inilah waktu pembalasan TUHAN,","poem":1},{"text":"Dia akan memberikan pembalasan kepadanya.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Babel dahulunya menjadi cawan emas di tangan TUHAN,","poem":1},{"text":"membuat seluruh bumi mabuk.","poem":2},{"text":"Bangsa-bangsa mabuk karena anggurnya.","poem":1},{"text":"Karena itu, bangsa-bangsa menjadi gila.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Dengan tiba-tiba, Babel jatuh dan dihancurkan,","poem":1},{"text":"merataplah karenanya!","poem":2},{"text":"Bawalah balsam untuk rasa sakitnya,","poem":1},{"text":"mungkin ia dapat disembuhkan.","poem":2}]},{"type":"line_break"},{"type":"verse","number":9,"content":[{"text":"Kami telah berusaha menyembuhkan Babel,","poem":1},{"text":"tetapi ia tidak dapat disembuhkan.","poem":2},{"text":"Tinggalkan saja ia,","poem":1},{"text":"dan mari kita masing-masing pergi ke negerinya sendiri.","poem":2},{"text":"Sebab, penghukumannya telah mencapai surga,","poem":1},{"text":"dan telah naik sampai ke langit.","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"TUHAN telah menunjukkan kebenaran kita,","poem":1},{"text":"datanglah, dan mari kita ceritakan di Sion","poem":2},{"lineBreak":true},{"text":"perbuatan TUHAN, Allah kita.","poem":2}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"Asahlah anak-anak panah,","poem":1},{"text":"siapkanlah perisai-perisai!","poem":2},{"text":"TUHAN telah membangkitkan roh raja-raja Media","poem":1},{"text":"karena rencana-Nya terhadap Babel untuk menghancurkannya,","poem":2},{"text":"karena ini adalah pembalasan TUHAN,","poem":1},{"text":"pembalasan untuk Bait Suci-Nya.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Angkatlah panji-panji terhadap tembok-tembok Babel,","poem":1},{"text":"buatlah pengawasan yang kuat,","poem":2},{"text":"siagakan para pengawas,","poem":1},{"text":"persiapkan penyergapan","poem":2},{"text":"karena TUHAN telah merencanakan dan melakukan","poem":1},{"text":"apa yang Dia firmankan mengenai penduduk Babel.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Hai kamu yang tinggal di dekat air yang banyak,","poem":1},{"text":"berlimpah-limpah harta benda,","poem":2},{"lineBreak":true},{"text":"kesudahanmu sudah tiba,","poem":2},{"lineBreak":true},{"text":"dan ukuran keserakahanmu.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"TUHAN semesta alam telah bersumpah demi diri-Nya sendiri,","poem":1},{"text":"“Sesungguhnya, Aku akan memenuhimu dengan banyak orang seperti kumpulan belalang,","poem":2},{"text":"dan mereka akan berteriak","poem":1},{"text":"dengan seruan kemenangan atasmu.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":15,"content":[{"text":"Dialah yang menciptakan bumi dengan kuasa-Nya,","poem":1},{"text":"yang menegakkan dunia dengan hikmat-Nya,","poem":2},{"lineBreak":true},{"text":"dan membentangkan langit dengan pengertian-Nya.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Ketika Dia memperdengarkan suara-Nya, ada gemuruh air di langit,","poem":1},{"text":"Dia membuat kabut naik dari ujung bumi.","poem":2},{"text":"Dia membuat kilat dan hujan,","poem":1},{"text":"Dia mengeluarkan angin dari tempat penyimpanan-Nya.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Semua manusia itu bodoh","poem":1},{"text":"dan tidak berpengetahuan.","poem":2},{"text":"Semua tukang emas dipermalukan","poem":1},{"text":"oleh patung ukirannya.","poem":2},{"text":"Patung-patung tuangannya adalah kebohongan,","poem":1},{"text":"dan tidak ada napas di dalam mereka.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Semua itu kesia-siaan,","poem":1},{"text":"suatu karya yang menjadi cemoohan.","poem":2},{"text":"Mereka akan binasa,","poem":1},{"text":"pada waktu penghakiman mereka.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Namun, Dia yang menjadi bagian Yakub tidaklah demikian","poem":1},{"text":"karena Dialah yang membentuk","poem":2},{"text":"segala sesuatu,","poem":1},{"text":"dan Israel adalah suku ahli waris-Nya.","poem":2},{"lineBreak":true},{"text":"TUHAN semesta alam adalah nama-Nya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":20,"content":[{"text":"Dia berkata, “Kamu adalah alat pemukul dan senjata perang-Ku,","poem":1},{"text":"bersamamu Aku menghancurkan bangsa-bangsa hingga berkeping-keping,","poem":2},{"lineBreak":true},{"text":"bersamamu Aku menghancurkan kerajaan-kerajaan,","poem":2}]},{"type":"verse","number":21,"content":[{"text":"bersamamu Aku menghancurkan kuda dan penunggangnya hingga berkeping-keping.","poem":1},{"text":"bersamamu Aku menghancurkan kereta dan pengemudinya,","poem":2}]},{"type":"verse","number":22,"content":[{"text":"bersamamu Aku menghancurkan laki-laki dan perempuan hingga berkeping-keping,","poem":1},{"text":"bersamamu Aku menghancurkan orang tua dan pemuda,","poem":2},{"lineBreak":true},{"text":"bersamamu Aku menghancurkan pemuda dan pemudi,","poem":2}]},{"type":"verse","number":23,"content":[{"text":"bersamamu Aku menghancurkan gembala dan kawanannya hingga berkeping-keping,","poem":1},{"text":"bersamamu Aku menghancurkan petani dan hewan pembajaknya,","poem":2},{"lineBreak":true},{"text":"bersamamu Aku menghancurkan para gubernur dan pejabat.","poem":2}]},{"type":"verse","number":24,"content":[{"text":"Akan tetapi, Aku akan membalas Babel dan semua penduduk Kasdim","poem":1},{"text":"atas semua kejahatan yang telah mereka lakukan di Sion di hadapan matamu,”","poem":2},{"lineBreak":true},{"text":"firman TUHAN.","poem":2}]},{"type":"line_break"},{"type":"verse","number":25,"content":[{"text":"“Ketahuilah, Aku menentangmu,","poem":1},{"lineBreak":true},{"text":"hai gunung yang menghancurkan,”","poem":1},{"text":"firman TUHAN, yang menghancurkan seluruh bumi.","poem":2},{"text":"“Aku merentangkan tangan-Ku menentangmu,","poem":1},{"text":"dan menggulingkanmu dari tebing-tebing serta akan membuatmu menjadi gunung yang terbakar.","poem":2}]},{"type":"verse","number":26,"content":[{"text":"Tidak ada batu yang akan diambil darimu","poem":1},{"text":"sebagai batu penjuru atau batu fondasi,","poem":2},{"text":"tetapi kamu akan menjadi tempat tandus untuk selama-lamanya,”","poem":1},{"text":"firman TUHAN.","poem":2}]},{"type":"line_break"},{"type":"verse","number":27,"content":[{"text":"“Angkatlah panji-panji di negeri,","poem":1},{"text":"tiuplah trompet di antara bangsa-bangsa,","poem":2},{"text":"persiapkanlah bangsa-bangsa untuk berperang melawan dia,","poem":1},{"text":"panggillah kerajaan-kerajaan melawan dia:","poem":2},{"lineBreak":true},{"text":"Ararat, Mini, dan Askenas.","poem":2},{"text":"Pilihlah seorang panglima melawan dia,","poem":1},{"text":"datangkan kuda-kuda seperti sekumpulan belalang muda.","poem":2}]},{"type":"verse","number":28,"content":[{"text":"Persiapkan bangsa-bangsa untuk berperang melawan dia,","poem":1},{"text":"raja-raja Media,","poem":2},{"text":"bersama para gubernurnya dan semua pemimpin mereka,","poem":1},{"text":"dan semua negeri di bawah kekuasaan mereka.","poem":2}]},{"type":"verse","number":29,"content":[{"text":"Tanah bergetar dan menggeliat","poem":1},{"text":"karena setiap rencana TUHAN akan dilakukan terhadap Babel,","poem":2},{"text":"untuk membuat negeri Babel menjadi tempat tandus,","poem":1},{"text":"tanpa penduduk.","poem":2}]},{"type":"verse","number":30,"content":[{"text":"Orang-orang gagah Babel telah berhenti berperang.","poem":1},{"text":"Mereka tinggal di benteng-benteng pertahanan mereka.","poem":2},{"text":"Kekuatan mereka telah hilang,","poem":1},{"text":"mereka menjadi seperti perempuan.","poem":2},{"text":"Tempat-tempat tinggalnya terbakar,","poem":1},{"text":"palang-palangnya dipatahkan.","poem":2}]},{"type":"verse","number":31,"content":[{"text":"Seorang pesuruh berlari menyusul pesuruh yang lain,","poem":1},{"text":"dan seorang pembawa berita menyusul pembawa berita yang lain,","poem":2},{"text":"untuk memberi tahu Raja Babel","poem":1},{"text":"bahwa kotanya telah direbut dari ujung ke ujung,","poem":2}]},{"type":"verse","number":32,"content":[{"text":"tempat-tempat penyeberangan telah direbut","poem":1},{"lineBreak":true},{"text":"dan rawa-rawa telah dibakar dengan api,","poem":1},{"text":"dan tentara-tentara ketakutan.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":33,"content":[{"text":"Sebab, beginilah firman TUHAN semesta alam, Allah Israel,","poem":1},{"lineBreak":true},{"text":"“Anak perempuan Babel itu seperti tempat pengirikan,","poem":1},{"text":"inilah waktu untuk mengiriknya.","poem":2},{"lineBreak":true},{"text":"Namun, sesaat lagi dan waktu panennya akan tiba.","poem":2}]},{"type":"line_break"},{"type":"verse","number":34,"content":[{"text":"Nebukadnezar, raja Babel,","poem":1},{"text":"telah melahapku","poem":2},{"text":"dan menghancurkanku.","poem":1},{"text":"Dia telah menjadikanku bejana kosong.","poem":2},{"text":"dia telah menelanku seperti seekor naga,","poem":1},{"text":"dia telah mengisi perutnya","poem":2},{"text":"dengan makananku yang enak-enak,","poem":1},{"text":"dia telah memuntahkanku.","poem":2}]},{"type":"verse","number":35,"content":[{"text":"Biarlah kekerasan yang dilakukan terhadapku","poem":1},{"text":"dan terhadap dagingku ditimpakan ke atas Babel,”","poem":2},{"lineBreak":true},{"text":"kata penduduk Sion.","poem":1},{"lineBreak":true},{"text":"“Biarlah darahku ditimpakan","poem":1},{"text":"ke atas penduduk Kasdim,”","poem":2},{"lineBreak":true},{"text":"kata Yerusalem.","poem":2}]},{"type":"verse","number":36,"content":[{"text":"Karena itu, beginilah firman TUHAN,","poem":1},{"lineBreak":true},{"text":"“Lihatlah, Aku akan membela perkaramu","poem":1},{"text":"dan melakukan pembalasan bagimu.","poem":2},{"text":"Aku akan mengeringkan lautnya","poem":1},{"text":"dan membuat mata airnya kering.","poem":2}]},{"type":"verse","number":37,"content":[{"text":"Babel akan menjadi tumpukan puing,","poem":1},{"text":"sarang serigala-serigala,","poem":2},{"text":"suatu kengerian dan suatu helaan napas,","poem":1},{"text":"tanpa penduduk.","poem":2}]},{"type":"line_break"},{"type":"verse","number":38,"content":[{"text":"Mereka akan mengaum bersama-sama seperti singa-singa muda,","poem":1},{"text":"menggeram seperti anak-anak singa.","poem":2}]},{"type":"verse","number":39,"content":[{"text":"Ketika mereka menjadi panas,","poem":1},{"text":"Aku akan menyiapkan pesta bagi mereka,","poem":2},{"lineBreak":true},{"text":"dan Aku akan membuat mereka mabuk,","poem":2},{"text":"supaya mereka bersukaria","poem":1},{"text":"dan tidur dalam tidur yang abadi,","poem":2},{"lineBreak":true},{"text":"dan tidak bangun lagi,”","poem":2},{"lineBreak":true},{"text":"firman TUHAN.","poem":1}]},{"type":"verse","number":40,"content":[{"lineBreak":true},{"text":"“Aku akan membawa mereka turun seperti anak-anak domba","poem":1},{"text":"kepada pembantai,","poem":2},{"lineBreak":true},{"text":"seperti biri-biri jantan dan kambing-kambing jantan.","poem":2}]},{"type":"line_break"},{"type":"verse","number":41,"content":[{"text":"Betapa Sesakh direbut,","poem":1},{"text":"pujian seluruh bumi dirampas!","poem":2},{"lineBreak":true},{"text":"Betapa Babel telah menjadi kengerian di antara bangsa-bangsa!","poem":2}]},{"type":"verse","number":42,"content":[{"text":"Laut telah membanjiri Babel.","poem":1},{"text":"gelombangnya yang bergelora telah menutupinya.","poem":2}]},{"type":"verse","number":43,"content":[{"text":"Kota-kotanya telah menjadi suatu kengerian,","poem":1},{"text":"suatu tanah kering dan suatu padang gurun,","poem":2},{"text":"Suatu negeri yang di dalamnya tidak seorang pun tinggal,","poem":1},{"text":"dan tidak seorang pun melintasinya.","poem":2}]},{"type":"verse","number":44,"content":[{"text":"Aku akan menghukum Bel di Babel,","poem":1},{"text":"dan Aku akan mengeluarkan dari mulutnya apa yang telah ia telan.","poem":2},{"text":"Bangsa-bangsa tidak akan mengalir kepadanya lagi,","poem":1},{"text":"tembok Babel telah roboh.","poem":2}]},{"type":"verse","number":45,"content":[{"text":"Keluarlah dari tengah-tengahnya, hai jemaat-Ku!","poem":1},{"text":"biarlah masing-masing orang menyelamatkan nyawanya","poem":2},{"lineBreak":true},{"text":"dari keganasan kemarahan TUHAN.","poem":2}]},{"type":"line_break"},{"type":"verse","number":46,"content":[{"text":"Jangan biarkan hatimu tawar","poem":1},{"text":"dan jangan takut terhadap laporan yang terdengar di negeri,","poem":2},{"text":"ketika sebuah kabar datang tahun ini","poem":1},{"text":"dan kemudian sebuah kabar di tahun berikutnya,","poem":2},{"text":"kekacauan akan terjadi di negeri,","poem":1},{"text":"penguasa melawan penguasa.","poem":2}]},{"type":"verse","number":47,"content":[{"text":"Karena itu, ketahuilah, hari-harinya akan datang","poem":1},{"text":"ketika Aku akan menghukum patung-patung Babel,","poem":2},{"text":"seluruh negerinya akan dipermalukan","poem":1},{"text":"dan orang-orangnya yang terbunuh akan rebah di tengah-tengahnya.","poem":2}]},{"type":"verse","number":48,"content":[{"text":"Kemudian, langit dan bumi serta semua yang ada di dalamnya,","poem":1},{"text":"akan bernyanyi gembira atas Babel.","poem":2},{"text":"Sebab, para perusak akan datang","poem":1},{"text":"kepadanya dari utara,”","poem":2},{"lineBreak":true},{"text":"firman TUHAN.","poem":2}]},{"type":"line_break"},{"type":"verse","number":49,"content":[{"text":"“Babel akan rebah karena orang-orang Israel yang terbunuh,","poem":1},{"text":"sama seperti karena Babel,","poem":2},{"lineBreak":true},{"text":"telah rebah orang-orang yang terbunuh di seluruh bumi.","poem":2}]},{"type":"verse","number":50,"content":[{"text":"Kamu yang lolos dari pedang,","poem":1},{"text":"pergilah,","poem":2},{"lineBreak":true},{"text":"jangan berdiam diri!","poem":2},{"text":"Ingatlah TUHAN dari jauh,","poem":1},{"text":"dan biarlah Yerusalem ada","poem":2},{"lineBreak":true},{"text":"dalam pikiranmu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":51,"content":[{"text":"Kami dipermalukan","poem":1},{"text":"karena kami telah mendengar ejekan.","poem":2},{"text":"Aib telah menutupi wajah kami","poem":1},{"text":"karena orang-orang asing telah memasuki tempat-tempat kudus di rumah TUHAN.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":52,"content":[{"text":"“Karena itu, ketahuilah, hari-harinya akan datang,”","poem":1},{"text":"firman TUHAN,","poem":2},{"text":"“ketika Aku akan menghukum patung-patungnya,","poem":1},{"text":"dan di seluruh negerinya, orang-orang terluka akan mengerang.","poem":2}]},{"type":"verse","number":53,"content":[{"text":"Meskipun Babel akan naik ke langit,","poem":1},{"text":"dan meskipun ia akan membentengi kekuatannya tinggi-tinggi,","poem":2},{"text":"tetapi dari-Ku,","poem":1},{"text":"akan datang para penghancur kepadanya,”","poem":2},{"lineBreak":true},{"text":"firman TUHAN.","poem":2}]},{"type":"line_break"},{"type":"verse","number":54,"content":[{"text":"“Suara jeritan datang dari Babel,","poem":1},{"text":"dan kehancuran besar dari negeri orang-orang Kasdim.","poem":2}]},{"type":"verse","number":55,"content":[{"text":"Sebab, TUHAN akan menghancurkan Babel","poem":1},{"text":"dan akan melenyapkan suaranya yang keras.","poem":2},{"text":"Gelombang-gelombang mereka akan bergemuruh seperti air bah.","poem":1},{"text":"riuh suara mereka terdengar,","poem":2}]},{"type":"verse","number":56,"content":[{"text":"karena penghancur telah datang ke atasnya,","poem":1},{"text":"ke atas Babel,","poem":2},{"text":"orang-orangnya yang gagah ditangkap,","poem":1},{"text":"busur-busur mereka dihancurkan berkeping-keping.","poem":2},{"text":"Sebab, TUHAN adalah Allah yang membalas,","poem":1},{"text":"Dia pasti akan mengadakan pembalasan.","poem":2}]},{"type":"verse","number":57,"content":[{"text":"Aku akan membuat mabuk para pejabatnya,","poem":1},{"text":"orang-orang bijaknya,","poem":2},{"text":"para gubernur, para pemimpin,","poem":1},{"text":"dan tentara-tentaranya.","poem":2},{"text":"Mereka akan tertidur selama-lamanya","poem":1},{"text":"dan tidak bangun,”","poem":2},{"text":"kata Sang Raja,","poem":1},{"text":"yang namanya adalah TUHAN semesta alam.","poem":2}]},{"type":"line_break"},{"type":"verse","number":58,"content":[{"text":"Beginilah firman TUHAN semesta alam,","poem":1},{"lineBreak":true},{"text":"“Tembok Babel yang luas akan diratakan sama sekali,","poem":1},{"text":"dan pintu-pintu gerbangnya yang tinggi akan dibakar","poem":2},{"text":"sehingga bangsa-bangsa bekerja keras","poem":1},{"text":"dengan sia-sia,","poem":2},{"text":"dan bangsa-bangsa menjadi lelah","poem":1},{"text":"hanya untuk api.”","poem":2}]},{"type":"heading","content":["Yeremia terhadap Babel"]},{"type":"verse","number":59,"content":["Perkataan yang Nabi Yeremia perintahkan kepada Seraya, anak Neria, anak Mahseya, ketika dia pergi bersama Zedekia, raja Yehuda, ke Babel pada tahun keempat pemerintahannya. Waktu itu, Seraya adalah kepala perlengkapan."]},{"type":"verse","number":60,"content":["Yeremia menuliskan dalam sebuah kitab semua bencana yang akan menimpa Babel, semua perkataan tadi yang ditulis mengenai Babel."]},{"type":"verse","number":61,"content":["Yeremia berkata kepada Seraya, “Ketika kamu tiba di Babel dan akan melihat serta membacakan semua perkataan ini,"]},{"type":"verse","number":62,"content":["maka katakan, ‘TUHAN, Engkau telah berfirman menentang tempat ini untuk menghancurkannya sehingga tidak ada apa pun yang akan tinggal di dalamnya, baik manusia atau binatang, tetapi tempat itu akan menjadi tempat tandus untuk selama-lamanya.’"]},{"type":"verse","number":63,"content":["Setelah kamu selesai membacakan kitab ini, ikatkanlah sebuah batu pada kitab ini dan lemparkan itu ke tengah-tengah Sungai Efrat,"]},{"type":"verse","number":64,"content":["dan katakan, ‘Seperti itulah Babel akan tenggelam, tidak akan muncul lagi, karena bencana yang akan Aku timpakan ke atasnya, dan mereka akan menjadi lelah.’” Sampai di sinilah perkataan Yeremia."]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/JER/51.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/JER/52.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/JER/50.json","previousChapterAudioLinks":{},"numberOfVerses":64}