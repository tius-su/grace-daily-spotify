{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"JER","translationId":"ind_ayt","name":"YEREMIA","commonName":"YEREMIA","title":"Yeremia","order":24,"numberOfChapters":52,"sha256":"a01e12b3ecfc86d080f4c575bcc6c056c26bc7651d1f251c60d7480ffa6e11e5","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/JER/1.json","lastChapterNumber":52,"lastChapterApiLink":"/api/ind_ayt/JER/52.json","totalNumberOfVerses":1364},"chapter":{"number":46,"content":[{"type":"heading","content":["Firman TUHAN Mengenai Bangsa-Bangsa"]},{"type":"verse","number":1,"content":["Firman TUHAN yang datang kepada Nabi Yeremia mengenai bangsa-bangsa."]},{"type":"heading","content":["Mengenai Mesir"]},{"type":"verse","number":2,"content":["Mengenai Mesir, mengenai pasukan Firaun Nekho, raja Mesir, yang ada di dekat Sungai Efrat di Karkemis, yang dikalahkan Nebukadnezar, raja Babel, pada tahun keempat pemerintahan Yoyakim, anak Yosia, raja Yehuda."]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"“Siapkan perisai besar dan perisai kecil,","poem":1},{"text":"dan majulah ke medan pertempuran!","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Persiapkan kuda","poem":1},{"text":"dan naiklah, hai para penunggang kuda.","poem":2},{"text":"Ambillah posisimu","poem":1},{"text":"dengan mengenakan ketopongmu,","poem":2},{"text":"Asahlah tombak-tombakmu,","poem":1},{"text":"kenakanlah baju perangmu.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Mengapa Aku melihat itu?","poem":1},{"text":"Mereka termangu-mangu dan","poem":2},{"text":"berbalik ke belakang.","poem":1},{"text":"Para pahlawan mereka dikalahkan","poem":2},{"text":"dan melarikan diri dengan cepat","poem":1},{"text":"tanpa menoleh ke belakang,","poem":2},{"lineBreak":true},{"text":"kengerian ada di mana-mana,”","poem":2},{"lineBreak":true},{"text":"firman TUHAN.","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"“Jangan biarkan orang perkasa melarikan diri,","poem":1},{"text":"atau orang kuat lolos.","poem":2},{"text":"Di utara di dekat Sungai Efrat,","poem":1},{"text":"mereka telah tersandung dan jatuh.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Siapakah ini yang meluap seperti Sungai Nil,","poem":1},{"text":"seperti sungai yang airnya bergelora?","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Mesir meluap seperti Sungai Nil,","poem":1},{"text":"seperti sungai-sungai yang airnya bergelora.","poem":2},{"text":"Ia berkata, ‘Aku akan meluap, aku akan menutupi bumi.","poem":1},{"text":"Aku akan menghancurkan kota-kota dan penduduknya.’","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Majulah, hai kuda-kuda,","poem":1},{"text":"dan mengamuklah, hai kereta-kereta.","poem":2},{"text":"Biarlah para pahlawan keluar,","poem":1},{"text":"orang-orang Kus dan orang-orang Put, yang memegang perisai,","poem":2},{"lineBreak":true},{"text":"dan orang-orang Lidia, yang memegang dan melengkungkan busur.","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"Sebab, inilah harinya TUHAN, Allah semesta alam,","poem":1},{"text":"hari pembalasan sehingga Dia dapat menuntut balas atas musuh-musuh-Nya.","poem":2},{"text":"Pedang akan melahap","poem":1},{"text":"dan dikenyangkan,","poem":2},{"lineBreak":true},{"text":"serta akan puas minum darah mereka.","poem":2},{"text":"Sebab, TUHAN, Allah semesta alam, mengadakan persembahan","poem":1},{"text":"di negeri utara, di dekat Sungai Efrat.","poem":2}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"Pergilah ke Gilead dan ambillah balsam, hai anak-anak dara Mesir.","poem":1},{"text":"Sia-sialah kamu menggunakan banyak obat,","poem":2},{"lineBreak":true},{"text":"tidak ada kesembuhan bagimu.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Bangsa-bangsa telah mendengar aibmu,","poem":1},{"text":"dan bumi penuh dengan tangisanmu","poem":2},{"text":"karena orang gagah telah tersandung pada orang gagah lainnya","poem":1},{"text":"dan keduanya jatuh bersama-sama.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":13,"content":["Firman yang TUHAN katakan kepada Nabi Yeremia mengenai kedatangan Nebukadnezar, raja Babel, untuk memukul negeri Mesir."]},{"type":"line_break"},{"type":"verse","number":14,"content":[{"text":"“Umumkanlah di Mesir","poem":1},{"text":"dan serukan di Migdol,","poem":2},{"lineBreak":true},{"text":"kabarkanlah di Memfis dan Tahpanhes.","poem":2},{"text":"Katakan, ‘Berdirilah tegak dan bersiap-siaplah","poem":1},{"text":"karena pedang akan menelan semua yang ada di sekelilingmu.’","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Mengapa orang-orang gagahmu tumbang?","poem":1},{"text":"Mereka tidak berdiri","poem":2},{"lineBreak":true},{"text":"karena TUHAN mendorong mereka jatuh.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Dia membuat banyak orang tersandung,","poem":1},{"text":"dan seorang jatuh ke atas yang lain,","poem":2},{"text":"dan mereka berkata,","poem":1},{"text":"‘Bangkitlah, mari kita kembali kepada bangsa kita sendiri,","poem":2},{"text":"dan ke tanah kelahiran kita,","poem":1},{"text":"menjauh dari pedang penindas ini.’","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Mereka berseru di sana,","poem":1},{"text":"‘Firaun, raja Mesir, hanyalah tukang ribut saja,","poem":2},{"lineBreak":true},{"text":"yang membiarkan waktu yang ditetapkan berlalu.’”","poem":2}]},{"type":"verse","number":18,"content":[{"text":"“Demi Aku yang hidup,”","poem":1},{"text":"seru Sang Raja,","poem":2},{"text":"yang namanya adalah","poem":1},{"text":"TUHAN semesta alam.","poem":2},{"text":"“Sesungguhnya, seperti Tabor di antara pegunungan","poem":1},{"text":"dan seperti Karmel di dekat laut, seperti itulah dia akan datang.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Kemasilah barang-barangmu","poem":1},{"lineBreak":true},{"text":"untuk pembuangan, hai putri yang tinggal di Mesir.","poem":1},{"text":"Sebab, Memfis akan menjadi suatu kengerian,","poem":2},{"text":"suatu reruntuhan,","poem":1},{"text":"tanpa penghuni.","poem":2}]},{"type":"line_break"},{"type":"verse","number":20,"content":[{"text":"Mesir itu seperti sapi muda yang cantik,","poem":1},{"text":"tetapi lalat pikat dari utara telah mendatanginya.","poem":2}]},{"type":"verse","number":21,"content":[{"text":"Bahkan, tentara-tentara bayarannya yang ada di tengah-tengahnya seperti anak lembu yang tambun.","poem":1},{"text":"Mereka pun berbalik dan melarikan diri bersama-sama.","poem":2},{"lineBreak":true},{"text":"Mereka tidak dapat bertahan","poem":2},{"text":"karena hari kemalangan mereka telah datang menimpa mereka,","poem":1},{"text":"yaitu hari penghukuman mereka.","poem":2}]},{"type":"verse","number":22,"content":[{"text":"Suaranya terdengar","poem":1},{"text":"seperti seekor ular","poem":2},{"text":"karena mereka maju","poem":1},{"text":"dalam pasukan,","poem":2},{"text":"dan mendatanginya dengan kapak","poem":1},{"text":"seperti para penebang pohon.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":23,"content":[{"text":"“Mereka akan menebang hutannya,”","poem":1},{"lineBreak":true},{"text":"firman TUHAN,","poem":1},{"text":"Meskipun hutan itu tidak dapat diselidiki,","poem":2},{"text":"karena mereka lebih banyak daripada belalang,","poem":1},{"text":"mereka tidak terhitung.","poem":2}]},{"type":"verse","number":24,"content":[{"text":"Anak perempuan Mesir akan dipermalukan,","poem":1},{"text":"dia akan diserahkan ke tangan orang-orang utara.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":25,"content":["TUHAN semesta alam, Allah Israel, berkata, “Ketahuilah, Aku akan menghukum Amon, dari Tebe, atas Firaun dan Mesir, beserta ilah-ilah dan raja-rajanya, bahkan atas Firaun dan orang-orang yang percaya kepadanya."]},{"type":"verse","number":26,"content":["Aku akan menyerahkan mereka ke tangan orang-orang yang berusaha membunuh mereka, ke tangan Nebukadnezar, raja Babel, dan ke tangan hamba-hambanya. Setelah itu, Mesir akan dihuni seperti zaman dahulu,” firman TUHAN."]},{"type":"heading","content":["Mengenai Israel utara"]},{"type":"verse","number":27,"content":[{"text":"“Akan tetapi, jangan takut, hai hamba-Ku, Yakub.","poem":1},{"text":"Jangan gentar, hai Israel.","poem":2},{"text":"Sebab, ketahuilah, Aku akan menyelamatkanmu dari jauh,","poem":1},{"text":"dan keturunanmu dari negeri tempat penawanan mereka.","poem":2},{"text":"Yakub akan kembali dan mendapatkan ketenangan dan kemudahan,","poem":1},{"text":"dan tidak seorang pun akan membuat ia takut.”","poem":2}]},{"type":"verse","number":28,"content":[{"text":"“Jangan takut, hai Yakub, hamba-Ku,”","poem":1},{"lineBreak":true},{"text":"firman TUHAN,","poem":1},{"text":"“karena Aku menyertaimu.","poem":2},{"text":"Aku akan mengakhiri semua bangsa","poem":1},{"text":"tempat Aku telah menghalaumu.","poem":2},{"lineBreak":true},{"text":"Aku tidak akan menghabisi kamu.","poem":2},{"text":"Namun, Aku akan menghajarmu dengan adil","poem":1},{"text":"dan Aku tidak akan membiarkanmu tanpa dihukum.”","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/JER/46.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/JER/47.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/JER/45.json","previousChapterAudioLinks":{},"numberOfVerses":28}