{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"DEU","translationId":"ind_ayt","name":"ULANGAN","commonName":"ULANGAN","title":"ULANGAN","order":5,"numberOfChapters":34,"sha256":"21b9606d578b2b5ef8768a27a01f15cab5da67ac26b44f6f6d45815ef5c2ee08","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/DEU/1.json","lastChapterNumber":34,"lastChapterApiLink":"/api/ind_ayt/DEU/34.json","totalNumberOfVerses":959},"chapter":{"number":33,"content":[{"type":"heading","content":["Musa Memberkati Umat"]},{"type":"verse","number":1,"content":["Inilah berkat yang diberikan Musa, abdi Allah, kepada orang Israel sebelum dia mati."]},{"type":"verse","number":2,"content":["Dia berkata,",{"lineBreak":true},{"text":"“TUHAN datang dari Sinai,","poem":1},{"text":"dan bangkit bagi mereka dari Seir,","poem":2},{"lineBreak":true},{"text":"Dia tampak bersinar dari Gunung Paran.","poem":2},{"text":"Dia datang dari antara puluhan ribu orang kudus.","poem":1},{"text":"Di sebelah kanan-Nya ada api yang bercahaya bagi mereka.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Sesungguhnya, Dia mengasihi umat-Nya.","poem":1},{"text":"‘Semua orang kudus-Mu ada di dalam tangan-Mu.","poem":2},{"text":"Mereka duduk di kaki-Mu","poem":1},{"text":"dan setiap orang menaati perintah-Mu.’”","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Musa memberikan kepada kita Taurat,","poem":1},{"text":"sebagai suatu milik bagi jemaat Yakub.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Dan, dia menjadi raja Yesyurun,","poem":1},{"text":"ketika para pemimpin umat berkumpul,","poem":2},{"lineBreak":true},{"text":"yaitu seluruh suku Israel bersama-sama.","poem":2}]},{"type":"heading","content":["Berkat untuk Ruben"]},{"type":"verse","number":6,"content":[{"text":"“Biarlah Ruben hidup dan jangan mati,","poem":1},{"text":"tetapi biarlah hanya sedikit orang laki-lakinya.”","poem":2}]},{"type":"heading","content":["Berkat untuk Yehuda"]},{"type":"verse","number":7,"content":["Inilah tentang Yehuda, katanya,",{"lineBreak":true},{"text":"“Dengarlah ya TUHAN dan","poem":1},{"text":"bawalah Yehuda kepada bangsanya.","poem":2},{"text":"Dengan tangannya, ia berjuang bagi mereka.","poem":1},{"text":"Dan, biarlah Engkau membantunya melawan musuh-musuhnya.”","poem":2}]},{"type":"heading","content":["Berkat untuk Lewi"]},{"type":"verse","number":8,"content":["Mengenai Lewi, dia berkata,",{"lineBreak":true},{"text":"“Biarlah Tumim-Mu dan Urim-Mu","poem":1},{"text":"menjadi milik orang saleh-Mu, yang","poem":2},{"text":"Engkau uji di Masa.","poem":1},{"text":"Dengannya Engkau berselisih di mata air Meriba.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Yang berkata kepada ayahnya dan ibunya,","poem":1},{"text":"‘Aku mengabaikan mereka.’","poem":2},{"text":"Dia tidak mengakui saudara-saudaranya,","poem":1},{"text":"ia juga tidak menganggap anak-anaknya.","poem":2},{"text":"Karena mereka memegang teguh firman-Mu","poem":1},{"text":"dan menjaga perjanjian-Mu.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Mereka akan mengajarkan peraturan-Mu kepada Yakub dan Taurat-Mu kepada Israel.","poem":1},{"lineBreak":true},{"text":"Mereka akan membakar dupa di hadapan-Mu","poem":1},{"text":"dan seluruh kurban bakaran di hadapan-Mu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"TUHAN, berkatilah segala sesuatunya,","poem":1},{"text":"dan terimalah pekerjaan tangannya.","poem":2},{"text":"Hancurkanlah pinggang orang-orang yang akan bangkit untuk melawannya dan","poem":1},{"text":"orang-orang yang membencinya sehingga mereka tidak akan pernah bangkit lagi.”","poem":2}]},{"type":"heading","content":["Berkat untuk Benyamin"]},{"type":"verse","number":12,"content":["Mengenai Benyamin, dia berkata,",{"lineBreak":true},{"text":"“Biarlah kekasih TUHAN berada","poem":1},{"text":"dengan aman oleh-Nya,","poem":2},{"text":"yang melindunginya sepanjang hari","poem":1},{"text":"dan tinggallah ia di antara bahu-Nya.”","poem":2}]},{"type":"heading","content":["Berkat untuk Yusuf"]},{"type":"verse","number":13,"content":["Mengenai Yusuf, dia berkata:",{"lineBreak":true},{"text":"“Diberkatilah negerinya oleh TUHAN","poem":1},{"text":"dengan yang terbaik dari surga, dengan embun,","poem":2},{"lineBreak":true},{"text":"dan dari kedalaman yang berada di bawah.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Dengan hasil yang terbaik dari matahari,","poem":1},{"text":"dan dengan hasil yang terbaik yang dihasilkan dari bulan.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Dengan hal-hal yang terbaik dari pegunungan kuno,","poem":1},{"text":"dan dengan hal-hal yang terbaik dari bukit-bukit yang kekal.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Dengan hal-hal yang terbaik dari bumi serta segala isinya,","poem":1},{"text":"dan perkenan-Nya yang berdiam di semak-semak.","poem":2},{"text":"Biarlah semua masuk ke atas kepala Yusuf dan","poem":1},{"text":"ke atas mahkota kepala orang yang teristimewa di antara saudara-saudaranya.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Anak sapi sulung adalah kehormatannya,","poem":1},{"text":"tanduk-tanduknya seperti tanduk sapi liar.","poem":2},{"text":"Dengan itu, ia akan menanduk bangsa-bangsa","poem":1},{"text":"sampai ke ujung bumi.","poem":2},{"text":"Itulah orang Efraim yang berjumlah puluhan ribu,","poem":1},{"text":"dan orang Manasye yang berjumlah ribuan.”","poem":2}]},{"type":"heading","content":["Berkat untuk Zebulon dan Isakhar"]},{"type":"verse","number":18,"content":["Mengenai Zebulon, dia berkata,",{"lineBreak":true},{"text":"“Bersukacitalah Zebulon, pada saat kamu dalam perjalanan-perjalananmu","poem":1},{"text":"dan Isakhar dalam kemah rumahmu.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Mereka akan memanggil bangsa-bangsa ke gunungnya.","poem":1},{"text":"Di sana, mereka akan memberikan kurban persembahan yang benar.","poem":2},{"text":"Mereka akan mengambil kekayaan dari laut","poem":1},{"text":"dan harta karun yang tersembunyi dari pasir.”","poem":2}]},{"type":"heading","content":["Berkat untuk Gad"]},{"type":"verse","number":20,"content":["Mengenai Gad, dia berkata,",{"lineBreak":true},{"text":"“Berbahagialah orang yang memperluas tanah Gad!","poem":1},{"text":"Ia berbaring seperti singa yang hendak","poem":2},{"lineBreak":true},{"text":"mengoyakkan lengan dan batok kepala.","poem":2}]},{"type":"verse","number":21,"content":[{"text":"Kemudian, ia memilih bagian yang pertama untuk dirinya sendiri","poem":1},{"text":"karena di sana terdapat bagian pemimpin.","poem":2},{"text":"Dan, datanglah para pemimpin umat kepadanya.","poem":1},{"text":"Ia melaksanakan keadilan TUHAN","poem":2},{"lineBreak":true},{"text":"dan hukum-hukum-Nya dengan Israel.”","poem":2}]},{"type":"heading","content":["Berkat untuk Dan"]},{"type":"verse","number":22,"content":["Mengenai Dan, dia berkata,",{"lineBreak":true},{"text":"“Dan adalah singa muda","poem":1},{"text":"yang melompat keluar dari Basan.”","poem":2}]},{"type":"heading","content":["Berkat untuk Naftali"]},{"type":"verse","number":23,"content":["Mengenai Naftali, dia berkata,",{"lineBreak":true},{"text":"“Ya Naftali, dilimpahkan dengan perkenanan","poem":1},{"text":"dan penuh berkat dari TUHAN,","poem":2},{"lineBreak":true},{"text":"milikilah wilayah barat dan selatan.”","poem":2}]},{"type":"heading","content":["Berkat untuk Asyer"]},{"type":"verse","number":24,"content":["Mengenai Asyer, dia berkata,",{"lineBreak":true},{"text":"“Asyerlah yang paling diberkati dari antara anak laki-laki.","poem":1},{"text":"Biarlah ia menjadi kesayangan di antara saudara-saudaranya","poem":2},{"lineBreak":true},{"text":"dan biarlah kakinya dicelupkan dalam minyak.","poem":2}]},{"type":"verse","number":25,"content":[{"text":"Besi dan perunggu akan menjadi palang pintumu.","poem":1},{"text":"Selama hidupmu kamu akan mendapat ketenteraman.”","poem":2}]},{"type":"heading","content":["Musa Memberikan Pujian kepada Allah"]},{"type":"verse","number":26,"content":[{"text":"“Tidak ada yang seperti Allah Yesyurun,","poem":1},{"text":"yang menunggangi langit untuk menolongmu dan","poem":2},{"lineBreak":true},{"text":"melintasi awan-awan dalam kemegahan-Nya.","poem":2}]},{"type":"verse","number":27,"content":[{"text":"Allah yang kekal","poem":1},{"text":"adalah tempat perlindunganmu","poem":2},{"text":"dan di bawahnya adalah","poem":1},{"text":"lengan yang kekal.","poem":2},{"text":"Dia mengusir musuh dari hadapanmu,","poem":1},{"text":"dan berkata, ‘Hancurkanlah.’","poem":2}]},{"type":"verse","number":28,"content":[{"text":"Israel akan tinggal dengan aman.","poem":1},{"text":"Mata air Yakub tinggal sendiri","poem":2},{"text":"di ladang gandum dan ladang anggur.","poem":1},{"text":"Langitnya pun akan memberikan embun.","poem":2}]},{"type":"verse","number":29,"content":[{"text":"Berbahagialah kamu, hai Israel.","poem":1},{"text":"Siapa yang akan sepertimu?","poem":2},{"text":"Sebuah bangsa yang diselamatkan oleh TUHAN","poem":1},{"text":"sebagai perisai penolongmu","poem":2},{"lineBreak":true},{"text":"dan pedang kejayaanmu.","poem":2},{"text":"Sehingga, musuh-musuhmu takut terhadapmu","poem":1},{"text":"kamu akan menginjak tempat-tempat mereka yang tinggi.”","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/DEU/33.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/DEU/34.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/DEU/32.json","previousChapterAudioLinks":{},"numberOfVerses":29}