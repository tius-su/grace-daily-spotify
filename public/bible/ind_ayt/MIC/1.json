{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"MIC","translationId":"ind_ayt","name":"MIKHA","commonName":"MIKHA","title":"Mikha","order":33,"numberOfChapters":7,"sha256":"f705f0f00178dca0d8eb3aa04c7bab906dce4818786c08c96eae2f7e00ff24da","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/MIC/1.json","lastChapterNumber":7,"lastChapterApiLink":"/api/ind_ayt/MIC/7.json","totalNumberOfVerses":105},"chapter":{"number":1,"content":[{"type":"heading","content":["Pendahuluan"]},{"type":"verse","number":1,"content":["Firman TUHAN yang datang kepada Mikha, orang Moresyet, pada zaman Yotam, Ahas, dan Hizkia, raja-raja Yehuda, yang ia lihat tentang Samaria dan Yerusalem."]},{"type":"line_break"},{"type":"heading","content":["Samaria dan Israel Akan Dihukum"]},{"type":"verse","number":2,"content":[{"text":"Dengarlah, hai bangsa-bangsa semua!","poem":1},{"text":"Perhatikanlah, bumi dan segala isinya!","poem":2},{"text":"Biarlah Tuhan ALLAH menjadi saksi,","poem":1},{"text":"Tuhan dari Bait-Nya yang kudus.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Sebab, lihat TUHAN keluar dari tempat-Nya,","poem":1},{"text":"dan turun menjejak di atas bukit-bukit pengurbanan di bumi.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Gunung-gunung akan luluh di bawah-Nya,","poem":1},{"text":"lembah-lembah terbelah","poem":2},{"text":"seperti lilin di depan api,","poem":1},{"text":"seperti air tercurah dari lereng.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Semua ini terjadi karena pelanggaran Yakub","poem":1},{"text":"dan karena dosa keturunan Israel.","poem":2},{"text":"Apakah pelanggaran Yakub?","poem":1},{"text":"Bukankah Samaria?","poem":2},{"text":"Apakah bukit pengurbanan Yehuda?","poem":1},{"text":"Bukankah Yerusalem?","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Sebab, Aku akan membuat Samaria menjadi timbunan puing di padang,","poem":1},{"text":"menjadi tempat penanaman kebun anggur.","poem":2},{"text":"Aku akan menuangkan batu-batunya ke lembah,","poem":1},{"text":"dan akan menyingkap dasar-dasarnya.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Semua patungnya","poem":1},{"text":"akan diremukkan,","poem":2},{"text":"semua upah sundalnya akan dibakar dengan api,","poem":1},{"text":"dan segala berhalanya akan Kuhancurkan.","poem":2},{"text":"Sebab, semuanya itu dikumpulkan dari upah persundalannya","poem":1},{"text":"sehingga semua itu akan kembali menjadi upah dari persundalan.","poem":2}]},{"type":"heading","content":["Mikha Meratapi Yehuda dan Yerusalem"]},{"type":"verse","number":8,"content":[{"text":"Karena inilah, aku akan meratap dan meraung,","poem":1},{"text":"aku akan berjalan tanpa alas kaki dan telanjang.","poem":2},{"text":"Aku akan melolong seperti serigala,","poem":1},{"text":"dan berkabung seperti anak-anak burung unta.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Sebab, lukanya tidak dapat disembuhkan,","poem":1},{"text":"sudah menjalar ke Yehuda,","poem":2},{"text":"sampai ke pintu gerbang bangsaku,","poem":1},{"text":"ke Yerusalem!","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Jangan kabarkan di Gat,","poem":1},{"text":"jangan sekali-kali menangis!","poem":2},{"text":"Berguling-bergulinglah dalam debu","poem":1},{"text":"di Bet-Le-Afra!","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Berjalanlah, hai penduduk Safir,","poem":1},{"text":"dengan telanjang dan malu.","poem":2},{"text":"Penduduk Zaanan","poem":1},{"text":"tidak keluar","poem":2},{"text":"Ratapan Bet-Haezel","poem":1},{"text":"akan mengambil perlindungannya.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Sebab, dengan bimbang penduduk Marot","poem":1},{"text":"menantikan keadaan baik.","poem":2},{"text":"Sebab, malapetaka turun dari TUHAN","poem":1},{"text":"sampai ke pintu gerbang Yerusalem.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Pasanglah kereta pada kuda-kuda,","poem":1},{"text":"hai penduduk Lakhis!","poem":2},{"text":"Inilah awal dosa bagi putri Sion","poem":1},{"text":"karena padamu terdapat perbuatan pelanggaran Israel.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Sebab itu, berikanlah hadiah perpisahan","poem":1},{"text":"kepada Moresyet-Gat.","poem":2},{"text":"Rumah-rumah Akhzib akan menjadi tipu daya","poem":1},{"text":"bagi raja-raja Israel.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Lalu, aku akan mendatangkan penakluk kepadamu,","poem":1},{"text":"hai penduduk Maresya!","poem":2},{"text":"Kemuliaan Israel","poem":1},{"text":"akan sampai ke Adulam.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Cukur dan gundulilah kepalamu","poem":1},{"text":"karena anak-anak kesayanganmu!","poem":2},{"text":"Lebarkanlah kebotakanmu seperti elang,","poem":1},{"text":"sebab mereka pergi darimu ke dalam pembuangan.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/MIC/1.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/MIC/2.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/JON/4.json","previousChapterAudioLinks":{},"numberOfVerses":16}