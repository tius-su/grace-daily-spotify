{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"MIC","translationId":"ind_ayt","name":"MIKHA","commonName":"MIKHA","title":"Mikha","order":33,"numberOfChapters":7,"sha256":"f705f0f00178dca0d8eb3aa04c7bab906dce4818786c08c96eae2f7e00ff24da","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/MIC/1.json","lastChapterNumber":7,"lastChapterApiLink":"/api/ind_ayt/MIC/7.json","totalNumberOfVerses":105},"chapter":{"number":2,"content":[{"type":"heading","content":["Kutuk bagi Penindas"]},{"type":"verse","number":1,"content":[{"text":"Celakalah orang-orang yang merancang kejahatan","poem":1},{"text":"dan berbuat kekejian di tempat tidurnya!","poem":2},{"text":"Waktu hari masih fajar, mereka melakukannya","poem":1},{"text":"karena hal itu ada dalam kekuasaan tangannya.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Mereka menginginkan ladang,","poem":1},{"text":"lalu merampasnya,","poem":2},{"text":"dan rumah-rumah,","poem":1},{"text":"lalu mengambilnya.","poem":2},{"text":"Mereka menindas orang dan rumahnya,","poem":1},{"text":"bahkan seseorang dengan milik pusakanya!","poem":2}]},{"type":"verse","number":3,"content":["Sebab itu, beginilah firman TUHAN,",{"lineBreak":true},{"text":"“Lihat, Aku merencanakan malapetaka terhadap kaum ini,","poem":1},{"text":"sehingga kamu tidak dapat menghindarkan lehermu darinya.","poem":2},{"text":"Kamu tidak dapat lagi berjalan dengan angkuh,","poem":1},{"text":"sebab waktu itu adalah waktu malapetaka.”","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Pada hari itu, mereka akan mengangkat sindiran terhadap kamu,","poem":1},{"text":"dan memperdengarkan ratapan kesedihan, serta berkata,","poem":2},{"text":"“Kita telah dihancurleburkan!","poem":1},{"text":"Bagian bangsaku telah ditukar-Nya.","poem":2},{"text":"Betapa itu telah beralih dariku!","poem":1},{"text":"Ladang-ladang kita dibagikan kepada orang yang menawan kita.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Sebab itu, tidak akan ada bagimu orang yang melemparkan tali pengukur dengan undian","poem":1},{"text":"di dalam jemaat TUHAN!”","poem":2}]},{"type":"heading","content":["Mikha Tidak Boleh Bernubuat"]},{"type":"verse","number":6,"content":[{"text":"“Jangan mengucapkan nubuat,” kata mereka","poem":1},{"text":"Namun, jika mereka tidak bernubuat atas hal ini,","poem":2},{"lineBreak":true},{"text":"aib tidak akan berbalik","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Bukankah sudah dikatakan, hai keturunan Yakub?","poem":1},{"text":"Apakah Roh TUHAN kurang sabar?","poem":2},{"text":"Atau seperti inikah perbuatan-Nya?","poem":1},{"text":"Bukankah firman-Ku mengerjakan yang baik","poem":2},{"text":"bagi orang-orang yang hidup benar?","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Bahkan belum lama, umat-Ku bangkit seperti seorang musuh.","poem":1},{"text":"Kamu merebut jubah orang-orang yang berjalan dengan aman,","poem":2},{"text":"yang berbalik dari peperangan.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Istri-istri di antara umat-Ku kamu halau","poem":1},{"text":"dari rumah kesayangannya,","poem":2},{"text":"dari bayi-bayinya kamu mengambil semarak-Ku","poem":1},{"text":"untuk selama-lamanya.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Bangkitlah dan pergilah,","poem":1},{"text":"sebab ini bukan tempat perhentian bagimu.","poem":2},{"text":"Karena tercemar, itu akan dihancurkan","poem":1},{"text":"dengan kebinasaan yang tidak dapat dipulihkan.","poem":2}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"Jika seseorang datang mereka-reka","poem":1},{"text":"yang hampa dan dusta, berkata","poem":2},{"lineBreak":true},{"text":"‘Aku akan bernubuat kepadamu mengenai anggur dan arak,’","poem":2},{"text":"dialah yang pantas bernubuat","poem":1},{"text":"bagi bangsa ini!”","poem":2}]},{"type":"heading","content":["Janji TUHAN"]},{"type":"verse","number":12,"content":[{"text":"Aku tentu akan mengumpulkan kamu seluruhnya, hai Yakub.","poem":1},{"text":"Aku tentu akan menghimpun sisa-sisa orang Israel;","poem":2},{"text":"Aku akan menyatukan mereka bersama-sama seperti kambing domba dalam kandang,","poem":1},{"text":"seperti kawanan binatang","poem":2},{"text":"di tengah-tengah padang rumputnya","poem":1},{"text":"yang akan ramai dengan manusia!","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Seorang penerobos maju di hadapan mereka,","poem":1},{"text":"mereka akan menerobos melewati pintu gerbang dan berjalan keluar.","poem":2},{"text":"Raja akan berjalan di depan mereka,","poem":1},{"text":"TUHAN di kepala barisan.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/MIC/2.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/MIC/3.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/MIC/1.json","previousChapterAudioLinks":{},"numberOfVerses":13}