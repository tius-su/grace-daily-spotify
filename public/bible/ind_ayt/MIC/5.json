{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"MIC","translationId":"ind_ayt","name":"MIKHA","commonName":"MIKHA","title":"Mikha","order":33,"numberOfChapters":7,"sha256":"f705f0f00178dca0d8eb3aa04c7bab906dce4818786c08c96eae2f7e00ff24da","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/MIC/1.json","lastChapterNumber":7,"lastChapterApiLink":"/api/ind_ayt/MIC/7.json","totalNumberOfVerses":105},"chapter":{"number":5,"content":[{"type":"verse","number":1,"content":[{"text":"(4-14) “Sekarang, berkumpullah dalam barisan, hai putri-putri pasukan","poem":1},{"text":"pengepungan telah disiapkannya terhadap kita.","poem":2},{"text":"Dengan tongkat, mereka akan memukul","poem":1},{"text":"hakim Israel pada pipinya.”","poem":2}]},{"type":"line_break"},{"type":"heading","content":["Mesias Lahir di Betlehem"]},{"type":"verse","number":2,"content":[{"text":"(5-1) “Akan tetapi kamu, hai Betlehem Efrata,","poem":1},{"text":"kamu yang terkecil di antara kaum-kaum Yehuda,","poem":2},{"text":"darimu akan bangkit bagi-Ku","poem":1},{"text":"seseorang yang memerintah Israel,","poem":2},{"text":"yang permulaannya sejak purbakala,","poem":1},{"text":"semenjak dahulu kala.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"(5-2) “Oleh sebab itu, dia akan membiarkan mereka","poem":1},{"text":"sampai perempuan yang bersalin itu melahirkan.","poem":2},{"text":"Lalu, saudara-saudaranya yang tersisa akan kembali","poem":1},{"text":"kepada keturunan Israel.”","poem":2}]},{"type":"verse","number":4,"content":[{"text":"(5-3) “Dia akan bangkit dan menggembalakan mereka dengan kekuatan TUHAN,","poem":1},{"text":"dalam keagungan nama TUHAN,","poem":2},{"lineBreak":true},{"text":"Allah-Nya.","poem":2},{"text":"Mereka akan tinggal dengan aman","poem":1},{"text":"karena saat itu Dia menjadi besar sampai ke ujung bumi.”","poem":2}]},{"type":"verse","number":5,"content":[{"text":"(5-4) “Dia akan menjadi damai sejahtera.","poem":1},{"text":"Apabila Asyur masuk ke negeri kita,","poem":2},{"lineBreak":true},{"text":"dan menginjak istana kita,","poem":2},{"text":"kita akan membangkitkan tujuh gembala untuk melawannya,","poem":1},{"text":"serta delapan pemimpin manusia.”","poem":2}]},{"type":"verse","number":6,"content":[{"text":"(5-5) “Mereka akan meremukkan","poem":1},{"text":"negeri Asyur dengan pedang,","poem":2},{"lineBreak":true},{"text":"dan negeri Nimrod di pintu-pintu masuk.","poem":2},{"text":"Dia akan membebaskan kita dari Asyur,","poem":1},{"text":"ketika dia masuk ke negeri kita dan menginjak daerah kita.”","poem":2}]},{"type":"verse","number":7,"content":[{"text":"(5-6) “Dan, sisa-sisa Yakub akan ada di tengah-tengah banyak bangsa,","poem":1},{"text":"seperti embun dari TUHAN,","poem":2},{"text":"seperti hujan lebat yang turun di atas tumbuh-tumbuhan,","poem":1},{"text":"yang tidak menanti-nantikan orang dan tidak menunggu anak-anak manusia.”","poem":2}]},{"type":"verse","number":8,"content":[{"text":"(5-7) “Sisa-sisa keturunan Yakub akan ada di antara suku-suku bangsa,","poem":1},{"text":"di tengah-tengah banyak bangsa, seperti singa di antara binatang-binatang hutan,","poem":2},{"text":"seperti singa muda di antara kawanan kambing domba.","poem":1},{"text":"Ke mana pun ia pergi,","poem":2},{"text":"ia akan menginjak-injak dan mencabik,","poem":1},{"text":"dan tidak ada yang akan melepaskan.”","poem":2}]},{"type":"verse","number":9,"content":[{"text":"(5-8) “Tanganmu akan diangkat mengatasi lawan-lawanmu","poem":1},{"text":"dan semua musuhmu akan dilenyapkan.”","poem":2}]},{"type":"verse","number":10,"content":[{"text":"(5-9) “Pada hari itu akan terjadi,”","poem":1},{"text":"firman TUHAN, “Aku akan melenyapkan kuda-kudamu dari antaramu,","poem":2},{"lineBreak":true},{"text":"dan membinasakan kereta-keretamu.”","poem":2}]},{"type":"verse","number":11,"content":[{"text":"(5-10) “Aku akan melenyapkan kota-kota di negerimu","poem":1},{"text":"dan akan menghancurkan semua kubu-kubumu.”","poem":2}]},{"type":"verse","number":12,"content":[{"text":"(5-11) “Aku akan melenyapkan alat-alat sihir dari tanganmu,","poem":1},{"text":"dan kamu tidak akan lagi memiliki peramal-peramal.”","poem":2}]},{"type":"verse","number":13,"content":[{"text":"(5-12) “Aku akan memusnahkan patung-patungmu,","poem":1},{"text":"dan tugu-tugu berhalamu dari tengah-tengahmu","poem":2},{"lineBreak":true},{"text":"sehingga kamu tidak akan lagi menyembah kepada buatan tanganmu.”","poem":2}]},{"type":"verse","number":14,"content":[{"text":"(5-13) “Aku akan mencabut Asyeramu dari tengah-tengahmu,","poem":1},{"text":"dan menghancurkan kota-kotamu.”","poem":2}]},{"type":"verse","number":15,"content":[{"text":"(5-14) “Aku akan membuat pembalasan dalam murka dan amarah-Ku","poem":1},{"text":"terhadap bangsa-bangsa yang tidak mau mendengarkan.”","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/MIC/5.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/MIC/6.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/MIC/4.json","previousChapterAudioLinks":{},"numberOfVerses":15}