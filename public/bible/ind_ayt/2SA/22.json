{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"2SA","translationId":"ind_ayt","name":"2 SAMUEL","commonName":"2 SAMUEL","title":"2 Samuel","order":10,"numberOfChapters":24,"sha256":"fa569d776688e00bb73589789e711254252d057974265e5f26885abc4ee3ddc4","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/2SA/1.json","lastChapterNumber":24,"lastChapterApiLink":"/api/ind_ayt/2SA/24.json","totalNumberOfVerses":695},"chapter":{"number":22,"content":[{"type":"heading","content":["Nyanyian Pujian Daud kepada TUHAN"]},{"type":"verse","number":1,"content":["Daud mengucapkan perkataan nyanyian ini kepada TUHAN pada waktu TUHAN menyelamatkan dia dari tangan semua musuhnya dan dari tangan Saul."]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"Dia berkata, “TUHAN adalah bukit batuku, benteng pertahananku, dan penyelamatku.","poem":1}]},{"type":"verse","number":3,"content":[{"text":"Allahku, bukit batuku, tempat aku berlindung,","poem":2},{"text":"perisaiku, tanduk keselamatanku,","poem":1},{"text":"kota bentengku, tempat perlindunganku,","poem":2},{"text":"dan Juru Selamatku.","poem":1},{"text":"Engkau menyelamatkan aku dari kekerasan.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Aku berseru kepada TUHAN yang layak dipuji,","poem":1},{"text":"maka aku diselamatkan dari musuh-musuhku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"Sesungguhnya gelora-gelora maut melingkupi aku,","poem":1},{"text":"dan arus-arus kejahatan meliputiku.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Tali-tali dunia orang mati meliliti aku,","poem":1},{"text":"dan jerat-jerat kematian mengadang aku.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Dalam kesesakan, aku berseru kepada TUHAN,","poem":1},{"text":"kepada Allahku, aku berseru.","poem":2},{"text":"Dari Bait-Nya, Dia mendengar suaraku,","poem":1},{"text":"dan teriakanku sampai di telinga-Nya.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Lalu, bumi berguncang dan bergetar,","poem":1},{"text":"dasar-dasar langit gemetar dan berguncang","poem":2},{"lineBreak":true},{"text":"karena Dia marah.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Asap naik dari lubang hidungnya,","poem":1},{"text":"api yang melahap keluar dari mulut-Nya,","poem":2},{"lineBreak":true},{"text":"bara yang menyala-nyala keluar dari diri-Nya.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Dia membungkukkan langit,","poem":1},{"text":"lalu turun, kegelapan ada di bawah kaki-Nya.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Dia mengendarai kerub,","poem":1},{"text":"lalu terbang, dan terlihat di atas sayap-sayap angin.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Dia membuat kegelapan menjadi pondok-pondok-Nya di sekelilingnya,","poem":1},{"text":"air yang gelap, dan awan-awan tebal.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Dari kilauan di hadapan-Nya,","poem":1},{"text":"bara api menyala.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"TUHAN mengguruh dari langit,","poem":1},{"text":"Yang Mahatinggi memperdengarkan suara-Nya.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Dia melepaskan anak-anak panah dan menyerakkan mereka,","poem":1},{"text":"kilat-kilat, dan mengacaukan mereka.","poem":2}]},{"type":"line_break"},{"type":"verse","number":16,"content":[{"text":"Alur-alur laut terlihat, dasar-dasar bumi tersingkap,","poem":1},{"text":"oleh karena teguran TUHAN,","poem":2},{"text":"karena embusan napas dari lubang hidung-Nya.","poem":1}]},{"type":"line_break"},{"type":"verse","number":17,"content":[{"text":"Dia menjangkau dari tempat tinggi,","poem":1},{"text":"Dia mengambil aku, Dia menarikku dari limpahan air.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Dia menyelamatkanku dari musuhku yang kuat, dari mereka yang membenciku,","poem":1},{"text":"Sebab, mereka terlalu kuat bagiku.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Mereka mengadangku pada hari kesengsaraanku,","poem":1},{"text":"tetapi TUHAN adalah penopangku.","poem":2}]},{"type":"verse","number":20,"content":[{"text":"Dia membawaku keluar ke tempat yang lapang,","poem":1},{"text":"Dia menyelamatkan aku, sebab Dia berkenan kepadaku.","poem":2}]},{"type":"verse","number":21,"content":[{"text":"TUHAN mengganjar aku sesuai dengan kebenaranku,","poem":1},{"text":"sesuai kesucian tanganku, Dia membalasku.","poem":2}]},{"type":"verse","number":22,"content":[{"text":"Sebab, aku mengikuti jalan TUHAN,","poem":1},{"text":"dan tidak berbuat jahat terhadap Allahku.","poem":2}]},{"type":"verse","number":23,"content":[{"text":"Sebab, semua hukum-Nya ada di hadapanku,","poem":1},{"text":"dan untuk ketetapan-ketetapan-Nya, aku tidak menyimpang darinya.","poem":2}]},{"type":"verse","number":24,"content":[{"text":"Aku tidak bercela di hadapan-Nya,","poem":1},{"text":"dan aku menjaga diriku dari kesalahan.","poem":2}]},{"type":"verse","number":25,"content":[{"text":"Karena itu, TUHAN membalasku sesuai dengan kebenaranku,","poem":1},{"text":"sesuai dengan kesucianku di depan mata-Nya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":26,"content":[{"text":"Terhadap orang yang murah hati, Engkau berlaku murah hati,","poem":1},{"text":"Terhadap orang yang tidak bercela, Engkau berlaku tidak bercela.","poem":2}]},{"type":"verse","number":27,"content":[{"text":"Terhadap orang yang suci, Engkau berlaku suci,","poem":1},{"text":"terhadap orang yang jahat, Engkau berbelit-belit.","poem":2}]},{"type":"verse","number":28,"content":[{"text":"Engkau menyelamatkan bangsa yang tertindas,","poem":1},{"text":"tetapi mata-Mu memandang orang yang tinggi hati,","poem":2},{"lineBreak":true},{"text":"supaya Engkau merendahkan dia.","poem":2}]},{"type":"verse","number":29,"content":[{"text":"Sebab, Engkaulah pelitaku, ya TUHAN,","poem":1},{"text":"dan TUHAN menyinari kegelapanku.","poem":2}]},{"type":"verse","number":30,"content":[{"text":"Sebab, bersama Engkau, aku dapat berlari menerobos gerombolan,","poem":1},{"text":"bersama Allahku, aku dapat melompati tembok.","poem":2}]},{"type":"line_break"},{"type":"verse","number":31,"content":[{"text":"Jalan Allah adalah sempurna,","poem":1},{"text":"perkataan TUHAN itu teruji.","poem":2},{"lineBreak":true},{"text":"Dia adalah perisai bagi semua orang yang berlindung kepada-Nya.","poem":2}]},{"type":"verse","number":32,"content":[{"text":"Sebab, siapakah Allah, selain TUHAN?","poem":1},{"text":"Siapakah gunung batu, selain Allah kita?","poem":2}]},{"type":"verse","number":33,"content":[{"text":"Allah adalah tempat perlindunganku yang kuat,","poem":1},{"text":"Dia membuat jalanku tidak bercela.","poem":2}]},{"type":"verse","number":34,"content":[{"text":"Dia membuat kakiku seperti kaki rusa,","poem":1},{"text":"dan membuat aku berdiri di tempat-tempat tinggi.","poem":2}]},{"type":"verse","number":35,"content":[{"text":"Dia melatih tanganku berperang","poem":1},{"text":"supaya lenganku dapat melenturkan busur tembaga.","poem":2}]},{"type":"line_break"},{"type":"verse","number":36,"content":[{"text":"Engkau memberikan perisai keselamatan-Mu kepadaku,","poem":1},{"text":"dan kebaikan-Mu membuatku besar.","poem":2}]},{"type":"verse","number":37,"content":[{"text":"Engkau memperbesar langkah-langkah di bawahku","poem":1},{"text":"sehingga mata kakiku tidak tergelincir.","poem":2}]},{"type":"verse","number":38,"content":[{"text":"Aku mengejar musuh-musuhku dan membinasakan mereka,","poem":1},{"text":"aku tidak berbalik sampai mereka dimusnahkan.","poem":2}]},{"type":"verse","number":39,"content":[{"text":"Aku memusnahkan dan meremukkan mereka","poem":1},{"text":"sehingga mereka tidak bisa bangkit lagi.","poem":2},{"text":"Mereka jatuh","poem":1},{"text":"di bawah kakiku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":40,"content":[{"text":"Engkau mengikat pinggangku dengan kekuatan untuk berperang.","poem":1},{"text":"Engkau menundukkan di bawahku orang yang bangkit melawan aku.","poem":2}]},{"type":"verse","number":41,"content":[{"text":"Engkau membuat lari musuh-musuh yang menentangku,","poem":1},{"text":"orang-orang yang membenciku kubinasakan.","poem":2}]},{"type":"verse","number":42,"content":[{"text":"Mereka berteriak,","poem":1},{"text":"tetapi tidak ada yang menyelamatkan.","poem":2},{"text":"Mereka berteriak kepada TUHAN,","poem":1},{"text":"tetapi Dia tidak menjawab.","poem":2}]},{"type":"verse","number":43,"content":[{"text":"Aku melumat mereka","poem":1},{"text":"seperti debu di atas tanah.","poem":2},{"text":"Seperti lumpur di jalanan,","poem":1},{"text":"aku menumbuk dan menginjak-injak mereka.","poem":2}]},{"type":"line_break"},{"type":"verse","number":44,"content":[{"text":"Engkau meluputkan aku dari perselisihan bangsaku,","poem":1},{"text":"Engkau menjagaku sebagai kepala atas bangsa-bangsa.","poem":2},{"lineBreak":true},{"text":"Bangsa yang tidak kukenal akan melayani aku.","poem":2}]},{"type":"verse","number":45,"content":[{"text":"Orang-orang asing tunduk kepadaku,","poem":1},{"text":"setelah telinga mereka mendengar tentangku, mereka taat kepadaku.","poem":2}]},{"type":"verse","number":46,"content":[{"text":"Orang-orang asing menjadi layu,","poem":1},{"text":"dan keluar dari kota kubunya dengan gemetar.","poem":2}]},{"type":"line_break"},{"type":"verse","number":47,"content":[{"text":"TUHAN itu hidup!","poem":1},{"text":"Terpujilah bukit batuku.","poem":2},{"text":"Ditinggikanlah Allah,","poem":1},{"text":"bukit batu keselamatanku.","poem":2}]},{"type":"verse","number":48,"content":[{"text":"Allah yang memberikan pembalasan bagiku,","poem":1},{"text":"dan membawa bangsa-bangsa tunduk di bawahku.","poem":2}]},{"type":"verse","number":49,"content":[{"text":"Dia membebaskanku dari musuh-musuhku.","poem":1},{"lineBreak":true},{"text":"Engkau meninggikan aku atas mereka","poem":1},{"text":"yang bangkit melawan aku.","poem":2},{"text":"Dari orang-orang kejam,","poem":1},{"text":"Engkau menyelamatkan aku.","poem":2}]},{"type":"verse","number":50,"content":[{"text":"Karena itu, aku akan mengucap syukur kepada-Mu, ya TUHAN,","poem":1},{"text":"di antara bangsa-bangsa,","poem":2},{"lineBreak":true},{"text":"aku akan menyanyikan pujian bagi Nama-Mu.","poem":2}]},{"type":"line_break"},{"type":"verse","number":51,"content":[{"text":"Dia mengaruniakan keselamatan yang besar kepada raja-Nya,","poem":1},{"text":"dan menunjukkan kasih setia-Nya kepada orang yang diurapi-Nya,","poem":2},{"lineBreak":true},{"text":"kepada Daud dan keturunannya sampai selamanya.”","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/2SA/22.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/2SA/23.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/2SA/21.json","previousChapterAudioLinks":{},"numberOfVerses":51}