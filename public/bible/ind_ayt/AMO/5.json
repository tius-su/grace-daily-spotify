{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"AMO","translationId":"ind_ayt","name":"AMOS","commonName":"AMOS","title":"Amos","order":30,"numberOfChapters":9,"sha256":"7c1718bece7d0241959ada8bf360aa6caab7f9745fc8fc00c8e9736b5402568d","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/AMO/1.json","lastChapterNumber":9,"lastChapterApiLink":"/api/ind_ayt/AMO/9.json","totalNumberOfVerses":146},"chapter":{"number":5,"content":[{"type":"heading","content":["Nyanyian Duka bagi Israel"]},{"type":"verse","number":1,"content":["Dengarlah firman ini, yang kuucapkan mengenai kamu dalam sebuah ratapan, hai kaum Israel,"]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"“Sudah rebah, dan takkan bangkit lagi","poem":1},{"text":"anak dara Israel.","poem":2},{"text":"Ia ditolak dari tanahnya sendiri,","poem":1},{"text":"tidak ada orang yang membangkitkannya.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":["Sebab, beginilah firman Tuhan ALLAH,",{"lineBreak":true},{"text":"“Kota yang maju perang dengan seribu orang,","poem":1},{"text":"akan tersisa seratus orang,","poem":2},{"text":"dan yang maju perang dengan seratus orang","poem":1},{"text":"akan tersisa sepuluh orang","poem":2},{"lineBreak":true},{"text":"dari kaum Israel.”","poem":2}]},{"type":"heading","content":["TUHAN, Jalan Menuju Hidup"]},{"type":"verse","number":4,"content":["Sebab, beginilah firman TUHAN kepada kaum Israel,",{"lineBreak":true},{"text":"“Carilah Aku, dan hiduplah!","poem":1}]},{"type":"verse","number":5,"content":[{"text":"Jangan mencari Betel,","poem":2},{"text":"jangan masuk ke Gilgal,","poem":1},{"text":"atau menyeberang ke Bersyeba.","poem":2},{"text":"Sebab, Gilgal pasti akan pergi ke pembuangan,","poem":1},{"text":"dan Betel akan sia-sia.”","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Carilah TUHAN, dan hiduplah.","poem":1},{"text":"Atau, Dia meletus seperti api melawan keturunan Yusuf,","poem":2},{"lineBreak":true},{"text":"dan api melahapnya dengan tidak seorang pun dapat memadamkannya untuk Betel.”","poem":2}]},{"type":"heading","content":["Melawan Ketidakadilan"]},{"type":"verse","number":7,"content":[{"text":"Kamu yang mengubah keadilan menjadi kepahitan,","poem":1},{"text":"dan melemparkan kebenaran ke tanah.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Dia menciptakan pleiades dan bintang orion,","poem":1},{"lineBreak":true},{"text":"yang mengubah kegelapan yang pekat menjadi pagi,","poem":1},{"text":"dan menggelapkan siang menjadi malam.","poem":2},{"text":"Dia memanggil air laut dan mencurahkannya ke atas permukaan bumi —","poem":1},{"text":"TUHAN, itulah nama-Nya.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Dia membuat kebinasaan memantul terhadap yang kuat","poem":1},{"text":"sehingga kebinasaan datang ke atas benteng.”","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Mereka membenci orang yang menegur","poem":1},{"text":"di pintu gerbang,","poem":2},{"text":"dan mereka jijik kepada orang yang berkata benar.","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"Karena kamu menginjak-injak orang miskin","poem":1},{"text":"dan mengambil pajak gandum darinya,","poem":2},{"text":"maka sekalipun kamu membangun rumah dari batu pahat,","poem":1},{"text":"kamu takkan menempatinya.","poem":2},{"text":"Sekalipun kamu menanam kebun anggur yang indah,","poem":1},{"text":"kamu takkan minum air anggurnya.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Sebab, Aku tahu betapa banyak pelanggaranmu,","poem":1},{"text":"dan betapa besar dosamu,","poem":2},{"text":"kamu yang menindas orang benar,","poem":1},{"text":"yang menerima uang suap,","poem":2},{"text":"dan menyingkirkan orang-orang miskin di pintu gerbang.","poem":1}]},{"type":"verse","number":13,"content":[{"lineBreak":true},{"text":"Oleh sebab itu, orang-orang yang bijaksana akan tetap berdiam diri saat itu,","poem":1},{"text":"karena saat itu adalah waktu yang jahat.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Carilah yang baik, jangan yang jahat,","poem":1},{"text":"supaya kamu hidup.","poem":2},{"text":"TUHAN, Allah semesta alam,","poem":1},{"text":"akan menyertaimu seperti yang sudah kamu katakan.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Bencilah kejahatan dan cintailah kebaikan,","poem":1},{"text":"tegakkan keadilan di pintu gerbang!","poem":2},{"text":"Mungkin, TUHAN, Allah semesta alam","poem":1},{"text":"akan berbelaskasihan kepada sisa-sisa keturunan Yusuf.","poem":2}]},{"type":"verse","number":16,"content":["Karena itu, beginilah firman TUHAN, Allah semesta alam:",{"lineBreak":true},{"text":"“Akan ada ratapan di semua jalan,","poem":1},{"text":"di setiap lorong orang-orang akan berkata: Aduh! Aduh!","poem":2},{"text":"Mereka akan memanggil petani untuk berkabung,","poem":1},{"text":"dan tukang pandai meratap untuk meratap.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Di semua kebun anggur akan ada ratapan,","poem":1},{"text":"karena Aku akan melintas di tengah-tengahmu,”","poem":2},{"text":"firman TUHAN.","poem":1}]},{"type":"heading","content":["Hari TUHAN"]},{"type":"verse","number":18,"content":[{"text":"Celakalah orang-orang yang menginginkan hari TUHAN!","poem":1},{"text":"Untuk apa hari TUHAN bagimu?","poem":2},{"text":"Itu adalah kegelapan,","poem":1},{"text":"bukan terang!","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Itu akan sama seperti orang yang lari dari seekor singa,","poem":1},{"text":"lalu seekor beruang mengadangnya,","poem":2},{"text":"atau saat dia masuk ke rumah,","poem":1},{"text":"menyadarkan tangannya ke dinding,","poem":2},{"lineBreak":true},{"text":"dan seekor ular memagutnya.","poem":2}]},{"type":"verse","number":20,"content":[{"text":"Bukankah hari TUHAN itu betul-betul kegelapan, dan bukan terang,","poem":1},{"text":"pekat kelam, tanpa cahaya apa pun?","poem":2}]},{"type":"heading","content":["TUHAN Menolak Ibadah Israel"]},{"type":"verse","number":21,"content":[{"text":"“Aku membenci,","poem":1},{"text":"Aku menghina hari-hari rayamu,","poem":2},{"lineBreak":true},{"text":"dan Aku tidak menyukai pertemuan agamawimu.","poem":2}]},{"type":"verse","number":22,"content":[{"text":"Sekalipun kamu mempersembahkan kurban-kurban bakaran dan kurban-kurban sajian,","poem":1},{"text":"Aku takkan menerimanya.","poem":2},{"text":"Demikian juga kurban pendamaian dari lemakmu,","poem":1},{"text":"Aku takkan memandang-Nya.","poem":2}]},{"type":"verse","number":23,"content":[{"text":"Singkirkanlah dari-Ku suara nyanyian-nyanyianmu,","poem":1},{"text":"Aku tidak akan mendengarkan musik harpamu.","poem":2}]},{"type":"verse","number":24,"content":[{"text":"Akan tetapi, biarlah keadilan mengalir seperti air","poem":1},{"text":"dan kebenaran seperti sungai yang senantiasa mengalir.”","poem":2}]},{"type":"verse","number":25,"content":[{"text":"“Pernahkah kamu mempersembahkan kurban sembelihan","poem":1},{"text":"dan persembahan selama empat puluh tahun di padang gurun, hai kaum Israel?","poem":2}]},{"type":"verse","number":26,"content":[{"text":"Namun, kamu mengangkut Sakut, rajamu,","poem":1},{"text":"dan Kewan, dewa bintangmu,","poem":2},{"text":"patung-patung yang kamu buat","poem":1},{"text":"bagi dirimu sendiri.","poem":2}]},{"type":"verse","number":27,"content":[{"text":"Karena itu, Aku akan mengirim kamu ke pembuangan","poem":1},{"text":"lebih jauh dari Damsyik,”","poem":2},{"text":"firman TUHAN, yang nama-Nya adalah Allah semesta alam.","poem":1}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/AMO/5.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/AMO/6.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/AMO/4.json","previousChapterAudioLinks":{},"numberOfVerses":27}