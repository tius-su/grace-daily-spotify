{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"AMO","translationId":"ind_ayt","name":"AMOS","commonName":"AMOS","title":"Amos","order":30,"numberOfChapters":9,"sha256":"7c1718bece7d0241959ada8bf360aa6caab7f9745fc8fc00c8e9736b5402568d","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/AMO/1.json","lastChapterNumber":9,"lastChapterApiLink":"/api/ind_ayt/AMO/9.json","totalNumberOfVerses":146},"chapter":{"number":1,"content":[{"type":"heading","content":["Pendahuluan"]},{"type":"verse","number":1,"content":["Perkataan dari Amos, salah seorang di antara para gembala dari Tekoa, yang dia lihat mengenai Israel pada masa pemerintahan Uzia, Raja Yehuda, dan pada masa pemerintahan Yerobeam, anak Yoas, Raja Israel, dua tahun sebelum gempa bumi."]},{"type":"heading","content":["Hukuman bagi Bangsa-Bangsa Lain"]},{"type":"verse","number":2,"content":["Amos berkata,",{"lineBreak":true},{"text":"“TUHAN mengaum dari Sion,","poem":1},{"text":"dan Dia memperdengarkan suara-Nya dari Yerusalem;","poem":2},{"text":"padang rumput para penggembala berkabung,","poem":1},{"text":"dan puncak Gunung Karmel layu.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":["Inilah firman TUHAN,",{"lineBreak":true},{"text":"“Untuk tiga pelanggaran Damsyik, bahkan empat,","poem":1},{"text":"Aku takkan menarik kembali hukumannya.","poem":2},{"text":"Sebab, mereka telah mengirik Gilead","poem":1},{"text":"dengan pengirik dari besi,","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Karena itu, Aku akan mengirimkan api ke dalam istana Hazael","poem":1},{"text":"yang akan melahap istana-istana Benhadad.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Aku akan mematahkan palang gerbang pintu Damsyik,","poem":1},{"text":"dan melenyapkan penduduk Lembah Awen,","poem":2},{"text":"dan orang yang memegang tongkat kerajaan dari Bet-Eden;","poem":1},{"text":"dan bangsa Aram akan diangkut ke pembuangan di Kir,”","poem":2},{"lineBreak":true},{"text":"firman TUHAN.","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":["Inilah firman TUHAN,",{"lineBreak":true},{"text":"“Untuk tiga pelanggaran Gaza, bahkan empat,","poem":1},{"text":"Aku takkan menarik kembali hukumannya.","poem":2},{"text":"Sebab, mereka telah menangkap","poem":1},{"text":"semua orang buangan,","poem":2},{"lineBreak":true},{"text":"dan menyerahkan mereka kepada Edom,","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Aku akan mengirimkan api","poem":1},{"text":"ke atas tembok Gaza","poem":2},{"lineBreak":true},{"text":"yang akan melahap istana-istananya.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Aku akan melenyapkan penduduk Asdod,","poem":1},{"text":"dan dia yang memegang tongkat kerajaan Askelon,","poem":2},{"text":"Aku akan mengacungkan tanganku","poem":1},{"text":"melawan Ekron,","poem":2},{"text":"sisa-sisa orang Filistin akan binasa,”","poem":1},{"text":"firman Tuhan ALLAH.","poem":2}]},{"type":"line_break"},{"type":"verse","number":9,"content":["Inilah firman TUHAN,",{"lineBreak":true},{"text":"“Untuk tiga pelanggaran Tirus, bahkan empat,","poem":1},{"text":"Aku takkan menarik kembali hukumannya.","poem":2},{"text":"Sebab, mereka telah menyerahkan semua orang buangan","poem":1},{"text":"ke Edom,","poem":2},{"text":"dengan tidak mengingat perjanjian persaudaraan,","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Aku akan mengirimkan api ke atas tembok Tirus","poem":1},{"text":"yang akan melahap istana-istananya.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":11,"content":["Inilah firman Tuhan,",{"lineBreak":true},{"text":"“Untuk tiga pelanggaran Edom, bahkan empat,","poem":1},{"text":"Aku takkan menarik kembali hukumannya.","poem":2},{"text":"Sebab, mereka mengejar saudaranya dengan pedang","poem":1},{"text":"dan menyingkirkan semua belas kasihnya,","poem":2},{"text":"kemarahannya melanda terus-menerus,","poem":1},{"text":"dan menyimpan murkanya selamanya.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Jadi, Aku akan mengirimkan api ke atas Teman","poem":1},{"text":"yang akan melahap istana-istana Bozra.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":13,"content":["Inilah firman TUHAN,",{"lineBreak":true},{"text":"“Untuk tiga pelanggaran orang Amon, bahkan empat,","poem":1},{"text":"Aku takkan menarik kembali hukumannya.","poem":2},{"text":"Sebab, mereka merobek perut perempuan-perempuan yang mengandung di Gilead,","poem":1},{"text":"untuk meluaskan wilayah mereka.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Aku akan menyalakan api di tembok Raba","poem":1},{"text":"yang akan melahap istana-istananya,","poem":2},{"text":"dengan sorak-sorai pada masa peperangan,","poem":1},{"text":"dengan angin badai pada saat puting beliung.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Raja mereka harus pergi ke tempat pembuangan,","poem":1},{"text":"dia dengan pemimpin-pemimpinnya,”","poem":2},{"lineBreak":true},{"text":"firman TUHAN.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/AMO/1.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/AMO/2.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/JOL/3.json","previousChapterAudioLinks":{},"numberOfVerses":15}