{"translation":{"id":"ind_obo","name":"Alkitab Terjemahan Sederhana Indonesia, Edisi Ketiga","website":"https://ebible.org/Scriptures/details.php?id=ind","licenseUrl":"https://ebible.org/Scriptures/details.php?id=ind","licenseNotes":null,"shortName":"OBO","englishName":"Indonesian Bible (TSI)","language":"ind","textDirection":"ltr","sha256":"01f327eca48c79ec8c0410383f6df1df8f240ba4d772ad1c3a27491176ca3054","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_obo/books.json","numberOfBooks":48,"totalNumberOfChapters":762,"totalNumberOfVerses":20650,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PRO","translationId":"ind_obo","name":"Amsal","commonName":"Amsal","title":"Amsal","order":20,"numberOfChapters":31,"sha256":"dc25f208340ba80ce449d59e31ae16f296a5c2209ac0c48fbd43a9788ef60359","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_obo/PRO/1.json","lastChapterNumber":31,"lastChapterApiLink":"/api/ind_obo/PRO/31.json","totalNumberOfVerses":898},"chapter":{"number":4,"content":[{"type":"heading","content":["Nasihat bijak seorang ayah"]},{"type":"verse","number":1,"content":[{"text":"Anakku, dengarkanlah nasihat ayahmu.","poem":1},{"lineBreak":true},{"text":"Perhatikanlah agar engkau beroleh pengertian","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"sebab yang aku ajarkan adalah baik.","poem":1},{"lineBreak":true},{"text":"Janganlah meninggalkan bimbinganku.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Semasa kecil, waktu aku masih tinggal bersama ayah ibuku","poem":1},{"lineBreak":true},{"text":"sebagai anak tunggal mereka,","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"ayahku mengajarkan,","poem":1},{"text":"“Anakku, bila engkau setia","poem":3},{"lineBreak":true},{"text":"mengikuti pengajaran dan petunjuk-petunjukku,","poem":3},{"lineBreak":true},{"text":"engkau akan hidup bahagia.","poem":3}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Sambutlah Hikmat menjadi guru kehidupanmu.","poem":3},{"lineBreak":true},{"text":"Mintalah pengertian darinya.","poem":3},{"lineBreak":true},{"text":"Janganlah lupa dan jangan berpaling dari pengajaranku.","poem":3}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Sang Hikmat itu akan menjagamu","poem":3},{"lineBreak":true},{"text":"bila engkau mengasihi dia dan berpegang padanya.","poem":3}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Sang Hikmat adalah guru kehidupan yang terutama.","poem":3},{"lineBreak":true},{"text":"Mintalah darinya pengertian.","poem":3},{"lineBreak":true},{"text":"Ya, carilah kebijaksanaan semahal apa pun harganya.","poem":3}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Bila engkau menghargai Sang Hikmat,","poem":3},{"lineBreak":true},{"text":"dia akan menjadikanmu terhormat.","poem":3},{"lineBreak":true},{"text":"Bila engkau menjunjungnya,","poem":3},{"lineBreak":true},{"text":"dia akan memberimu nama baik.","poem":3}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Hikmat itu bagai mahkota yang indah megah pada kepalamu,","poem":3},{"lineBreak":true},{"text":"yang menjadikan engkau seorang yang dihormati.”","poem":3}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"Hai anakku, dengarkan dan terimalah pengajaranku","poem":1},{"lineBreak":true},{"text":"supaya panjanglah umurmu.","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"Kebijaksanaan yang aku ajarkan adalah jalan yang lurus.","poem":1}]},{"type":"verse","number":12,"content":[{"lineBreak":true},{"text":"Saat melangkah, engkau tak akan mendapat masalah,","poem":1},{"lineBreak":true},{"text":"dan saat berlari, engkau tak akan tersandung jatuh.","poem":1}]},{"type":"verse","number":13,"content":[{"lineBreak":true},{"text":"Berpeganglah pada didikanku","poem":1},{"lineBreak":true},{"text":"dan jangan meninggalkannya.","poem":1},{"lineBreak":true},{"text":"Taatilah, sebab itulah yang membuat hidupmu aman.","poem":1}]},{"type":"line_break"},{"type":"verse","number":14,"content":[{"text":"Jangan mengikuti perbuatan orang jahat,","poem":2},{"lineBreak":true},{"text":"apalagi menjadi seperti mereka.","poem":2}]},{"type":"verse","number":15,"content":[{"lineBreak":true},{"text":"Hindarilah jalan orang jahat.","poem":2},{"lineBreak":true},{"text":"Jangan sekali-kali mendekatinya.","poem":2},{"lineBreak":true},{"text":"Berpalinglah dari jalan mereka","poem":2},{"lineBreak":true},{"text":"dan ambillah jalan yang lurus.","poem":2}]},{"type":"verse","number":16,"content":[{"lineBreak":true},{"text":"Orang-orang seperti itu tidak bisa tidur tenang sebelum berbuat jahat.","poem":2},{"lineBreak":true},{"text":"Mereka baru merasakan kantuk kalau berhasil menjatuhkan orang.","poem":2}]},{"type":"verse","number":17,"content":[{"lineBreak":true},{"text":"Bagi mereka, berbuat jahat memuaskan seperti makanan lezat,","poem":2},{"lineBreak":true},{"text":"dan melakukan kekerasan terasa manis seperti minuman anggur.","poem":2}]},{"type":"line_break"},{"type":"verse","number":18,"content":[{"text":"Tidaklah demikian dengan orang benar.","poem":3},{"lineBreak":true},{"text":"Jalan hidup orang benar bagaikan cerahnya pagi","poem":3},{"lineBreak":true},{"text":"yang semakin terang hingga siang hari.","poem":3}]},{"type":"verse","number":19,"content":[{"lineBreak":true},{"text":"Tetapi jalan hidup orang jahat teramat gelap.","poem":3},{"lineBreak":true},{"text":"Kaki mereka tersandung karena mereka tak dapat melihat.","poem":3}]},{"type":"line_break"},{"type":"verse","number":20,"content":[{"text":"Anakku, perhatikanlah nasihat-nasihatku","poem":1},{"lineBreak":true},{"text":"dan dengarkanlah ajaranku.","poem":1}]},{"type":"verse","number":21,"content":[{"lineBreak":true},{"text":"Simpanlah nasihatku di dalam hatimu","poem":1},{"lineBreak":true},{"text":"dan jadikanlah sebagai pengukur dalam tiap langkah hidupmu.","poem":1}]},{"type":"verse","number":22,"content":[{"lineBreak":true},{"text":"Karena seluruh nasihat dan pengajaranku","poem":1},{"lineBreak":true},{"text":"memberi hidup bahagia bagi yang menyelami artinya","poem":1},{"lineBreak":true},{"text":"dan mendatangkan kesegaran bagi tubuh.","poem":1}]},{"type":"line_break"},{"type":"verse","number":23,"content":[{"text":"Jagalah hatimu dengan waspada,","poem":1},{"lineBreak":true},{"text":"karena hati menentukan segala pilihan hidupmu.","poem":1}]},{"type":"line_break"},{"type":"verse","number":24,"content":[{"text":"Jangan mengucapkan kata-kata dusta.","poem":3},{"lineBreak":true},{"text":"Buanglah ucapan yang tak benar.","poem":3}]},{"type":"line_break"},{"type":"verse","number":25,"content":[{"text":"Tetaplah memandang tujuan hidupmu","poem":1},{"lineBreak":true},{"text":"supaya engkau tidak menyimpang.","poem":1}]},{"type":"verse","number":26,"content":[{"lineBreak":true},{"text":"Pertimbangkan baik-baik ke mana engkau melangkah","poem":1},{"lineBreak":true},{"text":"maka engkau dapat berjalan dengan tenang.","poem":1}]},{"type":"verse","number":27,"content":[{"lineBreak":true},{"text":"Jagalah dirimu supaya tetap mengikuti jalan yang benar.","poem":1},{"lineBreak":true},{"text":"Jangan pernah menyimpang ke jalan yang jahat.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/ind_obo/PRO/4.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_obo/PRO/5.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_obo/PRO/3.json","previousChapterAudioLinks":{},"numberOfVerses":27}