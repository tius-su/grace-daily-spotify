{"translation":{"id":"ind_obo","name":"Alkitab Terjemahan Sederhana Indonesia, Edisi Ketiga","website":"https://ebible.org/Scriptures/details.php?id=ind","licenseUrl":"https://ebible.org/Scriptures/details.php?id=ind","licenseNotes":null,"shortName":"OBO","englishName":"Indonesian Bible (TSI)","language":"ind","textDirection":"ltr","sha256":"01f327eca48c79ec8c0410383f6df1df8f240ba4d772ad1c3a27491176ca3054","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_obo/books.json","numberOfBooks":48,"totalNumberOfChapters":762,"totalNumberOfVerses":20650,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PRO","translationId":"ind_obo","name":"Amsal","commonName":"Amsal","title":"Amsal","order":20,"numberOfChapters":31,"sha256":"dc25f208340ba80ce449d59e31ae16f296a5c2209ac0c48fbd43a9788ef60359","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_obo/PRO/1.json","lastChapterNumber":31,"lastChapterApiLink":"/api/ind_obo/PRO/31.json","totalNumberOfVerses":898},"chapter":{"number":6,"content":[{"type":"heading","content":["Tentang utang piutang"]},{"type":"verse","number":1,"content":[{"text":"Anakku, janganlah engkau berjanji kepada orang lain,","poem":1},{"text":"“Saya akan menjamin utangmu.","poem":3},{"lineBreak":true},{"text":"Bila kamu tidak bisa membayar,","poem":3},{"lineBreak":true},{"text":"saya akan membayarnya.”","poem":3}]},{"type":"verse","number":2,"content":[{"text":"Karena, jika engkau menjadi penjamin utang orang lain,","poem":1},{"lineBreak":true},{"text":"engkau sudah terjerat oleh janjimu itu","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"dan terikat tanggung jawab kepadanya.","poem":1},{"text":"Bila itu terjadi, yang harus engkau lakukan adalah,","poem":2},{"lineBreak":true},{"text":"segera lepaskan dirimu darinya!","poem":2},{"lineBreak":true},{"text":"Pergilah kepadanya, rendahkan dirimu,","poem":2},{"lineBreak":true},{"text":"dan mintalah dia menghapuskan perjanjian itu.","poem":2}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Jangan tidur sebelum urusan itu selesai!","poem":2}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Bebaskanlah dirimu","poem":2},{"lineBreak":true},{"text":"seperti rusa lari kabur dari pemburunya,","poem":2},{"lineBreak":true},{"text":"seperti burung meloloskan diri dari perangkapnya.","poem":2}]},{"type":"heading","content":["Tentang kemalasan"]},{"type":"verse","number":6,"content":[{"text":"Hai orang malas, semut-semut pun lebih baik daripadamu!","poem":1},{"lineBreak":true},{"text":"Perhatikanlah cara hidup mereka dan belajarlah menjadi bijak!","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Meskipun semut tidak punya pemimpin atau penguasa","poem":1},{"lineBreak":true},{"text":"yang mengatur mereka untuk bekerja,","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"mereka teratur mencari makanan sepanjang musim panas","poem":1},{"lineBreak":true},{"text":"dan menyimpannya untuk musim hujan.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Tetapi pemalas hanya berbaring-baring sepanjang hari!","poem":1},{"lineBreak":true},{"text":"Kapan kamu mau bangun dan bekerja?","poem":1}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"“Ah, aku masih mengantuk.","poem":3},{"lineBreak":true},{"text":"Aku mau tidur sebentar lagi.","poem":3},{"lineBreak":true},{"text":"Biarkan aku melipat tangan dan berbaring sebentar saja,”","poem":3},{"lineBreak":true},{"text":"begitulah katamu.","poem":3}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"Maka seperti perampok yang datang tak terduga,","poem":1},{"lineBreak":true},{"text":"demikianlah kamu mendadak miskin.","poem":1},{"lineBreak":true},{"text":"Kekurangan tiba-tiba menyerangmu seperti seorang penjahat.","poem":1}]},{"type":"heading","content":["Tentang pembohong"]},{"type":"verse","number":12,"content":[{"text":"Pembohong itu sampah!","poem":1},{"lineBreak":true},{"text":"Mereka jahat dan tidak berguna.","poem":1}]},{"type":"verse","number":13,"content":[{"lineBreak":true},{"text":"Mereka mengedipkan mata","poem":1},{"lineBreak":true},{"text":"atau membuat isyarat kecil dengan tangan atau kaki","poem":1},{"lineBreak":true},{"text":"supaya rekannya membantu dalam penipuan.","poem":1}]},{"type":"verse","number":14,"content":[{"lineBreak":true},{"text":"Hati pembohong tak henti memikirkan tipu daya dan rencana licik.","poem":1},{"lineBreak":true},{"text":"Di mana-mana mereka menimbulkan pertengkaran.","poem":1}]},{"type":"verse","number":15,"content":[{"text":"Karena itu, dengan tiba-tiba","poem":3},{"lineBreak":true},{"text":"bencana akan menimpa mereka.","poem":3},{"lineBreak":true},{"text":"Dalam sekejap mereka akan remuk","poem":3},{"lineBreak":true},{"text":"tanpa dapat dipulihkan.","poem":3}]},{"type":"heading","content":["Tujuh hal yang dibenci TUHAN"]},{"type":"verse","number":16,"content":[{"text":"Ada beberapa kejahatan yang sangat dibenci TUHAN:","poem":1}]},{"type":"verse","number":17,"content":[{"text":"Mata yang memandang rendah orang lain,","poem":3},{"lineBreak":true},{"text":"mulut yang berbohong,","poem":3},{"lineBreak":true},{"text":"tangan yang membunuh orang tak bersalah,","poem":3}]},{"type":"verse","number":18,"content":[{"lineBreak":true},{"text":"hati yang merencanakan kejahatan,","poem":3},{"lineBreak":true},{"text":"kaki yang cepat melangkah untuk berbuat dosa,","poem":3}]},{"type":"verse","number":19,"content":[{"lineBreak":true},{"text":"orang yang memberi saksi dusta,","poem":3},{"lineBreak":true},{"text":"dan orang yang suka mengadu domba sehingga menimbulkan pertengkaran saudara.","poem":3}]},{"type":"heading","content":["Tentang perzinaan"]},{"type":"verse","number":20,"content":[{"text":"Anakku, ikutilah ajaran ayahmu","poem":1},{"lineBreak":true},{"text":"dan jangan tinggalkan nasihat ibumu.","poem":1}]},{"type":"verse","number":21,"content":[{"lineBreak":true},{"text":"Simpanlah semuanya baik-baik di dalam hatimu.","poem":1},{"lineBreak":true},{"text":"Biarlah ajaran orangtuamu seperti tali pengingat","poem":1},{"lineBreak":true},{"text":"yang selalu dikalungkan pada lehermu.","poem":1}]},{"type":"verse","number":22,"content":[{"lineBreak":true},{"text":"Bila engkau terus mengingatnya,","poem":1},{"lineBreak":true},{"text":"ajaran itu akan memandu langkah hidupmu.","poem":1},{"lineBreak":true},{"text":"Engkau akan terlindung di saat lelap,","poem":1},{"lineBreak":true},{"text":"dan dibimbingnya saat terjaga.","poem":1}]},{"type":"verse","number":23,"content":[{"lineBreak":true},{"text":"Karena nasihat, bimbingan, dan teguran itu ibarat cahaya terang","poem":1},{"lineBreak":true},{"text":"yang menuntunmu ke jalan kehidupan.","poem":1}]},{"type":"verse","number":24,"content":[{"text":"Dengan mengikutinya,","poem":3},{"lineBreak":true},{"text":"engkau akan luput dari bujukan perempuan sundal","poem":3},{"lineBreak":true},{"text":"dan rayuan istri orang.","poem":3}]},{"type":"verse","number":25,"content":[{"lineBreak":true},{"text":"Jangan tergoda oleh kecantikannya,","poem":3},{"lineBreak":true},{"text":"dan jangan terpikat oleh kedipan matanya.","poem":3}]},{"type":"verse","number":26,"content":[{"lineBreak":true},{"text":"Bila engkau tidur dengan pelacur,","poem":3},{"lineBreak":true},{"text":"engkau bisa membayar hanya seharga roti,","poem":3},{"lineBreak":true},{"text":"tetapi bila engkau berzina dengan istri orang,","poem":3},{"lineBreak":true},{"text":"harganya dibayar nyawa.","poem":3}]},{"type":"verse","number":27,"content":[{"text":"Bermain api, hangus,","poem":1},{"lineBreak":true},{"text":"bermain air, basah,","poem":1},{"lineBreak":true},{"text":"bermain pisau, luka.","poem":1},{"noteId":7}]},{"type":"verse","number":29,"content":[{"lineBreak":true},{"text":"Begitu juga bila engkau berzina dengan istri orang,","poem":1},{"lineBreak":true},{"text":"pastilah engkau dihukum.","poem":1}]},{"type":"line_break"},{"type":"verse","number":30,"content":[{"text":"Bila seseorang mencuri karena lapar,","poem":3},{"lineBreak":true},{"text":"orang lain masih bisa maklum","poem":3},{"lineBreak":true},{"text":"sebab mereka pikir,","poem":3},{"lineBreak":true},{"text":"“Kasihan, dia mencuri karena tak sanggup membeli makan.”","poem":3}]},{"type":"verse","number":31,"content":[{"lineBreak":true},{"text":"Meski demikian, bila pencuri itu tertangkap,","poem":3},{"lineBreak":true},{"text":"dia tetap akan dihukum","poem":3},{"lineBreak":true},{"text":"dan harus membayar tujuh kali lipat dari yang diambilnya.","poem":3},{"lineBreak":true},{"text":"Dia wajib membayar sekalipun harus menjual seluruh hartanya.","poem":3}]},{"type":"verse","number":32,"content":[{"text":"Jauh lebih celaka orang yang berzina!","poem":1},{"lineBreak":true},{"text":"Siapa berzina sungguh tak berotak.","poem":1},{"lineBreak":true},{"text":"Dia menghancurkan dirinya sendiri.","poem":1}]},{"type":"verse","number":33,"content":[{"lineBreak":true},{"text":"Orang seperti itu pasti dipukul dan dihina.","poem":1},{"lineBreak":true},{"text":"Dia tidak akan dihormati lagi,","poem":1},{"lineBreak":true},{"text":"karena aibnya tak terlupakan.","poem":1}]},{"type":"verse","number":34,"content":[{"text":"Rasa cemburu seorang suami","poem":3},{"lineBreak":true},{"text":"membuat hatinya dibakar amarah.","poem":3},{"lineBreak":true},{"text":"Saat membalas dendam, dia tak akan berbelas kasihan.","poem":3}]},{"type":"verse","number":35,"content":[{"lineBreak":true},{"text":"Dia tidak akan mau menerima ganti rugi.","poem":3},{"lineBreak":true},{"text":"Seberapa pun besarnya suap yang diberikan","poem":3},{"lineBreak":true},{"text":"untuk menutupi perzinaan itu,","poem":3},{"lineBreak":true},{"text":"dia pasti menolaknya!","poem":3}]},{"type":"line_break"}],"footnotes":[{"noteId":7,"caller":"+","text":"-28 Bermain api, … Secara harfiah, terjemahan kedua ayat ini berupa kiasan Ibrani, “Barangsiapa memangku api, pasti bajunya terbakar. Barangsiapa berjalan di atas arang membara, pasti kakinya melepuh.” TSI menerjemahkannya dengan peribahasa Indonesia yang memiliki makna serupa.","reference":{"chapter":6,"verse":27}}]},"thisChapterLink":"/api/ind_obo/PRO/6.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_obo/PRO/7.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_obo/PRO/5.json","previousChapterAudioLinks":{},"numberOfVerses":34}