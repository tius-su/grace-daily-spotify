{"translation":{"id":"ind_obo","name":"Alkitab Terjemahan Sederhana Indonesia, Edisi Ketiga","website":"https://ebible.org/Scriptures/details.php?id=ind","licenseUrl":"https://ebible.org/Scriptures/details.php?id=ind","licenseNotes":null,"shortName":"OBO","englishName":"Indonesian Bible (TSI)","language":"ind","textDirection":"ltr","sha256":"01f327eca48c79ec8c0410383f6df1df8f240ba4d772ad1c3a27491176ca3054","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_obo/books.json","numberOfBooks":48,"totalNumberOfChapters":762,"totalNumberOfVerses":20650,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PRO","translationId":"ind_obo","name":"Amsal","commonName":"Amsal","title":"Amsal","order":20,"numberOfChapters":31,"sha256":"dc25f208340ba80ce449d59e31ae16f296a5c2209ac0c48fbd43a9788ef60359","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_obo/PRO/1.json","lastChapterNumber":31,"lastChapterApiLink":"/api/ind_obo/PRO/31.json","totalNumberOfVerses":898},"chapter":{"number":5,"content":[{"type":"heading","content":["Nasihat bagi anak-anak lelaki untuk menjauhi perzinaan"]},{"type":"verse","number":1,"content":[{"text":"Anakku, perhatikanlah","poem":1},{"lineBreak":true},{"text":"kebijaksanaan dan pelajaran hidup yang aku ajarkan,","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"agar engkau dapat mempertimbangkan segala hal dengan baik","poem":1},{"lineBreak":true},{"text":"dan perkataanmu didasari oleh pengetahuan.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Bujukan istri orang manis seperti tetesan madu,","poem":1},{"lineBreak":true},{"text":"dan kata-katanya lihai merayu.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Namun pada akhirnya, bila engkau mengikut dia,","poem":1},{"lineBreak":true},{"text":"akibatnya akan pahit bagai empedu","poem":1},{"lineBreak":true},{"text":"dan menyakitkan bagai pisau belati.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Jalan hidup perempuan itu membinasakan.","poem":1},{"lineBreak":true},{"text":"Mengikutinya hanya akan menjerumuskan engkau ke dalam Syeol.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Tak pernah sekalipun dia berpikir","poem":1},{"lineBreak":true},{"text":"tentang hidup yang benar di mata Allah.","poem":1},{"lineBreak":true},{"text":"Tanpa dia sadari, jalan hidupnya sudah sesat.","poem":1}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Oleh sebab itu hai anak-anak, dengarkanlah aku.","poem":2},{"lineBreak":true},{"text":"Janganlah menyimpang dari pengajaranku.","poem":2}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Jauhilah perempuan seperti itu!","poem":2},{"lineBreak":true},{"text":"Jangan mendekat ke pintu rumahnya","poem":2}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"agar engkau tidak membuang masa keemasanmu dan kehormatanmu","poem":2},{"lineBreak":true},{"text":"hanya untuk memuaskan hawa nafsu.","poem":2},{"lineBreak":true},{"text":"Akibat satu kali percabulan,","poem":2},{"lineBreak":true},{"text":"hancurlah masa depanmu","poem":2},{"lineBreak":true},{"text":"di tangan suaminya yang tak akan melepaskanmu.","poem":2}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Jangan biarkan hartamu ditelan orang-orang asing","poem":2},{"lineBreak":true},{"text":"dan hasil kerja kerasmu dinikmati orang lain.","poem":2}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"Pada akhirnya engkau akan mengerang","poem":2},{"lineBreak":true},{"text":"ketika penyakit menggerogoti daging tubuhmu.","poem":2}]},{"type":"verse","number":12,"content":[{"lineBreak":true},{"text":"Saat itu engkau akan berkata,","poem":2},{"text":"“Ah, seharusnya dulu aku tidak keras kepala","poem":3},{"lineBreak":true},{"text":"menolak nasihat dan teguran!","poem":3}]},{"type":"verse","number":13,"content":[{"lineBreak":true},{"text":"Aku tidak taat pada guru-guru","poem":3},{"lineBreak":true},{"text":"yang memberi bimbingan kepadaku.","poem":3}]},{"type":"verse","number":14,"content":[{"lineBreak":true},{"text":"Akibatnya, aku nyaris hancur.","poem":3},{"lineBreak":true},{"text":"Aku menanggung malu dan menjadi tontonan semua orang.”","poem":3}]},{"type":"line_break"},{"type":"verse","number":15,"content":[{"text":"Anakku, setialah kepada istrimu,","poem":1},{"lineBreak":true},{"text":"sama seperti engkau tak boleh mengambil milik pribadi orang lain.","poem":1},{"noteId":6}]},{"type":"verse","number":16,"content":[{"lineBreak":true},{"text":"Bukankah engkau pun tak mau,","poem":1},{"lineBreak":true},{"text":"bila istrimu sendiri diambil orang lain?","poem":1}]},{"type":"verse","number":17,"content":[{"lineBreak":true},{"text":"Sebab istrimu bagaikan mata air murni","poem":1},{"lineBreak":true},{"text":"yang mengalir hanya untukmu,","poem":1},{"lineBreak":true},{"text":"bukan untuk dibagi dengan orang lain.","poem":1}]},{"type":"line_break"},{"type":"verse","number":18,"content":[{"text":"Biarlah rasa hausmu dipuaskan hanya oleh istrimu itu,","poem":3},{"lineBreak":true},{"text":"yang engkau nikahi sejak masa mudamu.","poem":3}]},{"type":"verse","number":19,"content":[{"lineBreak":true},{"text":"Dia bagaikan rusa betina muda:","poem":3},{"lineBreak":true},{"text":"anggun dan penuh kasih sayang.","poem":3},{"lineBreak":true},{"text":"Pelukan di dadanya memuaskan engkau,","poem":3},{"lineBreak":true},{"text":"dan cintanya selalu memikat hatimu.","poem":3}]},{"type":"verse","number":20,"content":[{"lineBreak":true},{"text":"Jadi anakku, untuk apa terpikat oleh perempuan sundal!","poem":3},{"lineBreak":true},{"text":"Tak ada gunanya memeluk dada perempuan lain.","poem":3}]},{"type":"line_break"},{"type":"verse","number":21,"content":[{"text":"Karena mata TUHAN selalu memperhatikan perbuatan tiap orang.","poem":1},{"lineBreak":true},{"text":"Dia mengawasi segala jalan hidup kita.","poem":1}]},{"type":"verse","number":22,"content":[{"lineBreak":true},{"text":"Orang jahat akan terjerat dalam pelanggaran-pelanggarannya sendiri.","poem":1},{"lineBreak":true},{"text":"Dosanya ibarat tali perangkap yang mengikatnya erat.","poem":1}]},{"type":"verse","number":23,"content":[{"lineBreak":true},{"text":"Dia akan binasa karena menolak didikan,","poem":1},{"lineBreak":true},{"text":"dan tersesat karena bebalnya keterlaluan.","poem":1}]}],"footnotes":[{"noteId":6,"caller":"+","text":"milik pribadi orang lain Terjemahan harfiahnya adalah, “Minumlah air dari sumurmu sendiri.” Pada zaman PL, sumur dan tempat penampungan air adalah hak milik yang berharga dan dilindungi.","reference":{"chapter":5,"verse":15}}]},"thisChapterLink":"/api/ind_obo/PRO/5.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_obo/PRO/6.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_obo/PRO/4.json","previousChapterAudioLinks":{},"numberOfVerses":23}