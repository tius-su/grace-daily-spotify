{"translation":{"id":"ind_obo","name":"Alkitab Terjemahan Sederhana Indonesia, Edisi Ketiga","website":"https://ebible.org/Scriptures/details.php?id=ind","licenseUrl":"https://ebible.org/Scriptures/details.php?id=ind","licenseNotes":null,"shortName":"OBO","englishName":"Indonesian Bible (TSI)","language":"ind","textDirection":"ltr","sha256":"01f327eca48c79ec8c0410383f6df1df8f240ba4d772ad1c3a27491176ca3054","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_obo/books.json","numberOfBooks":48,"totalNumberOfChapters":762,"totalNumberOfVerses":20650,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PRO","translationId":"ind_obo","name":"Amsal","commonName":"Amsal","title":"Amsal","order":20,"numberOfChapters":31,"sha256":"dc25f208340ba80ce449d59e31ae16f296a5c2209ac0c48fbd43a9788ef60359","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_obo/PRO/1.json","lastChapterNumber":31,"lastChapterApiLink":"/api/ind_obo/PRO/31.json","totalNumberOfVerses":898},"chapter":{"number":8,"content":[{"type":"heading","content":["Panggilan Sang Hikmat"]},{"type":"verse","number":1,"content":[{"text":"Dengarkanlah! Sang Hikmat berseru-seru","poem":1},{"lineBreak":true},{"text":"menawarkan kesempatan untuk mendapat pengertian.","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Dia mengumumkan kesempatan itu seluas-luasnya:","poem":1},{"text":"Di tempat orang sering berkumpul di samping gerbang kota,","poem":3},{"lineBreak":true},{"text":"di persimpangan yang banyak dilalui orang,","poem":3},{"lineBreak":true},{"text":"maupun di atas bukit-bukit tinggi di tepi jalan.","poem":3},{"lineBreak":true},{"text":"Sang Hikmat berseru,","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"“Aku memanggil kalian semua! Dengarkanlah aku!","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Siapa yang tidak berpengalaman,","poem":1},{"lineBreak":true},{"text":"belajarlah menjadi bijak.","poem":1},{"lineBreak":true},{"text":"Siapa yang bebal, belajarlah dariku","poem":1},{"lineBreak":true},{"text":"supaya hatimu terbuka untuk pengertian.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Dengarkanlah, karena aku akan memberitahukan","poem":1},{"lineBreak":true},{"text":"hal-hal yang sangat berharga.","poem":1},{"lineBreak":true},{"text":"Semua yang aku katakan adalah benar.","poem":1}]},{"type":"verse","number":7,"content":[{"text":"Ajaranku layak dipercaya,","poem":3},{"lineBreak":true},{"text":"dan aku sangat membenci dusta.","poem":3}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Semua nasihatku jujur.","poem":3},{"lineBreak":true},{"text":"Tidak ada yang menyimpang ataupun menyesatkan.","poem":3}]},{"type":"verse","number":9,"content":[{"text":"Bila engkau berpengertian,","poem":1},{"lineBreak":true},{"text":"tentu engkau akan menyukai nasihatku.","poem":1},{"lineBreak":true},{"text":"Dan bila engkau berpengetahuan,","poem":1},{"lineBreak":true},{"text":"engkau akan menyadari bahwa ajaranku tepat.","poem":1}]},{"type":"verse","number":10,"content":[{"text":"Terimalah ajaran penuh hikmat dariku,","poem":3},{"lineBreak":true},{"text":"karena itu lebih berharga daripada perak dan emas murni,","poem":3},{"lineBreak":true},{"text":"bahkan lebih bernilai daripada batu permata.","poem":3},{"lineBreak":true},{"text":"Semua yang diinginkan manusia","poem":3},{"lineBreak":true},{"text":"tak ada yang sebanding dengannya.","poem":3}]},{"type":"line_break"},{"type":"verse","number":12,"content":[{"text":"“Akulah Hikmat.","poem":1},{"lineBreak":true},{"text":"Bila engkau menerima aku,","poem":1},{"lineBreak":true},{"text":"engkau juga akan bertambah kecerdikan,","poem":1},{"lineBreak":true},{"text":"pengetahuan, dan kematangan berpikir.","poem":1}]},{"type":"verse","number":13,"content":[{"text":"Apabila mengenal aku,","poem":3},{"lineBreak":true},{"text":"tentu engkau akan hormat dan takut kepada TUHAN","poem":3},{"lineBreak":true},{"text":"dan membenci kejahatan,","poem":3},{"lineBreak":true},{"text":"karena aku benci segala macam kejahatan,","poem":3},{"lineBreak":true},{"text":"termasuk sifat sombong, membanggakan diri,","poem":3},{"lineBreak":true},{"text":"dan suka menipu.","poem":3}]},{"type":"verse","number":14,"content":[{"text":"Dengan mengenal aku,","poem":1},{"lineBreak":true},{"text":"engkau juga akan mendapat nasihat terbaik","poem":1},{"lineBreak":true},{"text":"serta pengetahuan, pengertian, dan kekuatan.","poem":1}]},{"type":"verse","number":15,"content":[{"text":"Para raja mampu memerintah","poem":3},{"lineBreak":true},{"text":"dan para penguasa dapat membuat hukum-hukum yang adil,","poem":3},{"lineBreak":true},{"text":"hanya melalui aku.","poem":3}]},{"type":"verse","number":16,"content":[{"lineBreak":true},{"text":"Setiap pemimpin dan pejabat,","poem":3},{"lineBreak":true},{"text":"hanya dapat belajar keadilan dari aku.","poem":3}]},{"type":"line_break"},{"type":"verse","number":17,"content":[{"text":"“Aku mengasihi orang yang mengasihi aku,","poem":1},{"lineBreak":true},{"text":"dan siapa yang sungguh-sungguh mencariku","poem":1},{"lineBreak":true},{"text":"pasti menemukanku.","poem":1}]},{"type":"verse","number":18,"content":[{"lineBreak":true},{"text":"Padaku tersedia kekayaan, kehormatan,","poem":1},{"lineBreak":true},{"text":"keberhasilan, dan kemakmuran yang mapan.","poem":1}]},{"type":"verse","number":19,"content":[{"lineBreak":true},{"text":"Manfaat yang aku berikan lebih berharga","poem":1},{"lineBreak":true},{"text":"daripada perak, bahkan emas murni.","poem":1}]},{"type":"verse","number":20,"content":[{"lineBreak":true},{"text":"Jalan hidup yang aku ajarkan adalah benar dan adil.","poem":1}]},{"type":"verse","number":21,"content":[{"lineBreak":true},{"text":"Aku memberikan harta pusaka bagi orang yang mengasihiku","poem":1},{"lineBreak":true},{"text":"dan mengisi penuh tempat kekayaan mereka.","poem":1}]},{"type":"line_break"},{"type":"verse","number":22,"content":[{"text":"“Sejak semula, aku, Hikmat,","poem":2},{"lineBreak":true},{"text":"ada pada diri TUHAN.","poem":2},{"lineBreak":true},{"text":"Oleh akulah Dia menjadikan karya ciptaan-Nya pada purba kala.","poem":2}]},{"type":"verse","number":23,"content":[{"lineBreak":true},{"text":"Pada permulaan segala sesuatu,","poem":2},{"lineBreak":true},{"text":"sebelum bumi ini ada,","poem":2},{"lineBreak":true},{"text":"Allah sudah memiliki aku.","poem":2}]},{"type":"verse","number":24,"content":[{"lineBreak":true},{"text":"Sebelum ada segala samudra,","poem":2},{"lineBreak":true},{"text":"dan semua mata air belum memancar,","poem":2}]},{"type":"verse","number":25,"content":[{"lineBreak":true},{"text":"juga sebelum gunung dan bukit didirikan-Nya,","poem":2},{"lineBreak":true},{"text":"aku sudah ada pada diri Allah,","poem":2}]},{"type":"verse","number":26,"content":[{"lineBreak":true},{"text":"sebelum Dia menjadikan bumi serta daratannya yang luas,","poem":2},{"lineBreak":true},{"text":"bahkan butiran debu yang pertama.","poem":2}]},{"type":"verse","number":27,"content":[{"lineBreak":true},{"text":"Melalui akulah, Sang Hikmat,","poem":2},{"lineBreak":true},{"text":"TUHAN menciptakan langit, menegakkan cakrawala,","poem":2}]},{"type":"verse","number":28,"content":[{"lineBreak":true},{"text":"menghiasi langit dengan awan gemawan,","poem":2},{"lineBreak":true},{"text":"dan menyemburkan mata air nan deras","poem":2},{"lineBreak":true},{"text":"membentuk lautan luas.","poem":2}]},{"type":"verse","number":29,"content":[{"lineBreak":true},{"text":"Oleh Hikmatlah TUHAN menata dasar-dasar bumi","poem":2},{"lineBreak":true},{"text":"dan mengatur batas-batas laut","poem":2},{"lineBreak":true},{"text":"agar airnya tak melampaui daratan.","poem":2}]},{"type":"verse","number":30,"content":[{"lineBreak":true},{"text":"Melalui akulah TUHAN berkarya.","poem":2},{"lineBreak":true},{"text":"Dia bersukacita karena memiliki Hikmat.","poem":2},{"lineBreak":true},{"text":"Aku pun bergirang karena penciptaan semesta,","poem":2},{"lineBreak":true},{"text":"dan paling bergembira karena umat manusia ciptaan-Nya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":32,"content":[{"text":"“Karena itu, hai semua manusia,","poem":1},{"lineBreak":true},{"text":"dengarkanlah aku, Sang Hikmat!","poem":1},{"lineBreak":true},{"text":"Sungguh diberkati orang yang mengikuti jalan-jalanku.","poem":1}]},{"type":"verse","number":33,"content":[{"lineBreak":true},{"text":"Dengarkan didikanku agar engkau menjadi bijak.","poem":1},{"lineBreak":true},{"text":"Janganlah mengabaikannya!","poem":1}]},{"type":"verse","number":34,"content":[{"lineBreak":true},{"text":"Sungguh diberkati orang yang senang mendengarkan ajaranku,","poem":1},{"lineBreak":true},{"text":"hingga mereka datang setiap hari untuk menerima pelajaran,","poem":1},{"lineBreak":true},{"text":"bahkan menunggu-nunggu pada pintu rumahku.","poem":1}]},{"type":"verse","number":35,"content":[{"text":"Sebab orang yang menerima aku akan hidup sejahtera","poem":3},{"lineBreak":true},{"text":"dan TUHAN akan berkenan kepadanya,","poem":3}]},{"type":"verse","number":36,"content":[{"lineBreak":true},{"text":"tetapi orang yang tidak mau menerima aku","poem":3},{"lineBreak":true},{"text":"mencelakakan dirinya sendiri.","poem":3},{"lineBreak":true},{"text":"Semua yang membenci Hikmat berarti mencintai maut.”","poem":3}]}],"footnotes":[]},"thisChapterLink":"/api/ind_obo/PRO/8.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_obo/PRO/9.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_obo/PRO/7.json","previousChapterAudioLinks":{},"numberOfVerses":33}