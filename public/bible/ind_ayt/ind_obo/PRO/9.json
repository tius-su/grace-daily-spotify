{"translation":{"id":"ind_obo","name":"Alkitab Terjemahan Sederhana Indonesia, Edisi Ketiga","website":"https://ebible.org/Scriptures/details.php?id=ind","licenseUrl":"https://ebible.org/Scriptures/details.php?id=ind","licenseNotes":null,"shortName":"OBO","englishName":"Indonesian Bible (TSI)","language":"ind","textDirection":"ltr","sha256":"01f327eca48c79ec8c0410383f6df1df8f240ba4d772ad1c3a27491176ca3054","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_obo/books.json","numberOfBooks":48,"totalNumberOfChapters":762,"totalNumberOfVerses":20650,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"PRO","translationId":"ind_obo","name":"Amsal","commonName":"Amsal","title":"Amsal","order":20,"numberOfChapters":31,"sha256":"dc25f208340ba80ce449d59e31ae16f296a5c2209ac0c48fbd43a9788ef60359","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_obo/PRO/1.json","lastChapterNumber":31,"lastChapterApiLink":"/api/ind_obo/PRO/31.json","totalNumberOfVerses":898},"chapter":{"number":9,"content":[{"type":"heading","content":["Kepuasan belajar dari Sang Hikmat"]},{"type":"verse","number":1,"content":[{"text":"Sang Hikmat sudah membangun rumahnya dengan kokoh,","poem":1},{"lineBreak":true},{"text":"ditopang tujuh tiang","poem":1},{"noteId":9},{"text":"yang kuat.","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Dia sudah menyediakan pesta makan yang mewah","poem":1},{"lineBreak":true},{"text":"dengan daging yang paling lezat","poem":1},{"lineBreak":true},{"text":"dan campuran air anggur paling istimewa.","poem":1},{"lineBreak":true},{"text":"Semua sudah disajikan dengan indah di mejanya.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Dia sudah menyuruh para pelayan perempuan untuk mengumumkan undangannya.","poem":1},{"lineBreak":true},{"text":"Sementara itu, Sang Hikmat sendiri berseru-seru","poem":1},{"lineBreak":true},{"text":"dari tempat tertinggi di kota,","poem":1}]},{"type":"verse","number":4,"content":[{"text":"“Hai orang yang belum berpengalaman,","poem":3},{"lineBreak":true},{"text":"datanglah ke rumahku.”","poem":3},{"text":"Dan kepada yang tak berakal budi dia berkata,","poem":1}]},{"type":"verse","number":5,"content":[{"text":"“Mari! Makanlah roti dan minumlah anggur","poem":3},{"lineBreak":true},{"text":"yang sudah aku siapkan.","poem":3}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Tinggalkan pikiran sempitmu agar engkau bahagia","poem":3},{"lineBreak":true},{"text":"dan majulah terus dalam pemahaman.”","poem":3}]},{"type":"heading","content":["Prinsip-prinsip dasar yang diajarkan oleh Sang Hikmat"]},{"type":"verse","number":7,"content":[{"text":"“Aku, Sang Hikmat, mengajarkan:","poem":1},{"text":"Bila engkau menegur orang yang suka menghina,","poem":3},{"lineBreak":true},{"text":"dia hanya akan menghinamu.","poem":3},{"lineBreak":true},{"text":"Dan bila engkau berusaha meluruskan orang jahat,","poem":3},{"lineBreak":true},{"text":"dia hanya akan menyakitimu.","poem":3}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Tak usah menegur orang yang suka menghina","poem":3},{"lineBreak":true},{"text":"karena dia hanya akan membencimu.","poem":3},{"lineBreak":true},{"text":"Tegurlah orang bijak, maka dia akan mengasihimu.","poem":3}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Ajarilah orang bijak, maka dia akan semakin bijak.","poem":3},{"lineBreak":true},{"text":"Ajarilah orang yang berkelakuan benar,","poem":3},{"lineBreak":true},{"text":"maka dia akan semakin berpengertian.","poem":3}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"“Sikap hormat dan takut akan TUHAN","poem":1},{"lineBreak":true},{"text":"adalah cara yang pertama dan terutama untuk menjadi bijak.","poem":1},{"lineBreak":true},{"text":"Mengenal Sang Mahakudus","poem":1},{"lineBreak":true},{"text":"adalah jalan untuk memiliki pengertian.","poem":1}]},{"type":"verse","number":11,"content":[{"text":"Hiduplah menurut ajaranku,","poem":3},{"lineBreak":true},{"text":"maka engkau akan berumur panjang.","poem":3}]},{"type":"verse","number":12,"content":[{"lineBreak":true},{"text":"Bila engkau bijaksana,","poem":3},{"lineBreak":true},{"text":"engkau sendiri yang akan menikmati hasilnya.","poem":3},{"lineBreak":true},{"text":"Bila engkau suka menghina,","poem":3},{"lineBreak":true},{"text":"engkau sendiri yang akan menanggung akibatnya.”","poem":3}]},{"type":"heading","content":["Sang Kebebalan melawan Sang Hikmat"]},{"type":"verse","number":13,"content":[{"text":"Kebebalan bagaikan seorang perempuan","poem":1},{"lineBreak":true},{"text":"yang berkepala kosong, bodoh, dan suka keributan.","poem":1}]},{"type":"verse","number":14,"content":[{"lineBreak":true},{"text":"Dia suka duduk di depan pintu rumahnya,","poem":1},{"text":"atau di tempat-tempat yang tinggi di kota.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Dia menggoda para lelaki yang lewat,","poem":1},{"lineBreak":true},{"text":"dan kepada siapa saja yang belum berpengalaman,","poem":1},{"lineBreak":true},{"text":"dia membujuk,","poem":1},{"text":"“Mari masuk ke rumahku.”","poem":3},{"text":"Kepada yang tak berakal budi, dia merayu,","poem":1}]},{"type":"verse","number":17,"content":[{"text":"“Kenikmatan yang tidak halal lebih enak rasanya,","poem":3},{"lineBreak":true},{"text":"apalagi saat dinikmati sembunyi-sembunyi.”","poem":3}]},{"type":"line_break"},{"type":"verse","number":18,"content":[{"text":"Namun, para lelaki yang dia rayu tidak tahu","poem":1},{"lineBreak":true},{"text":"bahwa rumahnya bagaikan liang Syeol","poem":1},{"lineBreak":true},{"text":"di mana tamunya terjerumus begitu dalam!","poem":1}]}],"footnotes":[{"noteId":9,"caller":"+","text":"tujuh tiang Dalam Firman TUHAN, angka tujuh sering mempunyai arti simbolis, yakni sebagai lambang kelengkapan atau keutuhan, dan menunjukkan kesempurnaan Allah.","reference":{"chapter":9,"verse":1}}]},"thisChapterLink":"/api/ind_obo/PRO/9.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_obo/PRO/10.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_obo/PRO/8.json","previousChapterAudioLinks":{},"numberOfVerses":17}