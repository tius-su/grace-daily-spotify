{"translation":{"id":"ind_obo","name":"Alkitab Terjemahan Sederhana Indonesia, Edisi Ketiga","website":"https://ebible.org/Scriptures/details.php?id=ind","licenseUrl":"https://ebible.org/Scriptures/details.php?id=ind","licenseNotes":null,"shortName":"OBO","englishName":"Indonesian Bible (TSI)","language":"ind","textDirection":"ltr","sha256":"01f327eca48c79ec8c0410383f6df1df8f240ba4d772ad1c3a27491176ca3054","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_obo/books.json","numberOfBooks":48,"totalNumberOfChapters":762,"totalNumberOfVerses":20650,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"ISA","translationId":"ind_obo","name":"Yesaya","commonName":"Yesaya","title":"Yesaya","order":23,"numberOfChapters":66,"sha256":"18925233aaa739e159a813aa3a4bae3ecde6ef1197f2e64ae26711a1a711004f","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_obo/ISA/1.json","lastChapterNumber":66,"lastChapterApiLink":"/api/ind_obo/ISA/66.json","totalNumberOfVerses":1285},"chapter":{"number":18,"content":[{"type":"heading","content":["Nubuat tentang hukuman atas bangsa Etiopia"]},{"type":"verse","number":1,"content":[{"text":"Celaka bagi suatu negeri di seberang sungai-sungai Etiopia,","poem":1},{"lineBreak":true},{"text":"negeri yang ramai oleh suara denging sayap-sayap serangga.","poem":1}]},{"type":"verse","number":2,"content":[{"text":"Negeri itu mengirim utusan mengendarai perahu-perahu dari alang-alang air","poem":2},{"lineBreak":true},{"text":"dengan suruhan “Cepat sampaikan pesan ini!”","poem":2},{"text":"Mereka pergi meminta bantuan militer","poem":3},{"lineBreak":true},{"text":"kepada suatu bangsa penakluk yang kuat.","poem":3},{"lineBreak":true},{"text":"Orangnya tinggi-tinggi dan berkulit mengkilap.","poem":3},{"lineBreak":true},{"text":"Di mana-mana bangsa itu ditakuti orang.","poem":3},{"lineBreak":true},{"text":"Negerinya dilintasi sungai-sungai.","poem":3}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Hai seluruh penduduk bumi, perhatikanlah!","poem":1},{"lineBreak":true},{"text":"Di atas gunung-gunung, bendera perang akan dikibarkan.","poem":1},{"lineBreak":true},{"text":"Hai semua orang di dunia, dengarkanlah!","poem":1},{"lineBreak":true},{"text":"Terompet tanda perang akan dibunyikan.","poem":1}]},{"type":"verse","number":4,"content":[{"text":"Sebab TUHAN telah berkata kepadaku:","poem":2},{"lineBreak":true},{"text":"Dari tempat-Ku bersemayam,","poem":2},{"lineBreak":true},{"text":"Aku akan memperhatikan dengan diam,","poem":2},{"lineBreak":true},{"text":"seperti sinar matahari memancar tanpa suara,","poem":2},{"lineBreak":true},{"text":"seperti embun diam-diam terbentuk pada malam yang hangat di musim panen.","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"Sebelum rencana perang kalian matang,","poem":1},{"lineBreak":true},{"text":"tiba-tiba musuh sudah menghantam","poem":1},{"lineBreak":true},{"text":"sehingga keadaanmu bagaikan ranting-ranting anggur yang dibabat","poem":1},{"lineBreak":true},{"text":"sebelum buahnya sempat ranum.","poem":1}]},{"type":"verse","number":6,"content":[{"text":"Mayat-mayat kalian akan dibiarkan bergelimpangan","poem":2},{"lineBreak":true},{"text":"menjadi makanan burung-burung dan binatang liar sepanjang tahun.","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Suatu hari nanti, persembahan akan dibawa ke Bukit Sion bagi TUHAN Panglima Semesta,","poem":3},{"lineBreak":true},{"text":"dari suatu bangsa penakluk yang kuat,","poem":3},{"lineBreak":true},{"text":"yang orangnya tinggi-tinggi dan berkulit mengkilap,","poem":3},{"lineBreak":true},{"text":"yang ditakuti orang di mana-mana,","poem":3},{"lineBreak":true},{"text":"dan yang negerinya dilintasi sungai-sungai.","poem":3}]}],"footnotes":[]},"thisChapterLink":"/api/ind_obo/ISA/18.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_obo/ISA/19.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_obo/ISA/17.json","previousChapterAudioLinks":{},"numberOfVerses":7}