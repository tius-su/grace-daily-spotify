{"translation":{"id":"ind_obo","name":"Alkitab Terjemahan Sederhana Indonesia, Edisi Ketiga","website":"https://ebible.org/Scriptures/details.php?id=ind","licenseUrl":"https://ebible.org/Scriptures/details.php?id=ind","licenseNotes":null,"shortName":"OBO","englishName":"Indonesian Bible (TSI)","language":"ind","textDirection":"ltr","sha256":"01f327eca48c79ec8c0410383f6df1df8f240ba4d772ad1c3a27491176ca3054","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_obo/books.json","numberOfBooks":48,"totalNumberOfChapters":762,"totalNumberOfVerses":20650,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"ISA","translationId":"ind_obo","name":"Yesaya","commonName":"Yesaya","title":"Yesaya","order":23,"numberOfChapters":66,"sha256":"18925233aaa739e159a813aa3a4bae3ecde6ef1197f2e64ae26711a1a711004f","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_obo/ISA/1.json","lastChapterNumber":66,"lastChapterApiLink":"/api/ind_obo/ISA/66.json","totalNumberOfVerses":1285},"chapter":{"number":12,"content":[{"type":"line_break"},{"type":"heading","content":["Nyanyian syukur umat Allah"]},{"type":"verse","number":1,"content":["Pada waktu semua itu terjadi, kalian akan berkata,",{"text":"“Aku bersyukur kepada-Mu, ya TUHAN,","poem":1},{"lineBreak":true},{"text":"karena meskipun Engkau pernah memurkai aku,","poem":1},{"lineBreak":true},{"text":"kini murka-Mu sudah berhenti","poem":1},{"lineBreak":true},{"text":"dan Engkau berbalik mengasihani aku.","poem":1}]},{"type":"verse","number":2,"content":[{"text":"Sungguh, Engkaulah penyelamatku, ya Allah.","poem":2},{"lineBreak":true},{"text":"Kepada-Mu aku percaya penuh.","poem":2},{"lineBreak":true},{"text":"Aku tidak takut apa pun, karena TUHAN memberiku kekuatan.","poem":2},{"lineBreak":true},{"text":"Segala nyanyianku adalah tentang-Mu","poem":2},{"lineBreak":true},{"text":"sebab Engkau telah menyelamatkan aku.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Hai umat Allah, suatu hari nanti","poem":3},{"lineBreak":true},{"text":"kalian akan menikmati indahnya diselamatkan oleh TUHAN,","poem":3},{"lineBreak":true},{"text":"bagaikan seorang yang haus menemukan mata air","poem":3},{"lineBreak":true},{"text":"lalu meminumnya banyak-banyak dengan kegirangan.","poem":3}]},{"type":"verse","number":4,"content":["Pada waktu itu kalian akan berkata,",{"text":"“Mari kita bersyukur kepada TUHAN!","poem":1},{"lineBreak":true},{"text":"Pujilah nama-Nya.","poem":1},{"lineBreak":true},{"text":"Ceritakanlah perbuatan-perbuatan-Nya kepada segala bangsa.","poem":1},{"lineBreak":true},{"text":"Beritakanlah bahwa Dia agung luhur!","poem":1}]},{"type":"verse","number":5,"content":[{"text":"Bernyanyilah bagi TUHAN, karena ajaib tindakan-tindakan-Nya.","poem":2},{"lineBreak":true},{"text":"Biarlah seluruh bumi mengetahui hal itu.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Bersoraklah dengan riang gembira, hai semua yang berada di Sion,","poem":3},{"lineBreak":true},{"text":"karena besarlah Yang Mahakudus Allah Israel di antara kita!”","poem":3}]}],"footnotes":[]},"thisChapterLink":"/api/ind_obo/ISA/12.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_obo/ISA/13.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_obo/ISA/11.json","previousChapterAudioLinks":{},"numberOfVerses":6}