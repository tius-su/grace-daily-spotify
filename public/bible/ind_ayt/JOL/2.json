{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"JOL","translationId":"ind_ayt","name":"YOEL","commonName":"YOEL","title":"Yoel","order":29,"numberOfChapters":3,"sha256":"1b0ea76b25063c5067724f9e85dfd9c283c94363290f5d8584d65338076bca09","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/JOL/1.json","lastChapterNumber":3,"lastChapterApiLink":"/api/ind_ayt/JOL/3.json","totalNumberOfVerses":73},"chapter":{"number":2,"content":[{"type":"heading","content":["Hari TUHAN Akan Datang"]},{"type":"verse","number":1,"content":[{"text":"Tiuplah trompet di Sion,","poem":1},{"text":"bersorak-soraklah di gunung-Ku yang kudus!","poem":2},{"text":"Biarlah seluruh penduduk negeri gemetar,","poem":1},{"text":"sebab hari TUHAN datang.","poem":2},{"text":"Sungguh, hari itu sudah dekat.","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Hari kegelapan dan kekelaman,","poem":1},{"text":"hari yang berawan dan gelap gulita,","poem":2},{"text":"seperti fajar menyebar di atas gunung-gunung.","poem":1},{"text":"Suatu bangsa yang besar dan kuat,","poem":2},{"text":"tidak pernah ada yang sepertinya sejak purbakala,","poem":1},{"text":"dan takkan ada lagi sesudahnya sampai tahun turun-temurun.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Di hadapan mereka, api melahap,","poem":1},{"text":"di belakang, nyala api membakar.","poem":2},{"text":"Di hadapan mereka, negeri itu seperti Taman Eden, tetapi di belakangnya padang gurun yang tandus,","poem":1},{"text":"dan tidak ada yang terluput darinya.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Rupa mereka seperti kuda,","poem":1},{"text":"dan seperti kuda perang mereka berlari.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Seperti suara kereta perang,","poem":1},{"lineBreak":true},{"text":"di atas puncak-puncak gunung","poem":1},{"text":"mereka melompat-lompat.","poem":2},{"text":"Seperti suara nyala api,","poem":1},{"text":"yang memakan habis jerami,","poem":2},{"text":"seperti suatu bangsa yang kuat,","poem":1},{"text":"yang mengatur barisan untuk perang.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Di hadapannya bangsa-bangsa gemetar;","poem":1},{"text":"semua wajah menjadi pucat.","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"Mereka berlari seperti pahlawan,","poem":1},{"text":"mereka memanjat tembok seperti pasukan perang.","poem":2},{"text":"Setiap orang berjalan dengan lurus","poem":1},{"text":"dan tidak menyimpang dari jalannya.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Satu dengan yang lain tidak berdesakan,","poem":1},{"text":"masing-masing berjalan di jalannya.","poem":2},{"text":"Mereka akan berjalan menerobos senjata,","poem":1},{"text":"dan saat jatuh, mereka tidak terluka.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Mereka menyerbu ke dalam kota,","poem":1},{"text":"mereka berlari ke atas tembok.","poem":2},{"text":"Mereka memanjat ke atas rumah-rumah,","poem":1},{"text":"mereka masuk melalui jendela-jendela seperti pencuri.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Bumi gemetar di hadapan mereka, langit akan berguncang.","poem":1},{"text":"Matahari dan bulan menjadi gelap,","poem":2},{"lineBreak":true},{"text":"dan bintang-bintang menutupi cahayanya.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"TUHAN memperdengarkan suara-Nya di hadapan bala tentara-Nya.","poem":1},{"text":"Sebab, pasukan-Nya sangat besar,","poem":2},{"text":"dan pelaku firman-Nya kuat.","poem":1},{"text":"Sebab, hari TUHAN sangat besar dan sangat dahsyat!","poem":2},{"text":"Dan, siapakah yang dapat bertahan?","poem":1}]},{"type":"heading","content":["Panggilan untuk Bertobat"]},{"type":"verse","number":12,"content":[{"text":"“Sebab itu sekarang juga,” ketetapan TUHAN,","poem":1},{"text":"“Bertobatlah kepada-Ku dengan segenap hatimu,","poem":2},{"text":"dengan berpuasa,","poem":1},{"text":"dengan menangis, dan dengan meratap.”","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Koyakkanlah hatimu,","poem":1},{"text":"bukan pakaianmu.","poem":2},{"text":"Bertobatlah kepada TUHAN Allahmu,","poem":1},{"text":"sebab Dia murah hati dan penyayang,","poem":2},{"text":"Dia lambat untuk marah, dan besar kasih setia,","poem":1},{"text":"dan menyesal karena hukuman-Nya.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Siapa tahu, mungkin Dia mau berbalik dan menyesal,","poem":1},{"text":"dan meninggalkan berkat,","poem":2},{"text":"menjadi kurban-kurban sajian dan kurban-kurban curahan","poem":1},{"text":"bagi TUHAN Allahmu.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Tiuplah trompet di Sion,","poem":1},{"text":"kuduskanlah puasa,","poem":2},{"lineBreak":true},{"text":"dan serukanlah hari pertemuan raya.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Kumpulkanlah bangsa ini,","poem":1},{"text":"kuduskanlah jemaat,","poem":2},{"text":"kumpulkanlah para tua-tua, kumpulkanlah anak-anak,","poem":1},{"text":"bahkan anak-anak yang menyusu.","poem":2},{"text":"Biarlah pengantin laki-laki keluar dari kamarnya,","poem":1},{"text":"dan pengantin-pengantin perempuan dari kamar tidurnya.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Biarlah para imam, pelayan-pelayan TUHAN,","poem":1},{"text":"menangis di antara serambi dan mazbah, serta berkata,","poem":2},{"text":"“Ya TUHAN, sayangilah umat-Mu.","poem":1},{"text":"Jangan biarkan milik pusaka-Mu menjadi celaan,","poem":2},{"lineBreak":true},{"text":"sehingga bangsa-bangsa menguasai mereka.","poem":2},{"text":"Mengapa mereka harus berkata terhadap bangsa-bangsa,","poem":1},{"text":"‘Di manakah Allah mereka?’”","poem":2}]},{"type":"heading","content":["Janji Pemulihan dari TUHAN kepada Bangsa yang Bertobat"]},{"type":"verse","number":18,"content":[{"text":"TUHAN menjadi cemburu karena negeri-Nya,","poem":1},{"text":"dan berbelas kasihan kepada umat-Nya.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"TUHAN akan menjawab dan berkata kepada umat-Nya,","poem":1},{"lineBreak":true},{"text":"“Aku akan mengirimkan kepadamu gandum, anggur, dan minyak,","poem":1},{"text":"dan engkau akan puas atasnya.","poem":2},{"text":"Aku tidak akan menyerahkan kamu lagi","poem":1},{"text":"menjadi celaan di antara bangsa-bangsa.","poem":2}]},{"type":"verse","number":20,"content":[{"text":"Akan Kujauhkan darimu yang dari utara,","poem":1},{"text":"dan akan Kucerai-beraikan mereka ke suatu negeri yang kering dan sunyi,","poem":2},{"text":"dengan barisan depannya menghadap ke laut timur,","poem":1},{"text":"dan barisan belakangnya ke laut barat,","poem":2},{"text":"Ke atas, akan naik bau busuknya dan akan naik bau anyirnya,","poem":1},{"text":"sebab Dia telah melakukan perkara yang besar.","poem":2}]},{"type":"verse","number":21,"content":[{"text":"Janganlah takut, hai negeri.","poem":1},{"text":"Bersorak-sorailah dan bersukacitalah,","poem":2},{"lineBreak":true},{"text":"sebab TUHAN telah melakukan perkara yang besar!","poem":2}]},{"type":"verse","number":22,"content":[{"text":"Janganlah takut, hewan-hewan di padang,","poem":1},{"text":"sebab padang rumput di padang gurun menghijau,","poem":2},{"text":"sebab pohon-pohon menghasilkan buahnya,","poem":1},{"text":"bahkan pohon ara dan pohon anggur memberi kekayaannya.","poem":2}]},{"type":"line_break"},{"type":"verse","number":23,"content":[{"text":"Bersorak-sorailah, hai orang-orang Sion,","poem":1},{"text":"dan bersukacitalah karena TUHAN Allahmu!","poem":2},{"text":"Sebab, Dia telah memberikan hujan pada awal musim dengan adil.","poem":1},{"text":"Diturunkan-Nya hujan, hujan pada awal musim dan hujan pada akhir musim,","poem":2},{"lineBreak":true},{"text":"seperti dahulu.","poem":2}]},{"type":"verse","number":24,"content":[{"text":"Tempat-tempat pengirikan akan penuh dengan gandum,","poem":1},{"text":"dan tempat pemerasan akan melimpah dengan anggur dan minyak.","poem":2}]},{"type":"verse","number":25,"content":[{"text":"“Aku akan memulihkan,","poem":1},{"text":"tahun-tahun yang hasilnya dimakan belalang pindahan,","poem":2},{"text":"belalang pelompat, belalang pelahap, dan belalang pengerip,","poem":1},{"text":"yaitu tentara-Ku yang besar yang Kukirimkan kepadamu.","poem":2}]},{"type":"verse","number":26,"content":[{"text":"Kamu akan makan banyak,","poem":1},{"text":"dan menjadi kenyang.","poem":2},{"text":"Kamu akan menyanyikan puji-pujian tentang nama TUHAN Allahmu,","poem":1},{"text":"yang telah melakukan perbuatan ajaib kepadamu.","poem":2},{"text":"Umat-Ku takkan lagi mendapat malu untuk selama-lamanya.","poem":1}]},{"type":"verse","number":27,"content":[{"lineBreak":true},{"text":"Kamu akan mengetahui bahwa Aku berada di tengah-tengah orang Israel,","poem":1},{"lineBreak":true},{"text":"dan Akulah TUHAN Allahmu,","poem":1},{"text":"tidak ada yang lain.","poem":2},{"text":"Umat-Ku takkan mendapat malu lagi untuk selama-lamanya.","poem":1}]},{"type":"heading","content":["Hari TUHAN"]},{"type":"verse","number":28,"content":[{"text":"“Setelah itu, akan terjadi,","poem":1},{"text":"Aku akan mencurahkan Roh-Ku ke atas semua manusia.","poem":2},{"text":"Anak-anakmu laki-laki dan anak-anakmu perempuan akan bernubuat,","poem":1},{"text":"orang-orang tua akan mendapat mimpi,","poem":2},{"lineBreak":true},{"text":"pemuda-pemuda akan mendapat penglihatan.","poem":2}]},{"type":"verse","number":29,"content":[{"text":"Bahkan, kepada para hamba laki-laki","poem":1},{"text":"dan kepada hamba perempuan,","poem":2},{"lineBreak":true},{"text":"Aku akan mencurahkan Roh-Ku pada hari-hari itu.","poem":2}]},{"type":"verse","number":30,"content":[{"text":"Aku akan melakukan mukjizat-mukjizat di langit dan di bumi,","poem":1},{"text":"darah, dan api, dan gumpalan-gumpalan asap.","poem":2}]},{"type":"verse","number":31,"content":[{"text":"Matahari akan berubah menjadi gelap","poem":1},{"text":"dan bulan menjadi darah","poem":2},{"text":"sebelum datangnya hari TUHAN","poem":1},{"text":"yang besar dan dahsyat itu.","poem":2}]},{"type":"verse","number":32,"content":[{"text":"Dan, akan terjadi, setiap orang yang berseru kepada nama TUHAN","poem":1},{"text":"akan diselamatkan.","poem":2},{"text":"Sebab, di Gunung Sion dan di Yerusalem akan ada keselamatan,","poem":1},{"text":"seperti yang difirmankan TUHAN,","poem":2},{"text":"dan yang selamat","poem":1},{"text":"adalah orang-orang yang TUHAN panggil.”","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/JOL/2.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/JOL/3.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/JOL/1.json","previousChapterAudioLinks":{},"numberOfVerses":32}