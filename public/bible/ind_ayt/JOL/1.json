{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"JOL","translationId":"ind_ayt","name":"YOEL","commonName":"YOEL","title":"Yoel","order":29,"numberOfChapters":3,"sha256":"1b0ea76b25063c5067724f9e85dfd9c283c94363290f5d8584d65338076bca09","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/JOL/1.json","lastChapterNumber":3,"lastChapterApiLink":"/api/ind_ayt/JOL/3.json","totalNumberOfVerses":73},"chapter":{"number":1,"content":[{"type":"heading","content":["Belalang sebagai Hukuman TUHAN"]},{"type":"verse","number":1,"content":["Firman TUHAN yang datang kepada Yoel anak Petuel:"]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"Dengarlah ini, hai para tua-tua,","poem":1},{"text":"perhatikanlah, hai seluruh penduduk negeri!","poem":2},{"text":"Pernahkah terjadi seperti ini pada zamanmu?","poem":1},{"text":"Atau, pada zaman nenek moyangmu?","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Ceritakanlah kepada anak-anakmu,","poem":1},{"text":"dan biarlah anak-anakmu akan menceritakannya kepada anak-anak mereka,","poem":2},{"lineBreak":true},{"text":"dan anak-anak mereka kepada keturunan berikutnya.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Apa yang ditinggalkan belalang pengerat,","poem":1},{"text":"telah dimakan belalang pindahan.","poem":2},{"text":"Apa yang ditinggalkan belalang pindahan,","poem":1},{"text":"dimakan belalang pelompat.","poem":2},{"text":"Dan, apa yang ditinggalkan belalang pelompat,","poem":1},{"text":"dimakan oleh belalang pelahap.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Bangunlah, hai para pemabuk, dan menangislah.","poem":1},{"text":"Merataplah, hai semua peminum air anggur karena anggur baru,","poem":2},{"text":"sebab, anggur itu telah dilenyapkan dari mulutmu.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Sebab, suatu bangsa telah maju menyerang negeriku,","poem":1},{"text":"kuat dan tidak terhitung banyaknya.","poem":2},{"text":"Giginya seperti gigi singa,","poem":1},{"text":"dan taringnya seperti singa betina.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Ia membuat pohon anggurku menjadi tandus,","poem":1},{"text":"dan menjadikan pohon araku buntung.","poem":2},{"text":"Ia mengelupas kulitnya, lalu melemparkannya;","poem":1},{"text":"sehingga cabang-cabangnya menjadi putih.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Merataplah seperti anak perawan","poem":1},{"text":"yang memakai kain kabung","poem":2},{"lineBreak":true},{"text":"karena mempelai masa mudanya.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Kurban persembahan dan kurban curahan telah lenyap dari Bait TUHAN.","poem":1},{"text":"Para imam berkabung,","poem":2},{"lineBreak":true},{"text":"para pelayan TUHAN.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Ladang musnah,","poem":1},{"text":"tanah berkabung;","poem":2},{"lineBreak":true},{"text":"karena gandum sudah dimusnahkan,","poem":2},{"text":"buah anggur menjadi kering,","poem":1},{"text":"dan minyak sudah menipis.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Malulah, hai para petani;","poem":1},{"text":"merataplah, hai para pekerja kebun anggur,","poem":2},{"text":"karena gandum dan karena jelai,","poem":1},{"text":"sebab tuaian ladang sudah musnah.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Pohon anggur menjadi kering,","poem":1},{"text":"dan pohon ara layu.","poem":2},{"text":"Pohon delima, juga pohon kurma, dan pohon apel,","poem":1},{"text":"semua pohon di ladang sudah mengering.","poem":2},{"lineBreak":true},{"text":"Sungguh, kegirangan menjadi layu di antara anak-anak manusia.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Kenakanlah kain kabung dan merataplah, hai para imam,","poem":1},{"text":"merataplah, hai para pelayan mazbah.","poem":2},{"text":"Masuk dan bermalamlah dengan kain kabung, hai para pelayan Allahku,","poem":1},{"text":"sebab kurban persembahan dan kurban curahan sudah ditahan dari Bait Allahmu.","poem":2}]},{"type":"heading","content":["Kerusakan Akibat Belalang"]},{"type":"verse","number":14,"content":[{"text":"Adakanlah puasa,","poem":1},{"text":"serukanlah hari raya perkumpulan kudus,","poem":2},{"text":"kumpulkanlah para tua-tua dan seluruh penduduk negeri ke Bait TUHAN Allahmu,","poem":1},{"text":"dan berserulah kepada TUHAN.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Aduh, hari itu! Sebab, hari TUHAN sudah dekat,","poem":1},{"text":"datang sebagai pembinasaan dari Yang Mahakuasa.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Bukankah di hadapan mata kita, sudah lenyap makanan,","poem":1},{"text":"sukacita dan sorak-sorai dari Bait Allah kita?","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Biji-bijian menjadi kering di dalam tanah,","poem":1},{"text":"tempat perbendaharaan ditinggalkan.","poem":2},{"text":"Lumbung-lumbung dihancurkan","poem":1},{"text":"karena gandum sudah mengering.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"Betapa binatang mengeluh,","poem":1},{"text":"dan kawanan sapi gempar","poem":2},{"text":"karena tidak ada lagi padang rumput bagi mereka.","poem":1},{"text":"Dan, kawanan domba menanggung hukuman.","poem":2}]},{"type":"verse","number":19,"content":[{"text":"Kepada-Mu, TUHAN, aku berseru,","poem":1},{"lineBreak":true},{"text":"karena api telah melahap padang rumput di padang gurun,","poem":1},{"text":"nyala api membakar hangus","poem":2},{"lineBreak":true},{"text":"pohon-pohon di ladang.","poem":2}]},{"type":"verse","number":20,"content":[{"text":"Bahkan, hewan-hewan di padang menjerit kepada-Mu","poem":1},{"text":"karena air di alur-alur sungai telah kering,","poem":2},{"text":"dan api telah melahap","poem":1},{"text":"tanah gembalaan di padang gurun.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/JOL/1.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/JOL/2.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/HOS/14.json","previousChapterAudioLinks":{},"numberOfVerses":20}