{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"HOS","translationId":"ind_ayt","name":"HOSEA","commonName":"HOSEA","title":"Hosea","order":28,"numberOfChapters":14,"sha256":"b38642cddd0453a1c298ac4b7dfc5d412f6f084e17077ac1feb9d0211e0c62d1","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/HOS/1.json","lastChapterNumber":14,"lastChapterApiLink":"/api/ind_ayt/HOS/14.json","totalNumberOfVerses":197},"chapter":{"number":10,"content":[{"type":"heading","content":["Penyembahan Berhala Mendatangkan Hukuman"]},{"type":"verse","number":1,"content":[{"text":"Israel adalah pohon anggur yang subur,","poem":1},{"text":"yang menghasilkan buah-buahnya.","poem":2},{"text":"Ketika buah-buahnya semakin banyak","poem":1},{"text":"ia menambah mazbah-mazbah.","poem":2},{"text":"Ketika negerinya bertambah makmur","poem":1},{"text":"mereka menghiasinya dengan tugu-tugu berhala.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Hati mereka menyeleweng.","poem":1},{"text":"Sekarang, mereka harus menanggung kesalahan mereka.","poem":2},{"text":"Tuhan akan menghancurkan mazbah-mazbah mereka","poem":1},{"text":"dan meruntuhkan tugu-tugu berhala mereka.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Sekarang mereka akan berkata,","poem":1},{"text":"“Kita tidak mempunyai raja","poem":2},{"text":"karena kita tidak takut kepada TUHAN.","poem":1},{"text":"Akan tetapi, apa yang dapat diperbuat raja bagi kita?”","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Mereka mengucapkan kata-kata, dengan sumpah-sumpah dusta mereka membuat perjanjian","poem":1},{"text":"sehingga penghukuman tumbuh seperti rumput beracun di sepanjang parit.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Penduduk Samaria ketakutan","poem":1},{"text":"karena anak sapi Bet-Awen.","poem":2},{"text":"umatnya akan berkabung karenanya,","poem":1},{"text":"para imam akan meratap keras,","poem":2},{"lineBreak":true},{"text":"sebab kemuliaannya akan meninggalkan mereka ke pembuangan.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Berhala anak sapi itu akan dibawa ke Asyur","poem":1},{"text":"sebagai hadiah","poem":2},{"lineBreak":true},{"text":"kepada Raja Yarib;","poem":2},{"text":"Efraim akan mendapat malu,","poem":1},{"text":"Israel akan menjadi malu karena berhalanya.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Raja Samaria akan dibinasakan","poem":1},{"text":"seperti ranting di atas air.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Bukit-bukit pengurbanan Awen,","poem":1},{"text":"dosa Israel, akan dibinasakan.","poem":2},{"text":"Semak duri dan rumput duri akan tumbuh di atas mazbah-mazbahnya.","poem":1},{"text":"Lalu, mereka akan berkata kepada gunung-gunung,","poem":2},{"text":"“Tutupilah kami!”","poem":1},{"text":"dan kepada bukit-bukit, “Runtuhlah atas kami!”","poem":2}]},{"type":"heading","content":["TUHAN Kecewa terhadap Efraim"]},{"type":"verse","number":9,"content":[{"text":"“Sejak hari Gibea, kamu telah berdosa, hai Israel.","poem":1},{"text":"Di situlah, mereka berlanjut.","poem":2},{"lineBreak":true},{"text":"Tidakkah peperangan melawan orang-orang yang tidak adil mengalahkan mereka di Gibea.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"jika Aku menginginkannya, Aku akan menghajar mereka.","poem":1},{"text":"bangsa-bangsa akan berkumpul melawan mereka,","poem":2},{"lineBreak":true},{"text":"ketika mereka dibelenggu karena dua kesalahan mereka.","poem":2}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"Efraim adalah anak sapi yang terlatih,","poem":1},{"text":"yang suka mengirik gandum.","poem":2},{"text":"Namun, Aku mengekang tengkuknya yang bagus,","poem":1},{"text":"Aku akan menempatkan Efraim pada kuk itu, Yehuda harus membajak,","poem":2},{"lineBreak":true},{"text":"Yakub harus gentar pada dirinya sendiri.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Taburlah bagimu kebenaran,","poem":1},{"text":"tuailah kasih yang teguh!","poem":2},{"text":"Bukalah tanah barumu,","poem":1},{"text":"sebab sudah waktunya untuk mencari Tuhan,","poem":2},{"text":"sampai Dia datang","poem":1},{"text":"menghujani kamu dengan kebenaran.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Namun, kamu telah membajak kefasikan,","poem":1},{"text":"kamu telah menuai pelanggaran,","poem":2},{"lineBreak":true},{"text":"kamu telah memakan buah kebohongan.","poem":2},{"text":"Sebab, kamu telah mengandalkan diri pada jalanmu sendiri,","poem":1},{"text":"dan pada pahlawan-pahlawanmu yang berjumlah besar.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Oleh sebab itu, keriuhan perang akan muncul di antara bangsamu,","poem":1},{"text":"semua bentengmu akan dihancurkan.","poem":2},{"text":"sama seperti Salman menghancurkan Bet-Arbel pada hari pertempuran,","poem":1},{"text":"ibu-ibu bersama dengan anak-anaknya diremukkan.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Demikianlah akan terjadi padamu, hai Betel,","poem":1},{"text":"karena kejahatanmu yang besar.","poem":2},{"text":"Pada waktu fajar,","poem":1},{"text":"raja Israel akan dilenyapkan sampai habis.”","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/HOS/10.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/HOS/11.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/HOS/9.json","previousChapterAudioLinks":{},"numberOfVerses":15}