{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"HOS","translationId":"ind_ayt","name":"HOSEA","commonName":"HOSEA","title":"Hosea","order":28,"numberOfChapters":14,"sha256":"b38642cddd0453a1c298ac4b7dfc5d412f6f084e17077ac1feb9d0211e0c62d1","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/HOS/1.json","lastChapterNumber":14,"lastChapterApiLink":"/api/ind_ayt/HOS/14.json","totalNumberOfVerses":197},"chapter":{"number":12,"content":[{"type":"heading","content":["Efraim dan Yakub"]},{"type":"verse","number":1,"content":[{"text":"(12-2) Efraim memakan angin,","poem":1},{"text":"dan mengejar angin timur sepanjang hari.","poem":2},{"text":"Ia terus memperbanyak kebohongan","poem":1},{"text":"dan kekejaman;","poem":2},{"text":"Mereka membuat perjanjian dengan Asyur,","poem":1},{"text":"dan minyak dibawa ke Mesir.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"(12-3) TUHAN membawa perkara terhadap Yehuda,","poem":1},{"text":"dan akan menghukum Yakub sesuai dengan jalan-jalannya,","poem":2},{"lineBreak":true},{"text":"dan akan membayarnya sesuai dengan perbuatan-perbuatannya.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"(12-4) Di dalam kandungan,","poem":1},{"text":"dia memegang tumit saudaranya.","poem":2},{"text":"dan dalam kekuatannya,","poem":1},{"text":"dia bergulat dengan Allah.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"(12-5) Dia bergulat dengan malaikat, dan menang.","poem":1},{"text":"Dia menangis dan memohon belas kasihan-Nya.","poem":2},{"text":"Dia berjumpa Tuhan di Betel,","poem":1},{"text":"dan di sanalah Dia berfirman kepada kita,","poem":2}]},{"type":"verse","number":5,"content":[{"text":"(12-6) TUHAN, Allah semesta alam,","poem":1},{"text":"TUHAN nama-Nya.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"(12-7) “Oleh sebab itu, kamu dengan pertolongan Allah berbaliklah.","poem":1},{"text":"Berpeganglah pada kasih setia dan keadilan,","poem":2},{"lineBreak":true},{"text":"dan berharaplah senantiasa pada Allahmu.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"(12-8) “Seorang pedagang, dalam tangannya memegang neraca yang menipu,","poem":1},{"text":"ia suka menindas.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"(12-9) Efraim berkata, “Namun, aku kaya.","poem":1},{"text":"Aku telah memperoleh kekayaan bagi diriku.","poem":2},{"text":"Dalam segala jerih lelahku mereka takkan menemukan kesalahan,","poem":1},{"text":"atau dosa dalam diriku.”","poem":2}]},{"type":"verse","number":9,"content":[{"text":"(12-10) Akulah TUHAN, Allahmu, sejak di tanah Mesir.","poem":1},{"text":"Aku akan sekali lagi membuatmu menetap dalam tenda-tenda,","poem":2},{"lineBreak":true},{"text":"seperti pada hari-hari pertemuan raya.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"(12-11) Akulah yang berfirman kepada para nabi,","poem":1},{"text":"dan Akulah yang memberi banyak penglihatan,","poem":2},{"text":"dan kepada para nabi,","poem":1},{"text":"Aku memberikan perumpamaan-perumpamaan.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"(12-12) Jika ada kejahatan di Gilead,","poem":1},{"text":"mereka tidak akan menemukan apa-apa.","poem":2},{"text":"Di Gilgal, mereka mempersembahkan sapi-sapi jantan,","poem":1},{"text":"mazbah-mazbah mereka seperti timbunan batu","poem":2},{"lineBreak":true},{"text":"di atas ladang-ladang kosong.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"(12-13) Yakub melarikan diri ke tanah Aram,","poem":1},{"text":"di sana Israel menjadi hamba untuk mendapatkan istri,","poem":2},{"lineBreak":true},{"text":"untuk mendapat istri, dia menggembalakan domba.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"(12-14) Dengan perantaraan seorang nabi, TUHAN membawa Israel keluar dari Mesir,","poem":1},{"text":"dengan perantaraan nabi ia dijagai.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"(12-15) Namun, Efraim membuat hasutan yang sangat pahit.","poem":1},{"text":"Oleh sebab itu, Tuannya akan membiarkan utang darah menimpanya,","poem":2},{"text":"dan akan membalas perbuatannya yang tercela.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/HOS/12.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/HOS/13.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/HOS/11.json","previousChapterAudioLinks":{},"numberOfVerses":14}