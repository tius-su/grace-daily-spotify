{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"HOS","translationId":"ind_ayt","name":"HOSEA","commonName":"HOSEA","title":"Hosea","order":28,"numberOfChapters":14,"sha256":"b38642cddd0453a1c298ac4b7dfc5d412f6f084e17077ac1feb9d0211e0c62d1","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/HOS/1.json","lastChapterNumber":14,"lastChapterApiLink":"/api/ind_ayt/HOS/14.json","totalNumberOfVerses":197},"chapter":{"number":9,"content":[{"type":"heading","content":["Kesedihan Akibat Pembuangan"]},{"type":"verse","number":1,"content":[{"text":"Jangan bersukacita, hai Israel!","poem":1},{"text":"Jangan bersuka ria seperti bangsa-bangsa lain!","poem":2},{"text":"Sebab, kamu telah bersundal terhadap Allahmu,","poem":1},{"text":"kamu mencintai upah persundalan,","poem":2},{"lineBreak":true},{"text":"di semua tempat pengirikan gandum.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Tempat pengirikan gandum dan pemerasan anggur","poem":1},{"text":"takkan memberi mereka makan,","poem":2},{"lineBreak":true},{"text":"dan anggur baru akan mengecewakan mereka.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Mereka tidak akan tinggal di negeri TUHAN,","poem":1},{"text":"tetapi Efraim akan kembali ke Mesir,","poem":2},{"lineBreak":true},{"text":"dan mereka akan makan makanan najis di Asyur.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Mereka takkan mencurahkan persembahan minuman anggur kepada TUHAN,","poem":1},{"text":"dan kurban-kurban persembahan mereka tidak menyukakan hati-Nya.","poem":2},{"text":"Itu akan menjadi seperti roti perkabungan,","poem":1},{"text":"semua orang yang memakannya akan menjadi najis.","poem":2},{"text":"Sebab, roti mereka adalah untuk kelaparan mereka sendiri,","poem":1},{"text":"dan tidak akan masuk ke dalam Bait TUHAN.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Apa yang akan kamu perbuat pada hari pertemuan raya,","poem":1},{"text":"dan pada hari raya TUHAN?","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Sebab, lihatlah mereka akan menghindarkan diri dari kebinasaan.","poem":1},{"text":"tetapi Mesir akan menghimpun mereka,","poem":2},{"lineBreak":true},{"text":"Memfis akan mengubur mereka.","poem":2},{"text":"Semak duri akan menguasai barang-barang perak mereka yang berharga,","poem":1},{"text":"rumput duri akan tumbuh dalam tenda-tenda mereka.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Hari-hari penghukuman telah datang,","poem":1},{"text":"hari-hari pembalasan telah datang,","poem":2},{"text":"Israel akan mengetahuinya, “Nabi adalah orang yang bodoh,","poem":1},{"text":"orang yang penuh Roh kemarahan!”","poem":2},{"text":"Oleh karena kesalahanmu yang sangat banyak","poem":1},{"text":"dan kebencianmu yang sangat besar","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Nabi adalah pengawas Efraim bersama Allahku,","poem":1},{"text":"tetapi para nabi juga perangkap di segala jalannya,","poem":2},{"text":"permusuhan di rumah Allahnya.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Mereka sudah sangat merusak diri","poem":1},{"text":"seperti pada hari-hari Gibea,","poem":2},{"text":"Dia akan mengingat pelanggaran mereka,","poem":1},{"text":"dan Dia akan menghukum dosa-dosa mereka.","poem":2}]},{"type":"heading","content":["Israel Hancur karena Menyembah Berhala"]},{"type":"verse","number":10,"content":[{"text":"“Aku menemukan Israel","poem":1},{"text":"seperti buah anggur di padang belantara.","poem":2},{"text":"Aku melihat nenek moyangmu","poem":1},{"text":"seperti buah sulung dari pohon ara pada musim pertama.","poem":2},{"lineBreak":true},{"text":"Akan tetapi, mereka pergi kepada Baal-Peor,","poem":2},{"text":"dan mengabdikan diri mereka kepada keaiban","poem":1},{"text":"sehingga mereka menjadi kebencian,","poem":2},{"lineBreak":true},{"text":"seperti hal yang mereka cintai.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Kemuliaan Efraim akan terbang seperti burung,","poem":1},{"text":"tidak ada kelahiran, tidak ada kehamilan, dan tidak ada pembuahan!","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Kalaupun mereka membesarkan anak-anak,","poem":1},{"text":"Aku akan membuat mereka kehilangan sehingga tidak ada lagi yang tersisa.","poem":2},{"text":"Celakalah mereka,","poem":1},{"text":"saat Aku meninggalkan mereka.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Aku melihat Efraim seperti tanaman muda","poem":1},{"text":"yang ditanam di padang rumput.","poem":2},{"text":"Namun, Efraim membawa anak-anaknya untuk dibantai.","poem":1}]},{"type":"verse","number":14,"content":[{"lineBreak":true},{"text":"Berikanlah kepada mereka, ya TUHAN,","poem":1},{"text":"apa yang akan Engkau berikan?","poem":2},{"text":"Berikanlah kepada mereka kandungan yang gugur,","poem":1},{"text":"dan buah dada yang kering.","poem":2}]},{"type":"line_break"},{"type":"verse","number":15,"content":[{"text":"Semua kejahatan mereka adalah di Gilgal;","poem":1},{"text":"di sanalah Aku mulai membenci mereka.","poem":2},{"text":"Oleh karena perbuatan-perbuatan jahat mereka,","poem":1},{"text":"Aku akan mengusir mereka dari rumah-Ku.","poem":2},{"lineBreak":true},{"text":"Aku takkan mengasihi mereka lagi;","poem":2},{"text":"semua pemimpin mereka adalah pemberontak.","poem":1}]},{"type":"verse","number":16,"content":[{"lineBreak":true},{"text":"Efraim dipukul,","poem":1},{"text":"akar-akar mereka telah kering.","poem":2},{"lineBreak":true},{"text":"Mereka takkan menghasilkan buah.","poem":2},{"text":"Sekalipun mereka melahirkan,","poem":1},{"text":"Aku akan membunuh keturunan mereka yang berharga.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Allahku akan menolak mereka,","poem":1},{"text":"sebab mereka tidak mendengarkan Dia.","poem":2},{"text":"Mereka akan menjadi pengembara","poem":1},{"text":"di antara bangsa-bangsa.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/HOS/9.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/HOS/10.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/HOS/8.json","previousChapterAudioLinks":{},"numberOfVerses":17}