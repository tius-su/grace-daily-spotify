{"translation":{"id":"ind_ayt","name":"Alkitab Yang Terbuka","website":"https://ebible.org/Scriptures/details.php?id=indayt","licenseUrl":"https://ebible.org/Scriptures/details.php?id=indayt","licenseNotes":null,"shortName":"AYT","englishName":"Indonesian AYT Bible","language":"ind","textDirection":"ltr","sha256":"4269ef50854c298173e215f3d2d10538056e18bb6fcd32957f34c255d8ecb12f","availableFormats":["json"],"listOfBooksApiLink":"/api/ind_ayt/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"Indonesia","languageEnglishName":"Indonesian"},"book":{"id":"HOS","translationId":"ind_ayt","name":"HOSEA","commonName":"HOSEA","title":"Hosea","order":28,"numberOfChapters":14,"sha256":"b38642cddd0453a1c298ac4b7dfc5d412f6f084e17077ac1feb9d0211e0c62d1","firstChapterNumber":1,"firstChapterApiLink":"/api/ind_ayt/HOS/1.json","lastChapterNumber":14,"lastChapterApiLink":"/api/ind_ayt/HOS/14.json","totalNumberOfVerses":197},"chapter":{"number":13,"content":[{"type":"heading","content":["Murka TUHAN terhadap Efraim"]},{"type":"verse","number":1,"content":[{"text":"“Ketika Efraim berbicara, ada kegentaran,","poem":1},{"text":"ia ditinggikan di Israel,","poem":2},{"text":"tetapi ia bersalah karena Baal,","poem":1},{"text":"sehingga ia mati.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Sekarang, mereka berdosa lebih banyak dan lebih banyak lagi,","poem":1},{"text":"dan membuat bagi mereka patung-patung tuangan besi,","poem":2},{"text":"dan berhala-berhala dibuat dengan terampil dari perak mereka,","poem":1},{"text":"semua itu buatan para pengrajin.","poem":2},{"text":"Dikatakan tentang mereka, “Biarlah mereka yang mempersembahkan kurban manusia","poem":1},{"text":"mencium anak-anak sapi!”","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Oleh karena itu, mereka akan seperti kabut pagi,","poem":1},{"text":"atau seperti embun yang lenyap pagi-pagi.","poem":2},{"text":"Seperti sekam yang diterbangkan berputar-putar dari tempat pengirikan,","poem":1},{"text":"atau seperti asap yang keluar jendela.","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"Namun, Akulah TUHAN, Allahmu","poem":1},{"text":"sejak dari Tanah Mesir.","poem":2},{"text":"Kamu tidak mengenal Allah lain selain Aku.","poem":1},{"text":"Kecuali Aku, tidak ada Juru Selamat.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Akulah yang mengenalmu di padang belantara,","poem":1},{"text":"di tanah yang kekeringan.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Namun, ketika mereka memiliki padang rumput,","poem":1},{"text":"mereka menjadi kenyang.","poem":2},{"text":"Setelah kenyang, hati mereka menjadi sombong.","poem":1},{"text":"Karena itu, mereka melupakan Aku.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Oleh karena itu, untuk mereka, Aku seperti seekor singa,","poem":1},{"text":"seperti macan tutul, Aku mengintai di tepi jalan.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Aku mendatangi mereka seperti beruang yang kehilangan anaknya,","poem":1},{"text":"Aku akan mengoyakkan dada mereka.","poem":2},{"lineBreak":true},{"text":"Di sana, Aku akan melahap mereka seperti singa,","poem":2},{"text":"binatang-binatang liar","poem":1},{"text":"akan mencabik-cabik mereka.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"“Hai Israel, kamu dibinasakan","poem":1},{"text":"tetapi Akulah penolongmu.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Di manakah rajamu?","poem":1},{"lineBreak":true},{"text":"yang akan menyelamatkanmu di semua kota-kotamu?","poem":1},{"text":"Di mana hakim-hakimmu,","poem":2},{"text":"yang kepada mereka kamu berkata,","poem":1},{"text":"‘Berikanlah kepadaku seorang raja dan pemimpin-pemimpin!’?","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Aku memberimu seorang raja dalam kemarahanku,","poem":1},{"text":"dan mengambilnya dalam murka-Ku.","poem":2}]},{"type":"line_break"},{"type":"verse","number":12,"content":[{"text":"Kejahatan Efraim diikat,","poem":1},{"text":"dosanya dicatat.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Kesakitan melahirkan akan menimpanya,","poem":1},{"text":"tetapi ia bukan anak yang bijaksana.","poem":2},{"lineBreak":true},{"text":"Sebab, ia seharusnya tidak tinggal dalam kandungan","poem":2},{"lineBreak":true},{"text":"ketika tiba saat ia dilahirkan","poem":2}]},{"type":"line_break"},{"type":"verse","number":14,"content":[{"text":"Haruskah Aku menyelamatkannya dari kuasa dunia orang mati?","poem":1},{"text":"Haruskah Aku menebusnya dari kematian","poem":2},{"text":"Hai maut, di manakah kekuatanmu?","poem":1},{"text":"Hai dunia orang mati, di manakah sengatmu?","poem":2},{"lineBreak":true},{"text":"Belas kasihan tersembunyi dari mata-Ku.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Meskipun ia tumbuh subur di antara saudara-saudaranya,","poem":1},{"text":"angin timur, angin dari TUHAN, akan datang bertiup dari padang belantara","poem":2},{"text":"sumber airnya akan mengering,","poem":1},{"text":"dan mata airnya akan menjadi kering.","poem":2},{"lineBreak":true},{"text":"Akan dirampas semua perbendaharaan dari setiap benda yang berharga.","poem":2}]},{"type":"line_break"},{"type":"verse","number":16,"content":[{"text":"(14-1) “Samaria akan menanggung rasa bersalahnya,","poem":1},{"text":"sebab ia telah memberontak terhadap Allahnya.","poem":2},{"text":"Mereka akan tewas oleh pedang,","poem":1},{"text":"bayi-bayi mereka akan diremukkan,","poem":2},{"lineBreak":true},{"text":"dan perempuan-perempuannya yang mengandung akan dibelah perutnya.”","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/ind_ayt/HOS/13.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/ind_ayt/HOS/14.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/ind_ayt/HOS/12.json","previousChapterAudioLinks":{},"numberOfVerses":16}